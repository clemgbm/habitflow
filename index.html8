<div class="modal-bg" id="modal-api-key">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">🔑 Clé API Anthropic</div><button class="modal-close" onclick="closeModal('modal-api-key')">✕</button></div>
    <div class="alert alert-info" style="margin-bottom:16px">Ta clé est stockée uniquement sur ton appareil. Elle n'est jamais partagée.</div>
    <div class="inp-group"><div class="inp-label">Clé API (sk-ant-...)</div><input class="inp" type="password" id="api-key-input" placeholder="sk-ant-api03-..."></div>
    <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveApiKey()">Enregistrer</button>
    <div style="font-size:.75rem;color:var(--text2);margin-top:10px">Obtiens ta clé sur <a href="https://console.anthropic.com" target="_blank" style="color:var(--accent)">console.anthropic.com</a></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// STATE
function defaultState(){return{transactions:[],products:[],campaigns:[],metrics:[],tasks:[],goals:[],links:[{id:'l1',name:'Shopify Admin',url:'https://purrlopets.myshopify.com/admin',icon:'🛒',cat:'E-commerce'},{id:'l2',name:'Mega.nz Formation',url:'https://mega.nz/folder/FQg2lSaS#rYlByvveQyHOpaXHvHDITg',icon:'🎓',cat:'Formation'},{id:'l3',name:'Meta Ads',url:'https://business.facebook.com',icon:'📘',cat:'Publicité'},{id:'l4',name:'TikTok Ads',url:'https://ads.tiktok.com',icon:'🎵',cat:'Publicité'},{id:'l5',name:'Gmail',url:'https://mail.google.com',icon:'📧',cat:'Communication'}],resources:[],formationActions:[],formationHours:0,formationNotes:'',strategyNotes:'',editingProductId:null}}
let state;
try{const s=JSON.parse(localStorage.getItem('gabos_v1')||'null');state=s?{...defaultState(),...s}:defaultState();}catch{state=defaultState();}
function save(){localStorage.setItem('gabos_v1',JSON.stringify(state))}

// UTILS
function todayKey(){return new Date().toISOString().slice(0,10)}
function fmtDate(d){return new Date(d+'T12:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'})}
function daysLeft(){return Math.ceil((new Date('2026-12-01')-new Date())/(1000*60*60*24))}

// NAV
function showView(name){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  const ni=document.getElementById('nav-'+name);if(ni)ni.classList.add('active');
  closeSidebar();
  if(name==='command')renderCommand();
  if(name==='finance')renderFinance('month');
  if(name==='products')renderProducts();
  if(name==='ads')renderAds();
  if(name==='analytics')renderAnalytics();
  if(name==='tasks')renderTasks();
  if(name==='strategy')renderStrategy();
  if(name==='hub')renderHub();
  if(name==='knowledge')renderKnowledge();
}
function openSidebar(){document.getElementById('sidebar').classList.add('open');document.getElementById('sidebarOverlay').classList.add('show')}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('show')}

// MODALS
function openModal(id){document.getElementById(id).classList.add('open');document.querySelectorAll('#'+id+' input[type="date"]').forEach(i=>{if(!i.value)i.value=todayKey()})}
function closeModal(id){document.getElementById(id).classList.remove('open')}

// TOAST
function toast(msg,color){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=color||'var(--accent)';t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2500)}

// COMMAND CENTER
function renderCommand(){
  const h=new Date().getHours();
  document.getElementById('cmd-greeting').textContent=(h<12?'Bonjour':'Bonsoir')+', Gab 👋';
  document.getElementById('cmd-date').textContent=new Date().toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  document.getElementById('goal-days-left').textContent=daysLeft()+' jours restants';
  updateClock();
  const totalRev=state.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=state.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=totalRev-totalExp;
  const todayRev=state.transactions.filter(t=>t.type==='revenue'&&t.date===todayKey()).reduce((s,t)=>s+t.amount,0);
  const todayM=state.metrics.find(m=>m.date===todayKey())||{adspend:0,revenue:0};
  const roas=todayM.adspend>0?(todayM.revenue/todayM.adspend).toFixed(2):'—';
  const activeCamp=state.campaigns.filter(c=>c.status==='active').length;
  document.getElementById('kpi-grid').innerHTML=`
    <div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">CA Total</div><div class="kpi-value" style="color:var(--accent3)">${totalRev.toFixed(0)}€</div><div class="kpi-sub">Objectif : 4 000€/jour</div></div>
    <div class="kpi-card" style="--kpi-color:${profit>=0?'var(--green)':'var(--red)'}"><div class="kpi-label">Profit net</div><div class="kpi-value" style="color:${profit>=0?'var(--green)':'var(--red)'}">${profit>=0?'+':''}${profit.toFixed(0)}€</div><div class="kpi-sub">Dépenses : ${totalExp.toFixed(0)}€</div></div>
    <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">CA Aujourd'hui</div><div class="kpi-value" style="color:var(--gold)">${todayRev.toFixed(0)}€</div><div class="kpi-sub">${daysLeft()} jours avant objectif</div></div>
    <div class="kpi-card" style="--kpi-color:var(--blue)"><div class="kpi-label">ROAS</div><div class="kpi-value" style="color:var(--blue)">${roas}</div><div class="kpi-sub">${activeCamp} campagne(s) active(s)</div></div>
  `;
  const alerts=[];
  if(profit<0)alerts.push({t:'danger',m:'⚠️ Profit négatif — dépenses > revenus'});
  if(state.products.length===0)alerts.push({t:'warn',m:'🧪 Aucun produit — commence à tracker tes tests'});
  if(state.tasks.filter(t=>t.priority==='high'&&!t.done).length>3)alerts.push({t:'warn',m:`🔴 ${state.tasks.filter(t=>t.priority==='high'&&!t.done).length} tâches haute priorité en attente`});
  if(activeCamp===0)alerts.push({t:'info',m:'📣 Aucune campagne active — mode construction'});
  if(alerts.length===0)alerts.push({t:'success',m:'✅ Tout est nominal — continue sur ta lancée !'});
  document.getElementById('alerts-zone').innerHTML=alerts.map(a=>`<div class="alert alert-${a.t}">${a.m}</div>`).join('');
  const highTasks=state.tasks.filter(t=>t.priority==='high'&&!t.done).slice(0,4);
  document.getElementById('priority-actions').innerHTML=highTasks.length?highTasks.map(t=>`<div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)"><span style="color:var(--red)">●</span><span style="font-size:.85rem">${t.title}</span></div>`).join(''):'<div class="empty"><div class="ei">✅</div><p>Aucune tâche urgente</p></div>';
  const days7=Array.from({length:7},(_,i)=>{const d=new Date();d.setDate(d.getDate()-i);return d.toISOString().slice(0,10)});
  const weekRev=state.transactions.filter(t=>t.type==='revenue'&&days7.includes(t.date)).reduce((s,t)=>s+t.amount,0);
  const weekExp=state.transactions.filter(t=>t.type==='expense'&&days7.includes(t.date)).reduce((s,t)=>s+t.amount,0);
  document.getElementById('week-summary').innerHTML=`<div style="display:flex;flex-direction:column;gap:10px"><div style="display:flex;justify-content:space-between"><span style="font-size:.82rem;color:var(--text2)">Revenus</span><span style="font-weight:700;color:var(--accent3)">${weekRev.toFixed(0)}€</span></div><div style="display:flex;justify-content:space-between"><span style="font-size:.82rem;color:var(--text2)">Dépenses</span><span style="font-weight:700;color:var(--red)">${weekExp.toFixed(0)}€</span></div><div class="divider" style="margin:0"></div><div style="display:flex;justify-content:space-between"><span style="font-size:.82rem;font-weight:700">Profit</span><span style="font-weight:800;color:${weekRev-weekExp>=0?'var(--green)':'var(--red)'}">${(weekRev-weekExp).toFixed(0)}€</span></div></div>`;
  const pct=Math.min(100,(todayRev/4000)*100);
  document.getElementById('goal-bar').style.width=pct+'%';
  document.getElementById('goal-progress').innerHTML=`<div style="text-align:center;padding:10px 0"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:2.5rem;color:var(--accent3)">${pct.toFixed(1)}%</div><div style="font-size:.82rem;color:var(--text2);margin:4px 0">de l'objectif journalier</div><div style="font-size:.78rem;color:var(--text3)">${todayRev}€ / 4 000€</div><div class="prog-bg" style="margin-top:12px"><div class="prog-fill" style="width:${pct}%;background:linear-gradient(90deg,var(--accent),var(--accent3))"></div></div></div>`;
  const pStats={testing:0,scaling:0,dead:0,paused:0};state.products.forEach(p=>{if(pStats[p.status]!==undefined)pStats[p.status]++});
  document.getElementById('products-summary').innerHTML=`<div style="display:flex;flex-direction:column;gap:8px"><div style="display:flex;justify-content:space-between"><span style="font-size:.82rem;color:var(--text2)">🟡 Testing</span><span class="tag tag-gold">${pStats.testing}</span></div><div style="display:flex;justify-content:space-between"><span style="font-size:.82rem;color:var(--text2)">🟢 Scaling</span><span class="tag tag-green">${pStats.scaling}</span></div><div style="display:flex;justify-content:space-between"><span style="font-size:.82rem;color:var(--text2)">🔴 Dead</span><span class="tag tag-red">${pStats.dead}</span></div><div class="divider" style="margin:4px 0"></div><div style="display:flex;justify-content:space-between"><span style="font-size:.82rem;font-weight:700">Total</span><span style="font-weight:700">${state.products.length}</span></div></div>`;
}
function updateClock(){const el=document.getElementById('cmd-time');if(el)el.textContent=new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit',second:'2-digit'})}
setInterval(updateClock,1000);

// FINANCE
function addTransaction(){
  const type=document.getElementById('t-type').value;
  const desc=document.getElementById('t-desc').value.trim();
  const amount=parseFloat(document.getElementById('t-amount').value)||0;
  const cat=document.getElementById('t-cat').value;
  const date=document.getElementById('t-date').value||todayKey();
  if(!desc||!amount){toast('Remplis tous les champs','var(--red)');return}
  state.transactions.push({id:'t'+Date.now(),type,desc,amount,cat,date});
  save();closeModal('modal-add-transaction');
  ['t-desc','t-amount'].forEach(id=>document.getElementById(id).value='');
  renderFinance('month');
  toast(`${type==='revenue'?'+':'-'}${amount}€ enregistré ✓`,type==='revenue'?'var(--green)':'var(--red)');
}
function renderFinance(period){
  const now=new Date();let filtered=state.transactions;
  if(period==='month')filtered=filtered.filter(t=>t.date.slice(0,7)===now.toISOString().slice(0,7));
  if(period==='week'){const d7=Array.from({length:7},(_,i)=>{const d=new Date();d.setDate(d.getDate()-i);return d.toISOString().slice(0,10)});filtered=filtered.filter(t=>d7.includes(t.date))}
  const rev=filtered.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const exp=filtered.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=rev-exp;
  document.getElementById('finance-kpis').innerHTML=`
    <div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">Revenus</div><div class="kpi-value" style="color:var(--accent3)">${rev.toFixed(2)}€</div></div>
    <div class="kpi-card" style="--kpi-color:var(--red)"><div class="kpi-label">Dépenses</div><div class="kpi-value" style="color:var(--red)">${exp.toFixed(2)}€</div></div>
    <div class="kpi-card" style="--kpi-color:${profit>=0?'var(--green)':'var(--red)'}"><div class="kpi-label">Profit net</div><div class="kpi-value" style="color:${profit>=0?'var(--green)':'var(--red)'}">${profit>=0?'+':''}${profit.toFixed(2)}€</div></div>
    <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">Marge</div><div class="kpi-value" style="color:var(--gold)">${rev>0?((profit/rev)*100).toFixed(1):0}%</div></div>
  `;
  const list=document.getElementById('transactions-list');
  if(!filtered.length){list.innerHTML='<div class="empty"><div class="ei">💰</div><p>Aucune transaction</p></div>';return}
  list.innerHTML=[...filtered].reverse().map(t=>`<div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)"><span>${t.type==='revenue'?'📈':'📉'}</span><div style="flex:1"><div style="font-size:.85rem;font-weight:600">${t.desc}</div><div style="font-size:.72rem;color:var(--text2)">${fmtDate(t.date)} · ${t.cat}</div></div><span style="font-weight:700;color:${t.type==='revenue'?'var(--accent3)':'var(--red)'}">${t.type==='revenue'?'+':'-'}${t.amount.toFixed(2)}€</span><button onclick="delTransaction('${t.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div>`).join('');
  const cats={};filtered.filter(t=>t.type==='expense').forEach(t=>{cats[t.cat]=(cats[t.cat]||0)+t.amount});
  const cc={'Publicité':'var(--accent)','Abonnements':'var(--blue)','Fournisseur':'var(--gold)','Autre':'var(--text2)'};
  document.getElementById('expense-breakdown').innerHTML=Object.entries(cats).length?Object.entries(cats).map(([k,v])=>`<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:4px"><span style="color:var(--text2)">${k}</span><span style="font-weight:700">${v.toFixed(2)}€</span></div><div class="prog-bg"><div class="prog-fill" style="width:${exp>0?(v/exp*100):0}%;background:${cc[k]||'var(--accent)'}"></div></div></div>`).join(''):'<div class="empty"><div class="ei">📊</div><p>Aucune dépense</p></div>';
}
function delTransaction(id){state.transactions=state.transactions.filter(t=>t.id!==id);save();renderFinance('month')}

// PRODUCTS
function saveProduct(){
  const name=document.getElementById('p-name').value.trim();
  if(!name){toast('Donne un nom','var(--red)');return}
  const prod={id:state.editingProductId||'p'+Date.now(),name,status:document.getElementById('p-status').value,budget:parseFloat(document.getElementById('p-budget').value)||0,revenue:parseFloat(document.getElementById('p-revenue').value)||0,score:parseInt(document.getElementById('p-score').value)||5,url:document.getElementById('p-url').value.trim(),notes:document.getElementById('p-notes').value.trim(),date:todayKey()};
  if(state.editingProductId){const i=state.products.findIndex(p=>p.id===state.editingProductId);if(i>=0)state.products[i]=prod;state.editingProductId=null}else{state.products.push(prod)}
  save();closeModal('modal-add-product');['p-name','p-budget','p-revenue','p-score','p-url','p-notes'].forEach(id=>document.getElementById(id).value='');renderProducts();toast('Produit enregistré ✓');
}
function renderProducts(){
  const sc={testing:'var(--gold)',scaling:'var(--green)',paused:'var(--blue)',dead:'var(--red)'};
  const sl={testing:'🟡 Testing',scaling:'🟢 Scaling',paused:'🔵 Pausé',dead:'🔴 Dead'};
  const testing=state.products.filter(p=>p.status==='testing').length;
  const scaling=state.products.filter(p=>p.status==='scaling').length;
  const bestRoi=state.products.length?Math.max(...state.products.map(p=>p.budget>0?((p.revenue-p.budget)/p.budget*100):0)).toFixed(0):0;
  const totalBudget=state.products.reduce((s,p)=>s+p.budget,0);
  document.getElementById('product-kpis').innerHTML=`<div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">En test</div><div class="kpi-value" style="color:var(--gold)">${testing}</div></div><div class="kpi-card" style="--kpi-color:var(--green)"><div class="kpi-label">En scaling</div><div class="kpi-value" style="color:var(--green)">${scaling}</div></div><div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">Meilleur ROI</div><div class="kpi-value" style="color:var(--accent3)">${bestRoi}%</div></div><div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">Budget total testé</div><div class="kpi-value" style="color:var(--accent)">${totalBudget.toFixed(0)}€</div></div>`;
  const tbody=document.getElementById('products-tbody');const empty=document.getElementById('products-empty');
  if(!state.products.length){tbody.innerHTML='';empty.style.display='block';return}
  empty.style.display='none';
  tbody.innerHTML=state.products.map(p=>{
    const roi=p.budget>0?((p.revenue-p.budget)/p.budget*100).toFixed(0):'—';
    const rc=roi==='—'?'var(--text2)':parseFloat(roi)>=0?'var(--green)':'var(--red)';
    const score_c=p.score>=7?'var(--green)':p.score>=4?'var(--gold)':'var(--red)';
    return`<tr><td><div style="font-weight:600">${p.name}</div>${p.url?`<a href="${p.url}" target="_blank" style="font-size:.72rem;color:var(--accent)">Voir →</a>`:''}</td><td><span class="tag" style="background:${sc[p.status]}22;border:1px solid ${sc[p.status]}44;color:${sc[p.status]}">${sl[p.status]}</span></td><td class="mono">${p.budget.toFixed(0)}€</td><td class="mono" style="color:var(--accent3)">${p.revenue.toFixed(0)}€</td><td class="mono" style="color:${rc}">${roi}${roi!=='—'?'%':''}</td><td style="font-weight:700;color:${score_c}">${p.score}/10</td><td style="max-width:120px;font-size:.78rem;color:var(--text2)">${p.notes||'—'}</td><td><button onclick="editProd('${p.id}')" style="background:none;border:none;color:var(--text2);cursor:pointer;margin-right:6px">✎</button><button onclick="delProd('${p.id}')" style="background:none;border:none;color:var(--red);cursor:pointer">✕</button></td></tr>`;
  }).join('');
}
function editProd(id){
  const p=state.products.find(x=>x.id===id);state.editingProductId=id;
  document.getElementById('prod-modal-title').textContent='Modifier le produit';
  ['p-name','p-status','p-budget','p-revenue','p-score','p-url','p-notes'].forEach((fid,i)=>{const vals=[p.name,p.status,p.budget,p.revenue,p.score,p.url||'',p.notes||''];document.getElementById(fid).value=vals[i]});
  openModal('modal-add-product');
}
function delProd(id){if(!confirm('Supprimer ?'))return;state.products=state.products.filter(p=>p.id!==id);save();renderProducts()}

// ADS
function saveCampaign(){
  const name=document.getElementById('c-name').value.trim();
  if(!name){toast('Donne un nom','var(--red)');return}
  state.campaigns.push({id:'c'+Date.now(),name,platform:document.getElementById('c-platform').value,budget:parseFloat(document.getElementById('c-budget').value)||0,revenue:parseFloat(document.getElementById('c-revenue').value)||0,ctr:parseFloat(document.getElementById('c-ctr').value)||0,cpa:parseFloat(document.getElementById('c-cpa').value)||0,status:document.getElementById('c-status').value,date:todayKey()});
  save();closeModal('modal-add-campaign');renderAds();toast('Campagne ajoutée ✓');
}
function renderAds(){
  const active=state.campaigns.filter(c=>c.status==='active');
  const tb=active.reduce((s,c)=>s+c.budget,0);const tr=active.reduce((s,c)=>s+c.revenue,0);
  const roas=tb>0?(tr/tb).toFixed(2):'—';const avgCtr=active.length?(active.reduce((s,c)=>s+c.ctr,0)/active.length).toFixed(2):'—';
  document.getElementById('ads-kpis').innerHTML=`<div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">Campagnes actives</div><div class="kpi-value" style="color:var(--accent)">${active.length}</div></div><div class="kpi-card" style="--kpi-color:var(--red)"><div class="kpi-label">Budget/jour</div><div class="kpi-value" style="color:var(--red)">${tb.toFixed(0)}€</div></div><div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">ROAS moyen</div><div class="kpi-value" style="color:var(--accent3)">${roas}</div></div><div class="kpi-card" style="--kpi-color:var(--blue)"><div class="kpi-label">CTR moyen</div><div class="kpi-value" style="color:var(--blue)">${avgCtr}%</div></div>`;
  const list=document.getElementById('campaigns-list');const empty=document.getElementById('campaigns-empty');
  if(!state.campaigns.length){list.innerHTML='';empty.style.display='block';return}
  empty.style.display='none';
  const sc={active:'var(--green)',paused:'var(--gold)',dead:'var(--red)'};
  list.innerHTML=state.campaigns.map(c=>{const roi=c.budget>0?((c.revenue-c.budget)/c.budget*100).toFixed(0):'—';return`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:10px"><div style="display:flex;justify-content:space-between;margin-bottom:8px"><div><div style="font-weight:700;font-size:.9rem">${c.name}</div><div style="font-size:.75rem;color:var(--text2)">${c.platform}</div></div><div style="display:flex;gap:6px;align-items:center"><span class="tag" style="background:${sc[c.status]}22;border:1px solid ${sc[c.status]}44;color:${sc[c.status]}">${c.status}</span><button onclick="delCamp('${c.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div></div><div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;font-size:.78rem"><div><div style="color:var(--text2)">Budget/j</div><div class="mono" style="font-weight:700">${c.budget}€</div></div><div><div style="color:var(--text2)">Revenus</div><div class="mono" style="font-weight:700;color:var(--accent3)">${c.revenue}€</div></div><div><div style="color:var(--text2)">CTR</div><div class="mono" style="font-weight:700">${c.ctr}%</div></div><div><div style="color:var(--text2)">ROI</div><div class="mono" style="font-weight:700;color:${roi==='—'?'var(--text2)':parseFloat(roi)>=0?'var(--green)':'var(--red)'}">${roi}${roi!=='—'?'%':''}</div></div></div></div>`}).join('');
  const sug=[];
  if(roas!=='—'&&parseFloat(roas)<2)sug.push({t:'danger',m:'🔴 ROAS < 2 — campagnes non rentables. Coupe les moins performantes.'});
  if(roas!=='—'&&parseFloat(roas)>=3)sug.push({t:'success',m:'✅ ROAS > 3 — augmente progressivement le budget des meilleures campagnes.'});
  if(avgCtr!=='—'&&parseFloat(avgCtr)<1)sug.push({t:'warn',m:"⚠️ CTR < 1% — tes créatifs n'accrochent pas. Teste de nouveaux visuels."});
  if(!sug.length)sug.push({t:'info',m:'💡 Ajoute tes campagnes pour recevoir des suggestions.'});
  document.getElementById('ads-suggestions').innerHTML=sug.map(s=>`<div class="alert alert-${s.t}">${s.m}</div>`).join('');
}
function delCamp(id){state.campaigns=state.campaigns.filter(c=>c.id!==id);save();renderAds()}

// ANALYTICS
function saveMetric(){
  const date=document.getElementById('m-date').value||todayKey();
  const existing=state.metrics.findIndex(m=>m.date===date);
  const metric={date,visitors:parseInt(document.getElementById('m-visitors').value)||0,orders:parseInt(document.getElementById('m-orders').value)||0,revenue:parseFloat(document.getElementById('m-revenue').value)||0,adspend:parseFloat(document.getElementById('m-adspend').value)||0};
  if(existing>=0)state.metrics[existing]=metric;else state.metrics.push(metric);
  save();closeModal('modal-add-metric');renderAnalytics();toast('Métriques enregistrées ✓');
}
function renderAnalytics(){
  const tm=state.metrics.find(m=>m.date===todayKey())||{visitors:0,orders:0,revenue:0,adspend:0};
  const conv=tm.visitors>0?((tm.orders/tm.visitors)*100).toFixed(2):'—';
  const aov=tm.orders>0?(tm.revenue/tm.orders).toFixed(0):'—';
  const roas=tm.adspend>0?(tm.revenue/tm.adspend).toFixed(2):'—';
  document.getElementById('analytics-kpis').innerHTML=`<div class="kpi-card" style="--kpi-color:var(--blue)"><div class="kpi-label">Visiteurs</div><div class="kpi-value" style="color:var(--blue)">${tm.visitors}</div></div><div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">Commandes</div><div class="kpi-value" style="color:var(--accent3)">${tm.orders}</div></div><div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">Taux de conversion</div><div class="kpi-value" style="color:var(--gold)">${conv}%</div></div><div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">Panier moyen (AOV)</div><div class="kpi-value" style="color:var(--accent)">${aov}${aov!=='—'?'€':''}</div></div>`;
  const cart=Math.round(tm.visitors*0.15);const checkout=Math.round(cart*0.4);
  document.getElementById('funnel').innerHTML=[{l:'Visiteurs',v:tm.visitors,c:'var(--blue)',p:100},{l:'Ajout panier (est.)',v:cart,c:'var(--accent)',p:tm.visitors>0?(cart/tm.visitors*100):0},{l:'Checkout (est.)',v:checkout,c:'var(--gold)',p:tm.visitors>0?(checkout/tm.visitors*100):0},{l:'Commandes',v:tm.orders,c:'var(--accent3)',p:tm.visitors>0?(tm.orders/tm.visitors*100):0}].map(s=>`<div style="margin-bottom:12px"><div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:4px"><span style="color:var(--text2)">${s.l}</span><span style="font-weight:700;color:${s.c}">${s.v} (${s.p.toFixed(1)}%)</span></div><div class="prog-bg"><div class="prog-fill" style="width:${s.p}%;background:${s.c}"></div></div></div>`).join('');
  const last7=state.metrics.sort((a,b)=>a.date>b.date?-1:1).slice(0,7);
  document.getElementById('metrics-history').innerHTML=last7.length?`<table class="data-table"><thead><tr><th>Date</th><th>Visiteurs</th><th>Cmd</th><th>CA</th><th>Pub</th><th>ROAS</th></tr></thead><tbody>${last7.map(m=>{const r=m.adspend>0?(m.revenue/m.adspend).toFixed(1):'—';return`<tr><td class="mono" style="font-size:.78rem">${fmtDate(m.date)}</td><td>${m.visitors}</td><td>${m.orders}</td><td style="color:var(--accent3)">${m.revenue}€</td><td style="color:var(--red)">${m.adspend}€</td><td style="color:${r==='—'?'var(--text2)':parseFloat(r)>=2?'var(--green)':'var(--red)'}">${r}</td></tr>`}).join('')}</tbody></table>`:'<div class="empty"><div class="ei">📊</div><p>Ajoute tes métriques quotidiennes</p></div>';
}

// TASKS
const TEMPLATES=[
  {name:'🚀 Lancer un produit',tasks:['Trouver le produit sur AliExpress/CJ','Créer la page produit Shopify','Configurer les prix & marges','Créer le créatif publicitaire','Lancer campagne test 5-10€/j','Analyser les résultats à J+3']},
  {name:'📣 Tester une créa',tasks:['Définir l\'angle marketing','Créer le visuel/vidéo','Dupliquer l\'adset existant','Lancer à 5€/j','Analyser CTR à 24h']},
  {name:'📈 Optimiser campagne',tasks:['Analyser ROAS par adset','Couper les adsets perdants','Scale les adsets rentables x1.5','Tester nouveau public','Vérifier le pixel Shopify']},
];
function renderTasks(){
  const high=state.tasks.filter(t=>t.priority==='high');
  const med=state.tasks.filter(t=>t.priority==='med');
  const low=state.tasks.filter(t=>t.priority==='low'||t.done);
  document.getElementById('count-high').textContent=high.filter(t=>!t.done).length;
  document.getElementById('count-med').textContent=med.filter(t=>!t.done).length;
  document.getElementById('count-low').textContent=low.length;
  ['high','med','low'].forEach(p=>{
    const list=p==='low'?low:state.tasks.filter(t=>t.priority===p);
    document.getElementById('tasks-'+p).innerHTML=list.length?list.map(t=>`<div style="display:flex;align-items:flex-start;gap:8px;padding:10px 0;border-bottom:1px solid var(--border);${t.done?'opacity:.5':''}"><input type="checkbox" ${t.done?'checked':''} onchange="toggleTask('${t.id}')" style="margin-top:3px;accent-color:var(--accent);cursor:pointer"><div style="flex:1"><div style="font-size:.85rem;font-weight:500;${t.done?'text-decoration:line-through':''}">${t.title}</div><div style="font-size:.72rem;color:var(--text2)">${t.cat||''}${t.deadline?' · ⏰ '+fmtDate(t.deadline):''}</div></div><button onclick="delTask('${t.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:.8rem">✕</button></div>`).join(''):'<div class="empty" style="padding:20px"><p>Aucune tâche</p></div>';
  });
  document.getElementById('templates-list').innerHTML=TEMPLATES.map((tpl,i)=>`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:10px"><div style="font-weight:700;margin-bottom:4px">${tpl.name}</div><div style="font-size:.8rem;color:var(--text2);margin-bottom:10px">${tpl.tasks.length} tâches</div><button class="btn btn-primary btn-sm" onclick="applyTemplate(${i})">Appliquer</button></div>`).join('');
}
function addTask(){
  const title=document.getElementById('task-title').value.trim();
  if(!title){toast('Écris une tâche','var(--red)');return}
  state.tasks.push({id:'t'+Date.now(),title,priority:document.getElementById('task-priority').value,deadline:document.getElementById('task-deadline').value||null,cat:document.getElementById('task-cat').value,done:false});
  save();closeModal('modal-add-task');document.getElementById('task-title').value='';renderTasks();toast('Tâche ajoutée ✓');
}
function toggleTask(id){const t=state.tasks.find(x=>x.id===id);if(t)t.done=!t.done;save();renderTasks()}
function delTask(id){state.tasks=state.tasks.filter(t=>t.id!==id);save();renderTasks()}
function applyTemplate(idx){const tpl=TEMPLATES[idx];tpl.tasks.forEach(title=>state.tasks.push({id:'t'+Date.now()+Math.random(),title,priority:'high',deadline:null,cat:'Business',done:false}));save();closeModal('modal-template');renderTasks();toast(`Template "${tpl.name}" appliqué ✓`)}

// STRATEGY
function renderStrategy(){
  document.getElementById('strategy-notes').value=state.strategyNotes||'';
  document.getElementById('goals-list').innerHTML=state.goals.length?state.goals.map(g=>`<div style="display:flex;justify-content:space-between;align-items:flex-start;padding:12px 0;border-bottom:1px solid var(--border)"><div><div style="font-weight:600;font-size:.88rem">${g.title}</div>${g.deadline?`<div style="font-size:.72rem;color:var(--text2);margin-top:2px">⏰ ${fmtDate(g.deadline)}</div>`:''}</div><div style="display:flex;gap:6px;align-items:center"><span class="tag tag-purple">${g.horizon}</span><button onclick="delGoal('${g.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div></div>`).join(''):'<div class="empty"><div class="ei">🎯</div><p>Définis tes objectifs</p></div>';
  const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];const now=new Date();
  document.getElementById('roadmap').innerHTML=`<div style="font-size:.8rem;color:var(--text2);margin-bottom:12px">Mars 2026 → Décembre 2026 · Objectif : 4 000€/jour</div><div style="display:flex;gap:4px;flex-wrap:wrap">${Array.from({length:10},(_,i)=>{const m=(now.getMonth()+i)%12;const isCur=i===0;return`<div style="flex:1;min-width:50px;background:${isCur?'var(--accent)22':'var(--surface2)'};border:1px solid ${isCur?'var(--accent)44':'var(--border)'};border-radius:8px;padding:8px 4px;text-align:center"><div style="font-size:.72rem;font-weight:700;color:${isCur?'var(--accent)':'var(--text2)'}">${months[m]}</div></div>`}).join('')}</div><div style="font-size:.72rem;color:var(--text3);margin-top:10px;text-align:center">9 mois · ${daysLeft()} jours restants</div>`;
}
function addGoal(){const title=document.getElementById('goal-title').value.trim();if(!title){toast('Écris un objectif','var(--red)');return}state.goals.push({id:'g'+Date.now(),title,deadline:document.getElementById('goal-deadline').value||null,horizon:document.getElementById('goal-horizon').value});save();closeModal('modal-add-goal');renderStrategy();toast('Objectif ajouté ✓')}
function delGoal(id){state.goals=state.goals.filter(g=>g.id!==id);save();renderStrategy()}
function saveStrategyNotes(){state.strategyNotes=document.getElementById('strategy-notes').value;save()}

// HUB
function renderHub(){
  const cats={};state.links.forEach(l=>{if(!cats[l.cat])cats[l.cat]=[];cats[l.cat].push(l)});
  document.getElementById('hub-categories').innerHTML=Object.entries(cats).map(([cat,links])=>`<div style="margin-bottom:24px"><div class="section-title">${cat}</div><div class="grid-auto">${links.map(l=>`<div onclick="window.open('${l.url}','_blank')" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;cursor:pointer;transition:all .2s;position:relative" onmouseover="this.style.borderColor='var(--accent)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='var(--border)';this.style.transform='none'"><div style="font-size:1.6rem;margin-bottom:8px">${l.icon||'🔗'}</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:4px">${l.name}</div><div style="font-size:.7rem;color:var(--text3);word-break:break-all">${l.url.replace(/^https?:\/\//,'').split('/')[0]}</div><button onclick="event.stopPropagation();delLink('${l.id}')" style="position:absolute;top:8px;right:8px;background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div>`).join('')}</div></div>`).join('');
}
function addLink(){
  const name=document.getElementById('l-name').value.trim();let url=document.getElementById('l-url').value.trim();
  if(!name||!url){toast('Remplis le nom et l\'URL','var(--red)');return}
  if(!url.startsWith('http'))url='https://'+url;
  state.links.push({id:'l'+Date.now(),name,url,icon:document.getElementById('l-icon').value.trim()||'🔗',cat:document.getElementById('l-cat').value});
  save();closeModal('modal-add-link');renderHub();toast('Lien ajouté ✓');
}
function delLink(id){state.links=state.links.filter(l=>l.id!==id);save();renderHub()}

// KNOWLEDGE
function renderKnowledge(){
  const h=state.formationHours||0;
  document.getElementById('formation-hours').value=h;
  document.getElementById('formation-bar').style.width=(h/80*100)+'%';
  document.getElementById('formation-pct').textContent=(h/80*100).toFixed(0)+'%';
  document.getElementById('formation-remaining').textContent=(80-h)+'h restantes';
  document.getElementById('formation-notes').value=state.formationNotes||'';
  const list=document.getElementById('resources-list');const empty=document.getElementById('resources-empty');
  if(!state.resources.length){list.innerHTML='';empty.style.display='block';return}
  empty.style.display='none';
  list.innerHTML=state.resources.map(r=>`<div style="display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);align-items:flex-start"><div style="font-size:1.2rem">${r.type==='Vidéo'?'🎬':r.type==='Article'?'📄':r.type==='Formation'?'🎓':'📦'}</div><div style="flex:1"><div style="font-weight:600;font-size:.85rem">${r.title}</div>${r.notes?`<div style="font-size:.75rem;color:var(--text2);margin-top:2px">${r.notes}</div>`:''} ${r.url?`<a href="${r.url}" target="_blank" style="font-size:.72rem;color:var(--accent)">Ouvrir →</a>`:''}</div><button onclick="delResource('${r.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div>`).join('');
  document.getElementById('formation-actions').innerHTML=state.formationActions.length?state.formationActions.map(a=>`<div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)"><input type="checkbox" ${a.done?'checked':''} onchange="toggleFA('${a.id}')" style="accent-color:var(--accent);cursor:pointer"><span style="flex:1;font-size:.85rem;${a.done?'text-decoration:line-through;opacity:.5':''}">${a.text}</span><button onclick="delFA('${a.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div>`).join(''):'';
}
function updateFormationProgress(){const h=parseInt(document.getElementById('formation-hours').value)||0;state.formationHours=h;document.getElementById('formation-bar').style.width=(h/80*100)+'%';document.getElementById('formation-pct').textContent=(h/80*100).toFixed(0)+'%';document.getElementById('formation-remaining').textContent=(80-h)+'h restantes';save()}
function saveFormationNotes(){state.formationNotes=document.getElementById('formation-notes').value;save()}
function addResource(){const title=document.getElementById('r-title').value.trim();if(!title){toast('Donne un titre','var(--red)');return}state.resources.push({id:'r'+Date.now(),title,url:document.getElementById('r-url').value.trim(),type:document.getElementById('r-type').value,notes:document.getElementById('r-notes').value.trim()});save();closeModal('modal-add-resource');renderKnowledge();toast('Ressource ajoutée ✓')}
function delResource(id){state.resources=state.resources.filter(r=>r.id!==id);save();renderKnowledge()}
function addFormationAction(){const text=document.getElementById('new-formation-action').value.trim();if(!text)return;state.formationActions.push({id:'fa'+Date.now(),text,done:false});document.getElementById('new-formation-action').value='';save();renderKnowledge()}
function toggleFA(id){const a=state.formationActions.find(x=>x.id===id);if(a)a.done=!a.done;save();renderKnowledge()}
function delFA(id){state.formationActions=state.formationActions.filter(a=>a.id!==id);save();renderKnowledge()}

// AI COACH
function saveApiKey(){const key=document.getElementById('api-key-input').value.trim();if(!key)return;localStorage.setItem('gabos_apikey',key);closeModal('modal-api-key');toast('Clé API enregistrée ✓','var(--green)')}
function getApiKey(){return localStorage.getItem('gabos_apikey')}
function coachQuick(type){
  const p={analyse:'Analyse mon business en détail et dis-moi où j\'en suis vraiment.',today:'Que dois-je absolument faire aujourd\'hui pour avancer vers mon objectif de 4000€/jour ?',product:'Comment je valide qu\'un produit est bon avant de mettre trop de budget pub dessus ?',motivation:'J\'ai besoin d\'un boost. Dis-moi pourquoi je vais y arriver et ce que je dois faire maintenant.'};
  document.getElementById('coach-input').value=p[type];sendCoach();
}
async function sendCoach(){
  const input=document.getElementById('coach-input');const msg=input.value.trim();if(!msg)return;input.value='';
  const apiKey=getApiKey();if(!apiKey){openModal('modal-api-key');return}
  const mode=document.getElementById('coach-mode').value;
  const modes={normal:'Sois direct et concret.',strict:'Sois très exigeant, ne tolère aucune excuse, pousse Gab à l\'action immédiate.',soft:'Sois encourageant et bienveillant tout en restant actionnable.'};
  const totalRev=state.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=state.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const sys=`Tu es l'AI Business Coach de Gab, 100% dédié à son succès en dropshipping.\n\nCONTEXTE:\n- Boutique: purrlopets.com (dropshipping)\n- Objectif: 4 000€/jour en décembre 2026 (${daysLeft()} jours restants)\n- Lycéen, entrepreneur autodidacte\n- CA total: ${totalRev.toFixed(0)}€ | Dépenses: ${totalExp.toFixed(0)}€ | Profit: ${(totalRev-totalExp).toFixed(0)}€\n- Produits actifs: ${state.products.filter(p=>p.status!=='dead').map(p=>p.name).join(', ')||'Aucun'}\n- Formation: ${state.formationHours||0}/80h regardées\n\nMODE: ${modes[mode]}\n\nRéponds toujours en français, avec des actions concrètes. Utilise des emojis. Sois bref et actionnable.`;
  const box=document.getElementById('coach-messages');
  box.innerHTML+=`<div class="ai-label user" style="margin-top:16px">TOI</div><div class="ai-message user">${msg}</div>`;
  const tid='ty'+Date.now();
  box.innerHTML+=`<div id="${tid}"><div class="ai-label coach">COACH</div><div class="ai-message"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`;
  document.getElementById('coach-box').scrollTop=99999;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:[{role:'user',content:msg}]})});
    const d=await r.json();const reply=d.content?.[0]?.text||'Erreur.';
    document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message">${reply.replace(/\n/g,'<br>')}</div>`;
  }catch{document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message" style="color:var(--red)">Erreur — vérifie ta clé API.</div>`}
  document.getElementById('coach-box').scrollTop=99999;
}
function clearCoach(){document.getElementById('coach-messages').innerHTML='<div class="ai-label coach">GAB OS COACH</div><div class="ai-message">Conversation effacée. Prêt à travailler, Gab 💪</div>'}

// INIT
renderCommand();
document.querySelectorAll('.modal-bg').forEach(bg=>bg.addEventListener('click',e=>{if(e.target===bg)bg.classList.remove('open')}));
</script>
</body>
</html>
