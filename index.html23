function saveSettingsName(){const n=document.getElementById('settings-name').value.trim();if(!n){toast('Écris un prénom','var(--red)');return;}localStorage.setItem('ascend_username',n);refreshUserName();toast('Nom mis à jour ✓','var(--g)');}
function saveSettingsGoal(){const v=parseFloat(document.getElementById('settings-goal').value);const p=document.getElementById('settings-goal-period').value;if(!v||v<=0){toast('Montant invalide','var(--red)');return;}localStorage.setItem('ascend_goal_amount',v);localStorage.setItem('ascend_goal_period',p);const label=p==='day'?'/jour':'/mois';document.getElementById('sidebar-goal-val').textContent=v.toLocaleString('fr-FR')+getCurrency()+label;renderCommand();toast('Objectif mis à jour ✓','var(--g)');}
function saveCurrency(){const c=document.getElementById('settings-currency').value;localStorage.setItem('ascend_currency',c);toast('Devise : '+c+' ✓','var(--g)');if(document.getElementById('view-finance').classList.contains('active'))renderFinance('month');}
function setTheme(theme){localStorage.setItem('ascend_theme',theme);applyTheme(theme);document.querySelectorAll('.theme-btn').forEach(b=>{b.classList.remove('sel');if(b.id==='theme-'+theme)b.classList.add('sel');});toast('Thème '+(theme==='dark'?'sombre':theme==='light'?'clair':'automatique')+' ✓','var(--g)');}
function applyTheme(theme){const body=document.body;if(theme==='dark'){body.setAttribute('data-theme','dark');}else if(theme==='light'){body.setAttribute('data-theme','light');}else{const prefersDark=window.matchMedia('(prefers-color-scheme:dark)').matches;body.setAttribute('data-theme',prefersDark?'dark':'light');}}
function setAccentColor(c1,c2){localStorage.setItem('ascend_accent',c1);localStorage.setItem('ascend_accent2',c2);document.documentElement.style.setProperty('--p',c1);document.documentElement.style.setProperty('--pk',c2);document.documentElement.style.setProperty('--pg',c1+'26');document.documentElement.style.setProperty('--biz',c1);toast('Couleur appliquée ✓','var(--g)');}
function toggleSettingsNotif(key,el){el.classList.toggle('on');localStorage.setItem('ascend_notif_'+key,el.classList.contains('on')?'1':'0');}
function exportData(){const data={username:getUserName(),currency:getCurrency(),theme:getTheme(),habits:hState,business:bState,exported:new Date().toISOString()};const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='ascend-v5-backup-'+new Date().toISOString().split('T')[0]+'.json';a.click();toast('Données exportées ✓','var(--g)');}
function importDataTrigger(){document.getElementById('import-file-input').click();}
function importData(e){const file=e.target.files[0];if(!file)return;const reader=new FileReader();reader.onload=ev=>{try{const data=JSON.parse(ev.target.result);if(data.username)localStorage.setItem('ascend_username',data.username);if(data.currency)localStorage.setItem('ascend_currency',data.currency);if(data.habits)localStorage.setItem('gabos_habits',JSON.stringify(data.habits));if(data.business)localStorage.setItem('gabos_biz',JSON.stringify(data.business));toast('Import réussi — recharge la page','var(--g)');setTimeout(()=>location.reload(),1500);}catch{toast('Fichier invalide','var(--red)');}};reader.readAsText(file);}
function confirmResetBiz(){if(confirm('Supprimer toutes les données Business ?')){localStorage.removeItem('gabos_biz');bState=defaultBizState();toast('Business réinitialisé','var(--t1)');}}
function confirmResetHabits(){if(confirm('Supprimer toutes les données Habitudes ?')){localStorage.removeItem('gabos_habits');hState=defaultHabitState();renderToday();renderStats();toast('Habitudes réinitialisées','var(--t1)');}}
function confirmResetAll(){if(confirm('TOUT supprimer ? Irréversible !')){localStorage.clear();location.reload();}}

function initSettings(){
  document.getElementById('settings-name').value=getUserName()!=='toi'?getUserName():'';
  document.getElementById('settings-currency').value=getCurrency();
  const lang=getLang();document.getElementById('settings-lang').value=lang;
  document.getElementById('settings-goal').value=getGoalAmount();
  document.getElementById('settings-goal-period').value=getGoalPeriod();
  const theme=getTheme();
  document.querySelectorAll('.theme-btn').forEach(b=>{b.classList.remove('sel');if(b.id==='theme-'+theme)b.classList.add('sel');});
  const nd=localStorage.getItem('ascend_notif_daily');const nw=localStorage.getItem('ascend_notif_weekly');
  if(nd==='1'||nd===null)document.getElementById('settings-notif-daily').classList.add('on');
  if(nw==='1'||nw===null)document.getElementById('settings-notif-weekly').classList.add('on');
  applyTheme(theme);
  const ac=getAccent(),ac2=getAccent2();
  document.documentElement.style.setProperty('--p',ac);
  document.documentElement.style.setProperty('--pk',ac2);
  document.documentElement.style.setProperty('--pg',ac+'26');
  // GCal
  const cid=localStorage.getItem('ascend_gcal_clientid');
  if(cid){document.getElementById('settings-gcal-clientid').value=cid;}
  if(localStorage.getItem('ascend_gcal_connected')==='1'&&gcalAccessToken){document.getElementById('gcal-status').textContent='✓ Connecté';document.getElementById('gcal-status').style.color='var(--g)';}
}

