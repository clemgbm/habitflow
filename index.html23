let hState, bState;
try { const hs=JSON.parse(localStorage.getItem('gabos_habits')||'null'); hState=hs?{...defaultHabitState(),...hs}:defaultHabitState(); } catch { hState=defaultHabitState(); }
try { const bs=JSON.parse(localStorage.getItem('gabos_biz')||'null'); bState=bs?{...defaultBizState(),...bs}:defaultBizState(); } catch { bState=defaultBizState(); }
// Ensure arrays exist after state merge
if(!hState.focusSessions) hState.focusSessions=[];
if(!hState.calEvents) hState.calEvents=[];
if(!bState.linkCategories||!bState.linkCategories.length) bState.linkCategories=[...DEFAULT_HUB_CATS];
function saveH() { localStorage.setItem('gabos_habits',JSON.stringify(hState)); }
function saveB() { localStorage.setItem('gabos_biz',JSON.stringify(bState)); }

// ══════════════════════════════════════════════════════
//  MODE
// ══════════════════════════════════════════════════════
let currentMode = localStorage.getItem('gabos_mode') || 'biz';

function setMode(mode) {
  currentMode = mode;
  localStorage.setItem('gabos_mode', mode);
  document.body.className = 'mode-' + mode;
  const bizNav = document.getElementById('nav-section-biz');
  const habNav = document.getElementById('nav-section-hab');
  const badge = document.getElementById('sidebar-mode-badge');
  const slider = document.getElementById('modeSlider');
  const pillBiz = document.querySelector('.mode-pill-biz');
  const pillHab = document.querySelector('.mode-pill-hab');
  const switcher = document.getElementById('modeSwitcher');
  if (mode === 'biz') {
    bizNav.classList.remove('hidden-section'); habNav.classList.add('hidden-section');
    badge.textContent = '<svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2L4 11h7l-2 7 9-10h-7l2-8z"/></svg> Business';
    pillBiz.classList.add('active-biz'); pillHab.classList.remove('active-hab');
    const br=pillBiz.getBoundingClientRect(),sr=switcher.getBoundingClientRect();
    slider.style.left=(br.left-sr.left)+'px'; slider.style.width=br.width+'px';
    showView('command');
  } else {
    bizNav.classList.add('hidden-section'); habNav.classList.remove('hidden-section');
    badge.innerHTML = '<svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 18V10M10 10C10 10 6 6 3 4c5-2 7 2 7 6M10 10c0 0 4-4 7-6-2 5-7 6-7 6"/></svg> Habitudes';
    pillBiz.classList.remove('active-biz'); pillHab.classList.add('active-hab');
    const hr=pillHab.getBoundingClientRect(),sr=switcher.getBoundingClientRect();
    slider.style.left=(hr.left-sr.left)+'px'; slider.style.width=hr.width+'px';
    showView('today');
  }
}

function initSlider() {
  document.body.className='mode-'+currentMode;
  const slider=document.getElementById('modeSlider');
  const switcher=document.getElementById('modeSwitcher');
  const pill=document.querySelector('.mode-pill-'+currentMode);
  if(pill&&switcher){
    const pr=pill.getBoundingClientRect(),sr=switcher.getBoundingClientRect();
    slider.style.transition='none';
    slider.style.left=(pr.left-sr.left)+'px'; slider.style.width=pr.width+'px';
    setTimeout(()=>{slider.style.transition='';},50);
  }
  const bizNav=document.getElementById('nav-section-biz');
  const habNav=document.getElementById('nav-section-hab');
  const badge=document.getElementById('sidebar-mode-badge');
  if(currentMode==='biz'){
    bizNav.classList.remove('hidden-section'); habNav.classList.add('hidden-section');
    badge.innerHTML='<svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M11 2L4 11h7l-2 7 9-10h-7l2-8z"/></svg> Business';
    document.querySelector('.mode-pill-biz').classList.add('active-biz');
  } else {
    bizNav.classList.add('hidden-section'); habNav.classList.remove('hidden-section');
    badge.innerHTML='<svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 18V10M10 10C10 10 6 6 3 4c5-2 7 2 7 6M10 10c0 0 4-4 7-6-2 5-7 6-7 6"/></svg> Habitudes';
    document.querySelector('.mode-pill-hab').classList.add('active-hab');
  }
}

// ══════════════════════════════════════════════════════
//  UTILS
// ══════════════════════════════════════════════════════
function todayKey() { return new Date().toISOString().slice(0,10); }
function keyForDate(d) { return d.toISOString().slice(0,10); }
function fmtDate(d) { return new Date(d+'T12:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'}); }
function daysLeft() { return Math.ceil((new Date('2026-12-01')-new Date())/(1000*60*60*24)); }
function todayData() { const k=todayKey();if(!hState.history[k])hState.history[k]={};return hState.history[k]; }
function getLast(n) { const days=[];for(let i=n-1;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);days.push(keyForDate(d));}return days; }
function dateShort(ds) { const d=new Date(ds+'T12:00:00');return['Di','Lu','Ma','Me','Je','Ve','Sa'][d.getDay()]; }
function formatDateFull(ds) { const d=new Date(ds+'T00:00:00');return d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'}); }
function getCurrency(){ return localStorage.getItem('ascend_currency')||'€'; }
function getTheme(){ return localStorage.getItem('ascend_theme')||'auto'; }
function getAccent(){ return localStorage.getItem('ascend_accent')||'#7c5cfc'; }
function getAccent2(){ return localStorage.getItem('ascend_accent2')||'#e040a8'; }
function getGoalAmount(){ return parseFloat(localStorage.getItem('ascend_goal_amount')||'4000'); }
function getGoalPeriod(){ return localStorage.getItem('ascend_goal_period')||'day'; }
function getUserName(){ return localStorage.getItem('ascend_username')||'toi'; }
function fmtDuration(ms){const s=Math.floor(ms/1000),m=Math.floor(s/60),h=Math.floor(m/60);return h>0?`${h}h${String(m%60).padStart(2,'0')}`:`${m}min ${String(s%60).padStart(2,'0')}s`;}
function fmtHHMMSS(ms){const s=Math.floor(ms/1000),m=Math.floor(s/60),h=Math.floor(m/60);return`${String(h).padStart(2,'0')}:${String(m%60).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;}
function fmtMMSS(s){return`${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;}

// ══════════════════════════════════════════════════════
//  MIDNIGHT RESET CHECK
// ══════════════════════════════════════════════════════
function checkMidnightReset(){
  // Check every minute if we've crossed midnight
  const now = new Date();
  const nextMidnight = new Date(now);
  nextMidnight.setDate(nextMidnight.getDate()+1);
  nextMidnight.setHours(0,0,0,0);
  const msToMidnight = nextMidnight - now;
  setTimeout(() => {
    // At midnight: force re-render of today view if active
    if(document.getElementById('view-today').classList.contains('active')) renderToday();
    checkMidnightReset(); // schedule next
  }, msToMidnight + 100);
}

// ══════════════════════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════════════════════
function showView(name) {
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const v=document.getElementById('view-'+name);if(v)v.classList.add('active');
  const ni=document.getElementById('nav-'+name);if(ni)ni.classList.add('active');
  if(name==='settings'){
    const nb=document.getElementById('nav-settings-biz');if(nb)nb.classList.add('active');
    const nh=document.getElementById('nav-settings-hab');if(nh)nh.classList.add('active');
    initSettings();
  }
  closeSidebar();
  if(name==='today'){renderToday();}
  if(name==='focus'){renderFocus();}
  if(name==='stats'){renderStats();checkMondayBilan();updateBilanBtn();}
  if(name==='objectives'){renderObjectives();}
  if(name==='rewards'){renderRewards();}
  if(name==='manage'){renderManage();renderColorPicker();}
  if(name==='command'){renderCommand();}
  if(name==='finance'){renderFinance('month');}
  if(name==='products'){renderProducts();}
  if(name==='ads'){renderAds();}
  if(name==='analytics'){renderAnalytics();}
  if(name==='tasks'){renderTasks();}
  if(name==='strategy'){renderStrategy();}
  if(name==='hub'){renderHub();}
  if(name==='knowledge'){renderKnowledge();}
  if(name==='calendar'){renderCalendar();}
  if(name==='integrations'){initIntegrations();}
}
function openSidebar(){document.getElementById('sidebar').classList.add('open');document.getElementById('sidebarOverlay').classList.add('show')}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('show')}
function openModal(id){document.getElementById(id).classList.add('open');document.querySelectorAll('#'+id+' input[type="date"]').forEach(i=>{if(!i.value)i.value=todayKey();});}
function closeModal(id){document.getElementById(id).classList.remove('open');}
function toast(msg,color){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=color||'var(--p)';t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2500);}
function showBurst(em){const b=document.getElementById('burst');b.textContent=em;b.classList.remove('show');void b.offsetWidth;b.classList.add('show');setTimeout(()=>b.classList.remove('show'),700);}

// ══════════════════════════════════════════════════════
//  CLOCK
// ══════════════════════════════════════════════════════
function updateClock() {
  const n=new Date(),t=n.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const el=document.getElementById('cmd-clock');if(el)el.textContent=t;
  const el2=document.getElementById('clock-today');if(el2)el2.textContent=t;
  const ds=document.getElementById('goal-days-left-sidebar');if(ds)ds.textContent=daysLeft()+' jours restants';
  setTimeout(updateClock,1000);
}

// ══════════════════════════════════════════════════════
//  HABIT CALCS
// ══════════════════════════════════════════════════════
function completionPct(dayKey){const h=hState.history[dayKey]||{};const total=hState.habits.length;if(!total)return 0;return Math.round((hState.habits.filter(hb=>h[hb.id]).length/total)*100);}
function avgPct(days){const vals=days.map(d=>completionPct(d));return Math.round(vals.reduce((a,b)=>a+b,0)/vals.length);}
function calcStreak(){let streak=0,d=new Date();while(streak<365){const k=keyForDate(d);if(completionPct(k)>=50)streak++;else break;d.setDate(d.getDate()-1);}return streak;}
function levelInfo(){const xp=hState.xp||0;let lv=0;for(let i=0;i<LEVELS.length;i++){if(xp>=LEVELS[i].min)lv=i;}const cur=LEVELS[lv],next=LEVELS[lv+1],xpIn=xp-cur.min,xpNeed=next?next.min-cur.min:500,progress=Math.min(100,Math.round((xpIn/xpNeed)*100));return{num:lv+1,name:cur.name,emoji:cur.emoji,progress,xpIn,xpNeed};}
// ══════════════════════════════════════════════════════
//  MICRO-ANIMATION UTILITIES
// ══════════════════════════════════════════════════════

/**
 * Animate a numeric counter from 0 (or current displayed value) to `target`.
 * el      – DOM element to update
 * target  – final numeric value
 * opts    – { duration:ms, decimals:int, suffix:str, prefix:str, easing:fn }
 */
function countUp(el, target, opts = {}) {
  const {
    duration = 900,
    decimals = 0,
    suffix   = '',
    prefix   = '',
    easing   = t => 1 - Math.pow(1 - t, 3)   // ease-out cubic
  } = opts;
  const start    = performance.now();
  const startVal = parseFloat(el.dataset.countVal || 0) || 0;
  el.dataset.countVal = target;

  function step(now) {
    const elapsed = Math.min(now - start, duration);
    const progress = easing(elapsed / duration);
    const current  = startVal + (target - startVal) * progress;
    el.textContent = prefix + current.toFixed(decimals) + suffix;
    if (elapsed < duration) requestAnimationFrame(step);
    else el.textContent = prefix + target.toFixed(decimals) + suffix;
  }
  requestAnimationFrame(step);
}

/**
 * Animate XP bar width from 0% → target% with spring feel,
 * then trigger the shimmer.
 */
function animateXPBar(barEl, targetPct) {
  // Reset to 0 so the transition is visible
  barEl.style.transition = 'none';
  barEl.style.width = '0%';
  barEl.classList.remove('xp-animate');

  // Force reflow
  void barEl.offsetWidth;

  // Re-enable transition and set target
  barEl.style.transition = '';
  barEl.style.width = targetPct + '%';

  // Add shimmer class after bar lands
  setTimeout(() => barEl.classList.add('xp-animate'), 800);
}

function updateXP(){
  const lv     = levelInfo();
  const streak = calcStreak();

  document.getElementById('s-level-badge').textContent =
    `Niv.${lv.num} — ${lv.name}`;
  document.getElementById('s-streak').innerHTML = `<svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 8 5 12.5a5 5 0 0010 0C15 8 10 2 10 2z"/><path d="M10 15.5a2 2 0 010-4"/></svg> ${streak} jours`;

  // Update Duolingo streak badge
  updateStreakBadgeDuo(streak);

  // Animated XP counter
  const xpValEl = document.getElementById('s-xp-val');
  xpValEl.textContent = `${lv.xpIn} / ${lv.xpNeed} XP`; // instant for label

  // Animated XP bar
  animateXPBar(document.getElementById('s-xp-bar'), lv.progress);
}

function updateStreakBadgeDuo(streak){
  const badge = document.getElementById('streak-badge-duo');
  const count = document.getElementById('streak-count-duo');
  if(!badge || !count) return;
  count.textContent = streak;
  badge.classList.remove('alive','dead');
  if(streak > 0){
    badge.classList.add('alive');
  } else {
    badge.classList.add('dead');
  }
}
function addXP(amount){const oldLv=levelInfo().num;hState.xp=(hState.xp||0)+amount;if(levelInfo().num>oldLv)toast(`Niveau ${levelInfo().num} — ${levelInfo().name}`,'var(--gold)');updateXP();}
function checkBadges(){const streak=calcStreak(),lv=levelInfo().num;BADGES.forEach(b=>{if((hState.unlockedBadges||[]).includes(b.id))return;let unlock=false;if(b.req.streak&&streak>=b.req.streak)unlock=true;if(b.req.perfect&&(hState.perfectDays||0)>=b.req.perfect)unlock=true;if(b.req.perfectDays&&(hState.perfectDays||0)>=b.req.perfectDays)unlock=true;if(b.req.level&&lv>=b.req.level)unlock=true;if(b.req.habitsCount&&hState.habits.length>=b.req.habitsCount)unlock=true;if(unlock){hState.unlockedBadges=[...(hState.unlockedBadges||[]),b.id];setTimeout(()=>toast(`★ Badge : ${b.icon} ${b.name} !`,'var(--gold)'),800);}});}

// ══════════════════════════════════════════════════════
//  RENDER TODAY
// ══════════════════════════════════════════════════════
function renderToday(){
  const td=todayData(),total=hState.habits.length,doneArr=hState.habits.filter(h=>td[h.id]),pct=total?Math.round((doneArr.length/total)*100):0;
  const now=new Date(),hour=now.getHours();
  document.getElementById('today-title').textContent=(hour<12?'Bonjour':'Bonsoir')+' '+getUserName();
  document.getElementById('today-date').textContent=formatDateFull(todayKey());
  // Animate ring
  const circ=2*Math.PI*54;
  const ringEl=document.getElementById('ring-circle');
  const targetOffset=circ-(pct/100)*circ;
  ringEl.style.transition='none';
  ringEl.style.strokeDashoffset=circ; // start at 0%
  void ringEl.offsetWidth;
  ringEl.style.transition='stroke-dashoffset .8s cubic-bezier(.34,1.1,.64,1)';
  ringEl.style.strokeDashoffset=targetOffset;
  // Animate pct text counter
  const ringPctEl=document.getElementById('ring-pct');
  ringPctEl.dataset.countVal=0;
  countUp(ringPctEl,pct,{decimals:0,suffix:'%',duration:800});
  // Animate done/remain/xp counters
  const doneEl=document.getElementById('done-count');
  const remEl=document.getElementById('remain-count');
  const xpEl=document.getElementById('today-xp-total');
  const todayXP=doneArr.reduce((s,h)=>s+(h.xp||10),0);
  if(doneEl){doneEl.dataset.countVal=0;countUp(doneEl,doneArr.length,{decimals:0,duration:600});}
  if(remEl) {remEl.dataset.countVal=0;countUp(remEl,total-doneArr.length,{decimals:0,duration:600});}
  if(xpEl)  {xpEl.dataset.countVal=0;countUp(xpEl,todayXP,{decimals:0,duration:750});}
  const msgs=[
    [0,'Lance-toi !','Commence par une petite habitude.'],
    [30,'En route !','Tu as démarré, continue l\'élan.'],
    [50,'À mi-chemin ','Tu es en bonne voie !'],
    [80,'Presque là','Plus qu\'une ou deux habitudes !'],
    [100,'Journée parfaite','Tu as tout fait aujourd\'hui !'],
  ];
  const m=msgs.reduce((a,b)=>pct>=b[0]?b:a,msgs[0]);
  document.getElementById('ring-msg').textContent=m[1];
  document.getElementById('ring-submsg').textContent=m[2];
  const list=document.getElementById('habits-list');
  list.innerHTML=hState.habits.map((h,i)=>{
    const done=!!td[h.id];
    const streak=habitStreak(h.id);
    return`<div class="habit-card ${done?'done':''}" style="animation-delay:${i*0.055}s" onclick="toggleHabit('${h.id}')">
      <div class="hc-icon" style="background:${h.color}22;border:1px solid ${h.color}44;font-size:1.1rem">${h.emoji||'⭐'}</div>
      <div class="hc-body">
        <div class="hc-name">${h.name}</div>
        <div class="hc-sub">+${h.xp||10} XP${streak>0?' · ' + streak + 'j':''}</div>
      </div>
      <div class="hc-actions">
        <button class="btn-icon" onclick="event.stopPropagation();editHabitQuick('${h.id}',event)" title="Modifier">
          <svg viewBox="0 0 20 20"><path d="M13 3l4 4-10 10H3v-4L13 3z"/></svg>
        </button>
      </div>
      <div class="hc-check" style="${done?'background:'+h.color+';border-color:'+h.color:'border-color:'+h.color+'66'}">
        ${done?'<svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><polyline points="2,6 5,9 10,3"/></svg>':''}
      </div>
    </div>`;
  }).join('');
  if(!total)list.innerHTML='<div class="empty"><div class="ei"><svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 18V10M10 10C10 10 6 6 3 4c5-2 7 2 7 6M10 10c0 0 4-4 7-6-2 5-7 6-7 6"/></svg></div><p>Ajoute ta première habitude !</p></div>';
  // Insight
  const ins=document.getElementById('today-insight');
  const streak=calcStreak();
  if(pct===100){ins.innerHTML=`<div class="insight-card ok-card"><div class="i-head"><span class="i-icon"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M6 2h8v7a4 4 0 01-8 0V2z"/><path d="M6 6H3a2 2 0 000 4h3M14 6h3a2 2 0 010 4h-3M10 13v4M7 17h6"/></svg></span><div><div class="i-title">Journée parfaite !</div></div></div><div class="i-body">Toutes tes habitudes sont faites. Streak actuel : ${streak} jours</div></div>`;}
  else if(streak>=3){ins.innerHTML=`<div class="insight-card ok-card"><div class="i-head"><span class="i-icon"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 8 5 12.5a5 5 0 0010 0C15 8 10 2 10 2z"/><path d="M10 15.5a2 2 0 010-4"/></svg></span><div><div class="i-title">Streak de ${streak} jours !</div></div></div><div class="i-body">Ne brise pas la chaîne — complète au moins une habitude aujourd'hui.</div></div>`;}
  else ins.innerHTML='';
}

function habitStreak(hid){let streak=0,d=new Date();d.setDate(d.getDate()-1);while(streak<365){const k=keyForDate(d);if(hState.history[k]&&hState.history[k][hid])streak++;else break;d.setDate(d.getDate()-1);}return streak;}

function toggleHabit(id){
  const td=todayData(),h=hState.habits.find(x=>x.id===id);if(!h)return;
  const total=hState.habits.length;
  if(td[id]){
    // Was today already counted as a perfect day?
    const wasPerfect=(hState.perfectDayKeys||[]).includes(todayKey());
    delete td[id];
    // Remove XP for this habit
    hState.xp=Math.max(0,(hState.xp||0)-(h.xp||10));
    // If today was perfect and now it's no longer complete, undo the perfect day
    if(wasPerfect){
      hState.xp=Math.max(0,(hState.xp||0)-10);
      hState.perfectDays=Math.max(0,(hState.perfectDays||1)-1);
      hState.perfectDayKeys=(hState.perfectDayKeys||[]).filter(k=>k!==todayKey());
    }
  }
  else{
    td[id]=true;addXP(h.xp||10);showBurst(h.emoji||'⭐');
    const done=hState.habits.filter(hb=>td[hb.id]).length;
    // Only grant perfect day bonus once per day
    const todayAlreadyPerfect=(hState.perfectDayKeys||[]).includes(todayKey());
    if(done===total&&total>0&&!todayAlreadyPerfect){
      hState.perfectDays=(hState.perfectDays||0)+1;
      hState.perfectDayKeys=[...(hState.perfectDayKeys||[]),todayKey()];
      setTimeout(()=>toast('⭐ Journée parfaite ! +10 XP bonus','var(--gold)'),300);
      addXP(10);
    }
  }
  hState.history[todayKey()]=td;saveH();
  // Re-render then briefly add pop class to the toggled card
  renderToday();checkBadges();updateXP();
  requestAnimationFrame(()=>{
    const cards=document.querySelectorAll('.habit-card');
    const idx=hState.habits.findIndex(x=>x.id===id);
    if(cards[idx]){
      cards[idx].classList.add('pop');
      setTimeout(()=>cards[idx].classList.remove('pop'),350);
    }
  });
}

// ══════════════════════════════════════════════════════
//  HABIT MODAL
// ══════════════════════════════════════════════════════
let selEmoji=EMOJIS[0],selColor=COLORS[0];
function renderEmojiGrid(){document.getElementById('emoji-grid').innerHTML=EMOJIS.map((e,i)=>`<div class="emoji-btn ${e===selEmoji?'sel':''}" data-ei="${i}" onclick="selEmoji=EMOJIS[this.dataset.ei|0];renderEmojiGrid()" style="font-size:1.3rem;cursor:pointer">${e}</div>`).join('');}
function renderModalColorPicker(){document.getElementById('modal-color-picker').innerHTML=COLORS.map(c=>`<div class="color-dot ${c===selColor?'sel':''}" style="background:${c}" onclick="selColor='${c}';renderModalColorPicker()"></div>`).join('');}
function renderColorPicker(){document.getElementById('color-picker').innerHTML=COLORS.map(c=>`<div class="color-dot ${c===selColor?'sel':''}" style="background:${c}" onclick="selColor='${c}';renderColorPicker()"></div>`).join('');}
function openAddModal(){hState.editingHabit=null;selEmoji=EMOJIS[0];selColor=COLORS[0];document.getElementById('modal-title').textContent='Nouvelle habitude';document.getElementById('modal-name').value='';document.getElementById('modal-xp').value=10;renderEmojiGrid();renderModalColorPicker();document.getElementById('habitModal').classList.add('open');}
function closeHabitModal(){document.getElementById('habitModal').classList.remove('open');hState.editingHabit=null;}
function saveHabit(){const name=document.getElementById('modal-name').value.trim();if(!name){toast('Donne un nom !','var(--red)');return;}const xp=parseInt(document.getElementById('modal-xp').value)||10;if(hState.editingHabit){const h=hState.habits.find(x=>x.id===hState.editingHabit);if(h){h.name=name;h.emoji=selEmoji;h.color=selColor;h.xp=xp;}}else hState.habits.push({id:'h'+Date.now(),name,emoji:selEmoji,color:selColor,xp});saveH();closeHabitModal();renderToday();renderManage&&renderManage();toast('Habitude enregistrée ✓','var(--g)');}
function editHabitQuick(id,e){e.stopPropagation();const h=hState.habits.find(x=>x.id===id);if(!h)return;hState.editingHabit=id;selEmoji=h.emoji||EMOJIS[0];selColor=h.color||COLORS[0];document.getElementById('modal-title').textContent='Modifier';document.getElementById('modal-name').value=h.name;document.getElementById('modal-xp').value=h.xp||10;renderEmojiGrid();renderModalColorPicker();document.getElementById('habitModal').classList.add('open');}
function editHabitQuick2(id){const h=hState.habits.find(x=>x.id===id);if(!h)return;hState.editingHabit=id;selEmoji=h.emoji||EMOJIS[0];selColor=h.color||COLORS[0];document.getElementById('modal-title').textContent='Modifier';document.getElementById('modal-name').value=h.name;document.getElementById('modal-xp').value=h.xp||10;renderEmojiGrid();renderModalColorPicker();document.getElementById('habitModal').classList.add('open');}
function removeHabit(id){hState.habits=hState.habits.filter(h=>h.id!==id);saveH();renderToday();renderManage&&renderManage();}
function quickAddHabit(){const name=document.getElementById('quick-name').value.trim();if(!name)return;hState.habits.push({id:'h'+Date.now(),name,emoji:'⭐',color:selColor,xp:10});document.getElementById('quick-name').value='';saveH();renderToday();renderManage();toast('Habitude ajoutée !');}
function toggleNotif(key,el){el.classList.toggle('on');hState.notifs[key]=el.classList.contains('on');saveH();}
function confirmReset(){if(confirm('Réinitialiser toutes les données habitudes ?')){localStorage.removeItem('gabos_habits');hState=defaultHabitState();saveH();renderToday();renderManage();updateXP();toast('Données réinitialisées');}}

function renderManage(){
  const ml=document.getElementById('manage-list');if(!ml)return;
  ml.innerHTML=hState.habits.map(h=>`<div class="habit-manage-item">
    <div style="font-size:1.2rem;width:28px;text-align:center">${h.emoji||'⭐'}</div>
    <div style="width:10px;height:10px;border-radius:50%;background:${h.color||COLORS[0]};flex-shrink:0"></div>
    <div class="hm-name">${h.name}</div>
    <div style="font-size:.68rem;color:var(--gold);margin-right:8px;font-family:'DM Mono',monospace">+${h.xp||10}XP</div>
    <div class="hm-btns">
      <button class="hm-btn" onclick="editHabitQuick2('${h.id}')"><svg viewBox="0 0 16 16"><path d="M11 2l3 3-8 8H3v-3L11 2z"/></svg></button>
      <button class="hm-btn" style="color:var(--red)" onclick="removeHabit('${h.id}')"><svg viewBox="0 0 16 16"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg></button>
    </div>
  </div>`).join('')||'<div class="empty-state">Aucune habitude</div>';
}

