function finishOnboarding(){const name=document.getElementById('onboarding-name').value.trim();if(!name){document.getElementById('onboarding-name').style.borderColor='var(--red)';return;}localStorage.setItem('ascend_username',name);const overlay=document.getElementById('onboarding-overlay');overlay.style.opacity='0';overlay.style.transition='opacity .4s ease';setTimeout(()=>{overlay.style.display='none';},400);refreshUserName();}
