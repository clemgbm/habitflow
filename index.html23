let currentFocusTab = 'meditation';
function setFocusTab(tab, btn){
  currentFocusTab = tab;
  document.querySelectorAll('.focus-tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('fp-meditation').style.display = tab==='meditation'?'block':'none';
  document.getElementById('fp-chrono').style.display = tab==='chrono'?'block':'none';
  document.getElementById('fp-calendar').style.display = tab==='calendar'?'block':'none';
  if(tab==='chrono'){ renderChronoStats(); renderChronoTodayLog(); renderChronoActivityChips(); }
  if(tab==='calendar'){ initCalendarPanel(); }
}
function renderFocus(){
  renderSoundGrid();
  renderMedSessionLog();
  renderChronoStats();
  renderChronoTodayLog();
  renderChronoActivityChips();
}

// ══════════════════════════════════════════════════════
//  MEDITATION
// ══════════════════════════════════════════════════════
let medDuration = 5 * 60; // seconds
let medRemaining = medDuration;
let medInterval = null;
let medRunning = false;
let medStartTimestamp = null;   // Date.now() when timer last started
let medRemainingAtStart = 0;    // medRemaining snapshot when timer last started
let medAudioCtx = null;
let medGainNodes = {};
let medSources = {};
let activeSound = null;
const DEFAULT_MED_SOUNDS = [];

function loadMedSounds(){
  const hidden = JSON.parse(localStorage.getItem('ascend_hidden_builtins')||'[]');
  const saved = localStorage.getItem('ascend_custom_sounds');
  let custom = [];
  if(saved){ try { custom = JSON.parse(saved); } catch(e){} }
  return [...DEFAULT_MED_SOUNDS.filter(s=>!hidden.includes(s.key)), ...custom];
}

function saveCustomSounds(){
  const custom = activeMedSounds.filter(s=>!s.builtin);
  localStorage.setItem('ascend_custom_sounds', JSON.stringify(custom));
}

let activeMedSounds = loadMedSounds();

function renderSoundGrid(){
  const container = document.getElementById('sound-grid-container');
  if(!container) return;
  container.innerHTML = activeMedSounds.map(s=>`
    <div class="sound-card" id="sc-${s.key}" onclick="toggleSound('${s.key}')">
      <span class="sound-icon">${s.emoji}</span>
      <div class="sound-name">${s.label}</div>
      <div class="sound-desc">${s.desc}</div>
    </div>`).join('');
}

function openSoundManager(){
  renderSoundManagerList();
  openModal('modal-sound-manager');
}

// Track hidden built-in sounds
let hiddenBuiltins = JSON.parse(localStorage.getItem('ascend_hidden_builtins')||'[]');

function saveHiddenBuiltins(){
  localStorage.setItem('ascend_hidden_builtins', JSON.stringify(hiddenBuiltins));
}

function renderSoundManagerList(){
  const el = document.getElementById('sound-manager-list');
  if(!el) return;
  const allSounds = [...DEFAULT_MED_SOUNDS, ...activeMedSounds.filter(s=>!s.builtin)];
  el.innerHTML = allSounds.map((s)=>{
    const hidden = hiddenBuiltins.includes(s.key);
    const srcBadge = s.srcType==='youtube' ? `<span style="font-size:.58rem;color:var(--blue);background:var(--blueo);border-radius:999px;padding:2px 7px;font-weight:700">YT</span>`
      : s.srcType==='file' ? `<span style="font-size:.58rem;color:var(--gold);background:var(--goldo);border-radius:999px;padding:2px 7px;font-weight:700">FILE</span>`
      : '';
    return `<div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--s1);border-radius:var(--rs);margin-bottom:6px;border:1px solid var(--b0);opacity:${hidden?0.4:1}">
      <span style="font-size:1.3rem;width:28px;text-align:center">${s.emoji}</span>
      <div style="flex:1">
        <div style="font-size:.83rem;font-weight:600;color:var(--t0)">${s.label} ${srcBadge}</div>
        <div style="font-size:.68rem;color:var(--t1)">${s.desc}</div>
      </div>
      ${s.builtin
        ? `<button onclick="toggleBuiltinVisibility('${s.key}')" title="${hidden?'Afficher':'Masquer'}" style="background:var(--s2);border:1px solid var(--b1);color:var(--t1);border-radius:7px;padding:4px 9px;cursor:pointer;font-size:.7rem;font-weight:600">${hidden?'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M2 10c2-4 4.7-6 8-6s6 2 8 6c-2 4-4.7 6-8 6s-6-2-8-6z"/><circle cx="10" cy="10" r="2.5"/></svg>':'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M2 10c2-4 4.7-6 8-6s6 2 8 6c-2 4-4.7 6-8 6s-6-2-8-6z"/><line x1="3" y1="3" x2="17" y2="17"/></svg>'}</button>`
        : `<button onclick="renameSoundPrompt('${s.key}')" style="background:var(--s2);border:1px solid var(--b1);color:var(--t1);border-radius:7px;padding:4px 9px;cursor:pointer;font-size:.7rem;font-weight:600"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M13 3l4 4-9 9H4v-4l9-9z"/><path d="M11 5l4 4"/></svg></button>
           <button onclick="deleteCustomSound('${s.key}')" style="background:rgba(240,71,111,.12);border:1px solid rgba(240,71,111,.25);color:var(--red);border-radius:7px;padding:4px 9px;cursor:pointer;font-size:.7rem;font-weight:600">✕</button>`
      }
    </div>`;
  }).join('');
}

function toggleBuiltinVisibility(key){
  if(hiddenBuiltins.includes(key)){
    hiddenBuiltins = hiddenBuiltins.filter(k=>k!==key);
  } else {
    hiddenBuiltins.push(key);
    if(activeSound===key){ stopAmbient(); activeSound=null; }
  }
  saveHiddenBuiltins();
  // Rebuild activeMedSounds
  activeMedSounds = DEFAULT_MED_SOUNDS.filter(s=>!hiddenBuiltins.includes(s.key))
    .concat(activeMedSounds.filter(s=>!s.builtin));
  renderSoundGrid();
  renderSoundManagerList();
}

let activeSrcTab = 'yt';
function switchSrcTab(tab){
  activeSrcTab = tab;
  ['yt','file'].forEach(t=>{
    const btn = document.getElementById('src-tab-'+t);
    const panel = document.getElementById('src-panel-'+t);
    if(t===tab){
      btn.style.background='var(--pg)'; btn.style.color='var(--p)'; btn.style.borderColor='var(--p)';
      if(panel) panel.style.display='';
    } else {
      btn.style.background='transparent'; btn.style.color='var(--t1)'; btn.style.borderColor='var(--b1)';
      if(panel) panel.style.display='none';
    }
  });
}

// ── Classify any URL into a playback strategy ──
function classifyUrl(url){
  if(!url) return null;
  // YouTube
  const ytMatch = url.match(/(?:v=|youtu\.be\/|embed\/|shorts\/)([A-Za-z0-9_-]{11})/);
  if(ytMatch) return { srcType:'youtube', ytId:ytMatch[1] };
  // Direct audio file
  if(/\.(mp3|ogg|wav|flac|aac|opus|m4a|webm)(\?.*)?$/i.test(url)) return { srcType:'audio', url };
  // Everything else → iframe (Generative.fm, SoundCloud, Spotify, etc.)
  return { srcType:'iframe', url };
}

function extractYouTubeId(url){
  const m = url.match(/(?:v=|youtu\.be\/|embed\/|shorts\/)([A-Za-z0-9_-]{11})/);
  return m ? m[1] : null;
}

function addCustomSound(){
  const emoji = document.getElementById('new-sound-emoji').value.trim() || '♪';
  const name  = document.getElementById('new-sound-name').value.trim();
  const desc  = document.getElementById('new-sound-desc').value.trim() || 'Son personnalisé';
  if(!name){ toast('Donne un nom au son','var(--red)'); return; }
  const key = 'custom_'+Date.now();

  if(activeSrcTab==='yt'){
    const rawUrl = document.getElementById('new-sound-yturl').value.trim();
    if(!rawUrl){ toast('Colle une URL','var(--red)'); return; }
    const classified = classifyUrl(rawUrl);
    if(!classified){ toast('URL invalide','var(--red)'); return; }
    if(classified.srcType==='youtube'){
      activeMedSounds.push({ key, emoji, label:name, desc, type:'youtube', srcType:'youtube', ytId:classified.ytId, builtin:false });
    } else if(classified.srcType==='audio'){
      activeMedSounds.push({ key, emoji, label:name, desc, type:'audio', srcType:'audio', url:classified.url, builtin:false });
    } else {
      // iframe (Generative.fm, SoundCloud, etc.)
      activeMedSounds.push({ key, emoji, label:name, desc, type:'iframe', srcType:'iframe', url:classified.url, builtin:false });
    }
    saveCustomSounds();
    renderSoundGrid(); renderSoundManagerList();
    document.getElementById('new-sound-yturl').value='';
    toast(`Son "${name}" ajouté ✓`,'var(--g)');

  } else if(activeSrcTab==='file'){
    const fileInput = document.getElementById('new-sound-file');
    const file = fileInput.files[0];
    if(!file){ toast('Sélectionne un fichier audio','var(--red)'); return; }
    const reader = new FileReader();
    reader.onload = function(e){
      const dataUrl = e.target.result;
      activeMedSounds.push({ key, emoji, label:name, desc, type:'file', srcType:'file', fileData:dataUrl, builtin:false });
      saveCustomSounds();
      renderSoundGrid(); renderSoundManagerList();
      toast(`Son "${name}" ajouté ✓`,'var(--g)');
    };
    reader.readAsDataURL(file);
    fileInput.value='';

  } else {
    toast('Sélectionne une source (Lien ou Fichier)','var(--red)');
    return;
  }

  document.getElementById('new-sound-emoji').value='';
  document.getElementById('new-sound-name').value='';
  document.getElementById('new-sound-desc').value='';
}

function deleteCustomSound(key){
  const s = activeMedSounds.find(s=>s.key===key);
  if(!s||s.builtin) return;
  if(activeSound===key){ stopAmbient(); stopExternalAudio(); activeSound=null; }
  activeMedSounds = activeMedSounds.filter(s=>s.key!==key);
  saveCustomSounds();
  renderSoundGrid();
  renderSoundManagerList();
  toast(`Son supprimé`,'var(--t1)');
}

function renameSoundPrompt(key){
  const s = activeMedSounds.find(s=>s.key===key);
  if(!s) return;
  const newName = prompt('Nouveau nom pour ce son :', s.label);
  if(!newName || !newName.trim()) return;
  const newEmoji = prompt('Nouvel emoji :', s.emoji) || s.emoji;
  const newDesc  = prompt('Nouvelle description :', s.desc) || s.desc;
  s.label = newName.trim();
  s.emoji = newEmoji.trim();
  s.desc  = newDesc.trim();
  saveCustomSounds();
  renderSoundGrid();
  renderSoundManagerList();
  toast(`Son renommé ✓`,'var(--g)');
}

function getAudioCtx(){
  if(!medAudioCtx) medAudioCtx = new (window.AudioContext||window.webkitAudioContext)();
  return medAudioCtx;
}

function createAmbientSound(key){
  const soundDef = activeMedSounds.find(s=>s.key===key);
  const type = soundDef ? soundDef.type : key;
  const ctx = getAudioCtx();
  const masterGain = ctx.createGain();
  const vol = parseInt(document.getElementById('med-volume').value)/100 * 0.6;
  masterGain.gain.setValueAtTime(vol, ctx.currentTime);
  masterGain.connect(ctx.destination);
  const nodes = [];
  if(type==='rain'){
    // White noise
    const bufSize = ctx.sampleRate * 2;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = Math.random()*2-1;
    const src = ctx.createBufferSource(); src.buffer=buf; src.loop=true;
    const filt = ctx.createBiquadFilter(); filt.type='bandpass'; filt.frequency.value=1200; filt.Q.value=0.5;
    src.connect(filt); filt.connect(masterGain); src.start();
    nodes.push(src);
  } else if(type==='ocean'){
    for(let f of [80,160,320]){
      const osc = ctx.createOscillator(); osc.type='sine'; osc.frequency.value=f;
      const lfo = ctx.createOscillator(); lfo.type='sine'; lfo.frequency.value=0.1+Math.random()*0.1;
      const lfoGain = ctx.createGain(); lfoGain.gain.value=0.4;
      lfo.connect(lfoGain); lfoGain.connect(osc.frequency);
      const g = ctx.createGain(); g.gain.value=0.15;
      osc.connect(g); g.connect(masterGain);
      osc.start(); lfo.start(); nodes.push(osc,lfo);
    }
  } else if(type==='forest'){
    const bufSize = ctx.sampleRate * 2;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = (Math.random()*2-1)*0.3;
    const src = ctx.createBufferSource(); src.buffer=buf; src.loop=true;
    const filt = ctx.createBiquadFilter(); filt.type='highpass'; filt.frequency.value=600;
    src.connect(filt); filt.connect(masterGain); src.start();
    nodes.push(src);
    // Bird-like chirps
    for(let i=0;i<3;i++){
      const osc2=ctx.createOscillator(); osc2.type='sine'; osc2.frequency.value=800+Math.random()*1200;
      const env=ctx.createGain(); env.gain.setValueAtTime(0,ctx.currentTime);
      const t=ctx.currentTime+Math.random()*4+1;
      env.gain.setTargetAtTime(0.08,t,0.02); env.gain.setTargetAtTime(0,t+0.15,0.05);
      osc2.connect(env); env.connect(masterGain); osc2.start(); nodes.push(osc2);
    }
  } else if(type==='cafe'){
    const bufSize = ctx.sampleRate * 2;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = (Math.random()*2-1)*0.4;
    const src = ctx.createBufferSource(); src.buffer=buf; src.loop=true;
    const lo = ctx.createBiquadFilter(); lo.type='lowpass'; lo.frequency.value=800;
    src.connect(lo); lo.connect(masterGain); src.start(); nodes.push(src);
  } else if(type==='bowls'){
    for(let f of [432,528,639,741]){
      const osc = ctx.createOscillator(); osc.type='sine'; osc.frequency.value=f;
      const g = ctx.createGain(); g.gain.setValueAtTime(0, ctx.currentTime);
      g.gain.linearRampToValueAtTime(0.06, ctx.currentTime+2);
      const lfo=ctx.createOscillator(); lfo.frequency.value=0.05; lfo.type='sine';
      const lfoG=ctx.createGain(); lfoG.gain.value=0.02;
      lfo.connect(lfoG); lfoG.connect(g.gain);
      osc.connect(g); g.connect(masterGain); osc.start(); lfo.start(); nodes.push(osc,lfo);
    }
  } else if(type==='lofi'){
    const bufSize = ctx.sampleRate * 2;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = (Math.random()*2-1)*0.15;
    const src = ctx.createBufferSource(); src.buffer=buf; src.loop=true;
    const lo=ctx.createBiquadFilter(); lo.type='lowpass'; lo.frequency.value=3000;
    src.connect(lo); lo.connect(masterGain); src.start(); nodes.push(src);
    // Sub bass
    const bass=ctx.createOscillator(); bass.type='sine'; bass.frequency.value=60;
    const bg=ctx.createGain(); bg.gain.value=0.1;
    bass.connect(bg); bg.connect(masterGain); bass.start(); nodes.push(bass);
  } else if(type==='wind'){
    const bufSize = ctx.sampleRate * 2;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = (Math.random()*2-1)*0.5;
    const src = ctx.createBufferSource(); src.buffer=buf; src.loop=true;
    const filt = ctx.createBiquadFilter(); filt.type='bandpass'; filt.frequency.value=400; filt.Q.value=0.3;
    const lfo = ctx.createOscillator(); lfo.type='sine'; lfo.frequency.value=0.07;
    const lfoG = ctx.createGain(); lfoG.gain.value=200;
    lfo.connect(lfoG); lfoG.connect(filt.frequency);
    src.connect(filt); filt.connect(masterGain); src.start(); lfo.start(); nodes.push(src,lfo);
  } else if(type==='fire'){
    const bufSize = ctx.sampleRate * 2;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = (Math.random()*2-1)*(0.3+0.3*Math.sin(i*0.001));
    const src = ctx.createBufferSource(); src.buffer=buf; src.loop=true;
    const lo = ctx.createBiquadFilter(); lo.type='lowpass'; lo.frequency.value=1200;
    const hi = ctx.createBiquadFilter(); hi.type='highpass'; hi.frequency.value=80;
    src.connect(hi); hi.connect(lo); lo.connect(masterGain); src.start(); nodes.push(src);
  } else if(type==='space'){
    for(let f of [40,80,120,200]){
      const osc = ctx.createOscillator(); osc.type='sine'; osc.frequency.value=f;
      const lfo = ctx.createOscillator(); lfo.type='sine'; lfo.frequency.value=0.02+f*0.0002;
      const lfoG = ctx.createGain(); lfoG.gain.value=0.3;
      const g = ctx.createGain(); g.gain.value=0.04;
      lfo.connect(lfoG); lfoG.connect(g.gain);
      osc.connect(g); g.connect(masterGain); osc.start(); lfo.start(); nodes.push(osc,lfo);
    }
  } else if(type==='heartbeat'){
    const scheduleBeats = ()=>{
      const bpm = 60;
      const interval = 60/bpm;
      for(let i=0;i<8;i++){
        const t = ctx.currentTime + i*interval;
        const osc1 = ctx.createOscillator(); osc1.type='sine'; osc1.frequency.value=60;
        const env1 = ctx.createGain(); env1.gain.setValueAtTime(0,t);
        env1.gain.linearRampToValueAtTime(0.5,t+0.04);
        env1.gain.exponentialRampToValueAtTime(0.001,t+0.2);
        osc1.connect(env1); env1.connect(masterGain); osc1.start(t); osc1.stop(t+0.25);
        const osc2 = ctx.createOscillator(); osc2.type='sine'; osc2.frequency.value=55;
        const env2 = ctx.createGain(); env2.gain.setValueAtTime(0,t+0.18);
        env2.gain.linearRampToValueAtTime(0.35,t+0.22);
        env2.gain.exponentialRampToValueAtTime(0.001,t+0.4);
        osc2.connect(env2); env2.connect(masterGain); osc2.start(t+0.18); osc2.stop(t+0.45);
        nodes.push(osc1,osc2);
      }
    };
    scheduleBeats();
    const beatInterval = setInterval(()=>{ if(!medSources[key]){ clearInterval(beatInterval); return; } scheduleBeats(); }, 7900);
  } else {
    // whitenoise / fallback
    const bufSize = ctx.sampleRate * 2;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = Math.random()*2-1;
    const src = ctx.createBufferSource(); src.buffer=buf; src.loop=true;
    const filt = ctx.createBiquadFilter(); filt.type='lowpass'; filt.frequency.value=2000;
    src.connect(filt); filt.connect(masterGain); src.start(); nodes.push(src);
  }
  return { masterGain, nodes };
}

// External audio (YouTube iframe or <audio> element)
let externalAudioEl = null;
let externalYTPlayer = null;

function stopExternalAudio(){
  if(externalAudioEl){ try{ externalAudioEl.pause(); externalAudioEl.src=''; } catch(e){} externalAudioEl=null; }
  const ytFrame = document.getElementById('yt-player-frame');
  if(ytFrame){ ytFrame.src=''; ytFrame.style.display='none'; }
  externalYTPlayer=null;
}

function toggleSound(key){
  if(activeSound===key){
    stopAmbient(); stopExternalAudio();
    document.querySelectorAll('.sound-card').forEach(c=>c.classList.remove('playing','active'));
    activeSound=null;
    return;
  }
  stopAmbient(); stopExternalAudio();
  if(activeSound) document.getElementById('sc-'+activeSound)?.classList.remove('playing','active');
  activeSound=key;
  document.querySelectorAll('.sound-card').forEach(c=>c.classList.remove('active','playing'));
  const sc=document.getElementById('sc-'+key);
  if(sc) sc.classList.add('playing','active');

  const soundDef = activeMedSounds.find(s=>s.key===key);
  if(soundDef && soundDef.srcType==='youtube'){
    const ytFrame = document.getElementById('yt-player-frame');
    const vol = parseInt(document.getElementById('med-volume').value);
    ytFrame.src = `https://www.youtube.com/embed/${soundDef.ytId}?autoplay=1&loop=1&playlist=${soundDef.ytId}&controls=0&modestbranding=1&rel=0&volume=${vol}`;
    ytFrame.style.display='none';
    return;
  }
  if(soundDef && soundDef.srcType==='iframe'){
    const ytFrame = document.getElementById('yt-player-frame');
    ytFrame.src = soundDef.url;
    ytFrame.style.display='none';
    return;
  }
  if(soundDef && soundDef.srcType==='audio'){
    const vol = parseInt(document.getElementById('med-volume').value)/100;
    const audio = new Audio(soundDef.url);
    audio.loop = true;
    audio.volume = vol;
    audio.play().catch(()=>toast('Lecture impossible (CORS ou URL invalide)','var(--red)'));
    externalAudioEl = audio;
    return;
  }
  if(soundDef && soundDef.srcType==='file'){
    const audio = new Audio(soundDef.fileData);
    audio.loop = true;
    audio.volume = parseInt(document.getElementById('med-volume').value)/100;
    audio.play().catch(()=>toast('Lecture impossible','var(--red)'));
    externalAudioEl = audio;
    return;
  }
  // Generative
  const data = createAmbientSound(key);
  medGainNodes[key]=data.masterGain;
  medSources[key]=data.nodes;
}

function stopAmbient(){
  Object.values(medSources).forEach(nodes=>{
    nodes.forEach(n=>{try{n.stop();}catch(e){}});
  });
  Object.values(medGainNodes).forEach(g=>{try{g.disconnect();}catch(e){}});
  medSources={}; medGainNodes={};
  if(medAudioCtx){try{medAudioCtx.close();}catch(e){} medAudioCtx=null;}
}

function setAmbientVolume(val){
  document.getElementById('vol-val').textContent=val+'%';
  Object.values(medGainNodes).forEach(g=>{if(g)g.gain.setValueAtTime(val/100*0.6,getAudioCtx().currentTime);});
  if(externalAudioEl) externalAudioEl.volume = val/100;
}

function setMedDuration(min, btn){
  medDuration = min*60;
  medRemaining = medDuration;
  document.querySelectorAll('.med-preset').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  updateMedDisplay();
  resetMedRing();
}

function updateMedDisplay(){
  document.getElementById('med-timer-display').textContent = fmtMMSS(medRemaining);
}

function resetMedRing(){
  const circ = 2*Math.PI*68;
  document.getElementById('med-ring-circle').style.strokeDashoffset = circ;
}

function _medTick(){
  // Always compute remaining from real wall-clock time
  const elapsed = Math.floor((Date.now() - medStartTimestamp) / 1000);
  medRemaining = Math.max(0, medRemainingAtStart - elapsed);
  updateMedDisplay();
  const circ = 2*Math.PI*68;
  const progress = (medDuration - medRemaining) / medDuration;
  document.getElementById('med-ring-circle').style.strokeDashoffset = circ - (circ * progress);
  if(medRemaining <= 0){ completeMeditation(); }
}

function startMeditation(){
  if(medRunning) return;
  medRunning = true;
  medStartTimestamp = Date.now();
  medRemainingAtStart = medRemaining;
  document.getElementById('med-btn-start').style.display='none';
  document.getElementById('med-btn-pause').style.display='';
  document.getElementById('med-btn-stop').style.display='';
  document.getElementById('med-phase').textContent='Méditation en cours...';
  medInterval = setInterval(_medTick, 500); // 500ms for snappier catch-up
}

function pauseMeditation(){
  if(!medRunning) return;
  // Snapshot remaining before stopping
  const elapsed = Math.floor((Date.now() - medStartTimestamp) / 1000);
  medRemaining = Math.max(0, medRemainingAtStart - elapsed);
  clearInterval(medInterval);
  medRunning = false;
  document.getElementById('med-btn-pause').style.display='none';
  document.getElementById('med-btn-start').style.display='';
  document.getElementById('med-btn-start').textContent='▶ Reprendre';
  document.getElementById('med-phase').textContent='En pause';
}

function stopMeditation(){
  clearInterval(medInterval);
  medRunning=false;
  medRemaining=medDuration;
  updateMedDisplay();
  resetMedRing();
  document.getElementById('med-btn-start').style.display='';
  document.getElementById('med-btn-start').textContent='▶ Démarrer';
  document.getElementById('med-btn-pause').style.display='none';
  document.getElementById('med-btn-stop').style.display='none';
  document.getElementById('med-phase').textContent='Prêt';
}

// Catch-up when screen wakes up (phone unlock / tab refocus)
document.addEventListener('visibilitychange', ()=>{
  if(!document.hidden && medRunning){
    // Recompute immediately without waiting for next tick
    _medTick();
  }
});

function completeMeditation(){
  clearInterval(medInterval);
  medRunning=false;
  const durationMin = Math.round(medDuration/60);
  // Play end bell
  playEndBell();
  // Save session
  hState.focusSessions.push({
    id:'fs'+Date.now(), date:todayKey(), type:'meditation',
    activity:'Méditation', duration:medDuration*1000, timestamp:Date.now()
  });
  saveH();
  // Award XP
  addXP(durationMin*2);
  toast(`<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="4" r="1.5"/><path d="M7 8h6M10 8v5M7 13l-2 3M13 13l2 3M8 13h4"/></svg> Méditation terminée ! +${durationMin*2} XP`,'var(--g)');
  showBurst('<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="4" r="1.5"/><path d="M7 8h6M10 8v5M7 13l-2 3M13 13l2 3M8 13h4"/></svg>');
  document.getElementById('med-phase').textContent='Terminé ! <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M3 17l4-8 4 4 3-6 3 10"/><path d="M7 9l-4 8M5 13h6"/></svg>';
  setTimeout(stopMeditation, 2000);
  renderMedSessionLog();
}

// ── END BELL SYSTEM ──
// ══════════════════════════════════════════════════════
//  END BELL SYSTEM — persistent list (like custom sounds)
// ══════════════════════════════════════════════════════

// Built-in synthesised bells (kept for playback but not shown in UI)
const END_BELLS_BUILTIN = [];

// Custom end bell entries — stored just like custom ambient sounds
function loadCustomEndBells(){
  try{ return JSON.parse(localStorage.getItem('ascend_custom_end_bells')||'[]'); }catch(e){ return []; }
}
function saveCustomEndBells(list){
  localStorage.setItem('ascend_custom_end_bells', JSON.stringify(list));
}
let customEndBells = loadCustomEndBells();

// Which bell is selected: 'none'|'ding'|'bowl'|'gong'|'chime'|'bell3'|'custom_XXX'
let selectedEndBell = localStorage.getItem('ascend_end_bell') || 'none';

function saveEndBell(id){
  selectedEndBell = id;
  localStorage.setItem('ascend_end_bell', id);
  renderEndBellOptions();
}

// ── Tab switcher for add-bell form ──
let _bellAddTab = 'link';
function switchBellAddTab(tab){
  _bellAddTab = tab;
  ['link','file'].forEach(t=>{
    const btn = document.getElementById('bell-tab-'+t);
    const pan = document.getElementById('bell-panel-'+t);
    if(t===tab){
      btn.style.background='var(--pg)'; btn.style.color='var(--p)'; btn.style.borderColor='var(--p)';
      if(pan) pan.style.display='';
    } else {
      btn.style.background='transparent'; btn.style.color='var(--t1)'; btn.style.borderColor='var(--b1)';
      if(pan) pan.style.display='none';
    }
  });
}

// ── Add a new custom end bell entry ──
function addCustomEndBellEntry(){
  const emoji = (document.getElementById('bell-add-emoji')?.value.trim()) || '🔔';
  const name  = document.getElementById('bell-add-name')?.value.trim();
  if(!name){ toast('Donne un nom au son','var(--red)'); return; }
  const key = 'custom_bell_'+Date.now();

  if(_bellAddTab === 'link'){
    const url = document.getElementById('bell-add-url')?.value.trim();
    if(!url){ toast('Colle une URL','var(--red)'); return; }
    const classified = classifyUrl(url);
    const bellType = classified ? classified.srcType : 'iframe';
    customEndBells.push({ key, emoji, label:name, type:bellType, url, ytId: classified?.ytId });
    saveCustomEndBells(customEndBells);
    document.getElementById('bell-add-url').value='';
    toast('Son de fin "'+name+'" ajouté ✓','var(--g)');
    renderEndBellOptions();

  } else {
    const fileInput = document.getElementById('bell-add-file');
    const file = fileInput?.files[0];
    if(!file){ toast('Sélectionne un fichier','var(--red)'); return; }
    if(file.size > 5*1024*1024){ toast('Fichier trop lourd (max 5 Mo)','var(--red)'); return; }
    const reader = new FileReader();
    reader.onload = function(e){
      const bytes = new Uint8Array(e.target.result);
      let bin=''; bytes.forEach(b=>bin+=String.fromCharCode(b));
      const b64 = btoa(bin);
      customEndBells.push({ key, emoji, label:name, type:'file', b64 });
      saveCustomEndBells(customEndBells);
      fileInput.value='';
      toast('Son de fin "'+name+'" ajouté ✓','var(--g)');
      renderEndBellOptions();
    };
    reader.readAsArrayBuffer(file);
  }
  document.getElementById('bell-add-emoji').value='';
  document.getElementById('bell-add-name').value='';
}

// ── Delete a custom end bell ──
function deleteCustomEndBell(key){
  customEndBells = customEndBells.filter(b=>b.key!==key);
  saveCustomEndBells(customEndBells);
  if(selectedEndBell===key){ selectedEndBell='none'; localStorage.setItem('ascend_end_bell','none'); }
  renderEndBellOptions();
  toast('Son supprimé','var(--t1)');
}

// ── Render all bell options ──
function renderEndBellOptions(){
  // Built-in pills
  const builtinEl = document.getElementById('end-bell-builtin-list');
  if(builtinEl){
    builtinEl.innerHTML = '<div style="display:flex;flex-wrap:wrap;gap:6px">' +
      END_BELLS_BUILTIN.map(b=>`
        <button onclick="saveEndBell('${b.id}')" style="
          display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:999px;
          border:1px solid ${selectedEndBell===b.id?'var(--p)':'var(--b1)'};
          background:${selectedEndBell===b.id?'rgba(124,92,252,.18)':'var(--s2)'};
          color:${selectedEndBell===b.id?'var(--t0)':'var(--t1)'};
          font-size:.73rem;font-weight:700;cursor:pointer;transition:all .18s;white-space:nowrap
        ">${b.emoji} ${b.label}</button>`).join('') +
      '</div>';
  }
  // Custom bells list
  const customEl = document.getElementById('end-bell-custom-list');
  if(customEl){
    if(!customEndBells.length){
      customEl.innerHTML='';
    } else {
      customEl.innerHTML = customEndBells.map(b=>`
        <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;
          background:${selectedEndBell===b.key?'rgba(124,92,252,.1)':'var(--s2)'};
          border:1px solid ${selectedEndBell===b.key?'var(--p)':'var(--b0)'};
          border-radius:var(--rs);margin-bottom:6px;cursor:pointer;transition:all .18s"
          onclick="saveEndBell('${b.key}')">
          <span style="font-size:1.2rem;width:26px;text-align:center">${b.emoji}</span>
          <div style="flex:1">
            <div style="font-size:.82rem;font-weight:600;color:var(--t0)">${b.label}</div>
            <div style="font-size:.66rem;color:var(--t1)">${b.type==='link'?'🔗 Lien':'📁 Fichier'}</div>
          </div>
          ${selectedEndBell===b.key?'<span style="color:var(--g);font-size:.7rem;font-weight:700">✓ Actif</span>':''}
          <button onclick="event.stopPropagation();deleteCustomEndBell('${b.key}')"
            style="background:var(--redo);border:none;color:var(--red);border-radius:7px;padding:4px 8px;cursor:pointer;font-size:.7rem;font-weight:700">✕</button>
        </div>`).join('');
    }
  }
}

// ── Play end bell ──
function playEndBell(){
  const vol = parseInt(document.getElementById('med-volume')?.value||70)/100;

  // Built-in synthesised bells
  if(['none','ding','bowl','gong','chime','bell3'].includes(selectedEndBell)){
    if(selectedEndBell==='none') return;
    try {
      const ctx = getAudioCtx();
      const now = ctx.currentTime;
      const makeOsc = (freq,type,start,dur,gain=vol)=>{
        const osc=ctx.createOscillator(),g=ctx.createGain();
        osc.type=type;osc.frequency.setValueAtTime(freq,now+start);
        g.gain.setValueAtTime(0,now+start);
        g.gain.linearRampToValueAtTime(gain,now+start+0.01);
        g.gain.exponentialRampToValueAtTime(0.001,now+start+dur);
        osc.connect(g);g.connect(ctx.destination);osc.start(now+start);osc.stop(now+start+dur);
      };
      if(selectedEndBell==='ding'){ makeOsc(880,'sine',0,2,vol);makeOsc(1320,'sine',0,1.5,vol*0.4); }
      else if(selectedEndBell==='bowl'){ [432,864,1296].forEach((f,i)=>makeOsc(f,'sine',0,4,vol*(0.6-i*0.15))); }
      else if(selectedEndBell==='gong'){ makeOsc(110,'sine',0,3.5,vol*0.8);makeOsc(220,'triangle',0,2.5,vol*0.5);makeOsc(330,'sine',0,2,vol*0.3); }
      else if(selectedEndBell==='chime'){ [523,659,784,1047].forEach((f,i)=>makeOsc(f,'sine',i*0.18,2.2,vol*0.55)); }
      else if(selectedEndBell==='bell3'){ [0,0.6,1.2].forEach(t=>{makeOsc(880,'sine',t,1.8,vol);makeOsc(1320,'sine',t,1.4,vol*0.35);}); }
    } catch(e){ console.warn('End bell error',e); }
    return;
  }

  // Custom end bell (from persistent list)
  const entry = customEndBells.find(b=>b.key===selectedEndBell);
  if(!entry) return;

  if(entry.type==='audio'){
    try{
      const audio = new Audio(entry.url);
      audio.volume = vol;
      audio.play().catch(()=>{ window.open(entry.url,'_blank'); });
    }catch(e){ window.open(entry.url,'_blank'); }
  } else if(entry.type==='youtube'){
    const bellFrame = document.getElementById('yt-player-frame');
    bellFrame.src = `https://www.youtube.com/embed/${entry.ytId}?autoplay=1&controls=0&modestbranding=1&rel=0`;
    bellFrame.style.display='none';
    setTimeout(()=>{ bellFrame.src=''; },30000);
  } else if(entry.type==='iframe' || entry.type==='link'){
    // For Generative.fm, SoundCloud etc.: open in new tab (can't auto-play iframe on bell end)
    window.open(entry.url,'_blank');
  } else if(entry.type==='file' && entry.b64){
    try{
      const bin=atob(entry.b64);
      const bytes=new Uint8Array(bin.length);
      for(let i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i);
      const ctx=getAudioCtx();
      ctx.decodeAudioData(bytes.buffer.slice(0)).then(buf=>{
        const src=ctx.createBufferSource(),g=ctx.createGain();
        src.buffer=buf;g.gain.value=vol;
        src.connect(g);g.connect(ctx.destination);src.start();
      }).catch(()=>{ toast('Format audio non supporté','var(--red)'); });
    }catch(e){ console.warn('Custom end bell error',e); }
  }
}

// Patch openSoundManager to also render bell options
const _origOpenSoundManager = openSoundManager;
openSoundManager = function(){
  _origOpenSoundManager();
  renderEndBellOptions();
};

function renderMedSessionLog(){
  const today = todayKey();
  const sessions = hState.focusSessions.filter(s=>s.date===today && s.type==='meditation');
  const el = document.getElementById('med-session-log');
  if(!el) return;
  if(!sessions.length){ el.innerHTML='<div class="empty-state">Aucune session aujourd\'hui. Lance ta première méditation !</div>'; return; }
  const total = sessions.reduce((s,x)=>s+x.duration,0);
  el.innerHTML = `<div style="font-size:.72rem;color:var(--t1);margin-bottom:8px">Total aujourd'hui : <strong style="color:var(--g)">${fmtDuration(total)}</strong></div>`+
    sessions.map(s=>`<div class="focus-log-item">
      <div class="focus-log-act"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="4" r="1.5"/><path d="M7 8h6M10 8v5M7 13l-2 3M13 13l2 3M8 13h4"/></svg> ${s.activity}</div>
      <div class="focus-log-dur">${fmtDuration(s.duration)}</div>
    </div>`).join('');
}

// ══════════════════════════════════════════════════════
//  CHRONO
// ══════════════════════════════════════════════════════
let chronoRunning=false, chronoStart=0, chronoElapsed=0, chronoInterval=null;
let chronoActivity='Devoirs';

function getChronoActivities(){
  const custom=JSON.parse(localStorage.getItem('ascend_chrono_activities')||'null');
  return custom||[...DEFAULT_CHRONO_ACTIVITIES];
}

function saveChronoActivities(list){
  localStorage.setItem('ascend_chrono_activities',JSON.stringify(list));
}

function renderChronoActivityChips(){
  const el=document.getElementById('chrono-activity-chips');if(!el)return;
  const acts=getChronoActivities();
  el.innerHTML=acts.map(a=>`<div class="activity-chip ${a===chronoActivity?'sel':''}" onclick="setChronoActivity(this.dataset.act)" data-act="${a}">${a}</div>`).join('');
}

function setChronoActivity(act){
  if(!act||!act.trim())return;
  chronoActivity=act.trim();
  renderChronoActivityChips();
  document.getElementById('chrono-act-label').textContent=chronoActivity;
  document.getElementById('chrono-custom-act').value='';
}

function addAndSetChronoActivity(){
  const inp=document.getElementById('chrono-custom-act');
  const val=(inp.value||'').trim();
  if(!val)return;
  setChronoActivity(val);
}

function openChronoActivitiesModal(){
  renderManageChronoActivities();
  document.getElementById('new-chrono-act-input').value='';
  openModal('modal-chrono-activities');
}

function renderManageChronoActivities(){
  const list=document.getElementById('manage-chrono-activities-list');
  if(!list)return;
  const acts=getChronoActivities();
  const defaults=new Set(DEFAULT_CHRONO_ACTIVITIES);
  if(!acts.length){list.innerHTML='<div class="empty-state">Aucune activite.</div>';return;}
  list.innerHTML=acts.map((a,i)=>`
    <div style="display:flex;align-items:center;justify-content:space-between;padding:9px 12px;background:var(--s1);border:1px solid var(--b1);border-radius:var(--rs);margin-bottom:7px">
      <span style="font-weight:600;font-size:.86rem">${a}</span>
      <div style="display:flex;gap:6px;align-items:center">
        ${defaults.has(a)?'<span style="font-size:.62rem;color:var(--t2);letter-spacing:1px;text-transform:uppercase">defaut</span>':''}
        <button onclick="deleteChronoActivity(${i})" style="background:none;border:none;color:var(--t2);cursor:pointer;font-size:.85rem;padding:2px 6px;border-radius:6px;transition:color .15s" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--t2)'">x</button>
      </div>
    </div>`).join('');
}

function saveNewChronoActivity(){
  const inp=document.getElementById('new-chrono-act-input');
  const val=(inp.value||'').trim();
  if(!val){toast("Entre un nom d'activite",'var(--red)');return;}
  const acts=getChronoActivities();
  if(acts.includes(val)){toast('Activite deja existante','var(--gold)');return;}
  acts.push(val);
  saveChronoActivities(acts);
  inp.value='';
  renderManageChronoActivities();
  renderChronoActivityChips();
  toast('Activite ajoutee !','var(--g)');
}

function deleteChronoActivity(idx){
  const acts=getChronoActivities();
  const name=acts[idx];
  acts.splice(idx,1);
  saveChronoActivities(acts);
  if(chronoActivity===name){chronoActivity=acts[0]||'';}
  renderManageChronoActivities();
  renderChronoActivityChips();
  toast('Activite supprimee','var(--t1)');
}

function startChrono(){
  if(chronoRunning)return;
  if(!chronoActivity){toast('Sélectionne une activité','var(--red)');return;}
  chronoRunning=true;
  chronoStart=Date.now()-chronoElapsed;
  document.getElementById('chrono-btn-start').style.display='none';
  document.getElementById('chrono-btn-pause').style.display='';
  document.getElementById('chrono-btn-save').style.display='';
  document.getElementById('chrono-btn-reset').style.display='';
  document.getElementById('chrono-act-label').textContent=chronoActivity+' ⏱';
  chronoInterval=setInterval(()=>{
    chronoElapsed=Date.now()-chronoStart;
    document.getElementById('chrono-display').textContent=fmtHHMMSS(chronoElapsed);
  },100);
}

function pauseChrono(){
  if(!chronoRunning)return;
  clearInterval(chronoInterval); chronoRunning=false;
  document.getElementById('chrono-btn-pause').style.display='none';
  document.getElementById('chrono-btn-start').style.display='';
  document.getElementById('chrono-btn-start').textContent='▶ Reprendre';
  document.getElementById('chrono-act-label').textContent=chronoActivity+' ⏸';
}

function resetChrono(){
  clearInterval(chronoInterval); chronoRunning=false; chronoElapsed=0;
  document.getElementById('chrono-display').textContent='00:00:00';
  document.getElementById('chrono-btn-start').style.display='';
  document.getElementById('chrono-btn-start').textContent='▶ Démarrer';
  document.getElementById('chrono-btn-pause').style.display='none';
  document.getElementById('chrono-btn-save').style.display='none';
  document.getElementById('chrono-btn-reset').style.display='none';
  document.getElementById('chrono-act-label').textContent=chronoActivity||'Aucune activité';
}

function saveChrono(){
  if(chronoElapsed < 10000){toast('Session trop courte (min 10s)','var(--red)');return;}
  clearInterval(chronoInterval); chronoRunning=false;
  playEndBell();
  hState.focusSessions.push({
    id:'fc'+Date.now(), date:todayKey(), type:'work',
    activity:chronoActivity, duration:chronoElapsed, timestamp:Date.now()
  });
  const xpGained=Math.max(5,Math.floor(chronoElapsed/60000)*3);
  addXP(xpGained);
  saveH();
  toast(`⏱ Session sauvegardée ! ${fmtDuration(chronoElapsed)} · +${xpGained}XP`,'var(--g)');
  resetChrono();
  renderChronoTodayLog();
  renderChronoStats();
}

function renderChronoTodayLog(){
  const el=document.getElementById('chrono-today-log');if(!el)return;
  const today=todayKey();
  const sessions=hState.focusSessions.filter(s=>s.date===today&&s.type==='work');
  if(!sessions.length){el.innerHTML='<div class="empty-state">Aucune session enregistrée.</div>';return;}
  const total=sessions.reduce((s,x)=>s+x.duration,0);
  el.innerHTML=`<div style="font-size:.72rem;color:var(--t1);margin-bottom:8px">Total : <strong style="color:var(--g)">${fmtDuration(total)}</strong></div>`+
    sessions.map(s=>`<div class="focus-log-item">
      <div class="focus-log-act">${s.activity}</div>
      <div class="focus-log-dur">${fmtDuration(s.duration)}</div>
    </div>`).join('');
}

function renderChronoStats(){
  const el=document.getElementById('chrono-stats');if(!el)return;
  const last7=getLast(7);
  const byAct={};
  hState.focusSessions.filter(s=>s.type==='work'&&last7.includes(s.date)).forEach(s=>{
    byAct[s.activity]=(byAct[s.activity]||0)+s.duration;
  });
  if(!Object.keys(byAct).length){el.innerHTML='<div class="empty-state">Aucune donnée sur 7 jours.</div>';return;}
  const sorted=Object.entries(byAct).sort((a,b)=>b[1]-a[1]);
  const max=sorted[0][1];
  el.innerHTML=sorted.map(([act,dur])=>`<div class="mini-bar-row">
    <div class="mini-bar-lbl">${act}</div>
    <div class="mini-bar-bg"><div class="mini-bar-fill" style="width:${Math.round(dur/max*100)}%;background:var(--p)"></div></div>
    <div class="mini-bar-pct">${fmtDuration(dur)}</div>
  </div>`).join('');
}

// ══════════════════════════════════════════════════════
//  GOOGLE CALENDAR
// ══════════════════════════════════════════════════════
let gcalTokenClient=null, gcalAccessToken=null;
const GCAL_SCOPES='https://www.googleapis.com/auth/calendar.readonly';

function saveGCalClientId(){
  const cid=document.getElementById('settings-gcal-clientid').value.trim();
  if(!cid){toast('Saisis le Client ID','var(--red)');return;}
  localStorage.setItem('ascend_gcal_clientid',cid);
  toast('Client ID enregistré ✓','var(--g)');
  document.getElementById('gcal-connect-btn').style.display='';
}

function connectGoogleCalendar(){
  const cid=localStorage.getItem('ascend_gcal_clientid');
  if(!cid){toast('Configure d\'abord le Client ID dans Paramètres','var(--red)');return;}
  if(!window.google){
    // Load GSI script
    const s=document.createElement('script');
    s.src='https://accounts.google.com/gsi/client';
    s.onload=()=>initGcalClient(cid);
    document.head.appendChild(s);
  } else {
    initGcalClient(cid);
  }
}

function initGcalClient(cid){
  gcalTokenClient=google.accounts.oauth2.initTokenClient({
    client_id:cid, scope:GCAL_SCOPES,
    callback:(resp)=>{
      if(resp.error){toast('Erreur OAuth: '+resp.error,'var(--red)');return;}
      gcalAccessToken=resp.access_token;
      localStorage.setItem('ascend_gcal_connected','1');
      document.getElementById('gcal-status').textContent='✓ Connecté';
      document.getElementById('gcal-status').style.color='var(--g)';
      toast('Google Agenda connecté ✓','var(--g)');
      initCalendarPanel();
    }
  });
  gcalTokenClient.requestAccessToken();
}

function disconnectGCal(){
  gcalAccessToken=null;
  localStorage.removeItem('ascend_gcal_connected');
  document.getElementById('gcal-status').textContent='';
  document.getElementById('gcal-connected').style.display='none';
  document.getElementById('gcal-not-connected').style.display='block';
  toast('Google Agenda déconnecté','var(--t1)');
}

function initCalendarPanel(){
  if(gcalAccessToken){
    document.getElementById('gcal-not-connected').style.display='none';
    document.getElementById('gcal-connected').style.display='block';
    fetchGoogleCalendarEvents();
  } else {
    document.getElementById('gcal-not-connected').style.display='block';
    document.getElementById('gcal-connected').style.display='none';
  }
  setTimeout(()=>{
    renderCalendar();
  },50);
}

async function fetchGoogleCalendarEvents(){
  if(!gcalAccessToken){return;}
  const now=new Date(),weekEnd=new Date(now);weekEnd.setDate(now.getDate()+7);
  const params=new URLSearchParams({
    timeMin:now.toISOString(), timeMax:weekEnd.toISOString(),
    singleEvents:'true', orderBy:'startTime', maxResults:'20'
  });
  try{
    const r=await fetch(`https://www.googleapis.com/calendar/v3/calendars/primary/events?${params}`,{headers:{Authorization:'Bearer '+gcalAccessToken}});
    const data=await r.json();
    const events=data.items||[];
    renderCalendarEvents(events);
  }catch(e){toast('Erreur Google Agenda: '+e.message,'var(--red)');}
}

function renderCalendarEvents(events){
  const today=todayKey();
  const todayEvts=events.filter(e=>{const d=(e.start?.dateTime||e.start?.date||'').slice(0,10);return d===today;});
  const weekEvts=events.filter(e=>{const d=(e.start?.dateTime||e.start?.date||'').slice(0,10);return d>today;});
  function renderEvt(e){
    const startRaw=e.start?.dateTime||e.start?.date||'';
    let timeLabel='';
    if(e.start?.dateTime){const d=new Date(startRaw);timeLabel=d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});}
    else timeLabel='Toute la journée';
    return`<div class="gcal-event">
      <div class="gcal-dot" style="background:${e.colorId?'#'+e.colorId:'var(--p)'}"></div>
      <div class="gcal-time">${timeLabel}</div>
      <div><div class="gcal-title">${e.summary||'Sans titre'}</div>${e.location?`<div class="gcal-loc"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2a5 5 0 015 5c0 4-5 10-5 10S5 11 5 7a5 5 0 015-5z"/><circle cx="10" cy="7" r="2"/></svg> ${e.location}</div>`:''}</div>
    </div>`;
  }
  document.getElementById('gcal-today').innerHTML=todayEvts.length?todayEvts.map(renderEvt).join(''):'<div class="empty-state">Aucun événement aujourd\'hui.</div>';
  document.getElementById('gcal-week').innerHTML=weekEvts.length?weekEvts.slice(0,8).map(renderEvt).join(''):'<div class="empty-state">Aucun événement cette semaine.</div>';
}

// ══════════════════════════════════════════════════════
//  STATS (HABITS)
// ══════════════════════════════════════════════════════
let statRange='week',ch1,ch2;
function setStatRange(r,el){statRange=r;document.querySelectorAll('.chart-tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');renderStats();}
function renderStats(){
  const days=getLast(statRange==='week'?7:30),wa=avgPct(days),streak=calcStreak(),lv=levelInfo();
  document.getElementById('stats-kpis').innerHTML=`
    <div class="stat-card"><div class="s-val" id="skpi-wa"  style="color:var(--p)">0%</div><div class="s-lbl">Moy. ${statRange==='week'?'7j':'30j'}</div></div>
    <div class="stat-card"><div class="s-val" id="skpi-str" style="color:var(--gold)">0</div><div class="s-lbl">Streak</div></div>
    <div class="stat-card"><div class="s-val" id="skpi-xp"  style="color:var(--g)">0</div><div class="s-lbl">XP Total</div></div>
    <div class="stat-card"><div class="s-val" id="skpi-prf" style="color:var(--pk)">0</div><div class="s-lbl">Jours parfaits</div></div>`;
  requestAnimationFrame(()=>{
    const el=id=>document.getElementById(id);
    if(el('skpi-wa'))  countUp(el('skpi-wa'),  wa,                   {decimals:0,suffix:'%',duration:700});
    if(el('skpi-str')) countUp(el('skpi-str'), streak,               {decimals:0,duration:650});
    if(el('skpi-xp'))  countUp(el('skpi-xp'),  hState.xp||0,         {decimals:0,duration:900});
    if(el('skpi-prf')) countUp(el('skpi-prf'), hState.perfectDays||0,{decimals:0,duration:600});
  });
  const pcts=days.map(d=>completionPct(d)),labels=days.map(dateShort);
  if(ch1)ch1.destroy();
  ch1=new Chart(document.getElementById('chart-daily'),{type:'bar',data:{labels,datasets:[{data:pcts,backgroundColor:pcts.map(p=>p>=80?'rgba(0,229,160,.7)':p>=50?'rgba(124,92,252,.7)':'rgba(240,71,111,.7)'),borderRadius:5,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{min:0,max:100,grid:{color:'rgba(255,255,255,.05)'},ticks:{color:'#7878a8',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#7878a8',font:{size:10}}}}}});
  const xpHist=days.map((_,i)=>{let x=0;days.slice(0,i+1).forEach(d=>{const h2=hState.history[d]||{};hState.habits.forEach(h=>{if(h2[h.id])x+=h.xp||10;});});return x;});
  if(ch2)ch2.destroy();
  ch2=new Chart(document.getElementById('chart-xp'),{type:'line',data:{labels,datasets:[{data:xpHist,borderColor:'var(--p)',backgroundColor:'rgba(124,92,252,.1)',tension:.4,fill:true,pointBackgroundColor:'var(--p)',pointRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{grid:{color:'rgba(255,255,255,.05)'},ticks:{color:'#7878a8',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#7878a8',font:{size:10}}}}}});
  const week7=getLast(7);
  document.getElementById('mini-bars').innerHTML=hState.habits.map(h=>{const d=week7.filter(day=>hState.history[day]&&hState.history[day][h.id]).length;const pct=Math.round(d/7*100);return`<div class="mini-bar-row"><div class="mini-bar-lbl">${h.emoji||''} ${h.name}</div><div class="mini-bar-bg"><div class="mini-bar-fill" style="width:${pct}%;background:${h.color||'var(--p)'}"></div></div><div class="mini-bar-pct">${pct}%</div></div>`;}).join('');
  const ic=document.getElementById('insight-cards');ic.innerHTML='';
  if(wa>=80)ic.innerHTML+=`<div class="insight-card ok-card"><div class="i-head"><span class="i-icon"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 6 5 12l5 6 5-6c0-6-5-10-5-10z"/><circle cx="10" cy="10" r="2"/><path d="M7 15l-3 3M13 15l3 3"/></svg></span><div><div class="i-title">Excellent momentum !</div></div></div><div class="i-body">Tu complètes ${wa}% de tes habitudes. Continue !</div></div>`;
  else if(wa<50)ic.innerHTML+=`<div class="insight-card warn-card"><div class="i-head"><span class="i-icon"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3L2 17h16L10 3z"/><path d="M10 9v4M10 15h.01"/></svg></span><div><div class="i-title">Régularité à améliorer</div></div></div><div class="i-body">Fixe-toi 3 habitudes piliers non-négociables.</div></div>`;
  const ng=document.getElementById('next-goal-text');
  if(wa>=90)ng.textContent='Maintiens ton score. Essaie de ne pas manquer plus d\'1 habitude/jour.';
  else if(wa>=70)ng.textContent=`Passe de ${wa}% à ${Math.min(wa+10,100)}%.`;
  else ng.textContent='Objectif : 70% minimum. Choisis 3 habitudes piliers.';
}

// ══════════════════════════════════════════════════════
//  OBJECTIVES / REWARDS / RECAP — (same logic as v4)
// ══════════════════════════════════════════════════════
function renderObjectives(){
  const streak=calcStreak(),lv=levelInfo(),wa7=avgPct(getLast(7)),wa30=avgPct(getLast(30));
  const days7=getLast(7);
  const habitStats=hState.habits.map(h=>{const done=days7.filter(d=>hState.history[d]&&hState.history[d][h.id]).length;return{h,done,pct:Math.round((done/7)*100)};});
  const sorted=[...habitStats].sort((a,b)=>b.pct-a.pct);
  const best=sorted[0],worst=sorted[sorted.length-1];
  let nextGoalTarget,nextGoalText;
  if(wa7>=90){nextGoalTarget=95;nextGoalText='Tu es au sommet ! Vise les 95%.';}
  else if(wa7>=75){nextGoalTarget=Math.min(wa7+10,100);nextGoalText=`Passe de ${wa7}% à ${nextGoalTarget}%.`;}
  else if(wa7>=50){nextGoalTarget=70;nextGoalText='Atteins les 70% cette semaine.';}
  else{nextGoalTarget=50;nextGoalText='Objectif minimal : 50%. Concentre-toi sur 2-3 habitudes piliers.';}
  document.getElementById('objectives-content').innerHTML=`
  <div class="grid-2">
    <div class="card"><div class="card-title">Performance</div>
      <div class="grid-2" style="margin-bottom:0">
        <div style="text-align:center;padding:16px 0"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.9rem;color:var(--p)">${wa7}%</div><div style="font-size:.7rem;color:var(--t1);margin-top:4px">Moy. 7 jours</div></div>
        <div style="text-align:center;padding:16px 0"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.9rem;color:var(--g)">${wa30}%</div><div style="font-size:.7rem;color:var(--t1);margin-top:4px">Moy. 30 jours</div></div>
      </div>
    </div>
    <div class="card"><div class="card-title">Niveau & XP</div>
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:10px">
        <div style="font-size:2.5rem">${lv.emoji}</div>
        <div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem">${lv.name}</div><div style="font-size:.78rem;color:var(--t1)">Niveau ${lv.num} · ${hState.xp||0} XP</div></div>
      </div>
      <div class="xp-bar-bg"><div class="xp-bar-fill" style="width:${lv.progress}%"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:.7rem;color:var(--t1);margin-top:5px"><span>${lv.xpIn} XP</span><span>${lv.xpNeed} XP → niv. ${lv.num+1}</span></div>
    </div>
  </div>
  <div class="card" style="margin-bottom:14px;border-color:rgba(124,92,252,.2)">
    <div class="card-title">Objectif semaine prochaine</div>
    <div style="display:flex;align-items:center;gap:14px">
      <div style="font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;color:var(--p)">${nextGoalTarget}%</div>
      <div style="font-size:.86rem;color:var(--t1);line-height:1.6">${nextGoalText}</div>
    </div>
    <div class="prog-bg" style="margin-top:10px"><div class="prog-fill" style="width:${wa7}%"></div></div>
  </div>
  <div class="card" style="border-color:rgba(0,229,160,.15)">
    <div class="card-title">Streak actuel</div>
    <div style="display:flex;align-items:center;gap:18px">
      <div style="font-family:'Syne',sans-serif;font-size:3rem;font-weight:800;color:var(--gold)">${streak}</div>
      <div><div style="font-family:'Syne',sans-serif;font-size:1rem;font-weight:700">jours consécutifs</div><div style="font-size:.8rem;color:var(--t1);margin-top:3px">${streak>=30?'Incroyable':streak>=14?'Excellent':streak>=7?'Très bien':streak>0?'Lance-toi':'Commence aujourd\'hui'}</div></div>
    </div>
  </div>`;
}

function renderRewards(){
  const streak=calcStreak(),lv=levelInfo();
  document.getElementById('rewards-stats').innerHTML=`<div class="stat-card"><div class="s-val" id="rkpi-xp"  style="color:var(--p)">0</div><div class="s-lbl">XP Total</div></div><div class="stat-card"><div class="s-val" id="rkpi-lv"  style="color:var(--gold)">0</div><div class="s-lbl">Niveau</div></div><div class="stat-card"><div class="s-val" id="rkpi-bdg" style="color:var(--g)">0/${BADGES.length}</div><div class="s-lbl">Badges</div></div><div class="stat-card"><div class="s-val" id="rkpi-prf" style="color:var(--pk)">0</div><div class="s-lbl">Jours parfaits</div></div>`;
  requestAnimationFrame(()=>{
    const el=id=>document.getElementById(id);
    if(el('rkpi-xp'))  countUp(el('rkpi-xp'),  hState.xp||0,                         {decimals:0,duration:900});
    if(el('rkpi-lv'))  countUp(el('rkpi-lv'),  lv.num,                               {decimals:0,duration:600});
    if(el('rkpi-bdg')) countUp(el('rkpi-bdg'), (hState.unlockedBadges||[]).length,   {decimals:0,suffix:'/'+BADGES.length,duration:700});
    if(el('rkpi-prf')) countUp(el('rkpi-prf'), hState.perfectDays||0,               {decimals:0,duration:650});
  });
  document.getElementById('rewards-grid').innerHTML=BADGES.map(b=>{const unlocked=(hState.unlockedBadges||[]).includes(b.id);return`<div class="reward-card ${unlocked?'unlocked':'locked'}"><div class="reward-icon">${b.icon}</div><div class="reward-name">${b.name}</div><div class="reward-cond">${b.cond}</div>${unlocked?`<div class="reward-unlocked-tag">DÉBLOQUÉ ✓</div>`:''}</div>`;}).join('');
}

// ══════════════════════════════════════════════════════
//  RECAP / BILAN — (kept from v4, condensed)
// ══════════════════════════════════════════════════════
function getWeekNumber(d){const date=new Date(Date.UTC(d.getFullYear(),d.getMonth(),d.getDate()));const dayNum=date.getUTCDay()||7;date.setUTCDate(date.getUTCDate()+4-dayNum);const yearStart=new Date(Date.UTC(date.getUTCFullYear(),0,1));return Math.ceil((((date-yearStart)/86400000)+1)/7);}
function getMondayOfWeek(date){const d=new Date(date);const day=d.getDay(),diff=d.getDate()-day+(day===0?-6:1);return new Date(d.setDate(diff));}
function formatDateShort(d){return d.toLocaleDateString('fr-FR',{day:'numeric',month:'short'});}
function getLastWeekDays(){const today=new Date();const thisMonday=getMondayOfWeek(today);const lastMonday=new Date(thisMonday);lastMonday.setDate(thisMonday.getDate()-7);const days=[];for(let i=0;i<7;i++){const d=new Date(lastMonday);d.setDate(lastMonday.getDate()+i);days.push({key:d.toISOString().split('T')[0],date:d,label:['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'][i]});}return days;}
function getWeekDaysForOffset(offset){const today=new Date();const thisMonday=getMondayOfWeek(today);const monday=new Date(thisMonday);monday.setDate(thisMonday.getDate()-7*(offset+1));const days=[];for(let i=0;i<7;i++){const d=new Date(monday);d.setDate(monday.getDate()+i);days.push({key:d.toISOString().split('T')[0],date:d,label:['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'][i]});}return days;}
function calcWeekStats(days){const wa=avgPct(days.map(d=>d.key));const perfectDays=days.filter(({key})=>completionPct(key)===100).length;const grade=wa>=90?'S':wa>=75?'A':wa>=60?'B':wa>=40?'C':'D';const gradeColor=wa>=90?'var(--gold)':wa>=75?'var(--p)':wa>=60?'var(--blue)':wa>=40?'var(--gold)':'var(--red)';let xpWeek=0;days.forEach(({key})=>{const h2=hState.history[key]||{};hState.habits.forEach(h=>{if(h2[h.id])xpWeek+=h.xp||10;});});const dayPcts=days.map(({key})=>completionPct(key));return{wa,perfectDays,grade,gradeColor,xpWeek,dayPcts};}
function showRecap(){showRecapForDays(getLastWeekDays());}
function showRecapForOffset(offset){showRecapForDays(getWeekDaysForOffset(offset));}
function showRecapForDays(weekDays){
  const lastMonday=weekDays[0].date,lastSunday=weekDays[6].date;
  const weekNum=getWeekNumber(lastMonday);
  const wa=avgPct(weekDays.map(d=>d.key)),streak=calcStreak();
  document.getElementById('recap-title').textContent=`Bilan semaine #${weekNum}`;
  document.getElementById('recap-date-range').textContent=`${formatDateShort(lastMonday)} — ${formatDateShort(lastSunday)} ${lastMonday.getFullYear()}`;
  document.getElementById('recap-streak-badge').innerHTML=`<svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 8 5 12.5a5 5 0 0010 0C15 8 10 2 10 2z"/><path d="M10 15.5a2 2 0 010-4"/></svg> ${streak} jour${streak>1?'s':''}`;
  const grade=wa>=90?'S':wa>=75?'A':wa>=60?'B':wa>=40?'C':'D';
  const grEmoji='';
  document.getElementById('recap-badge').textContent=`Grade ${grade} ${grEmoji}`;
  document.getElementById('recap-kpi-pct').textContent=`${wa}%`;
  let xpWeek=0;weekDays.forEach(({key})=>{const h2=hState.history[key]||{};hState.habits.forEach(h=>{if(h2[h.id])xpWeek+=h.xp||10;});});
  document.getElementById('recap-kpi-xp').textContent=`${xpWeek} XP`;
  document.getElementById('recap-kpi-perfect').textContent=weekDays.filter(({key})=>completionPct(key)===100).length;
  document.getElementById('recap-day-dots').innerHTML=weekDays.map(({key,label})=>{const pct=completionPct(key);const cls=pct===100?'rdd-done':pct>0?'rdd-partial':'rdd-miss';return`<div class="recap-day-dot ${cls}"><span>${label}</span><span style="font-size:.55rem;opacity:.7">${pct>0?pct+'%':''}</span></div>`;}).join('');
  const habitBars=hState.habits.map(h=>{const d=weekDays.filter(({key})=>hState.history[key]&&hState.history[key][h.id]).length;const pct=Math.round(d/7*100);return{h,pct};});
  document.getElementById('recap-habit-bars').innerHTML=habitBars.map(({h,pct})=>`<div class="recap-bar-row"><div class="recap-bar-label">${h.emoji} ${h.name}</div><div class="recap-bar-track"><div class="recap-bar-fill" style="width:${pct}%;background:${h.color}"></div></div><div class="recap-bar-pct">${pct}%</div></div>`).join('');
  const sorted=[...habitBars].sort((a,b)=>b.pct-a.pct);const best=sorted[0],worst=sorted[sorted.length-1];
  let phrase;
  if(wa>=90)phrase=`Semaine exceptionnelle ! ${wa}% de complétion, tu es dans la zone d'excellence.`;
  else if(wa>=70)phrase=`Bonne semaine ! ${wa}% de complétion. Quelques ajustements et tu atteindrais les 90%.`;
  else if(wa>=40)phrase=`Semaine correcte. ${wa}% — identifie ce qui a bloqué et agis dessus.`;
  else phrase=`Semaine difficile. Pas de jugement — recommence aujourd'hui, 1 jour à la fois.`;
  document.getElementById('recap-phrase').innerHTML=phrase;
  const nextTarget=wa>=90?95:wa>=70?Math.min(wa+10,100):70;
  document.getElementById('recap-next').innerHTML=`Objectif semaine prochaine : <strong>${nextTarget}%</strong>${worst&&worst.pct<50?` · Focus sur <strong>${worst.h.name}</strong>`:''}.`;
  let insights=[];
  if(streak>=7)insights.push({icon:'<svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 8 5 12.5a5 5 0 0010 0C15 8 10 2 10 2z"/><path d="M10 15.5a2 2 0 010-4"/></svg>',text:`<strong>${streak} jours de streak</strong> — ne brise pas la chaîne.`});
  if(best&&best.pct===100)insights.push({icon:'',text:`<strong>${best.h.emoji} ${best.h.name}</strong> est ton point fort.`});
  if(worst&&worst.pct<40)insights.push({icon:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3L2 17h16L10 3z"/><path d="M10 9v4M10 14.5v.5"/></svg>',text:`<strong>${worst.h.emoji} ${worst.h.name}</strong> à ${worst.pct}% — à travailler.`});
  document.getElementById('recap-insights').innerHTML=insights.map(ins=>`<div class="recap-insight"><span style="font-size:1rem;flex-shrink:0">${ins.icon}</span><div style="font-size:.8rem;color:var(--t1);line-height:1.55">${ins.text}</div></div>`).join('');
  document.getElementById('recapModal').classList.add('open');
}
function closeRecap(){document.getElementById('recapModal').classList.remove('open');}
let bilanSelectedWeeks=[];
function showBilanHistory(){bilanSelectedWeeks=[];renderBilanHistoryList();document.getElementById('bilanHistoryModal').classList.add('open');}
function closeBilanHistory(){document.getElementById('bilanHistoryModal').classList.remove('open');}
function renderBilanHistoryList(){
  const list=document.getElementById('bilan-history-list');let cards='';let weeksWithData=0;
  for(let offset=0;offset<52;offset++){
    const days=getWeekDaysForOffset(offset);const hasData=days.some(({key})=>{const h=hState.history[key]||{};return hState.habits.some(hb=>h[hb.id]);});
    if(!hasData&&weeksWithData>0)break;if(!hasData&&offset>3)break;weeksWithData++;
    const monday=days[0].date,sunday=days[6].date,weekNum=getWeekNumber(monday);
    const{wa,perfectDays,grade,gradeColor,xpWeek,dayPcts}=calcWeekStats(days);
    const isSelected1=bilanSelectedWeeks[0]===offset,isSelected2=bilanSelectedWeeks[1]===offset;
    const selClass=isSelected1?'selected':isSelected2?'selected-2':'';
    const selIcon=isSelected1?' <svg width="8" height="8" viewBox="0 0 8 8" fill="var(--blue)" style="display:inline-block;vertical-align:middle;border-radius:50%"><circle cx="4" cy="4" r="4"/></svg>':isSelected2?' <svg width="8" height="8" viewBox="0 0 8 8" fill="var(--g)" style="display:inline-block;vertical-align:middle;border-radius:50%"><circle cx="4" cy="4" r="4"/></svg>':'';
    const ageLabel=offset===0?'Semaine dernière':offset===1?'Il y a 2 semaines':offset===2?'Il y a 3 semaines':`Il y a ${offset+1} semaines`;
    const barHtml=dayPcts.map((p,i)=>{const h=Math.max(4,Math.round((p/100)*22));const col=p===100?'var(--g)':p>=50?'var(--p)':'var(--s3)';const labels=['L','M','M','J','V','S','D'];return`<div style="display:flex;flex-direction:column;align-items:center;gap:2px"><div class="bhc-bar" style="height:${h}px;background:${col}"></div><div style="font-size:.5rem;color:var(--t2)">${labels[i]}</div></div>`;}).join('');
    cards+=`<div class="bilan-history-card grade-${grade.toLowerCase()} ${selClass}" onclick="selectBilanWeek(${offset},this)">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:7px">
        <div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.86rem">Semaine #${weekNum}${selIcon}</div><div style="font-size:.66rem;color:var(--t1)">${formatDateShort(monday)} — ${formatDateShort(sunday)} · ${ageLabel}</div></div>
        <div style="display:flex;align-items:center;gap:8px"><div class="bhc-bars">${barHtml}</div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.72rem;padding:2px 9px;border-radius:999px;background:${gradeColor}18;color:${gradeColor};border:1px solid ${gradeColor}30">Grade ${grade}</div></div>
      </div>
      <div class="bhc-stats"><div class="bhc-stat"><strong>${wa}%</strong> complétion</div><div class="bhc-stat"><strong>${perfectDays}</strong> parfait${perfectDays>1?'s':''}</div><div class="bhc-stat"><strong>${xpWeek} XP</strong></div></div>
    </div>`;
  }
  if(!cards)cards='<div class="empty-state" style="padding:32px;text-align:center">Aucune donnée pour l\'instant.</div>';
  list.innerHTML=cards;updateBilanCompare();
}
function selectBilanWeek(offset,el){
  if(bilanSelectedWeeks.includes(offset)){bilanSelectedWeeks=bilanSelectedWeeks.filter(w=>w!==offset);}
  else if(bilanSelectedWeeks.length===0){bilanSelectedWeeks=[offset];closeBilanHistory();showRecapForOffset(offset);return;}
  else if(bilanSelectedWeeks.length===1){bilanSelectedWeeks.push(offset);}
  else{bilanSelectedWeeks=[offset];}
  renderBilanHistoryList();
}
function updateBilanCompare(){
  const bar=document.getElementById('bilan-compare-bar'),content=document.getElementById('bilan-compare-content');
  if(bilanSelectedWeeks.length===2){
    bar.style.display='block';const[o1,o2]=bilanSelectedWeeks;const days1=getWeekDaysForOffset(o1),days2=getWeekDaysForOffset(o2);
    const s1=calcWeekStats(days1),s2=calcWeekStats(days2);const weekNum1=getWeekNumber(days1[0].date),weekNum2=getWeekNumber(days2[0].date);
    const diff=s1.wa-s2.wa;const diffText=diff>0?`<span style="color:var(--g)">+${diff}%</span>`:diff<0?`<span style="color:var(--red)">${diff}%</span>`:`<span style="color:var(--t1)">=</span>`;
    content.innerHTML=`<div style="text-align:center"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;color:var(--p)">${s1.wa}%</div><div style="font-size:.66rem;color:var(--t1)">Sem. #${weekNum1} <svg width="8" height="8" viewBox="0 0 8 8" fill="var(--blue)" style="display:inline-block;vertical-align:middle;border-radius:50%"><circle cx="4" cy="4" r="4"/></svg></div><button class="btn btn-ghost btn-sm" style="margin-top:7px;font-size:.68rem" onclick="closeBilanHistory();showRecapForOffset(${o1})">Voir →</button></div>
    <div style="text-align:center"><div style="font-size:.72rem;color:var(--t1)">vs</div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;margin-top:3px">${diffText}</div><div style="font-size:.62rem;color:var(--t2);margin-top:2px">${diff>0?'en progrès':diff<0?'en recul':'stable'}</div></div>
    <div style="text-align:center"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;color:var(--g)">${s2.wa}%</div><div style="font-size:.66rem;color:var(--t1)">Sem. #${weekNum2} <svg width="8" height="8" viewBox="0 0 8 8" fill="var(--g)" style="display:inline-block;vertical-align:middle;border-radius:50%"><circle cx="4" cy="4" r="4"/></svg></div><button class="btn btn-ghost btn-sm" style="margin-top:7px;font-size:.68rem" onclick="closeBilanHistory();showRecapForOffset(${o2})">Voir →</button></div>`;
  } else {bar.style.display='none';}
}
function checkMondayBilan(){const today=new Date(),isMonday=today.getDay()===1;const banner=document.getElementById('weekly-notif-banner');if(!banner)return;if(isMonday&&hState.notifs?.weekly){banner.style.display='';if(hState.lastRecapKey!==todayKey())banner.style.display='';}else banner.style.display='none';}
function updateBilanBtn(){const btn=document.getElementById('bilan-btn');if(!btn)return;const hasHistory=Object.keys(hState.history||{}).length>0;btn.style.display=hasHistory?'':'none';}

// Plan d'action
function showPlanAction(){
  const weekDays=getWeekDaysForOffset(0);const today=new Date();const thisMonday=getMondayOfWeek(today);const thisSunday=new Date(thisMonday);thisSunday.setDate(thisMonday.getDate()+6);
  document.getElementById('plan-action-week-label').textContent=`Semaine en cours : ${formatDateShort(thisMonday)} — ${formatDateShort(thisSunday)}`;
  const habitStats=hState.habits.map(h=>{const done=weekDays.filter(({key})=>hState.history[key]&&hState.history[key][h.id]).length;return{h,done,pct:Math.round((done/7)*100)};});
  const sorted=[...habitStats].sort((a,b)=>b.pct-a.pct);const worst=sorted[sorted.length-1],best=sorted[0];const wa=avgPct(weekDays.map(d=>d.key));const streak=calcStreak();
  const habItems=[];
  if(worst&&worst.pct<70)habItems.push(`<strong>${worst.h.emoji} ${worst.h.name}</strong> : bloque un créneau fixe chaque jour. Cible : ${Math.min(worst.pct+30,100)}%`);
  if(best&&best.pct>=80)habItems.push(`<strong>${best.h.emoji} ${best.h.name}</strong> est ton ancre — enchaîne une habitude difficile juste après.`);
  if(streak<7)habItems.push(`Atteins <strong>7 jours de streak</strong>. Fais au moins 1 habitude chaque jour.`);
  habItems.push(`Chaque soir, planifie mentalement tes habitudes du lendemain (30 secondes).`);
  const bizItems=[];
  const tasks=bState.tasks.filter(t=>!t.done&&t.priority==='high').slice(0,3);
  tasks.forEach(t=>bizItems.push(`<strong>${t.title}</strong> — priorité haute`));
  if(!tasks.length)bizItems.push(`Définis 3 tâches haute priorité pour cette semaine.`);
  const totalRev=bState.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  if(totalRev<100)bizItems.push(`Lance ton premier test produit cette semaine.`);
  document.getElementById('plan-hab-count').textContent=habItems.length+' actions';
  document.getElementById('plan-biz-count').textContent=bizItems.length+' actions';
  const mkItem=(txt,col)=>`<div class="plan-item"><div class="plan-item-num" style="background:${col}"></div><div class="plan-item-body">${txt}</div></div>`;
  document.getElementById('plan-hab-list').innerHTML=habItems.slice(0,4).map(t=>mkItem(t,'var(--g)')).join('');
  document.getElementById('plan-biz-list').innerHTML=bizItems.slice(0,4).map(t=>mkItem(t,'var(--p)')).join('');
  document.getElementById('planActionModal').classList.add('open');
}
function closePlanAction(){document.getElementById('planActionModal').classList.remove('open');}

// ══════════════════════════════════════════════════════
//  HUB — CATÉGORIES DYNAMIQUES
// ══════════════════════════════════════════════════════
function renderHub(){
  const cats={};
  // Sort by category order
  bState.linkCategories.forEach(cat=>{cats[cat]=[];});
  bState.links.forEach(l=>{
    if(!cats[l.cat])cats[l.cat]=[];
    cats[l.cat].push(l);
  });
  const el=document.getElementById('hub-categories');
  const entries=Object.entries(cats).filter(([,links])=>links.length>0);
  if(!entries.length){el.innerHTML='<div class="empty"><div class="ei"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M8 11a4 4 0 006 0l2-2a4 4 0 00-6-6l-1 1"/><path d="M12 9a4 4 0 00-6 0L4 11a4 4 0 006 6l1-1"/></svg></div><p>Ajoute des liens pour les voir ici</p></div>';return;}
  el.innerHTML=entries.map(([cat,links])=>`
    <div style="margin-bottom:24px">
      <div class="hub-cat-header">
        <div class="section-title" style="margin-bottom:0">${cat}</div>
        <span style="font-size:.68rem;color:var(--t2)">${links.length} lien${links.length>1?'s':''}</span>
      </div>
      <div class="grid-auto">
        ${links.map(l=>`<div class="link-card" onclick="window.open('${l.url}','_blank')">
          <button class="link-card-del" onclick="event.stopPropagation();delLink('${l.id}')">✕</button>
          <div class="link-card-icon">${l.icon||'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M8 11a4 4 0 006 0l2-2a4 4 0 00-6-6l-1 1"/><path d="M12 9a4 4 0 00-6 0L4 11a4 4 0 006 6l1-1"/></svg>'}</div>
          <div class="link-card-name">${l.name}</div>
          <div class="link-card-url">${l.url.replace(/^https?:\/\//,'').split('/')[0]}</div>
        </div>`).join('')}
      </div>
    </div>`).join('');
}

function populateLinkCatSelect(){
  const sel=document.getElementById('l-cat');if(!sel)return;
  sel.innerHTML=bState.linkCategories.map(c=>`<option value="${c}">${c}</option>`).join('');
}

function addLinkCategory(){
  const val=document.getElementById('l-new-cat').value.trim();
  if(!val)return;
  if(!bState.linkCategories.includes(val)){bState.linkCategories.push(val);saveB();}
  document.getElementById('l-new-cat').value='';
  populateLinkCatSelect();
  toast('Catégorie ajoutée ✓','var(--g)');
}

function openManageCategories(){
  renderCatsList();
  openModal('modal-manage-cats');
}

function renderCatsList(){
  const el=document.getElementById('cats-list');if(!el)return;
  el.innerHTML=bState.linkCategories.map((cat,i)=>`<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--b0)">
    <div style="flex:1;font-size:.88rem;font-weight:600">${cat}</div>
    <button class="btn-icon" onclick="deleteCat(${i})" title="Supprimer" style="color:var(--red)">
      <svg viewBox="0 0 16 16"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg>
    </button>
  </div>`).join('');
}

function deleteCat(i){
  const cat=bState.linkCategories[i];
  if(bState.links.some(l=>l.cat===cat)){toast('Supprime d\'abord les liens de cette catégorie','var(--red)');return;}
  bState.linkCategories.splice(i,1);
  saveB();renderCatsList();populateLinkCatSelect();toast('Catégorie supprimée');
}

function addCatFromModal(){
  const val=document.getElementById('new-cat-input').value.trim();
  if(!val)return;
  if(!bState.linkCategories.includes(val)){bState.linkCategories.push(val);saveB();}
  document.getElementById('new-cat-input').value='';
  renderCatsList();populateLinkCatSelect();
}

function addLink(){
  const name=document.getElementById('l-name').value.trim();
  let url=document.getElementById('l-url').value.trim();
  if(!name||!url){toast('Remplis le nom et l\'URL','var(--red)');return;}
  if(!url.startsWith('http'))url='https://'+url;
  bState.links.push({id:'l'+Date.now(),name,url,icon:document.getElementById('l-icon').value.trim()||'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M8 11a4 4 0 006 0l2-2a4 4 0 00-6-6l-1 1"/><path d="M12 9a4 4 0 00-6 0L4 11a4 4 0 006 6l1-1"/></svg>',cat:document.getElementById('l-cat').value});
  saveB();closeModal('modal-add-link');
  document.getElementById('l-name').value='';document.getElementById('l-url').value='';document.getElementById('l-icon').value='';
  renderHub();toast('Lien ajouté ✓','var(--g)');
}
function delLink(id){bState.links=bState.links.filter(l=>l.id!==id);saveB();renderHub();}

// ══════════════════════════════════════════════════════
//  BUSINESS VIEWS (kept from v4, adapted)
// ══════════════════════════════════════════════════════
let chF=null,chP=null,chA=null;

function renderCommand(){
  const now=new Date(),hour=now.getHours();
  const greeting=hour<12?'Bonjour':'Bonsoir';
  document.getElementById('cmd-greeting').textContent=`${greeting}, ${getUserName()}`;
  document.getElementById('cmd-date').textContent=now.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'});
  const gl=getGoalAmount(),gp=getGoalPeriod();
  document.getElementById('cmd-goal-label').textContent=`${gl.toLocaleString('fr-FR')}${getCurrency()}/${gp==='day'?'jour':'mois'} en Décembre 2026`;
  document.getElementById('goal-days-left').textContent=daysLeft()+' jours restants';
  document.getElementById('sidebar-goal-val').textContent=`${gl.toLocaleString('fr-FR')}${getCurrency()}/${gp==='day'?'jour':'mois'}`;
  const totalRev=bState.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=bState.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=totalRev-totalExp;
  const wa7=avgPct(getLast(7)),streak=calcStreak(),lv=levelInfo();
  const C=getCurrency();
  document.getElementById('cmd-kpis').innerHTML=`
    <div class="kpi-card" style="--kpi-c:var(--g)"><div class="kpi-lbl">CA Total</div><div class="kpi-val" id="kpi-ca" style="color:var(--g)">0${C}</div><div class="kpi-sub">Depuis le début</div></div>
    <div class="kpi-card" style="--kpi-c:${profit>=0?'var(--g)':'var(--red)'}"><div class="kpi-lbl">Profit</div><div class="kpi-val" id="kpi-profit" style="color:${profit>=0?'var(--g)':'var(--red)'}">0${C}</div></div>
    <div class="kpi-card" style="--kpi-c:var(--p)"><div class="kpi-lbl">Habitudes</div><div class="kpi-val" id="kpi-hab" style="color:var(--p)">0%</div><div class="kpi-sub">Moy. 7j</div></div>
    <div class="kpi-card" style="--kpi-c:var(--gold)"><div class="kpi-lbl">Streak</div><div class="kpi-val" id="kpi-streak" style="color:var(--gold)">0j</div><div class="kpi-sub">Niveau ${lv.num}</div></div>`;
  // Animate counters after DOM paint
  requestAnimationFrame(() => {
    const el = (id) => document.getElementById(id);
    if(el('kpi-ca'))     countUp(el('kpi-ca'),     totalRev, {decimals:0, suffix:C});
    if(el('kpi-profit')) countUp(el('kpi-profit'), profit,   {decimals:0, suffix:C});
    if(el('kpi-hab'))    countUp(el('kpi-hab'),    wa7,      {decimals:0, suffix:'%'});
    if(el('kpi-streak')) countUp(el('kpi-streak'), streak,   {decimals:0, suffix:'j', duration:700});
  });
  const tasks=bState.tasks.filter(t=>!t.done&&t.priority==='high').slice(0,4);
  document.getElementById('cmd-tasks').innerHTML=tasks.length?tasks.map(t=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--b0)"><div style="width:7px;height:7px;border-radius:50%;background:var(--red);flex-shrink:0"></div><div style="font-size:.84rem;flex:1">${t.title}</div><span class="tag tag-r" style="font-size:.58rem">Haute</span></div>`).join(''):'<div style="padding:16px 0;text-align:center;color:var(--t1);font-size:.82rem">Aucune tâche haute priorité</div>';
  const products=bState.products.filter(p=>p.status!=='dead').slice(0,4);
  document.getElementById('cmd-products').innerHTML=products.length?products.map(p=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--b0)"><div style="font-size:.82rem;flex:1">${p.name}</div><span class="tag ${p.status==='scaling'?'tag-g':p.status==='testing'?'tag-gold':'tag-p'}" style="font-size:.58rem">${p.status==='scaling'?'Scaling':p.status==='testing'?'Test':'Pausé'}</span></div>`).join(''):'<div style="padding:16px 0;text-align:center;color:var(--t1);font-size:.82rem">Aucun produit actif</div>';
  // alert zone
  const az=document.getElementById('cmd-alert-zone');az.innerHTML='';
  if(totalRev===0)az.innerHTML='<div class="alert alert-warn" style="margin-bottom:12px"> Aucune vente enregistrée — commence ton premier test produit dès aujourd\'hui.</div>';
}

function addTransaction(){const desc=document.getElementById('t-desc').value.trim(),amount=parseFloat(document.getElementById('t-amount').value);if(!desc||!amount){toast('Remplis tous les champs','var(--red)');return;}bState.transactions.push({id:'t'+Date.now(),type:document.getElementById('t-type').value,desc,amount,cat:document.getElementById('t-cat').value,date:document.getElementById('t-date').value||todayKey()});saveB();closeModal('modal-add-transaction');document.getElementById('t-desc').value='';document.getElementById('t-amount').value='';renderFinance('month');toast('Transaction ajoutée ✓','var(--g)');}
function delTransaction(id){bState.transactions=bState.transactions.filter(t=>t.id!==id);saveB();renderFinance('month');}

function renderFinance(range){
  const C=getCurrency();const all=range==='all';const cutoff=all?'2000-01-01':new Date(Date.now()-30*86400000).toISOString().slice(0,10);
  const trans=bState.transactions.filter(t=>t.date>=cutoff).sort((a,b)=>b.date>a.date?1:-1);
  const rev=trans.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const exp=trans.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=rev-exp;const margin=rev>0?((profit/rev)*100).toFixed(1):0;
  document.getElementById('finance-kpis').innerHTML=`
    <div class="kpi-card" style="--kpi-c:var(--g)"><div class="kpi-lbl">CA</div><div class="kpi-val" id="fkpi-ca" style="color:var(--g)">0${C}</div><div class="kpi-sub">${all?'Total':'30 jours'}</div></div>
    <div class="kpi-card" style="--kpi-c:var(--red)"><div class="kpi-lbl">Dépenses</div><div class="kpi-val" id="fkpi-exp" style="color:var(--red)">0${C}</div></div>
    <div class="kpi-card" style="--kpi-c:${profit>=0?'var(--g)':'var(--red)'}"><div class="kpi-lbl">Profit</div><div class="kpi-val" id="fkpi-profit" style="color:${profit>=0?'var(--g)':'var(--red)'}">0${C}</div></div>
    <div class="kpi-card" style="--kpi-c:var(--gold)"><div class="kpi-lbl">Marge</div><div class="kpi-val" id="fkpi-margin" style="color:var(--gold)">0%</div></div>`;
  requestAnimationFrame(() => {
    const el = (id) => document.getElementById(id);
    if(el('fkpi-ca'))     countUp(el('fkpi-ca'),     rev,            {decimals:0, suffix:C});
    if(el('fkpi-exp'))    countUp(el('fkpi-exp'),    exp,            {decimals:0, suffix:C});
    if(el('fkpi-profit')) countUp(el('fkpi-profit'), profit,         {decimals:0, suffix:C});
    if(el('fkpi-margin')) countUp(el('fkpi-margin'), parseFloat(margin), {decimals:1, suffix:'%'});
  });
  const last7=getLast(7);const chartLabels=last7.map(dateShort);
  const chartRev=last7.map(d=>bState.transactions.filter(t=>t.type==='revenue'&&t.date===d).reduce((s,t)=>s+t.amount,0));
  const chartExp=last7.map(d=>bState.transactions.filter(t=>t.type==='expense'&&t.date===d).reduce((s,t)=>s+t.amount,0));
  if(chF)chF.destroy();
  chF=new Chart(document.getElementById('chart-finance'),{type:'bar',data:{labels:chartLabels,datasets:[{label:'Revenus',data:chartRev,backgroundColor:'rgba(0,229,160,.6)',borderRadius:4},{label:'Dépenses',data:chartExp,backgroundColor:'rgba(240,71,111,.6)',borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7878a8',font:{size:10}}}},scales:{y:{grid:{color:'rgba(255,255,255,.05)'},ticks:{color:'#7878a8',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#7878a8',font:{size:10}}}}}});
  const catExp={};trans.filter(t=>t.type==='expense').forEach(t=>{catExp[t.cat]=(catExp[t.cat]||0)+t.amount;});
  if(chP)chP.destroy();
  if(Object.keys(catExp).length){chP=new Chart(document.getElementById('chart-pie'),{type:'doughnut',data:{labels:Object.keys(catExp),datasets:[{data:Object.values(catExp),backgroundColor:['rgba(124,92,252,.7)','rgba(224,64,168,.7)','rgba(0,229,160,.7)','rgba(245,200,66,.7)','rgba(56,189,248,.7)']}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7878a8',font:{size:9}}}}}});}
  document.getElementById('transactions-table').innerHTML=trans.length?`<table class="data-table"><thead><tr><th>Date</th><th>Description</th><th>Catégorie</th><th>Montant</th></tr></thead><tbody>${trans.slice(0,30).map(t=>`<tr><td class="mono" style="font-size:.72rem">${fmtDate(t.date)}</td><td style="font-size:.82rem">${t.desc}</td><td><span class="tag ${t.type==='revenue'?'tag-g':'tag-r'}">${t.cat}</span></td><td style="font-family:'DM Mono',monospace;font-weight:700;color:${t.type==='revenue'?'var(--g)':'var(--red)'};">${t.type==='revenue'?'+':'−'}${t.amount}${C}<button onclick="delTransaction('${t.id}')" style="background:none;border:none;color:var(--t2);cursor:pointer;margin-left:8px;font-size:.75rem">✕</button></td></tr>`).join('')}</tbody></table>`:'<div class="empty"><div class="ei"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="10" r="7"/><path d="M10 6v1m0 6v1M8 9.5h3a1 1 0 010 2H9a1 1 0 000 2h3"/></svg></div><p>Ajoute tes transactions</p></div>';
}

// Products
function calcProductMetrics(){const price=parseFloat(document.getElementById('p-price').value)||0,cost=parseFloat(document.getElementById('p-cost').value)||0;const prev=document.getElementById('p-metrics-preview');if(!price&&!cost){prev.style.display='none';return;}prev.style.display='block';const pp=price-cost,margin=price>0?((pp/price)*100).toFixed(1):'—',roi=cost>0?((pp/cost)*100).toFixed(0):'—';document.getElementById('p-calc-margin').textContent=margin!=='—'?margin+'%':'—';document.getElementById('p-calc-profit').textContent=price>0?pp.toFixed(2)+(getCurrency()):'—';document.getElementById('p-calc-roi').textContent=roi!=='—'?roi+'%':'—';document.getElementById('p-calc-margin').style.color=parseFloat(margin)>=50?'var(--g)':parseFloat(margin)>=30?'var(--gold)':'var(--red)';document.getElementById('p-calc-roi').style.color=parseFloat(roi)>=200?'var(--g)':parseFloat(roi)>=100?'var(--gold)':'var(--red)';}
function scoreProduct(p){let score=0;const details=[];if(p.price&&p.cost){const margin=((p.price-p.cost)/p.price)*100;if(margin>=65){score+=3.0;}else if(margin>=50){score+=2.2;}else if(margin>=35){score+=1.4;}else if(margin>=20){score+=0.7;}const roi=((p.price-p.cost)/p.cost)*100;if(roi>=400)score+=2.0;else if(roi>=250)score+=1.5;else if(roi>=150)score+=1.0;else if(roi>=80)score+=0.5;}const rev=p.revenue||0;if(rev>=5000)score+=2.0;else if(rev>=1000)score+=1.5;else if(rev>=200)score+=1.0;else if(rev>=1)score+=0.5;if(p.status==='scaling')score+=1.0;else if(p.status==='testing')score+=0.5;else if(p.status==='paused')score+=0.2;return Math.min(10,Math.round(score*10)/10);}
function scoreLabel(s){if(s>=8.5)return{emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M5 3h10v6a5 5 0 01-10 0V3z"/><path d="M5 6H3a2 2 0 000 4h2M15 6h2a2 2 0 010 4h-2M10 14v3M7 17h6"/></svg>',label:'Pépite',color:'var(--g)'};if(s>=7)return{emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 6 5 12l5 6 5-6c0-6-5-10-5-10z"/><circle cx="10" cy="10" r="2"/><path d="M7 15l-3 3M13 15l3 3"/></svg>',label:'Prometteur',color:'var(--g)'};if(s>=5.5)return{emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="10" r="7"/><path d="M7 10l2 2 4-4"/></svg>',label:'Correct',color:'var(--gold)'};if(s>=4)return{emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3L2 17h16L10 3z"/><path d="M10 9v4M10 14.5v.5"/></svg>',label:'À optimiser',color:'#f97316'};if(s>=2)return{emoji:'<svg width="11" height="11" viewBox="0 0 20 20" fill="currentColor" style="display:inline-block;vertical-align:middle"><path d="M10 15L3 6h14L10 15z"/></svg>',label:'Faible',color:'var(--red)'};return{emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3a6 6 0 016 6c0 2-1 4-3 5v2H7v-2c-2-1-3-3-3-5a6 6 0 016-6z"/><path d="M7 16h6M8 12v2M12 12v2"/></svg>',label:'À écarter',color:'var(--t2)'};}
function saveProduct(){const name=document.getElementById('p-name').value.trim();if(!name){toast('Donne un nom','var(--red)');return;}const p={name,status:document.getElementById('p-status').value,price:parseFloat(document.getElementById('p-price').value)||0,cost:parseFloat(document.getElementById('p-cost').value)||0,revenue:parseFloat(document.getElementById('p-revenue').value)||0,adbudget:parseFloat(document.getElementById('p-adbudget').value)||0,url:document.getElementById('p-url').value.trim(),notes:document.getElementById('p-notes').value.trim()};if(bState.editingProductId){const idx=bState.products.findIndex(x=>x.id===bState.editingProductId);if(idx>=0)bState.products[idx]={...bState.products[idx],...p};}else bState.products.push({id:'p'+Date.now(),...p});saveB();closeModal('modal-add-product');document.getElementById('p-name').value='';bState.editingProductId=null;renderProducts();toast('Produit enregistré ✓','var(--g)');}
function renderProducts(){
  const C=getCurrency();
  document.getElementById('products-list').innerHTML=bState.products.length?bState.products.map(p=>{const sc=scoreProduct(p),sl=scoreLabel(sc),margin=p.price&&p.cost?((p.price-p.cost)/p.price*100).toFixed(0):null;return`<div class="card" style="margin-bottom:10px">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
      <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:200px">
        <div style="font-size:1.6rem;font-weight:800;font-family:'Syne',sans-serif;color:${sl.color}"></div>
        <div><div style="font-weight:700;font-size:.95rem">${p.name}</div><div style="font-size:.72rem;color:var(--t1);margin-top:2px">${p.url?`<a href="${p.url}" target="_blank" style="color:var(--p)">Voir →</a>`:''}</div></div>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <span class="tag ${p.status==='scaling'?'tag-g':p.status==='testing'?'tag-gold':'tag-p'}">${p.status==='scaling'?'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 6 5 12l5 6 5-6c0-6-5-10-5-10z"/><circle cx="10" cy="10" r="2"/><path d="M7 15l-3 3M13 15l3 3"/></svg> Scaling':p.status==='testing'?'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M7 2v8l-4 7h14l-4-7V2"/><path d="M7 2h6M7 12h6"/></svg> Test':p.status==='paused'?'⏸ Pausé':'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3a6 6 0 016 6c0 2-1 4-3 5v2H7v-2c-2-1-3-3-3-5a6 6 0 016-6z"/><path d="M7 16h6M8 12v2M12 12v2"/></svg> Mort'}</span>
        ${margin?`<span class="tag tag-p">Marge ${margin}%</span>`:''}
        <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:.9rem;color:${sl.color}">${sc}/10</span>
        <button class="btn-icon" onclick="editProduct('${p.id}')"><svg viewBox="0 0 20 20"><path d="M13 3l4 4-10 10H3v-4L13 3z"/></svg></button>
        <button class="btn-icon" style="color:var(--red)" onclick="delProduct('${p.id}')"><svg viewBox="0 0 16 16"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg></button>
      </div>
    </div>
    <div class="product-metrics-grid" style="margin-top:12px">
      <div style="text-align:center;background:var(--s1);border-radius:8px;padding:8px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:var(--g)">${p.revenue||0}${C}</div><div style="font-size:.58rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Revenus</div></div>
      <div style="text-align:center;background:var(--s1);border-radius:8px;padding:8px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:var(--gold)">${p.price||'—'}${p.price?C:''}</div><div style="font-size:.58rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Prix</div></div>
      <div style="text-align:center;background:var(--s1);border-radius:8px;padding:8px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:var(--red)">${p.cost||'—'}${p.cost?C:''}</div><div style="font-size:.58rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Coût</div></div>
      <div style="text-align:center;background:var(--s1);border-radius:8px;padding:8px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:var(--p)">${p.adbudget||0}${C}</div><div style="font-size:.58rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Budget/j</div></div>
      <div style="text-align:center;background:var(--s1);border-radius:8px;padding:8px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:${sl.color}">${sc}/10</div><div style="font-size:.58rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Score</div></div>
      <div style="text-align:center;background:var(--s1);border-radius:8px;padding:8px"><div style="font-size:.82rem;color:var(--t0);font-weight:700">${sl.label}</div><div style="font-size:.58rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Statut</div></div>
    </div>
    ${p.notes?`<div style="font-size:.78rem;color:var(--t1);margin-top:10px;line-height:1.6;background:var(--s1);padding:9px 12px;border-radius:8px">${p.notes}</div>`:''}
  </div>`;}).join(''):'<div class="empty"><div class="ei"><svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M7 2h6M9 2v5L5 15a2 2 0 001.8 3h6.4A2 2 0 0015 15L11 7V2"/></svg></div><p>Ajoute ton premier produit</p></div>';
}
function editProduct(id){const p=bState.products.find(x=>x.id===id);if(!p)return;bState.editingProductId=id;document.getElementById('p-name').value=p.name;document.getElementById('p-status').value=p.status;document.getElementById('p-price').value=p.price||'';document.getElementById('p-cost').value=p.cost||'';document.getElementById('p-revenue').value=p.revenue||'';document.getElementById('p-adbudget').value=p.adbudget||'';document.getElementById('p-url').value=p.url||'';document.getElementById('p-notes').value=p.notes||'';document.getElementById('modal-product-title').textContent='Modifier produit';calcProductMetrics();openModal('modal-add-product');}
function delProduct(id){if(!confirm('Supprimer ce produit ?'))return;bState.products=bState.products.filter(p=>p.id!==id);saveB();renderProducts();}

// Ads
function addCampaign(){const name=document.getElementById('c-name').value.trim();if(!name){toast('Nom requis','var(--red)');return;}bState.campaigns.push({id:'ca'+Date.now(),name,platform:document.getElementById('c-platform').value,budget:parseFloat(document.getElementById('c-budget').value)||0,revenue:parseFloat(document.getElementById('c-revenue').value)||0,ctr:parseFloat(document.getElementById('c-ctr').value)||0,status:document.getElementById('c-status').value});saveB();closeModal('modal-add-campaign');renderAds();toast('Campagne ajoutée ✓','var(--g)');}
function renderAds(){
  const C=getCurrency();const active=bState.campaigns.filter(c=>c.status==='active');const totalBudget=active.reduce((s,c)=>s+c.budget,0),totalRev=active.reduce((s,c)=>s+c.revenue,0),roas=totalBudget>0?(totalRev/totalBudget).toFixed(2):0;
  document.getElementById('ads-kpis').innerHTML=`<div class="kpi-card" style="--kpi-c:var(--p)"><div class="kpi-lbl">Campagnes actives</div><div class="kpi-val" id="akpi-camps" style="color:var(--p)">0</div></div><div class="kpi-card" style="--kpi-c:var(--red)"><div class="kpi-lbl">Budget/jour</div><div class="kpi-val" id="akpi-budget" style="color:var(--red)">0${C}</div></div><div class="kpi-card" style="--kpi-c:var(--g)"><div class="kpi-lbl">Revenus</div><div class="kpi-val" id="akpi-rev" style="color:var(--g)">0${C}</div></div><div class="kpi-card" style="--kpi-c:var(--gold)"><div class="kpi-lbl">ROAS</div><div class="kpi-val" id="akpi-roas" style="color:var(--gold)">0x</div></div>`;
  requestAnimationFrame(()=>{
    const el=id=>document.getElementById(id);
    if(el('akpi-camps'))  countUp(el('akpi-camps'),  active.length,          {decimals:0, duration:600});
    if(el('akpi-budget')) countUp(el('akpi-budget'), totalBudget,            {decimals:0, suffix:C});
    if(el('akpi-rev'))    countUp(el('akpi-rev'),    totalRev,               {decimals:0, suffix:C});
    if(el('akpi-roas'))   countUp(el('akpi-roas'),   parseFloat(roas)||0,    {decimals:1, suffix:'x', duration:700});
  });
  document.getElementById('campaigns-list').innerHTML=bState.campaigns.length?bState.campaigns.map(c=>{const roas=c.budget>0?(c.revenue/c.budget).toFixed(1):0;return`<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--b0);flex-wrap:wrap;gap:8px"><div style="flex:1;min-width:150px"><div style="font-weight:600;font-size:.88rem">${c.name}</div><div style="font-size:.72rem;color:var(--t1);margin-top:2px">${c.platform}</div></div><div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap"><span class="tag ${c.status==='active'?'tag-g':c.status==='paused'?'tag-gold':'tag-r'}">${c.status}</span><span style="font-size:.78rem;font-family:'DM Mono',monospace">${roas}x ROAS</span><span style="font-size:.78rem;color:var(--red);font-family:'DM Mono',monospace">${c.budget}${C}/j</span><button class="btn-icon" style="color:var(--red)" onclick="delCampaign('${c.id}')"><svg viewBox="0 0 16 16"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg></button></div></div>`;}).join(''):'';
  document.getElementById('campaigns-empty').style.display=bState.campaigns.length?'none':'';
}
function delCampaign(id){bState.campaigns=bState.campaigns.filter(c=>c.id!==id);saveB();renderAds();}

// Analytics
function saveMetric(){const date=document.getElementById('m-date').value||todayKey();const existing=bState.metrics.findIndex(m=>m.date===date);const metric={date,visitors:parseInt(document.getElementById('m-visitors').value)||0,orders:parseInt(document.getElementById('m-orders').value)||0,revenue:parseFloat(document.getElementById('m-revenue').value)||0,adspend:parseFloat(document.getElementById('m-adspend').value)||0};if(existing>=0)bState.metrics[existing]={...bState.metrics[existing],...metric};else bState.metrics.push({id:'m'+Date.now(),...metric});saveB();closeModal('modal-add-metric');renderAnalytics();toast('Métriques enregistrées ✓','var(--g)');}
function renderAnalytics(){
  const C=getCurrency();const last7=getLast(7);const recent=bState.metrics.filter(m=>last7.includes(m.date));const totalRev=recent.reduce((s,m)=>s+m.revenue,0),totalOrders=recent.reduce((s,m)=>s+m.orders,0),totalVisitors=recent.reduce((s,m)=>s+m.visitors,0),totalAds=recent.reduce((s,m)=>s+m.adspend,0);const cvr=totalVisitors>0?((totalOrders/totalVisitors)*100).toFixed(2):0;
  document.getElementById('analytics-kpis').innerHTML=`<div class="kpi-card" style="--kpi-c:var(--g)"><div class="kpi-lbl">CA 7j</div><div class="kpi-val" id="ankpi-ca" style="color:var(--g)">0${C}</div></div><div class="kpi-card" style="--kpi-c:var(--p)"><div class="kpi-lbl">Commandes</div><div class="kpi-val" id="ankpi-orders" style="color:var(--p)">0</div></div><div class="kpi-card" style="--kpi-c:var(--blue)"><div class="kpi-lbl">Visiteurs</div><div class="kpi-val" id="ankpi-vis" style="color:var(--blue);font-size:1.4rem">0</div></div><div class="kpi-card" style="--kpi-c:var(--gold)"><div class="kpi-lbl">CVR</div><div class="kpi-val" id="ankpi-cvr" style="color:var(--gold)">0%</div></div>`;
  requestAnimationFrame(()=>{
    const el=id=>document.getElementById(id);
    if(el('ankpi-ca'))     countUp(el('ankpi-ca'),     totalRev,             {decimals:0, suffix:C});
    if(el('ankpi-orders')) countUp(el('ankpi-orders'), totalOrders,          {decimals:0, duration:650});
    if(el('ankpi-vis'))    countUp(el('ankpi-vis'),    totalVisitors,        {decimals:0, duration:800});
    if(el('ankpi-cvr'))    countUp(el('ankpi-cvr'),    parseFloat(cvr)||0,   {decimals:1, suffix:'%'});
  });
  document.getElementById('funnel').innerHTML=totalVisitors?`<div style="padding:8px 0"><div style="background:rgba(56,189,248,.2);border-radius:6px;padding:8px 12px;margin-bottom:6px;font-size:.82rem"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="7" cy="7" r="3"/><circle cx="13" cy="7" r="3"/><path d="M1 17c0-3 2.7-5 6-5M13 12c3.3 0 6 2 6 5"/><path d="M7 12c3.3 0 6 2 6 5H1c0-3 2.7-5 6-5z"/></svg> ${totalVisitors} visiteurs</div><div style="background:rgba(124,92,252,.2);border-radius:6px;padding:8px 12px;margin-bottom:6px;font-size:.82rem"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M2 3h2l2.5 9h9L18 6H6"/><circle cx="8" cy="17" r="1.5"/><circle cx="15" cy="17" r="1.5"/></svg> ${totalOrders} commandes (${cvr}%)</div><div style="background:rgba(0,229,160,.2);border-radius:6px;padding:8px 12px;font-size:.82rem"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="10" r="7"/><path d="M10 6v1m0 6v1M8 9.5h3a1 1 0 010 2H9a1 1 0 000 2h3"/></svg> ${totalRev.toFixed(0)}${C} revenus</div></div>`:'<div class="empty-state">Ajoute des métriques</div>';
  document.getElementById('metrics-history').innerHTML=bState.metrics.slice(-7).reverse().map(m=>`<div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--b0);font-size:.8rem"><span style="color:var(--t1)">${fmtDate(m.date)}</span><span style="color:var(--g)">${m.revenue.toFixed(0)}${C}</span><span class="tag tag-g">${m.orders} cmd</span></div>`).join('')||'<div class="empty-state">Aucune métrique</div>';
}

// Tasks
function addTask(){const title=document.getElementById('task-title').value.trim();if(!title){toast('Titre requis','var(--red)');return;}bState.tasks.push({id:'tk'+Date.now(),title,priority:document.getElementById('task-priority').value,cat:document.getElementById('task-cat').value,deadline:document.getElementById('task-deadline').value||null,done:false});saveB();closeModal('modal-add-task');document.getElementById('task-title').value='';renderTasks();toast('Tâche ajoutée ✓','var(--g)');}
function toggleTask(id){const t=bState.tasks.find(x=>x.id===id);if(t){t.done=!t.done;saveB();renderTasks();if(t.done)toast('Tâche complétée ✓','var(--g)');}}
function delTask(id){bState.tasks=bState.tasks.filter(t=>t.id!==id);saveB();renderTasks();}
function renderTasks(){
  const mkTask=t=>`<div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--b0)">
    <div onclick="toggleTask('${t.id}')" style="width:18px;height:18px;border-radius:5px;border:2px solid ${t.done?'var(--g)':'var(--b2)'};background:${t.done?'var(--g)':'transparent'};cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center">${t.done?'<svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="black" stroke-width="2" stroke-linecap="round"><polyline points="1,5 4,8 9,2"/></svg>':''}</div>
    <div style="flex:1;font-size:.83rem;${t.done?'text-decoration:line-through;color:var(--t1)':''}">${t.title}</div>
    ${t.deadline?`<span style="font-size:.65rem;color:var(--t2);font-family:'DM Mono',monospace">${t.deadline}</span>`:''}
    <button class="btn-icon" style="color:var(--red)" onclick="delTask('${t.id}')"><svg viewBox="0 0 16 16"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg></button>
  </div>`;
  const high=bState.tasks.filter(t=>t.priority==='high'),med=bState.tasks.filter(t=>t.priority==='med'),low=bState.tasks.filter(t=>t.priority==='low'||t.done);
  document.getElementById('count-high').textContent=high.filter(t=>!t.done).length;
  document.getElementById('count-med').textContent=med.filter(t=>!t.done).length;
  document.getElementById('count-low').textContent=low.length;
  document.getElementById('tasks-high').innerHTML=high.length?high.map(mkTask).join(''):'<div class="empty-state">Aucune tâche haute</div>';
  document.getElementById('tasks-med').innerHTML=med.length?med.map(mkTask).join(''):'<div class="empty-state">Aucune tâche</div>';
  document.getElementById('tasks-low').innerHTML=low.length?low.map(mkTask).join(''):'<div class="empty-state">Aucune tâche</div>';
}

// Strategy
function addGoal(){const title=document.getElementById('goal-title').value.trim();if(!title){toast('Écris un objectif','var(--red)');return;}bState.goals.push({id:'g'+Date.now(),title,deadline:document.getElementById('goal-deadline').value||null,horizon:document.getElementById('goal-horizon').value});saveB();closeModal('modal-add-goal');renderStrategy();toast('Objectif ajouté ✓','var(--g)');}
function delGoal(id){bState.goals=bState.goals.filter(g=>g.id!==id);saveB();renderStrategy();}
function saveStrategyNotes(){bState.strategyNotes=document.getElementById('strategy-notes').value;saveB();}
function renderStrategy(){
  document.getElementById('goals-list').innerHTML=bState.goals.length?bState.goals.map(g=>`<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--b0)"><div style="width:7px;height:7px;border-radius:50%;background:var(--p);flex-shrink:0;margin-top:6px"></div><div style="flex:1"><div style="font-weight:600;font-size:.88rem">${g.title}</div>${g.deadline?`<div style="font-size:.7rem;color:var(--t1);margin-top:2px">${g.horizon} · ${fmtDate(g.deadline)}</div>`:''}</div><button class="btn-icon" style="color:var(--red)" onclick="delGoal('${g.id}')"><svg viewBox="0 0 16 16"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg></button></div>`).join(''):'<div class="empty-state">Aucun objectif</div>';
  const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'],now=new Date();
  document.getElementById('roadmap').innerHTML=`<div style="font-size:.75rem;color:var(--t1);margin-bottom:10px">Mars 2026 → Déc. 2026 · Objectif : 4 000€/jour</div><div style="display:flex;gap:3px;flex-wrap:wrap">${Array.from({length:10},(_,i)=>{const m=(now.getMonth()+i)%12,isCur=i===0;return`<div style="flex:1;min-width:44px;background:${isCur?'rgba(124,92,252,.12)':'var(--s1)'};border:1px solid ${isCur?'rgba(124,92,252,.25)':'var(--b0)'};border-radius:7px;padding:7px 4px;text-align:center"><div style="font-size:.7rem;font-weight:700;color:${isCur?'var(--p)':'var(--t1)'}">${months[m]}</div></div>`;}).join('')}</div>`;
  const sn=document.getElementById('strategy-notes');if(sn)sn.value=bState.strategyNotes||'';
}

// Knowledge
function getResourceTypes(){return bState.resourceTypes&&bState.resourceTypes.length?bState.resourceTypes:[{id:'t_video',name:'Vidéo',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><rect x="2" y="4" width="16" height="12" rx="1"/><path d="M2 8h16M8 4l2 4M14 4l2 4M2 12h16M8 12v4M14 12v4"/></svg>'},{id:'t_article',name:'Article',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M5 3h7l4 4v11a1 1 0 01-1 1H5a1 1 0 01-1-1V4a1 1 0 011-1z"/><path d="M12 3v4h4M7 9h6M7 12h6M7 15h4"/></svg>'},{id:'t_formation',name:'Formation',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3L2 7l8 4 8-4-8-4z"/><path d="M4 9v5c0 1.66 2.69 3 6 3s6-1.34 6-3V9"/><path d="M18 7v6"/></svg>'},{id:'t_livre',name:'Livre',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 4C8 2 4 2 2 4v12c2-2 6-2 8 0M10 4c2-2 6-2 8 0v12c-2-2-6-2-8 0"/></svg>'},{id:'t_podcast',name:'Podcast',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><rect x="7" y="2" width="6" height="9" rx="3"/><path d="M4 11a6 6 0 0012 0M10 17v2M7 19h6"/></svg>'},{id:'t_outil',name:'Outil',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M14 3a4 4 0 010 8l-8 8a1 1 0 01-1-1l-1-1a1 1 0 010-1l8-8a4 4 0 01-4-4l2 2a2 2 0 002-2L14 3z"/></svg>'},{id:'t_autre',name:'Autre',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M3 7l7-4 7 4v9l-7 4-7-4V7z"/><path d="M3 7l7 4 7-4M10 11v9"/></svg>'}];}
function getTypeInfo(typeName){const t=getResourceTypes().find(x=>x.name===typeName);return t||{name:typeName||'Autre',emoji:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M3 7l7-4 7 4v9l-7 4-7-4V7z"/><path d="M3 7l7 4 7-4M10 11v9"/></svg>'};}
function populateTypeSelect(){const sel=document.getElementById('r-type');if(!sel)return;const types=getResourceTypes();sel.innerHTML=types.map(t=>`<option value="${t.name}">${t.emoji} ${t.name}</option>`).join('');}
function openAddResource(){document.getElementById('r-edit-id').value='';document.getElementById('modal-resource-title').textContent='+ Nouvelle source';document.getElementById('r-title').value='';document.getElementById('r-url').value='';document.getElementById('r-desc').value='';document.getElementById('r-notes').value='';document.getElementById('r-duration').value='';document.getElementById('r-duration-unit').value='h';populateTypeSelect();openModal('modal-add-resource');}
function openEditResource(id){const r=bState.resources.find(x=>x.id===id);if(!r)return;document.getElementById('r-edit-id').value=id;document.getElementById('modal-resource-title').textContent='Modifier la source';document.getElementById('r-title').value=r.title||'';document.getElementById('r-url').value=r.url||'';document.getElementById('r-desc').value=r.desc||'';document.getElementById('r-notes').value=r.notes||'';document.getElementById('r-duration').value=r.duration||'';document.getElementById('r-duration-unit').value=r.durationUnit||'h';populateTypeSelect();setTimeout(()=>{const sel=document.getElementById('r-type');if(sel&&r.type)sel.value=r.type;},50);openModal('modal-add-resource');}
function saveResource(){const title=document.getElementById('r-title').value.trim();if(!title){toast('Donne un titre','var(--red)');return;}const editId=document.getElementById('r-edit-id').value;const type=document.getElementById('r-type').value;const ti=getTypeInfo(type);const obj={title,type,emoji:ti.emoji,url:document.getElementById('r-url').value.trim(),desc:document.getElementById('r-desc').value.trim(),duration:parseFloat(document.getElementById('r-duration').value)||0,durationUnit:document.getElementById('r-duration-unit').value,notes:document.getElementById('r-notes').value.trim()};if(editId){const idx=bState.resources.findIndex(x=>x.id===editId);if(idx>-1){bState.resources[idx]={...bState.resources[idx],...obj};}}else{bState.resources.push({id:'res'+Date.now(),progress:0,...obj});}saveB();closeModal('modal-add-resource');renderKnowledge();toast(editId?'Source mise à jour ✓':'Source ajoutée ✓','var(--g)');}
function updateResourceProgress(id,val){const r=bState.resources.find(x=>x.id===id);if(!r)return;r.progress=parseFloat(val)||0;saveB();renderKnowledge();}
function updateResourceNotes(id,val){const r=bState.resources.find(x=>x.id===id);if(!r)return;r.notes=val;saveB();}
function delResource(id){if(!confirm('Supprimer cette source ?'))return;bState.resources=bState.resources.filter(r=>r.id!==id);saveB();renderKnowledge();}
function addCustomType(){const name=document.getElementById('new-type-name').value.trim();const emoji=document.getElementById('new-type-emoji').value.trim()||'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M3 7l7-4 7 4v9l-7 4-7-4V7z"/><path d="M3 7l7 4 7-4M10 11v9"/></svg>';if(!name){toast('Donne un nom','var(--red)');return;}if(getResourceTypes().find(t=>t.name.toLowerCase()===name.toLowerCase())){toast('Ce type existe déjà','var(--red)');return;}if(!bState.resourceTypes)bState.resourceTypes=[...getResourceTypes()];bState.resourceTypes.push({id:'t_'+Date.now(),name,emoji});saveB();document.getElementById('new-type-name').value='';document.getElementById('new-type-emoji').value='';renderManageTypes();toast('Type ajouté ✓','var(--g)');}
function delCustomType(id){const defaults=['t_video','t_article','t_formation','t_livre','t_podcast','t_outil','t_autre'];if(defaults.includes(id)){toast('Type par défaut non supprimable','var(--red)');return;}if(!bState.resourceTypes)bState.resourceTypes=[...getResourceTypes()];bState.resourceTypes=bState.resourceTypes.filter(t=>t.id!==id);saveB();renderManageTypes();}
function renderManageTypes(){const el=document.getElementById('types-list');if(!el)return;el.innerHTML=getResourceTypes().map(t=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--b0)"><span style="font-size:1.1rem">${t.emoji}</span><span style="flex:1;font-size:.85rem;font-weight:500">${t.name}</span><button onclick="delCustomType('${t.id}')" style="background:none;border:none;color:var(--t2);cursor:pointer;font-size:.8rem" title="Supprimer">✕</button></div>`).join('');}
function addFormationAction(){const text=document.getElementById('new-formation-action').value.trim();if(!text)return;if(!bState.formationActions)bState.formationActions=[];bState.formationActions.push({id:'fa'+Date.now(),text,done:false});document.getElementById('new-formation-action').value='';saveB();renderKnowledge();}
function toggleFA(id){const a=bState.formationActions&&bState.formationActions.find(x=>x.id===id);if(a)a.done=!a.done;saveB();renderKnowledge();}
function delFA(id){bState.formationActions=bState.formationActions.filter(a=>a.id!==id);saveB();renderKnowledge();}
function updateFormationProgress(){const h=parseInt(document.getElementById('formation-hours')?.value)||0;bState.formationHours=h;saveB();}
function saveFormationNotes(){bState.formationNotes=document.getElementById('formation-notes')?.value||'';saveB();}
function renderKnowledge(){
  const grid=document.getElementById('knowledge-grid');
  const empty=document.getElementById('knowledge-empty');
  const statsBar=document.getElementById('knowledge-stats-bar');
  if(!bState.resources||!bState.resources.length){if(grid)grid.innerHTML='';if(empty)empty.style.display='';if(statsBar)statsBar.innerHTML='';renderKnowledgeActions();return;}
  if(empty)empty.style.display='none';
  const total=bState.resources.length;
  const done=bState.resources.filter(r=>r.duration>0&&r.progress>=r.duration).length;
  const inprog=bState.resources.filter(r=>r.duration>0&&r.progress>0&&r.progress<r.duration).length;
  if(statsBar)statsBar.innerHTML=`<div style="background:var(--s1);border:1px solid var(--b0);border-radius:999px;padding:5px 14px;font-size:.75rem;font-weight:600;color:var(--t1)">${total} source${total>1?'s':''}</div>${done?`<div style="background:var(--go);border:1px solid rgba(0,229,160,.2);border-radius:999px;padding:5px 14px;font-size:.75rem;font-weight:600;color:var(--g)">✓ ${done} terminée${done>1?'s':''}</div>`:''}${inprog?`<div style="background:var(--pg2);border:1px solid rgba(124,92,252,.2);border-radius:999px;padding:5px 14px;font-size:.75rem;font-weight:600;color:var(--p)">▶ ${inprog} en cours</div>`:''}`;
  if(grid)grid.innerHTML=bState.resources.map(r=>{
    const pct=r.duration>0?Math.min(100,Math.round(((r.progress||0)/r.duration)*100)):0;
    const remain=r.duration>0?Math.max(0,r.duration-(r.progress||0)):0;
    const ti=getTypeInfo(r.type);
    const isDone=r.duration>0&&(r.progress||0)>=r.duration;
    return `<div class="card" id="kcard-${r.id}" style="border-color:${isDone?'rgba(0,229,160,.3)':'rgba(124,92,252,.15)'};position:relative">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px">
        <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0">
          <div style="width:40px;height:40px;border-radius:11px;background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0">${r.emoji||ti.emoji}</div>
          <div style="flex:1;min-width:0">
            <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.93rem;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.title}</div>
            ${r.desc?`<div style="font-size:.72rem;color:var(--t1);margin-top:2px">${r.desc}</div>`:''}
          </div>
        </div>
        <div style="display:flex;gap:5px;align-items:center;flex-shrink:0;margin-left:8px">
          <span style="background:var(--s2);border-radius:999px;padding:3px 8px;font-size:.64rem;font-weight:700;color:var(--t1);white-space:nowrap">${ti.emoji} ${r.type}</span>
          <button onclick="openEditResource('${r.id}')" title="Modifier" style="background:var(--s2);border:1px solid var(--b1);color:var(--t1);border-radius:7px;width:26px;height:26px;cursor:pointer;font-size:.72rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">✏</button>
          <button onclick="delResource('${r.id}')" title="Supprimer" style="background:var(--s2);border:1px solid var(--b1);color:var(--t2);border-radius:7px;width:26px;height:26px;cursor:pointer;font-size:.72rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">✕</button>
        </div>
      </div>
      ${r.duration>0?`<div style="margin-bottom:10px">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
          <span style="font-size:.65rem;text-transform:uppercase;letter-spacing:1px;color:var(--t2);font-weight:700">Progression</span>
          <span style="flex:1"></span>
          <input type="number" value="${r.progress||0}" min="0" max="${r.duration}" step="${r.durationUnit==='h'?'0.5':'1'}" onchange="updateResourceProgress('${r.id}',this.value)" style="width:62px;background:var(--s2);border:1px solid var(--b1);border-radius:7px;color:var(--t0);font-family:'DM Mono',monospace;font-size:.8rem;padding:3px 8px;text-align:center;outline:none">
          <span style="font-size:.8rem;color:var(--t1);white-space:nowrap">/ ${r.duration} ${r.durationUnit}</span>
        </div>
        <div class="prog-bg" style="margin-bottom:6px"><div class="prog-fill kcard-bar-${r.id}" style="width:${pct}%;${isDone?'background:linear-gradient(90deg,var(--g),var(--g2))':''}"></div></div>
        <div style="display:flex;justify-content:space-between;font-size:.7rem;color:var(--t1)">
          <span class="kcard-pct-${r.id}">${pct}%</span>
          <span class="kcard-remain-${r.id}">${isDone?'✓ Terminé <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M3 17l4-8 4 4 3-6 3 10"/><path d="M7 9l-4 8M5 13h6"/></svg>':remain+' '+r.durationUnit+' restant'+(remain>1&&r.durationUnit==='h'?'es':'')}</span>
        </div>
      </div>`:''}
      <textarea rows="2" placeholder="Notes..." onchange="updateResourceNotes('${r.id}',this.value)" style="width:100%;background:var(--s1);border:1px solid var(--b1);border-radius:8px;color:var(--t0);font-family:'Plus Jakarta Sans',sans-serif;font-size:.78rem;padding:8px 10px;resize:vertical;outline:none;margin-bottom:${r.url?'10px':'0'}">${r.notes||''}</textarea>
      ${r.url?`<a href="${r.url}" target="_blank" class="btn btn-primary" style="width:100%;text-align:center;text-decoration:none;display:block;font-size:.83rem;padding:10px">▶ Ouvrir</a>`:''}
    </div>`;
  }).join('');
  renderKnowledgeActions();
}
function renderKnowledgeActions(){const el=document.getElementById('formation-actions');if(!el)return;el.innerHTML=bState.formationActions&&bState.formationActions.length?bState.formationActions.map(a=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--b0)"><input type="checkbox" ${a.done?'checked':''} onchange="toggleFA('${a.id}')" style="accent-color:var(--p);cursor:pointer"><span style="flex:1;font-size:.83rem;${a.done?'text-decoration:line-through;opacity:.5':''}">${a.text}</span><button onclick="delFA('${a.id}')" style="background:none;border:none;color:var(--t2);cursor:pointer">✕</button></div>`).join(''):'';}

// AI Coach
function saveApiKey(){const key=document.getElementById('api-key-input').value.trim();if(!key)return;localStorage.setItem('gabos_apikey',key);closeModal('modal-api-key');toast('Clé API enregistrée ✓','var(--g)');}
function getApiKey(){return localStorage.getItem('gabos_apikey');}
function coachQuick(type){const p={analyse:'Analyse mon business en détail.',today:'Que dois-je absolument faire aujourd\'hui ?',product:'Comment valider un produit avant de mettre trop de budget pub ?',motivation:'J\'ai besoin d\'un boost. Dis-moi pourquoi je vais y arriver.'};document.getElementById('coach-input').value=p[type];sendCoach();}
async function sendCoach(){
  const input=document.getElementById('coach-input'),msg=input.value.trim();if(!msg)return;input.value='';
  const apiKey=getApiKey();if(!apiKey){openModal('modal-api-key');return;}
  const mode=document.getElementById('coach-mode').value;
  const modes={normal:'Sois direct et concret.',strict:'Sois très exigeant, pousse à l\'action immédiate.',soft:'Sois encourageant et bienveillant.'};
  const streak=calcStreak(),lv=levelInfo();
  const totalRev=bState.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=bState.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const C=getCurrency();
  const sys=`Tu es l'AI Business Coach de ${getUserName()}, 100% dédié à son succès.\n\nCONTEXTE:\n- Objectif: ${getGoalAmount()}${C}/${getGoalPeriod()==='day'?'jour':'mois'} en décembre 2026 (${daysLeft()} jours restants)\n- CA total: ${totalRev.toFixed(0)}${C} | Profit: ${(totalRev-totalExp).toFixed(0)}${C}\n- Habitudes: Streak ${streak} jours, Niveau ${lv.num}\n- Formation: ${bState.formationHours||0}/80h\n\nMODE: ${modes[mode]}\n\nRéponds en français, avec des actions concrètes. Utilise des emojis. Sois bref et impactant.`;
  const box=document.getElementById('coach-messages');
  box.innerHTML+=`<div class="ai-label user" style="margin-top:14px">TOI</div><div class="ai-message user">${msg}</div>`;
  const tid='ty'+Date.now();
  box.innerHTML+=`<div id="${tid}"><div class="ai-label coach">COACH</div><div class="ai-message"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`;
  document.getElementById('coach-box').scrollTop=99999;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:[{role:'user',content:msg}]})});
    const d=await r.json();
    if(d.error){document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message" style="color:var(--red)"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="10" r="7"/><path d="M7 7l6 6M13 7l-6 6"/></svg> Erreur API : ${d.error.message||d.error.type}</div>`;return;}
    const reply=d.content?.[0]?.text||'Réponse vide.';
    document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message">${reply.replace(/\n/g,'<br>')}</div>`;
  }catch(e){document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message" style="color:var(--red)"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="10" r="7"/><path d="M7 7l6 6M13 7l-6 6"/></svg> Erreur réseau — ${e.message}</div>`;}
  document.getElementById('coach-box').scrollTop=99999;
}
function clearCoach(){document.getElementById('coach-messages').innerHTML='<div class="ai-label coach">ASCEND COACH</div><div class="ai-message">Conversation effacée. Prêt à travailler </div>';}

// ══════════════════════════════════════════════════════
//  GOAL PLAN
// ══════════════════════════════════════════════════════
function openGoalPlan(){
  const totalRev=bState.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=bState.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=totalRev-totalExp;const C=getCurrency();const dl=daysLeft();const gl=getGoalAmount(),gp=getGoalPeriod();
  const streak=calcStreak(),lv=levelInfo();
  document.getElementById('goal-plan-subtitle').textContent=`Ce que tu dois faire pour atteindre ${gl.toLocaleString('fr-FR')}${C}/${gp==='day'?'jour':'mois'}`;
  let phase,phaseColor,steps=[];
  if(totalRev===0){phase='Phase 1 : Trouver et tester un produit';phaseColor='var(--blue)';steps=['Identifie 3 produits gagnants potentiels sur AliExpress/CJ','Calcule les marges (cible : 60%+ de marge brute)','Lance une première campagne test à 10€/jour','Analyse les résultats après 48h de données'];}
  else if(totalRev<500){phase='Phase 2 : Optimiser les premières campagnes';phaseColor='var(--gold)';steps=['Optimise ta créa publicitaire avec les données actuelles','Teste différents angles marketing','Augmente progressivement le budget sur les campagnes positives','Travaille ton taux de conversion de la landing page'];}
  else if(totalRev<5000){phase='Phase 3 : Scaler les campagnes rentables';phaseColor='var(--p)';steps=['Scale tes campagnes rentables (augmente le budget de 20%/jour)','Duplique les audiences qui convertissent','Testes de nouvelles créas sur tes meilleures campagnes','Automatise la gestion des commandes'];}
  else{phase='Phase 4 : Systématiser et scaler massivement';phaseColor='var(--g)';steps=['Délègue la gestion quotidienne pour te concentrer sur la stratégie','Lance de nouveaux produits en parallèle','Explore de nouveaux marchés/pays','Mets en place des systèmes d\'automatisation'];}
  document.getElementById('goal-plan-content').innerHTML=`
    <div style="background:linear-gradient(135deg,${phaseColor}18,transparent);border:1px solid ${phaseColor}30;border-radius:var(--rs);padding:14px;margin-bottom:16px">
      <div style="font-size:.62rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--t1);margin-bottom:4px;font-family:'Syne',sans-serif">Phase actuelle</div>
      <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:${phaseColor}">${phase}</div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,130px),1fr));gap:10px;margin-bottom:16px">
      <div style="text-align:center;background:var(--s1);border-radius:var(--rs);padding:12px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:var(--g)">${totalRev.toFixed(0)}${C}</div><div style="font-size:.62rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">CA Total</div></div>
      <div style="text-align:center;background:var(--s1);border-radius:var(--rs);padding:12px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:${profit>=0?'var(--g)':'var(--red)'}">${profit.toFixed(0)}${C}</div><div style="font-size:.62rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Profit</div></div>
      <div style="text-align:center;background:var(--s1);border-radius:var(--rs);padding:12px"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:var(--gold)">${dl}</div><div style="font-size:.62rem;color:var(--t1);margin-top:2px;text-transform:uppercase;letter-spacing:.8px">Jours restants</div></div>
    </div>
    <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.7rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--t1);margin-bottom:10px">Actions prioritaires</div>
    ${steps.map((s,i)=>`<div class="plan-item"><div class="plan-item-num" style="background:${phaseColor}">${i+1}</div><div class="plan-item-body">${s}</div></div>`).join('')}
    <div style="background:rgba(0,229,160,.07);border:1px solid rgba(0,229,160,.15);border-radius:var(--rs);padding:12px;margin-top:14px">
      <div style="font-size:.7rem;font-weight:700;color:var(--g);margin-bottom:5px;font-family:'Syne',sans-serif"><svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 18V10M10 10C10 10 6 6 3 4c5-2 7 2 7 6M10 10c0 0 4-4 7-6-2 5-7 6-7 6"/></svg> Habitudes · Streak ${streak}j · Niveau ${lv.num}</div>
      <div style="font-size:.8rem;color:var(--t1);line-height:1.55">Tes habitudes te donnent l'énergie et la discipline pour atteindre ton objectif. Maintiens ton streak !</div>
    </div>`;
  openModal('modal-goal-plan');
}

// ══════════════════════════════════════════════════════
//  INTEGRATIONS (kept from v4)
// ══════════════════════════════════════════════════════
let currentIntegration=null;
const INT_CONFIG={
  shopify:{name:'Shopify',icon:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M2 3h2l2.5 9h9L18 6H6"/><circle cx="8" cy="17" r="1.5"/><circle cx="15" cy="17" r="1.5"/></svg>',fields:[{id:'shopify-store',label:'Boutique (.myshopify.com)',type:'text',placeholder:'purrlopets.myshopify.com'},{id:'shopify-token',label:'Access Token',type:'password',placeholder:'shpat_...'}],how:'Shopify Admin → Apps → Develop apps → Create app → Configure API scopes (read_orders) → Install app → Copy Admin API access token.',fetch:fetchShopifyData},
  meta:{name:'Meta Ads',icon:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M4 3h12a1 1 0 011 1v13l-3-2-3 2-3-2-3 2V4a1 1 0 011-1z"/></svg>',fields:[{id:'meta-token',label:'Access Token',type:'password',placeholder:'EAABx...'},{id:'meta-account',label:'Ad Account ID',type:'text',placeholder:'act_123456789'}],how:'Meta Business Suite → Paramètres → API Business → Générer un token (ads_read).',fetch:fetchMetaData},
  tiktok:{name:'TikTok Ads',icon:'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',fields:[{id:'tiktok-token',label:'Access Token',type:'password',placeholder:'...'},{id:'tiktok-account',label:'Advertiser ID',type:'text',placeholder:'7...'}],how:'TikTok Ads Manager → Assets → Business Center → Autorisation de compte → Générer token.',fetch:fetchTikTokData},
};
function renderCustomIntCards(){const el=document.getElementById('custom-int-cards');if(!el)return;const customs=JSON.parse(localStorage.getItem('gabos_custom_ints')||'[]');el.innerHTML=customs.map(c=>`<div class="int-card" onclick="toast('Intégration custom: '+${JSON.stringify(c.name)},'var(--p)')"><div class="int-card-icon">${c.icon||'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M7 2v5M13 2v5M5 7h10l-1 6a4 4 0 01-8 0L5 7zM8 16v2M12 16v2"/></svg>'}</div><div class="int-card-name">${c.name}</div><div class="int-card-desc">${c.desc||''}</div><div><span class="tag tag-p" style="font-size:.6rem">Custom</span></div></div>`).join('');}
function openAddCustomIntegration(){openModal('modal-add-integration');}
function saveCustomIntegration(){const name=document.getElementById('ci-name').value.trim();if(!name){toast('Nom requis','var(--red)');return;}const customs=JSON.parse(localStorage.getItem('gabos_custom_ints')||'[]');customs.push({id:'ci'+Date.now(),name,icon:document.getElementById('ci-icon').value||'<svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M7 2v5M13 2v5M5 7h10l-1 6a4 4 0 01-8 0L5 7zM8 16v2M12 16v2"/></svg>',desc:document.getElementById('ci-desc').value,url:document.getElementById('ci-url').value,token:document.getElementById('ci-token').value,authType:document.getElementById('ci-auth-type').value});localStorage.setItem('gabos_custom_ints',JSON.stringify(customs));closeModal('modal-add-integration');renderCustomIntCards();toast('Intégration ajoutée ✓','var(--g)');}
function openIntDetail(key){currentIntegration=key;const cfg=INT_CONFIG[key];if(!cfg)return;document.getElementById('int-list-view').style.display='none';document.getElementById('int-detail-view').style.display='block';document.getElementById('int-detail-title').textContent=cfg.icon+' '+cfg.name;let fieldsHtml='<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-bottom:10px">';cfg.fields.forEach(f=>{const saved=localStorage.getItem('gabos_'+f.id.replace(/-/g,'_'));fieldsHtml+=`<div><div class="inp-lbl">${f.label}</div><input class="inp" id="detail-${f.id}" type="${f.type}" placeholder="${f.placeholder}" value="${saved||''}"></div>`;});fieldsHtml+='</div>';fieldsHtml+=`<button class="btn btn-primary btn-sm" onclick="saveCurrentIntegration()">Connecter</button>`;document.getElementById('int-detail-config-fields').innerHTML=fieldsHtml;document.getElementById('int-detail-how').innerHTML=` <strong style="color:var(--t1)">Comment obtenir le token :</strong> ${cfg.how}`;const badge=document.getElementById(key+'-card-status');const isConnected=badge&&badge.innerHTML.includes('Connecté');document.getElementById('int-detail-disconnect-btn').style.display=isConnected?'block':'none';renderIntDetailData(key);updateDetailBadge(key);}
function closeIntDetail(){document.getElementById('int-list-view').style.display='block';document.getElementById('int-detail-view').style.display='none';currentIntegration=null;}
function saveCurrentIntegration(){if(!currentIntegration)return;const cfg=INT_CONFIG[currentIntegration];cfg.fields.forEach(f=>{const val=document.getElementById('detail-'+f.id)?.value.trim();if(val)localStorage.setItem('gabos_'+f.id.replace(/-/g,'_'),val);});cfg.fetch();toast(cfg.name+' connecté ✓','var(--g)');}
function syncCurrentIntegration(){if(!currentIntegration)return;INT_CONFIG[currentIntegration]?.fetch();toast('Sync lancée...','var(--p)');}
function disconnectCurrentIntegration(){if(!currentIntegration)return;const cfg=INT_CONFIG[currentIntegration];cfg.fields.forEach(f=>localStorage.removeItem('gabos_'+f.id.replace(/-/g,'_')));updateCardStatus(currentIntegration,false);document.getElementById('int-detail-data').innerHTML='';document.getElementById('int-detail-disconnect-btn').style.display='none';updateDetailBadge(currentIntegration);toast(cfg.name+' déconnecté','var(--t1)');}
function updateCardStatus(key,connected,text){const el=document.getElementById(key+'-card-status');if(!el)return;el.innerHTML=connected?`<span class="tag tag-g" style="font-size:.6rem">✓ Connecté</span>`:`<span class="tag tag-r" style="font-size:.6rem">${text||'Non connecté'}</span>`;}
function updateDetailBadge(key){const badge=document.getElementById('int-detail-badge');const cardStatus=document.getElementById(key+'-card-status');if(!badge||!cardStatus)return;const connected=cardStatus.innerHTML.includes('Connecté');badge.className=connected?'tag tag-g':'tag tag-r';badge.textContent=connected?'Connecté ✓':'Non connecté';document.getElementById('int-detail-disconnect-btn').style.display=connected?'block':'none';}
function renderIntDetailData(key){if(key==='shopify')fetchShopifyData(true);else if(key==='meta')fetchMetaData(true);else if(key==='tiktok')fetchTikTokData(true);}
function syncAllIntegrations(){fetchShopifyData();fetchMetaData();fetchTikTokData();toast('Sync lancée...','var(--p)');}
function initIntegrations(){renderCustomIntCards();if(localStorage.getItem('gabos_shopify_token'))fetchShopifyData();if(localStorage.getItem('gabos_meta_token'))fetchMetaData();if(localStorage.getItem('gabos_tiktok_token'))fetchTikTokData();}

async function fetchShopifyData(fromDetail=false){const token=localStorage.getItem('gabos_shopify_token');const store=localStorage.getItem('gabos_shopify_store');if(!token||!store)return;updateCardStatus('shopify',false,'Chargement...');try{const r=await fetch(`https://${store}/admin/api/2024-01/orders.json?status=any&limit=50&created_at_min=${new Date(Date.now()-30*86400000).toISOString()}`,{headers:{'X-Shopify-Access-Token':token,'Content-Type':'application/json'}});if(!r.ok)throw new Error('HTTP '+r.status);const data=await r.json();const orders=data.orders||[];const C=getCurrency();const rev=orders.filter(o=>o.financial_status==='paid').reduce((s,o)=>s+parseFloat(o.total_price||0),0);updateCardStatus('shopify',true);if(currentIntegration==='shopify'||fromDetail){updateDetailBadge('shopify');document.getElementById('int-detail-data').innerHTML=`<div class="grid-4" style="margin-bottom:14px"><div class="kpi-card" style="--kpi-c:var(--g)"><div class="kpi-lbl">CA 30j</div><div class="kpi-val" style="color:var(--g)">${rev.toFixed(0)}${C}</div></div><div class="kpi-card" style="--kpi-c:var(--p)"><div class="kpi-lbl">Commandes</div><div class="kpi-val" style="color:var(--p)">${orders.length}</div></div></div>`;}}catch(e){updateCardStatus('shopify',false,'Erreur');toast('Erreur Shopify — '+e.message,'var(--red)');}}
async function fetchMetaData(fromDetail=false){const token=localStorage.getItem('gabos_meta_token');const account=localStorage.getItem('gabos_meta_account');if(!token||!account)return;updateCardStatus('meta',false,'Chargement...');try{const since=new Date(Date.now()-30*86400000).toISOString().split('T')[0];const r=await fetch(`https://graph.facebook.com/v19.0/${account}/insights?fields=spend,impressions,clicks,cpc&time_range={'since':'${since}','until':'${new Date().toISOString().split('T')[0]}'}&access_token=${token}`);if(!r.ok)throw new Error('HTTP '+r.status);const data=await r.json();if(data.error)throw new Error(data.error.message);const d=(data.data&&data.data[0])||{};const C=getCurrency();updateCardStatus('meta',true);if(currentIntegration==='meta'||fromDetail){updateDetailBadge('meta');document.getElementById('int-detail-data').innerHTML=`<div class="grid-4" style="margin-bottom:14px"><div class="kpi-card" style="--kpi-c:var(--red)"><div class="kpi-lbl">Dépenses 30j</div><div class="kpi-val" style="color:var(--red)">${parseFloat(d.spend||0).toFixed(0)}${C}</div></div><div class="kpi-card" style="--kpi-c:var(--blue)"><div class="kpi-lbl">Impressions</div><div class="kpi-val" style="color:var(--blue);font-size:1.3rem">${(parseInt(d.impressions||0)/1000).toFixed(1)}k</div></div><div class="kpi-card" style="--kpi-c:var(--gold)"><div class="kpi-lbl">Clics</div><div class="kpi-val" style="color:var(--gold)">${parseInt(d.clicks||0)}</div></div><div class="kpi-card" style="--kpi-c:var(--p)"><div class="kpi-lbl">CPC</div><div class="kpi-val" style="color:var(--p)">${parseFloat(d.cpc||0).toFixed(2)}${C}</div></div></div>`;}}catch(e){updateCardStatus('meta',false,'Erreur');toast('Erreur Meta — '+e.message,'var(--red)');}}
async function fetchTikTokData(fromDetail=false){const token=localStorage.getItem('gabos_tiktok_token');const account=localStorage.getItem('gabos_tiktok_account');if(!token||!account)return;updateCardStatus('tiktok',false,'Chargement...');try{const endDate=new Date().toISOString().split('T')[0];const startDate=new Date(Date.now()-30*86400000).toISOString().split('T')[0];const url=`https://business-api.tiktok.com/open_api/v1.3/report/integrated/get/?advertiser_id=${account}&report_type=BASIC&data_level=AUCTION_ADVERTISER&dimensions=["stat_time_day"]&metrics=["spend","impressions","clicks"]&start_date=${startDate}&end_date=${endDate}&page_size=30`;const r=await fetch(url,{headers:{'Access-Token':token,'Content-Type':'application/json'}});if(!r.ok)throw new Error('HTTP '+r.status);const data=await r.json();if(data.code!==0)throw new Error(data.message||'Erreur TikTok');const rows=data.data?.list||[];const spend=rows.reduce((s,r)=>s+parseFloat(r.metrics?.spend||0),0);const impressions=rows.reduce((s,r)=>s+parseInt(r.metrics?.impressions||0),0);const clicks=rows.reduce((s,r)=>s+parseInt(r.metrics?.clicks||0),0);const C=getCurrency();updateCardStatus('tiktok',true);if(currentIntegration==='tiktok'||fromDetail){updateDetailBadge('tiktok');document.getElementById('int-detail-data').innerHTML=`<div class="grid-4" style="margin-bottom:14px"><div class="kpi-card" style="--kpi-c:var(--red)"><div class="kpi-lbl">Dépenses 30j</div><div class="kpi-val" style="color:var(--red)">${spend.toFixed(0)}${C}</div></div><div class="kpi-card" style="--kpi-c:var(--blue)"><div class="kpi-lbl">Impressions</div><div class="kpi-val" style="color:var(--blue);font-size:1.3rem">${(impressions/1000).toFixed(1)}k</div></div><div class="kpi-card" style="--kpi-c:var(--gold)"><div class="kpi-lbl">Clics</div><div class="kpi-val" style="color:var(--gold)">${clicks}</div></div></div>`;}}catch(e){updateCardStatus('tiktok',false,'Erreur');toast('Erreur TikTok — '+e.message,'var(--red)');}}

// Templates
function renderTemplates(){document.getElementById('templates-list').innerHTML=`<div style="font-size:.84rem;color:var(--t1);margin-bottom:14px">Sélectionne un template pour importer des tâches :</div>${[{name:'Lancement produit',tasks:['Choisir 3 produits à tester','Calculer les marges','Créer les créas publicitaires','Lancer campagne test 10€/j','Analyser après 48h']},{name:'Optimisation campagne',tasks:['Analyser les métriques actuelles','Identifier les audiences gagnantes','Créer 3 nouvelles créas','Tester différents angles','Scale les campagnes positives']},{name:'Semaine type entrepreneur',tasks:['Review métriques hebdo (lundi)','Créer 2 nouvelles créas','Contacter fournisseur','Mise à jour landing page','Bilan et planification vendredi']}].map(tpl=>`<div class="card" style="margin-bottom:10px;cursor:pointer" onclick="importTemplate(${JSON.stringify(tpl.tasks)})"><div style="font-weight:700;font-size:.9rem;margin-bottom:8px">${tpl.name}</div><div style="font-size:.78rem;color:var(--t1)">${tpl.tasks.slice(0,3).join(' · ')}${tpl.tasks.length>3?'...':''}</div></div>`).join('')}`;}
function importTemplate(tasks){tasks.forEach(t=>bState.tasks.push({id:'tk'+Date.now()+Math.random(),title:t,priority:'med',cat:'Business',done:false}));saveB();closeModal('modal-template');renderTasks();toast(`${tasks.length} tâches importées ✓`,'var(--g)');}

