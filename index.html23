</aside>

<!-- ══ MODE SWITCHER ══ -->
<div class="mode-wrap">
  <div class="mode-inner">
    <button class="hamburger" onclick="openSidebar()">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="2" y1="4" x2="14" y2="4"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="2" y1="12" x2="14" y2="12"/></svg>
    </button>
    <div class="mode-switcher" id="modeSwitcher">
      <div class="mode-slider" id="modeSlider"></div>
      <div class="mode-pill mode-pill-biz active-biz" onclick="setMode('biz')">
        <svg viewBox="0 0 20 20"><path d="M10 3L4 11h5v6h2v-6h5L10 3z"/></svg> <span data-i18n="mode.biz">Business</span>
      </div>
      <div class="mode-divider"></div>
      <div class="mode-pill mode-pill-hab" onclick="setMode('hab')">
        <svg viewBox="0 0 20 20"><path d="M10 2c0 0-7 4-7 9a7 7 0 0014 0c0-5-7-9-7-9z"/></svg> <span data-i18n="mode.hab">Habitudes</span>
      </div>
    </div>
  </div>
</div>

<!-- ══ MAIN ══ -->
<main class="main">
<!-- ══ BUSINESS: COMMAND CENTER ══ -->
<div class="view active" id="view-command">
  <div class="topbar">
    <div class="topbar-left"><div>
      <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.58rem;letter-spacing:3px;text-transform:uppercase;background:linear-gradient(135deg,var(--p),var(--pk));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:3px">ASCEND</div>
      <h2 id="cmd-greeting">Bonjour</h2><div class="sub" id="cmd-date"></div>
    </div></div>
    <div class="topbar-right"><div class="date-chip mono" id="cmd-clock">--:--:--</div></div>
  </div>
  <div id="cmd-alert-zone" style="margin-bottom:16px"></div>
  <div class="grid-4" id="cmd-kpis"></div>
  <div class="grid-2">
    <div class="card"><div class="card-title" data-i18n="view.command.tasks">Tâches du jour</div><div id="cmd-tasks"></div><button class="btn btn-ghost btn-sm" onclick="closeSidebar();showView('tasks')" style="margin-top:10px;width:100%" data-i18n="view.command.seeall">Voir tout →</button></div>
    <div class="card"><div class="card-title" data-i18n="view.command.products">Produits actifs</div><div id="cmd-products"></div><button class="btn btn-ghost btn-sm" onclick="closeSidebar();showView('products')" style="margin-top:10px;width:100%" data-i18n="view.command.seeall">Voir tout →</button></div>
  </div>
  <div class="card" onclick="openGoalPlan()" style="margin-top:0;cursor:pointer;transition:all .2s" onmouseover="this.style.borderColor='rgba(0,229,160,.3)'" onmouseout="this.style.borderColor=''">
    <div class="card-title"><span data-i18n="view.command.goal">Objectif final</span> <span class="tag tag-g" style="font-size:.6rem" data-i18n="view.command.seeplan">Voir plan →</span></div>
    <div style="font-size:.78rem;color:var(--t1);margin-bottom:6px" id="goal-days-left">— jours restants</div>
    <div style="font-family:'Syne',sans-serif;font-size:1.15rem;font-weight:800;color:var(--g)" id="cmd-goal-label">4 000€/jour en Décembre 2026</div>
    <div class="goal-bar-bg" style="margin-top:12px"><div class="goal-bar-fill" id="goal-progress-bar" style="width:1%"></div></div>
  </div>
</div>

<!-- ══ BUSINESS: FINANCE ══ -->
<div class="view" id="view-finance">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.finance">Finance Tracker</h2></div>
    <div class="topbar-right">
      <button class="btn btn-ghost btn-sm" onclick="renderFinance('month')" data-i18n="finance.btn30">30j</button>
      <button class="btn btn-ghost btn-sm" onclick="renderFinance('all')" data-i18n="finance.btnAll">Tout</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-add-transaction')" data-i18n="finance.addTx">+ Transaction</button>
    </div>
  </div>
  <div class="grid-4" id="finance-kpis"></div>
  <div class="grid-2">
    <div class="card"><div class="card-title" data-i18n="finance.revenue">Revenus vs Dépenses</div><div style="position:relative;height:180px"><canvas id="chart-finance"></canvas></div></div>
    <div class="card"><div class="card-title" data-i18n="finance.split">Répartition dépenses</div><div style="position:relative;height:180px"><canvas id="chart-pie"></canvas></div></div>
  </div>
  <div class="card"><div class="card-title" data-i18n="finance.history">Historique transactions</div><div id="transactions-table" style="overflow-x:auto"></div></div>
</div>

<!-- ══ BUSINESS: PRODUCTS ══ -->
<div class="view" id="view-products">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.products">Product Lab</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-product')" data-i18n="products.add">+ Produit</button></div>
  </div>
  <div id="products-list"></div>
</div>

<!-- ══ BUSINESS: ADS ══ -->
<div class="view" id="view-ads">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.ads">Ads Control</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-campaign')" data-i18n="ads.add">+ Campagne</button></div>
  </div>
  <div class="grid-4" id="ads-kpis"></div>
  <div id="ads-suggestions" style="margin-bottom:14px"></div>
  <div class="card"><div class="card-title" data-i18n="ads.campaigns">Campagnes</div><div id="campaigns-list"></div><div class="empty" id="campaigns-empty" style="display:none"><div class="ei"><svg width="32" height="32" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h8l4-3v12l-4-3H3V7z"/><path d="M15 9a2 2 0 010 2"/></svg></div><p data-i18n="ads.noCampaigns">Ajoute tes campagnes pub</p></div></div>
</div>

<!-- ══ BUSINESS: ANALYTICS ══ -->
<div class="view" id="view-analytics">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.analytics">Analytics</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-metric')" data-i18n="analytics.add">+ Métriques</button></div>
  </div>
  <div class="grid-4" id="analytics-kpis"></div>
  <div class="grid-2">
    <div class="card"><div class="card-title" data-i18n="analytics.funnel">Funnel</div><div id="funnel"></div></div>
    <div class="card"><div class="card-title" data-i18n="analytics.history">Historique 7j</div><div id="metrics-history"></div></div>
  </div>
</div>

<!-- ══ BUSINESS: TASKS / EXECUTION PANEL ══ -->
<div class="view" id="view-tasks">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.tasks">Panneau d'exécution</h2></div>
    <div class="topbar-right">
      <button class="btn btn-ghost btn-sm" onclick="openModal('modal-template')" data-i18n="tasks.templates">Templates</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-add-task')" data-i18n="tasks.add">+ Tâche</button>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:14px" id="tasks-grid">
    <div class="card"><div class="card-title"><span data-i18n="tasks.high">Priorité Haute</span> <span class="tag tag-r" id="count-high">0</span></div><div id="tasks-high"></div></div>
    <div class="card"><div class="card-title"><span data-i18n="tasks.med">Priorité Moyenne</span> <span class="tag tag-gold" id="count-med">0</span></div><div id="tasks-med"></div></div>
    <div class="card"><div class="card-title"><span data-i18n="tasks.low">Faible / Terminé</span> <span class="tag tag-g" id="count-low">0</span></div><div id="tasks-low"></div></div>
  </div>
</div>

<!-- ══ BUSINESS: STRATEGY ══ -->
<div class="view" id="view-strategy">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.strategy">Strategy Board</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-goal')" data-i18n="strategy.add">+ Objectif</button></div>
  </div>
  <div class="grid-2">
    <div class="card"><div class="card-title" data-i18n="strategy.vision">Vision & Objectifs</div><div id="goals-list"></div></div>
    <div class="card"><div class="card-title" data-i18n="strategy.roadmap">Roadmap 2026</div><div id="roadmap"></div></div>
  </div>
  <div class="card" style="margin-top:0">
    <div class="card-title" data-i18n="strategy.notes">Notes stratégiques</div>
    <textarea class="inp" id="strategy-notes" rows="6" data-i18n-placeholder="strategy.placeholder" placeholder="Angles marketing, idées, observations..." style="resize:vertical" oninput="saveStrategyNotes()"></textarea>
  </div>
</div>

<!-- ══ HUB ══ -->
<div class="view" id="view-hub">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.hub">Hub de liens</h2></div>
    <div class="topbar-right">
      <button class="btn btn-ghost btn-sm" onclick="openManageCategories()" data-i18n="hub.manage">Gérer catégories</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-add-link')" data-i18n="hub.add">+ Lien</button>
    </div>
  </div>
  <div id="hub-categories"></div>
</div>

<!-- ══ KNOWLEDGE ══ -->
<div class="view" id="view-knowledge">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.knowledge">Knowledge Center</h2></div>
    <div class="topbar-right" style="display:flex;gap:8px">
      <button class="btn btn-sm" style="background:var(--s2);border:1px solid var(--b1);color:var(--t1)" onclick="renderManageTypes();openModal('modal-manage-types')"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="10" r="2.5"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.9 4.9l1.4 1.4M13.7 13.7l1.4 1.4M4.9 15.1l1.4-1.4M13.7 6.3l1.4-1.4"/></svg> Types</button>
      <button class="btn btn-primary btn-sm" onclick="openAddResource()">+ Source</button>
    </div>
  </div>

  <!-- Stats bar -->
  <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap" id="knowledge-stats-bar"></div>

  <!-- Sources grid -->
  <div id="knowledge-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,320px),1fr));gap:14px;margin-bottom:16px"></div>

  <!-- Empty state -->
  <div id="knowledge-empty" class="card" style="display:none;text-align:center;padding:40px 20px">
    <div style="font-size:2.5rem;margin-bottom:12px"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M4 4h4v12H4zM10 4h4v12h-4z"/><path d="M16 5l2 11"/><path d="M2 5L0 16"/></svg></div>
    <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:6px">Aucune source pour l'instant</div>
    <div style="color:var(--t1);font-size:.83rem;margin-bottom:16px">Ajoute ta première formation, vidéo, livre...</div>
    <button class="btn btn-primary btn-sm" onclick="openModal('modal-add-resource')">+ Ajouter une source</button>
  </div>

  <!-- Actions globales -->
  <div class="card" style="margin-top:0">
    <div class="card-title">Actions à appliquer</div>
    <div id="formation-actions"></div>
    <div class="inp-row" style="margin-top:12px">
      <input class="inp" id="new-formation-action" placeholder="Action concrète à appliquer...">
      <button class="btn btn-primary btn-sm" onclick="addFormationAction()" style="white-space:nowrap">+ Ajouter</button>
    </div>
  </div>
</div>

<!-- ══ AI COACH ══ -->
<div class="view" id="view-coach">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.coach">AI Business Coach</h2></div>
    <div class="topbar-right">
      <select class="inp" id="coach-mode" style="width:auto;padding:6px 12px;font-size:.8rem">
        <option value="normal" data-i18n="coach.modeNormal">Mode Normal</option>
        <option value="strict" data-i18n="coach.modeStrict">Mode Strict</option>
        <option value="soft" data-i18n="coach.modeSoft">Mode Soft</option>
      </select>
      <button class="btn btn-ghost btn-sm" onclick="clearCoach()" data-i18n="coach.clear">Effacer</button>
      <button class="btn btn-ghost btn-sm" onclick="openModal('modal-api-key')"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="11.5" r="3.5"/><path d="M10.5 9L17 2M14 5l2 2"/></svg> API</button>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:8px;margin-bottom:14px">
    <button class="btn btn-ghost" onclick="coachQuick('analyse')" style="font-size:.78rem" data-i18n="coach.analyse"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><rect x="2" y="12" width="4" height="6" rx="1"/><rect x="8" y="8" width="4" height="10" rx="1"/><rect x="14" y="4" width="4" height="14" rx="1"/></svg> Analyser</button>
    <button class="btn btn-ghost" onclick="coachQuick('today')" style="font-size:.78rem" data-i18n="coach.today"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M11 2L4 11h7l-2 7 9-10h-7l2-8z"/></svg> Que faire ?</button>
    <button class="btn btn-ghost" onclick="coachQuick('product')" style="font-size:.78rem" data-i18n="coach.product"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M7 2h6M9 2v5L5 15a2 2 0 001.8 3h6.4A2 2 0 0015 15L11 7V2"/></svg> Valider produit</button>
    <button class="btn btn-ghost" onclick="coachQuick('motivation')" style="font-size:.78rem" data-i18n="coach.motivation"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 8 5 12.5a5 5 0 0010 0C15 8 10 2 10 2z"/><path d="M10 15.5a2 2 0 010-4"/></svg> Remotiver</button>
  </div>
  <div class="card" style="margin-bottom:14px;overflow:hidden;display:flex;flex-direction:column" id="coach-outer">
    <div style="flex:1;overflow-y:auto;min-height:260px;max-height:420px;padding:4px" id="coach-box">
      <div id="coach-messages">
        <div class="ai-label coach">ASCEND COACH</div>
        <div class="ai-message" id="coach-welcome-msg" data-i18n-html="coach.welcome">Je suis ton AI Business Coach, 100% dédié à ton objectif.<br><br>Configure ta clé API Anthropic (bouton API) pour activer le coaching IA. </div>
      </div>
    </div>
  </div>
  <div class="inp-row"><input class="inp" id="coach-input" data-i18n-placeholder="coach.placeholder" placeholder="Pose une question ou décris ta situation..." onkeydown="if(event.key==='Enter')sendCoach()"><button class="btn btn-primary" onclick="sendCoach()" data-i18n="coach.send">Envoyer</button></div>
  <div style="font-size:.7rem;color:var(--t2);margin-top:5px"><span data-i18n="coach.apiNote">Nécessite une clé API Anthropic —</span> <span style="color:var(--p);cursor:pointer" onclick="openModal('modal-api-key')" data-i18n="coach.apiConfig">Configurer →</span></div>
</div>

<!-- ══ INTEGRATIONS ══ -->
<div class="view" id="view-integrations">
  <div id="int-list-view">
    <div class="topbar">
      <div class="topbar-left"><h2 data-i18n="view.integrations">Intégrations API</h2><div class="sub" data-i18n="int.sub">Connecte tes outils pour centraliser tes données</div></div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm" onclick="syncAllIntegrations()" data-i18n="int.sync"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 7.5A6 6 0 0116 7M4 4v4h4M15.5 12.5A6 6 0 014 13M20 16v-4h-4"/></svg> Sync</button>
        <button class="btn btn-primary btn-sm" onclick="openAddCustomIntegration()" data-i18n="int.add">+ Ajouter</button>
      </div>
    </div>
    <div style="margin-bottom:24px">
      <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.68rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--t2);margin-bottom:10px" data-i18n="int.mine">Mes intégrations</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px" id="int-cards-grid">
        <div class="int-card" id="int-card-shopify" onclick="openIntDetail('shopify')">
          <div class="int-card-icon" style="background:rgba(150,191,71,.1);border-color:rgba(150,191,71,.2)"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M2 3h2l2.5 9h9L18 6H6"/><circle cx="8" cy="17" r="1.5"/><circle cx="15" cy="17" r="1.5"/></svg></div>
          <div class="int-card-name">Shopify</div>
          <div class="int-card-desc" data-i18n="int.shopify.desc">Commandes & revenus</div>
          <div id="shopify-card-status"><span class="tag tag-r" style="font-size:.6rem" data-i18n="int.notConnected">Non connecté</span></div>
        </div>
        <div class="int-card" id="int-card-meta" onclick="openIntDetail('meta')">
          <div class="int-card-icon" style="background:rgba(79,133,255,.1);border-color:rgba(79,133,255,.2)"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M4 3h12a1 1 0 011 1v13l-3-2-3 2-3-2-3 2V4a1 1 0 011-1z"/></svg></div>
          <div class="int-card-name">Meta Ads</div>
          <div class="int-card-desc" data-i18n="int.meta.desc">Facebook & Instagram</div>
          <div id="meta-card-status"><span class="tag tag-r" style="font-size:.6rem" data-i18n="int.notConnected">Non connecté</span></div>
        </div>
        <div class="int-card" id="int-card-tiktok" onclick="openIntDetail('tiktok')">
          <div class="int-card-icon" style="background:rgba(255,0,80,.08);border-color:rgba(255,0,80,.15)"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
          <div class="int-card-name">TikTok Ads</div>
          <div class="int-card-desc" data-i18n="int.tiktok.desc">Campagnes TikTok</div>
          <div id="tiktok-card-status"><span class="tag tag-r" style="font-size:.6rem" data-i18n="int.notConnected">Non connecté</span></div>
        </div>
        <div id="custom-int-cards"></div>
        <div class="int-card int-card-add" onclick="openAddCustomIntegration()">
          <div class="int-card-icon" style="background:rgba(124,92,252,.08);border-color:rgba(124,92,252,.2);font-size:1.4rem;color:var(--p)">+</div>
          <div class="int-card-name" style="color:var(--p)" data-i18n="int.addNew">Ajouter</div>
          <div class="int-card-desc" data-i18n="int.newInt">Nouvelle intégration</div>
        </div>
      </div>
    </div>
    <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.68rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--t2);margin-bottom:10px" data-i18n="int.soon">Bientôt disponible</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px">
      <div class="int-card" style="opacity:.4;cursor:default"><div class="int-card-icon" style="background:rgba(234,67,53,.07)"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="12" width="4" height="6" rx="1"/><rect x="8" y="8" width="4" height="10" rx="1"/><rect x="14" y="4" width="4" height="14" rx="1"/></svg></div><div class="int-card-name">Google Analytics</div><div class="int-card-desc">Traffic & conversions</div><div><span class="tag tag-gold" style="font-size:.6rem" data-i18n="int.soonTag">Bientôt</span></div></div>
      <div class="int-card" style="opacity:.4;cursor:default"><div class="int-card-icon" style="background:rgba(245,200,66,.07)"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="16" height="12" rx="2"/><path d="M2 7l8 5 8-5"/></svg></div><div class="int-card-name">Klaviyo</div><div class="int-card-desc">Email marketing</div><div><span class="tag tag-gold" style="font-size:.6rem" data-i18n="int.soonTag">Bientôt</span></div></div>
      <div class="int-card" style="opacity:.4;cursor:default"><div class="int-card-icon" style="background:rgba(79,195,255,.07)"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2L2 6v8l8 4 8-4V6l-8-4z"/><path d="M2 6l8 4M18 6l-8 4M10 10v8"/></svg></div><div class="int-card-name">CJ Dropshipping</div><div class="int-card-desc">Fournisseur & stock</div><div><span class="tag tag-gold" style="font-size:.6rem" data-i18n="int.soonTag">Bientôt</span></div></div>
    </div>
  </div>
  <div id="int-detail-view" style="display:none">
    <div class="topbar">
      <div class="topbar-left" style="display:flex;align-items:center;gap:12px">
        <button class="btn btn-ghost btn-sm" onclick="closeIntDetail()" data-i18n="int.back">← Retour</button>
        <h2 id="int-detail-title">Shopify</h2>
        <span id="int-detail-badge" class="tag tag-r">Non connecté</span>
      </div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm" onclick="syncCurrentIntegration()"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 7.5A6 6 0 0116 7M4 4v4h4M15.5 12.5A6 6 0 014 13M20 16v-4h-4"/></svg> Sync</button>
        <button class="btn btn-danger btn-sm" id="int-detail-disconnect-btn" onclick="disconnectCurrentIntegration()" style="display:none">Déconnecter</button>
      </div>
    </div>
    <div class="card" style="margin-bottom:14px" id="int-detail-config">
      <div class="card-title">Configuration</div>
      <div id="int-detail-config-fields"></div>
      <div id="int-detail-how" style="font-size:.68rem;color:var(--t2);margin-top:10px;line-height:1.7"></div>
    </div>
    <div id="int-detail-data"></div>
  </div>
</div>

<!-- ══ SETTINGS (SHARED) ══ -->
<div class="view" id="view-settings">
  <div class="topbar"><div class="topbar-left"><h2 data-i18n="nav.settings">Paramètres</h2><div class="sub" data-i18n="settings.sub">Personnalise ton expérience ASCEND</div></div></div>
  <div class="card" style="margin-bottom:14px">
    <div class="card-title" data-i18n="settings.profile">Profil</div>
    <div class="grid-2" style="margin-bottom:0">
      <div class="inp-group"><div class="inp-lbl" data-i18n="settings.name">Ton prénom / blaze</div><div style="display:flex;gap:8px"><input class="inp" id="settings-name" data-i18n-placeholder="settings.namePlaceholder" placeholder="Ex: Gab, Shadow..."><button class="btn btn-primary btn-sm" onclick="saveSettingsName()" style="white-space:nowrap" data-i18n="settings.save">Sauvegarder</button></div></div>
      <div class="inp-group"><div class="inp-lbl" data-i18n="settings.goal">Objectif business</div><div style="display:flex;gap:8px"><input class="inp" id="settings-goal" type="number" placeholder="4000"><select class="inp" id="settings-goal-period" style="width:auto;flex-shrink:0"><option value="day" data-i18n="settings.perDay">/ jour</option><option value="month" data-i18n="settings.perMonth">/ mois</option></select><button class="btn btn-primary btn-sm" onclick="saveSettingsGoal()" style="white-space:nowrap">OK</button></div></div>
    </div>
  </div>
  <div class="card" style="margin-bottom:14px">
    <div class="card-title" data-i18n="settings.appearance">Apparence</div>
    <div class="grid-2" style="margin-bottom:0">
      <div class="inp-group"><div class="inp-lbl" data-i18n="settings.theme">Thème</div><div style="display:flex;gap:8px">
        <div class="theme-btn" id="theme-dark" onclick="setTheme('dark')"><div style="font-size:1.1rem;margin-bottom:3px"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10.5A8 8 0 119.5 2a6 6 0 108.5 8.5z"/></svg></div><div style="font-size:.72rem;font-weight:700" data-i18n="settings.dark">Sombre</div></div>
        <div class="theme-btn" id="theme-light" onclick="setTheme('light')"><div style="font-size:1.1rem;margin-bottom:3px"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="4"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.9 4.9l1.4 1.4M13.7 13.7l1.4 1.4M4.9 15.1l1.4-1.4M13.7 6.3l1.4-1.4"/></svg></div><div style="font-size:.72rem;font-weight:700" data-i18n="settings.light">Clair</div></div>
        <div class="theme-btn sel" id="theme-auto" onclick="setTheme('auto')"><div style="font-size:1.1rem;margin-bottom:3px"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 7.5A6 6 0 0116 7M4 4v4h4M15.5 12.5A6 6 0 014 13M20 16v-4h-4"/></svg></div><div style="font-size:.72rem;font-weight:700" data-i18n="settings.auto">Auto</div></div>
      </div></div>
      <div class="inp-group"><div class="inp-lbl" data-i18n="settings.accent">Couleur accent</div><div style="display:flex;gap:8px;flex-wrap:wrap">
        <div onclick="setAccentColor('#7c5cfc','#e040a8')" style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#7c5cfc,#e040a8);cursor:pointer;border:2px solid white" title="Violet"></div>
        <div onclick="setAccentColor('#00b4d8','#90e0ef')" style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#00b4d8,#90e0ef);cursor:pointer;border:2px solid transparent" title="Bleu"></div>
        <div onclick="setAccentColor('#06d6a0','#00e5a0')" style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#06d6a0,#00e5a0);cursor:pointer;border:2px solid transparent" title="Vert"></div>
        <div onclick="setAccentColor('#f72585','#b5179e')" style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#f72585,#b5179e);cursor:pointer;border:2px solid transparent" title="Rose"></div>
        <div onclick="setAccentColor('#ff6b35','#f5c842')" style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#ff6b35,#f5c842);cursor:pointer;border:2px solid transparent" title="Orange"></div>
      </div></div>
    </div>
  </div>
  <div class="card" style="margin-bottom:14px">
    <div class="card-title" data-i18n="settings.prefs">Préférences</div>
    <div class="grid-2" style="margin-bottom:0">
      <div class="inp-group"><div class="inp-lbl" data-i18n="settings.currency">Devise</div><select class="inp" id="settings-currency" onchange="saveCurrency()"><option value="€">€ Euro</option><option value="$">$ Dollar US</option><option value="£">£ Livre</option><option value="CHF">CHF Franc suisse</option><option value="MAD">MAD Dirham</option></select></div>
      <div class="inp-group"><div class="inp-lbl" data-i18n="settings.lang">Langue</div><select class="inp" id="settings-lang" onchange="saveLangAndApply()"><option value="fr">FR Français</option><option value="en">EN English</option></select></div>
    </div>
  </div>

  <div class="card" style="margin-bottom:14px">
    <div class="card-title" data-i18n="settings.notifs">Notifications</div>
    <div style="display:flex;flex-direction:column;gap:10px">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:11px;background:var(--s1);border-radius:var(--rs)">
        <div><div style="font-size:.86rem;font-weight:600" data-i18n="settings.notif.daily">Rappel quotidien habitudes</div><div style="font-size:.72rem;color:var(--t1)" data-i18n="settings.notif.daily.sub">Chaque soir</div></div>
        <div class="toggle" id="settings-notif-daily" onclick="toggleSettingsNotif('daily',this)"></div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:11px;background:var(--s1);border-radius:var(--rs)">
        <div><div style="font-size:.86rem;font-weight:600" data-i18n="settings.notif.weekly">Bilan hebdo</div><div style="font-size:.72rem;color:var(--t1)" data-i18n="settings.notif.weekly.sub">Chaque lundi à l'ouverture</div></div>
        <div class="toggle" id="settings-notif-weekly" onclick="toggleSettingsNotif('weekly',this)"></div>
      </div>
    </div>
  </div>
  <div class="card" style="margin-bottom:14px;border-color:rgba(240,71,111,.15)">
    <div class="card-title" data-i18n="settings.data">Données & Compte</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px">
      <button class="btn btn-ghost btn-sm" onclick="exportData()"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16v1a2 2 0 002 2h8a2 2 0 002-2v-1M13 7l-3-3-3 3M10 4v10"/></svg> Exporter</button>
      <button class="btn btn-ghost btn-sm" onclick="importDataTrigger()"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16v1a2 2 0 002 2h8a2 2 0 002-2v-1M7 11l3 3 3-3M10 14V4"/></svg> Importer</button>
      <input type="file" id="import-file-input" accept=".json" style="display:none" onchange="importData(event)">
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn btn-danger btn-sm" onclick="confirmResetBiz()" data-i18n="settings.resetBiz">Reset Business</button>
      <button class="btn btn-danger btn-sm" onclick="confirmResetHabits()" data-i18n="settings.resetHab">Reset Habitudes</button>
      <button class="btn btn-danger btn-sm" onclick="confirmResetAll()" data-i18n="settings.resetAll">Reset complet</button>
    </div>
  </div>
  <div style="text-align:center;padding:16px;font-size:.68rem;color:var(--t2)">ASCEND v5 · Unified Dashboard · Fait avec <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 17S3 12 3 7a4 4 0 017-3 4 4 0 017 3c0 5-7 10-7 10z"/></svg></div>
</div>

<!-- ══ HABITS: TODAY ══ -->
<div class="view" id="view-today">
  <div class="topbar">
    <div class="topbar-left"><div>
      <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.58rem;letter-spacing:3px;text-transform:uppercase;background:linear-gradient(135deg,#00c49a,var(--g));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:3px">ASCEND</div>
      <h2 id="today-title">Bonjour</h2><div class="sub" id="today-date"></div>
    </div></div>
    <div class="topbar-right" style="align-items:center">
      <div class="date-chip mono" id="clock-today">--:--</div>
      <!-- Streak badge Duolingo-style -->
      <div class="streak-badge-duo" id="streak-badge-duo" title="Jours consécutifs">
        <div class="streak-flame-wrap">
          <svg class="streak-flame-svg" viewBox="0 0 24 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- outer flame -->
            <path d="M12 2C12 2 6 8.5 4.5 13.5C3.2 17.8 4.5 21 7 23.5C7 23.5 6.5 19.5 9 18C9 18 8 22 10.5 24.5C11.5 25.5 13 26 13 26C13 26 12.5 23 14 21.5C15 20.5 16 19 16 19C16.5 21 16 23.5 15 25.5C17.5 24 19.5 21.5 19.5 18C19.5 14 17 10.5 12 2Z" fill="url(#flameOuter)"/>
            <!-- inner core -->
            <path d="M12 14C12 14 10 17 10 19.5C10 21.5 11 23 12 23.5C12 23.5 11.8 21.5 13 20.5C13.8 19.8 14.5 18.5 14 17C13.5 15.5 12 14 12 14Z" fill="url(#flameInner)" opacity="0.9"/>
            <defs>
              <linearGradient id="flameOuter" x1="12" y1="2" x2="12" y2="26" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#ff9500"/>
                <stop offset="55%" stop-color="#ff4500"/>
                <stop offset="100%" stop-color="#c0392b"/>
              </linearGradient>
              <linearGradient id="flameInner" x1="12" y1="14" x2="12" y2="24" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#ffe066"/>
                <stop offset="100%" stop-color="#ff9500"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="streak-badge-num">
          <span id="streak-count-duo">0</span>
          <span class="streak-badge-lbl">jours</span>
        </div>
      </div>
      <button class="btn btn-green btn-sm" onclick="openAddModal()" data-i18n="today.addHabit">+ Habitude</button>
    </div>
  </div>
  <div class="ring-block">
    <div class="ring-wrap">
      <svg class="progress-ring" width="130" height="130" viewBox="0 0 130 130">
        <circle cx="65" cy="65" r="54" fill="none" stroke="var(--s2)" stroke-width="10"/>
        <circle id="ring-circle" cx="65" cy="65" r="54" fill="none" stroke="url(#ringGrad)" stroke-width="10" stroke-linecap="round" stroke-dasharray="339.3" stroke-dashoffset="339.3" style="transition:stroke-dashoffset .7s cubic-bezier(.4,0,.2,1)"/>
        <defs><linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#00c49a"/><stop offset="100%" stop-color="var(--g)"/></linearGradient></defs>
      </svg>
      <div class="ring-label"><div class="ring-pct" id="ring-pct">0%</div><div class="ring-sub" data-i18n="today.complete">Complété</div></div>
    </div>
    <div class="ring-info">
      <div class="ring-msg" id="ring-msg">Lance-toi !</div>
      <div class="ring-submsg" id="ring-submsg">Commence par une petite habitude.</div>
      <div class="tag-row">
        <span class="tag tag-g">✓ <span id="done-count">0</span> <span data-i18n="today.done">faites</span></span>
        <span class="tag tag-p"><svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M5 2h10M5 18h10M6 2v5l4 3-4 3v5M14 2v5l-4 3 4 3v5"/></svg> <span id="remain-count">0</span> <span data-i18n="today.remaining">restantes</span></span>
        <span class="tag tag-gold"><svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2L4 11h7l-2 7 9-10h-7l2-8z"/></svg> +<span id="today-xp-total">0</span> XP</span>
      </div>
    </div>
  </div>
  <div class="habits-list" id="habits-list"></div>
  <div id="today-insight"></div>
</div>

<!-- ══ HABITS: FOCUS (NEW) ══ -->
<div class="view" id="view-focus">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.focus">Focus & Bien-être</h2><div class="sub" data-i18n="focus.sub">Méditation et chrono d'activités</div></div>
  </div>
  <!-- Tab bar -->
  <div class="focus-tab-bar">
    <button class="focus-tab-btn active" onclick="setFocusTab('meditation',this)">
      <svg viewBox="0 0 20 20"><circle cx="10" cy="10" r="7"/><path d="M10 7v3l2 2"/><path d="M6 2l1 2M14 2l-1 2"/></svg>
      <span data-i18n="focus.tab.meditation">Méditation</span>
    </button>
    <button class="focus-tab-btn" onclick="setFocusTab('chrono',this)">
      <svg viewBox="0 0 20 20"><circle cx="10" cy="11" r="7"/><path d="M10 8v3l2 2M10 4V2M7 2h6"/></svg>
      <span data-i18n="focus.tab.chrono">Chrono</span>
    </button>

  </div>

  <!-- ── MÉDITATION PANEL ── -->
  <div class="focus-panel" id="fp-meditation">
    <!-- Sound grid header -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <div style="font-family:'Syne',sans-serif;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--t1)">Sons ambiants</div>
      <button class="btn btn-ghost btn-sm" onclick="openSoundManager()" style="font-size:.7rem;gap:5px;display:flex;align-items:center">
        <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="10" cy="10" r="3"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.9 4.9l1.4 1.4M13.7 13.7l1.4 1.4M4.9 15.1l1.4-1.4M13.7 6.3l1.4-1.4"/></svg>
        Gérer sons
      </button>
    </div>
    <!-- Sound grid (dynamic) -->
    <div class="sound-grid" id="sound-grid-container"></div>
    <!-- Volume -->
    <div class="vol-row">
      <div class="vol-label" data-i18n="focus.volume">Volume</div>
      <input type="range" id="med-volume" min="0" max="100" value="70" oninput="setAmbientVolume(this.value)">
      <div class="vol-val" id="vol-val">70%</div>
    </div>
    <!-- Timer ring -->
    <div class="med-center">
      <div class="med-ring-wrap">
        <svg width="160" height="160" viewBox="0 0 160 160">
          <circle cx="80" cy="80" r="68" fill="none" stroke="var(--s2)" stroke-width="8"/>
          <circle id="med-ring-circle" cx="80" cy="80" r="68" fill="none" stroke="url(#medGrad)" stroke-width="8" stroke-linecap="round"
            stroke-dasharray="427.3" stroke-dashoffset="427.3"
            style="transition:stroke-dashoffset .5s linear;transform:rotate(-90deg);transform-origin:80px 80px"/>
          <defs><linearGradient id="medGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="var(--p)"/><stop offset="100%" stop-color="var(--g)"/></linearGradient></defs>
        </svg>
        <div class="med-ring-info">
          <div class="med-time" id="med-timer-display">00:00</div>
          <div class="med-phase" id="med-phase" data-i18n="focus.ready">Prêt</div>
        </div>
      </div>
      <div class="med-presets">
        <button class="med-preset sel" onclick="setMedDuration(5,this)">5 min</button>
        <button class="med-preset" onclick="setMedDuration(10,this)">10 min</button>
        <button class="med-preset" onclick="setMedDuration(15,this)">15 min</button>
        <button class="med-preset" onclick="setMedDuration(20,this)">20 min</button>
        <button class="med-preset" onclick="setMedDuration(30,this)">30 min</button>
      </div>
      <div class="med-controls">
        <button class="btn btn-ghost" id="med-btn-start" onclick="startMeditation()" data-i18n="focus.start">▶ Démarrer</button>
        <button class="btn btn-ghost" id="med-btn-pause" onclick="pauseMeditation()" style="display:none" data-i18n="focus.pause">⏸ Pause</button>
        <button class="btn btn-ghost" id="med-btn-stop" onclick="stopMeditation()" style="display:none" data-i18n="focus.stop">⏹ Arrêter</button>
      </div>
    </div>
    <!-- Today's meditation sessions -->
    <div class="card">
      <div class="card-title" data-i18n="focus.sessions">Sessions d'aujourd'hui</div>
      <div id="med-session-log"><div class="empty-state" data-i18n="focus.noSession">Aucune session aujourd'hui. Lance ta première méditation !</div></div>
    </div>
  </div>

  <!-- ── CHRONO PANEL ── -->
  <div class="focus-panel" id="fp-chrono" style="display:none">
    <div class="card" style="margin-bottom:14px">
      <div class="card-title" data-i18n="chrono.activity">Activité en cours</div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <div class="inp-lbl" style="margin-bottom:0" data-i18n="chrono.select">Sélectionne une activité</div>
        <button class="btn btn-ghost btn-sm" onclick="openChronoActivitiesModal()" style="display:flex;align-items:center;gap:5px;font-size:.7rem">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/></svg>
          Gérer
        </button>
      </div>
      <div class="activity-chips" id="chrono-activity-chips"></div>
      <div style="display:flex;gap:8px;margin-top:8px">
        <input class="inp" id="chrono-custom-act" data-i18n-placeholder="chrono.placeholder" placeholder="Ou tape une activité...">
        <button class="btn btn-ghost btn-sm" onclick="addAndSetChronoActivity()" style="white-space:nowrap">OK</button>
      </div>
    </div>
    <div class="card" style="text-align:center;padding:32px 20px;margin-bottom:14px">
      <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:2px;color:var(--t1);margin-bottom:4px;font-family:'Syne',sans-serif" id="chrono-act-label" data-i18n="chrono.noActivity">Aucune activité</div>
      <div class="chrono-display" id="chrono-display">00:00:00</div>
      <div class="chrono-controls">
        <button class="btn btn-green" id="chrono-btn-start" onclick="startChrono()" data-i18n="focus.start">▶ Démarrer</button>
        <button class="btn btn-ghost" id="chrono-btn-pause" onclick="pauseChrono()" style="display:none" data-i18n="focus.pause">⏸ Pause</button>
        <button class="btn btn-ghost btn-sm" id="chrono-btn-save" onclick="saveChrono()" style="display:none"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M3 3h11l3 3v11a1 1 0 01-1 1H4a1 1 0 01-1-1V3z"/><path d="M7 3v5h6V3M7 13h6"/></svg> Sauvegarder</button>
        <button class="btn btn-danger btn-sm" id="chrono-btn-reset" onclick="resetChrono()" style="display:none" data-i18n="chrono.reset">✕ Reset</button>
      </div>
    </div>
    <div class="grid-2">
      <div class="card">
        <div class="card-title" data-i18n="focus.sessions">Sessions d'aujourd'hui</div>
        <div id="chrono-today-log"><div class="empty-state" data-i18n="chrono.noSession">Aucune session enregistrée.</div></div>
      </div>
      <div class="card">
        <div class="card-title" data-i18n="chrono.stats7j">Temps par activité (7j)</div>
        <div id="chrono-stats"></div>
      </div>
    </div>
  </div>

</div>

<!-- ══ HABITS: STATS ══ -->
<div class="view" id="view-stats">
  <div class="topbar">
    <div class="topbar-left"><h2 data-i18n="view.stats">Statistiques</h2></div>
    <div class="topbar-right">
      <button class="btn btn-ghost btn-sm" id="bilan-btn" onclick="showBilanHistory()">Bilans</button>
      <div class="chart-tabs">
        <button class="chart-tab active" id="tab-week" onclick="setStatRange('week',this)">7j</button>
        <button class="chart-tab" id="tab-month" onclick="setStatRange('month',this)">30j</button>
      </div>
    </div>
  </div>
  <div class="weekly-notif-bar" id="weekly-notif-banner" style="display:none" onclick="showRecap()">
    <div><div class="wn-text"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M7 3h6a1 1 0 011 1v1H6V4a1 1 0 011-1z"/><rect x="4" y="5" width="12" height="12" rx="1"/><path d="M8 9h4M8 12h4"/></svg> Ton bilan de la semaine est prêt !</div><div class="wn-sub">C'est lundi — prends 2 min pour analyser ta semaine.</div></div>
    <button class="wn-cta" onclick="event.stopPropagation();showRecap()">Voir →</button>
  </div>
  <div class="stats-grid" id="stats-kpis"></div>
  <div class="chart-grid">
    <div class="chart-card"><div class="chart-title">Complétion quotidienne</div><div style="position:relative;height:180px"><canvas id="chart-daily"></canvas></div></div>
    <div class="chart-card"><div class="chart-title">Progression XP</div><div style="position:relative;height:180px"><canvas id="chart-xp"></canvas></div></div>
  </div>
  <div class="chart-card" style="margin-bottom:14px"><div class="chart-title">Par habitude — 7 jours</div><div id="mini-bars"></div></div>
  <div id="insight-cards"></div>
  <div class="insight-card goal-card" id="next-goal">
    <div class="i-head"><span class="i-icon"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="7"/><circle cx="10" cy="10" r="3"/><path d="M10 3v2M10 15v2M3 10h2M15 10h2"/></svg></span><div><div class="i-title">Objectif semaine prochaine</div></div></div>
    <div class="i-body" id="next-goal-text">Complète au moins 5 habitudes/jour.</div>
  </div>
</div>

<!-- ══ HABITS: OBJECTIVES ══ -->
<div class="view" id="view-objectives">
  <div class="topbar"><div class="topbar-left"><h2 data-i18n="view.objectives">Objectifs & Analyse</h2></div></div>
  <div id="objectives-content"></div>
</div>

<!-- ══ HABITS: REWARDS ══ -->
<div class="view" id="view-rewards">
  <div class="topbar"><div class="topbar-left"><h2 data-i18n="view.rewards">Récompenses</h2></div></div>
  <div class="stats-grid" id="rewards-stats"></div>
  <div class="section-title">Badges</div>
  <div class="rewards-grid" id="rewards-grid"></div>
</div>

<!-- ══ HABITS: MANAGE ══ -->
<div class="view" id="view-manage">
  <div class="topbar"><div class="topbar-left"><h2 data-i18n="view.manage">Gérer les habitudes</h2></div></div>
  <div class="manage-section">
    <div class="section-title">Mes habitudes</div>
    <div id="manage-list"></div>
    <button class="btn btn-green" onclick="openAddModal()" style="width:100%;margin-top:10px">+ Nouvelle habitude</button>
  </div>
  <div class="manage-section">
    <div class="section-title">Ajout rapide</div>
    <div style="display:flex;gap:8px;margin-bottom:10px">
      <input class="inp" id="quick-name" placeholder="Nom de l'habitude...">
      <button class="btn btn-green btn-sm" onclick="quickAddHabit()" style="white-space:nowrap">Ajouter</button>
    </div>
    <div class="color-picker-row" id="color-picker"></div>
  </div>
  <div class="manage-section">
    <div class="section-title">Notifications</div>
    <div class="notif-card">
      <div class="notif-row"><div><div class="notif-label">Rappel quotidien</div><div class="notif-sub">Rappel pour compléter tes habitudes</div></div><div class="toggle on" id="tog-daily" onclick="toggleNotif('daily',this)"></div></div>
      <div class="notif-row"><div><div class="notif-label">Récap lundi</div><div class="notif-sub">Bilan semaine à l'ouverture</div></div><div class="toggle on" id="tog-weekly" onclick="toggleNotif('weekly',this)"></div></div>
    </div>
  </div>
  <div class="manage-section" style="border-color:rgba(240,71,111,.15)">
    <div class="section-title">Zone de danger</div>
    <button class="btn btn-danger" style="width:100%" onclick="confirmReset()">Réinitialiser les données habitudes</button>
  </div>
</div>


<!-- ══ HABITS: CALENDAR ══ -->
<div class="view" id="view-calendar">
  <!-- Google Calendar-style header -->
  <div class="gcal-header">
    <button class="gcal-burger" onclick="toggleCalDrawer()" aria-label="Vues">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="2" y1="5" x2="18" y2="5"/><line x1="2" y1="10" x2="18" y2="10"/><line x1="2" y1="15" x2="18" y2="15"/></svg>
    </button>
    <div class="gcal-title-block">
      <div class="gcal-period" id="cal-period-label">Mars 2026</div>
      <div class="gcal-sub" id="cal-nav-label">Semaine</div>
    </div>
    <button class="gcal-today-pill" onclick="calNavToday()">Auj.</button>
  </div>
  <!-- View drawer (burger menu) -->
  <div class="gcal-drawer-overlay" id="calDrawerOverlay" onclick="closeCalDrawer()"></div>
  <div class="gcal-drawer" id="calDrawer">
    <div class="gcal-drawer-title">Vue</div>
    <button class="gcal-drawer-item" data-view="schedule" onclick="calSetView('schedule');closeCalDrawer()">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><line x1="3" y1="5" x2="17" y2="5"/><line x1="3" y1="9" x2="12" y2="9"/><line x1="3" y1="13" x2="15" y2="13"/><line x1="3" y1="17" x2="10" y2="17"/></svg>
      Planning
    </button>
    <button class="gcal-drawer-item" data-view="day" onclick="calSetView('day');closeCalDrawer()">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><rect x="3" y="3" width="14" height="14" rx="2"/><line x1="10" y1="3" x2="10" y2="17"/></svg>
      Jour
    </button>
    <button class="gcal-drawer-item" data-view="3day" onclick="calSetView('3day');closeCalDrawer()">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><rect x="1" y="3" width="5" height="14" rx="1"/><rect x="8" y="3" width="5" height="14" rx="1"/><rect x="15" y="3" width="4" height="14" rx="1"/></svg>
      3 jours
    </button>
    <button class="gcal-drawer-item active" id="gcal-item-week" data-view="week" onclick="calSetView('week');closeCalDrawer()">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><rect x="1" y="3" width="2" height="14" rx="1"/><rect x="5" y="3" width="2" height="14" rx="1"/><rect x="9" y="3" width="2" height="14" rx="1"/><rect x="13" y="3" width="2" height="14" rx="1"/><rect x="17" y="3" width="2" height="14" rx="1"/></svg>
      Semaine
    </button>
    <button class="gcal-drawer-item" data-view="month" onclick="calSetView('month');closeCalDrawer()">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><rect x="2" y="3" width="16" height="14" rx="2"/><line x1="2" y1="8" x2="18" y2="8"/><line x1="7" y1="3" x2="7" y2="17"/><line x1="13" y1="3" x2="13" y2="17"/></svg>
      Mois
    </button>
  </div>

  <!-- ══ MONTH VIEW ══ -->
  <div id="cal-month-view" style="display:none">
    <div class="card" style="margin-bottom:14px">
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:6px" id="cal-day-headers"></div>
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px" id="cal-grid"></div>
    </div>
    <div class="card" style="margin-bottom:14px">
      <div class="card-title" id="cal-selected-label">Sélectionne un jour</div>
      <div id="cal-day-events"><div class="empty-state">Clique sur un jour pour voir ses événements.</div></div>
    </div>
    <div class="card">
      <div class="card-title">Événements à venir</div>
      <div id="cal-upcoming"></div>
    </div>
  </div>

  <!-- ══ WEEK / DAY / 3DAY VIEW ══ -->
  <div id="cal-week-view">
    <div class="wcal-outer">
      <div class="wcal-header">
        <div class="wcal-time-gutter"></div>
        <div class="wcal-days-header" id="wcal-days-header"></div>
      </div>
      <div class="wcal-body" id="wcal-body">
        <div class="wcal-time-col" id="wcal-time-col"></div>
        <div class="wcal-days-grid" id="wcal-days-grid"></div>
      </div>
    </div>
  </div>

  <!-- ══ SCHEDULE / PLANNING VIEW ══ -->
  <div id="cal-schedule-view" style="display:none;overflow-y:auto;flex:1"></div>
</div>

<!-- Modal Calendrier -->
<div class="modal-bg" id="modal-cal-event"><div class="modal-box" style="max-width:480px">
  <div class="modal-header">
    <div class="modal-title" id="cal-modal-title">+ Événement</div>
    <button class="modal-close" onclick="closeModal('modal-cal-event')">✕</button>
  </div>
  <div class="inp-group"><div class="inp-lbl">Titre</div><input class="inp" id="cal-ev-title" placeholder="Ex: Muscu, Cours, Réunion..."></div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
    <div class="inp-group"><div class="inp-lbl">Début</div><input class="inp" type="time" id="cal-ev-start" value="09:00"></div>
    <div class="inp-group"><div class="inp-lbl">Fin</div><input class="inp" type="time" id="cal-ev-end" value="10:00"></div>
  </div>
  <div class="inp-group"><div class="inp-lbl">Description</div><textarea class="inp" id="cal-ev-desc" rows="2" placeholder="Notes..."></textarea></div>

  <!-- Récurrence — UI custom style Google Calendar -->
  <!-- Champ caché utilisé par saveCalEvent() -->
  <input type="hidden" id="cal-ev-recur" value="once">

  <div class="inp-group" id="cal-recur-ui">
    <div class="inp-lbl">Répétition</div>

    <!-- Chip principal : Une fois / Chaque jour / Chaque semaine / Perso -->
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px" id="recur-freq-chips">
      <button type="button" class="recur-chip active" data-freq="once"    onclick="calSetFreq('once')">Une fois</button>
      <button type="button" class="recur-chip"        data-freq="daily"   onclick="calSetFreq('daily')">Chaque jour</button>
      <button type="button" class="recur-chip"        data-freq="weekly"  onclick="calSetFreq('weekly')">Chaque semaine</button>
      <button type="button" class="recur-chip"        data-freq="custom"  onclick="calSetFreq('custom')">Perso</button>
    </div>

    <!-- Sélecteur de jours (visible uniquement en mode Perso) -->
    <div id="recur-days-row" style="display:none;margin-bottom:10px">
      <div style="font-size:.68rem;color:var(--t1);margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:.8px">Répéter le</div>
      <div style="display:flex;gap:6px">
        <button type="button" class="recur-day-btn" data-day="mon" onclick="calToggleDay('mon')">L</button>
        <button type="button" class="recur-day-btn" data-day="tue" onclick="calToggleDay('tue')">M</button>
        <button type="button" class="recur-day-btn" data-day="wed" onclick="calToggleDay('wed')">M</button>
        <button type="button" class="recur-day-btn" data-day="thu" onclick="calToggleDay('thu')">J</button>
        <button type="button" class="recur-day-btn" data-day="fri" onclick="calToggleDay('fri')">V</button>
        <button type="button" class="recur-day-btn" data-day="sat" onclick="calToggleDay('sat')">S</button>
        <button type="button" class="recur-day-btn" data-day="sun" onclick="calToggleDay('sun')">D</button>
      </div>
    </div>

    <!-- Se termine (visible si récurrent) -->
    <div id="recur-end-row" style="display:none">
      <div style="font-size:.68rem;color:var(--t1);margin-bottom:8px;font-weight:600;text-transform:uppercase;letter-spacing:.8px">Se termine</div>
      <label style="display:flex;align-items:center;gap:10px;padding:8px 0;cursor:pointer;border-bottom:1px solid var(--b0)">
        <input type="radio" name="recur-end" value="never" id="recur-end-never" checked style="accent-color:var(--p)">
        <span style="font-size:.88rem">Jamais</span>
      </label>
      <label style="display:flex;align-items:center;gap:10px;padding:8px 0;cursor:pointer;border-bottom:1px solid var(--b0)">
        <input type="radio" name="recur-end" value="date"  id="recur-end-date"        style="accent-color:var(--p)">
        <span style="font-size:.88rem;flex-shrink:0">Le</span>
        <input class="inp" type="date" id="recur-end-date-val" style="flex:1;padding:5px 10px;font-size:.82rem" onclick="document.getElementById('recur-end-date').checked=true">
      </label>
      <label style="display:flex;align-items:center;gap:10px;padding:8px 0;cursor:pointer">
        <input type="radio" name="recur-end" value="count" id="recur-end-count"       style="accent-color:var(--p)">
        <span style="font-size:.88rem;flex-shrink:0">Après</span>
        <input class="inp" type="number" id="recur-end-count-val" value="4" min="1" max="365" style="width:64px;padding:5px 10px;font-size:.82rem;text-align:center" onclick="document.getElementById('recur-end-count').checked=true">
        <span style="font-size:.88rem;color:var(--t1)">occurrences</span>
      </label>
    </div>
  </div>

  <!-- Date (only shown for non-recurring) -->
  <div class="inp-group" id="cal-date-row">
    <div class="inp-lbl">Date</div>
    <input class="inp" type="date" id="cal-ev-date">
  </div>

  <!-- Couleur -->
  <div class="inp-group"><div class="inp-lbl">Couleur</div>
    <div style="display:flex;gap:8px;margin-top:4px">
      <div class="color-dot sel" id="cal-col-p" style="background:#7c5cfc" onclick="calSelectColor('#7c5cfc','cal-col-p')"></div>
      <div class="color-dot" id="cal-col-g" style="background:#00e5a0" onclick="calSelectColor('#00e5a0','cal-col-g')"></div>
      <div class="color-dot" id="cal-col-b" style="background:#38bdf8" onclick="calSelectColor('#38bdf8','cal-col-b')"></div>
      <div class="color-dot" id="cal-col-r" style="background:#f0476f" onclick="calSelectColor('#f0476f','cal-col-r')"></div>
      <div class="color-dot" id="cal-col-y" style="background:#f5c842" onclick="calSelectColor('#f5c842','cal-col-y')"></div>
      <div class="color-dot" id="cal-col-pk" style="background:#e040a8" onclick="calSelectColor('#e040a8','cal-col-pk')"></div>
    </div>
  </div>
  <div style="display:flex;gap:8px;margin-top:4px">
    <button class="btn btn-primary" style="flex:1" onclick="saveCalEvent()">Enregistrer</button>
    <button class="btn btn-danger" id="cal-del-btn" style="display:none" onclick="delEditingCalEvent()">Supprimer</button>
  </div>
</div></div>

</main>
</div>

<!-- ══════════ SOUND MANAGER MODAL ══════════ -->
<div class="modal-bg" id="modal-sound-manager"><div class="modal-box" style="max-width:540px">
  <div class="modal-header">
    <div class="modal-title"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg> Gérer les sons</div>
    <button class="modal-close" onclick="closeModal('modal-sound-manager')">✕</button>
  </div>
  <div style="font-size:.76rem;color:var(--t1);margin-bottom:16px">Ajoute ou supprime des sons ambiants. Les sons intégrés peuvent être masqués.</div>

  <!-- ── Son de fin ── -->
  <div style="background:var(--s1);border:1px solid var(--b1);border-radius:var(--r);padding:14px;margin-bottom:16px">
    <div style="font-family:'Syne',sans-serif;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--t1);margin-bottom:6px">🔔 Son de fin de session</div>
    <div style="font-size:.75rem;color:var(--t1);margin-bottom:10px">Joué automatiquement à la fin d'une méditation ou d'un chrono.</div>
    <!-- Sons custom de fin (liste persistante) -->
    <div id="end-bell-custom-list" style="margin-bottom:12px"></div>
    <!-- Ajouter un son de fin -->
    <div style="border-top:1px solid var(--b0);padding-top:12px">
      <div style="font-size:.72rem;font-weight:700;color:var(--t1);margin-bottom:8px">+ Ajouter un son de fin</div>
      <div style="display:grid;grid-template-columns:70px 1fr;gap:8px;margin-bottom:8px">
        <div><div style="font-size:.6rem;color:var(--t2);margin-bottom:4px">Emoji</div>
          <input class="inp" id="bell-add-emoji" placeholder="🔔" maxlength="4" style="text-align:center;font-size:1.2rem"></div>
        <div><div style="font-size:.6rem;color:var(--t2);margin-bottom:4px">Nom</div>
          <input class="inp" id="bell-add-name" placeholder="Ex: Cloche zen"></div>
      </div>
      <div style="display:flex;gap:6px;margin-bottom:8px">
        <button id="bell-tab-link" onclick="switchBellAddTab('link')" style="flex:1;padding:7px;border-radius:8px;border:1px solid var(--p);background:var(--pg);color:var(--p);font-size:.72rem;font-weight:700;cursor:pointer">🔗 Lien</button>
        <button id="bell-tab-file" onclick="switchBellAddTab('file')" style="flex:1;padding:7px;border-radius:8px;border:1px solid var(--b1);background:transparent;color:var(--t1);font-size:.72rem;font-weight:700;cursor:pointer">📁 Fichier</button>
      </div>
      <div id="bell-panel-link">
        <input class="inp" id="bell-add-url" placeholder="YouTube, Generative.fm, SoundCloud, MP3 direct..." style="margin-bottom:8px">
      </div>
      <div id="bell-panel-file" style="display:none">
        <input type="file" class="inp" id="bell-add-file" accept="audio/*" style="padding:8px;cursor:pointer;margin-bottom:8px">
      </div>
      <button class="btn btn-primary" style="width:100%" onclick="addCustomEndBellEntry()">Ajouter ce son de fin</button>
    </div>
    <div id="custom-bell-status" style="display:none"></div>
  </div>
  <div id="sound-manager-list" style="margin-bottom:16px;max-height:260px;overflow-y:auto;padding-right:4px"></div>
  <!-- Add custom sound -->
  <div style="border-top:1px solid var(--b0);padding-top:14px">
    <div style="font-family:'Syne',sans-serif;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--t1);margin-bottom:10px">+ Ajouter un son</div>
    <div style="display:grid;grid-template-columns:80px 1fr;gap:8px;margin-bottom:8px">
      <div class="inp-group" style="margin-bottom:0">
        <div class="inp-lbl">Emoji</div>
        <input class="inp" id="new-sound-emoji" placeholder="🎶" maxlength="4" style="text-align:center;font-size:1.2rem">
      </div>
      <div class="inp-group" style="margin-bottom:0">
        <div class="inp-lbl">Nom</div>
        <input class="inp" id="new-sound-name" placeholder="Ex: Vent, Cosmos...">
      </div>
    </div>
    <div class="inp-group" style="margin-bottom:8px">
      <div class="inp-lbl">Description courte</div>
      <input class="inp" id="new-sound-desc" placeholder="Ex: Ambiance douce">
    </div>
    <!-- Source type tabs -->
    <div style="margin-bottom:10px">
      <div style="font-size:.72rem;color:var(--t1);margin-bottom:6px;font-weight:600">Source audio</div>
      <div style="display:flex;gap:6px;margin-bottom:10px">
        <button id="src-tab-yt"    onclick="switchSrcTab('yt')"    style="flex:1;padding:7px;border-radius:8px;border:1px solid var(--p);background:var(--pg);color:var(--p);font-size:.72rem;font-weight:700;cursor:pointer">🔗 Lien (tout site)</button>
        <button id="src-tab-file"  onclick="switchSrcTab('file')"  style="flex:1;padding:7px;border-radius:8px;border:1px solid var(--b1);background:transparent;color:var(--t1);font-size:.72rem;font-weight:700;cursor:pointer"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M2 6a1 1 0 011-1h4l2 2h8a1 1 0 011 1v7a1 1 0 01-1 1H3a1 1 0 01-1-1V6z"/></svg> Fichier</button>
      </div>
      <!-- Lien (YouTube, Generative FM, etc.) -->
      <div id="src-panel-yt">
        <div class="inp-group" style="margin-bottom:0">
          <div class="inp-lbl">URL du son</div>
          <input class="inp" id="new-sound-yturl" placeholder="YouTube, Generative.fm, SoundCloud, MP3 direct...">
        </div>
        <div style="font-size:.68rem;color:var(--t1);margin-top:5px">Fonctionne avec YouTube, Generative.fm, SoundCloud, Spotify, liens MP3 directs, et tout autre lien audio ou page web.</div>
      </div>
      <!-- Fichier local -->
      <div id="src-panel-file" style="display:none">
        <div class="inp-group" style="margin-bottom:0">
          <div class="inp-lbl">Fichier audio (mp3, wav, ogg…)</div>
          <input type="file" class="inp" id="new-sound-file" accept="audio/*" style="padding:8px;cursor:pointer">
        </div>
        <div style="font-size:.68rem;color:var(--t1);margin-top:5px">Le fichier sera stocké localement dans le navigateur.</div>
      </div>
    </div>
    <button class="btn btn-primary" style="width:100%" onclick="addCustomSound()">Ajouter ce son</button>
  </div>
</div></div>

<!-- ══════════ MODALS ══════════ -->
<!-- Transaction -->
<div class="modal-bg" id="modal-add-transaction"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Transaction</div><button class="modal-close" onclick="closeModal('modal-add-transaction')">✕</button></div>
  <div class="inp-group"><div class="inp-lbl">Type</div><select class="inp" id="t-type"><option value="revenue">Revenu <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><polyline points="3,14 7,9 11,12 17,5"/><polyline points="13,5 17,5 17,9"/></svg></option><option value="expense">Dépense <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><polyline points="3,6 7,11 11,8 17,15"/><polyline points="13,15 17,15 17,11"/></svg></option></select></div>
  <div class="inp-group"><div class="inp-lbl">Description</div><input class="inp" id="t-desc" placeholder="Ex: Vente produit X"></div>
  <div class="inp-group"><div class="inp-lbl">Montant (€)</div><input class="inp" type="number" id="t-amount" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-lbl">Catégorie</div><select class="inp" id="t-cat"><option>Ventes</option><option>Publicité</option><option>Abonnements</option><option>Fournisseur</option><option>Autre</option></select></div>
  <div class="inp-group"><div class="inp-lbl">Date</div><input class="inp" type="date" id="t-date"></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addTransaction()">Ajouter</button>
</div></div>

<!-- Produit -->
<div class="modal-bg" id="modal-add-product"><div class="modal-box" style="max-width:560px">
  <div class="modal-header"><div class="modal-title" id="modal-product-title">+ Produit</div><button class="modal-close" onclick="closeModal('modal-add-product')">✕</button></div>
  <div class="inp-group"><div class="inp-lbl">Nom du produit</div><input class="inp" id="p-name" placeholder="Ex: Collier LED chat"></div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,200px),1fr));gap:10px">
    <div class="inp-group"><div class="inp-lbl">Statut</div><select class="inp" id="p-status"><option value="testing"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M7 2v8l-4 7h14l-4-7V2"/><path d="M7 2h6M7 12h6"/></svg> En test</option><option value="scaling"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 2C10 2 5 6 5 12l5 6 5-6c0-6-5-10-5-10z"/><circle cx="10" cy="10" r="2"/><path d="M7 15l-3 3M13 15l3 3"/></svg> Scaling</option><option value="paused">⏸ Pausé</option><option value="dead"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3a6 6 0 016 6c0 2-1 4-3 5v2H7v-2c-2-1-3-3-3-5a6 6 0 016-6z"/><path d="M7 16h6M8 12v2M12 12v2"/></svg> Mort</option></select></div>
    <div class="inp-group"><div class="inp-lbl">Budget pub/jour (€)</div><input class="inp" type="number" id="p-adbudget" placeholder="10" min="0" step="0.01"></div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,160px),1fr));gap:10px">
    <div class="inp-group"><div class="inp-lbl">Prix vente (€)</div><input class="inp" type="number" id="p-price" placeholder="29.99" min="0" step="0.01" oninput="calcProductMetrics()"></div>
    <div class="inp-group"><div class="inp-lbl">Coût produit (€)</div><input class="inp" type="number" id="p-cost" placeholder="5.00" min="0" step="0.01" oninput="calcProductMetrics()"></div>
    <div class="inp-group"><div class="inp-lbl">Revenus générés (€)</div><input class="inp" type="number" id="p-revenue" placeholder="0" min="0" step="0.01" oninput="calcProductMetrics()"></div>
  </div>
  <div id="p-metrics-preview" style="display:none;background:var(--s1);border:1px solid var(--b1);border-radius:var(--rs);padding:12px;margin-bottom:12px">
    <div style="font-size:.65rem;text-transform:uppercase;letter-spacing:1px;color:var(--t1);margin-bottom:8px;font-weight:700">Calculé automatiquement</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;text-align:center">
      <div><div id="p-calc-margin" style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:var(--gold)">—</div><div style="font-size:.65rem;color:var(--t1)">Marge brute</div></div>
      <div><div id="p-calc-profit" style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:var(--g)">—</div><div style="font-size:.65rem;color:var(--t1)">Profit / vente</div></div>
      <div><div id="p-calc-roi" style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:var(--p)">—</div><div style="font-size:.65rem;color:var(--t1)">ROI</div></div>
    </div>
  </div>
  <div class="inp-group"><div class="inp-lbl">URL produit</div><input class="inp" id="p-url" placeholder="https://..."></div>
  <div class="inp-group"><div class="inp-lbl">Notes</div><textarea class="inp" id="p-notes" rows="3" placeholder="Fournisseur, angles testés..." style="resize:vertical"></textarea></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveProduct()">Enregistrer</button>
</div></div>

<!-- Campagne -->
<div class="modal-bg" id="modal-add-campaign"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Campagne</div><button class="modal-close" onclick="closeModal('modal-add-campaign')">✕</button></div>
  <div class="inp-group"><div class="inp-lbl">Nom</div><input class="inp" id="c-name" placeholder="Ex: LED Cat Collar - FR"></div>
  <div class="inp-group"><div class="inp-lbl">Plateforme</div><select class="inp" id="c-platform"><option>Meta Ads</option><option>TikTok Ads</option><option>Google Ads</option><option>Pinterest Ads</option></select></div>
  <div class="inp-group"><div class="inp-lbl">Budget/jour (€)</div><input class="inp" type="number" id="c-budget" placeholder="10" min="0"></div>
  <div class="inp-group"><div class="inp-lbl">Revenus générés (€)</div><input class="inp" type="number" id="c-revenue" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-lbl">CTR (%)</div><input class="inp" type="number" id="c-ctr" placeholder="0.00" step="0.01" min="0"></div>
  <div class="inp-group"><div class="inp-lbl">Statut</div><select class="inp" id="c-status"><option value="active">Active</option><option value="paused">Pausée</option><option value="dead">Coupée</option></select></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addCampaign()">Ajouter</button>
</div></div>

<!-- Métriques -->
<div class="modal-bg" id="modal-add-metric"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Métriques du jour</div><button class="modal-close" onclick="closeModal('modal-add-metric')">✕</button></div>
  <div class="inp-group"><div class="inp-lbl">Date</div><input class="inp" type="date" id="m-date"></div>
  <div class="inp-group"><div class="inp-lbl">Visiteurs</div><input class="inp" type="number" id="m-visitors" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-lbl">Commandes</div><input class="inp" type="number" id="m-orders" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-lbl">Revenus (€)</div><input class="inp" type="number" id="m-revenue" placeholder="0" min="0" step="0.01"></div>
  <div class="inp-group"><div class="inp-lbl">Dépenses pub (€)</div><input class="inp" type="number" id="m-adspend" placeholder="0" min="0" step="0.01"></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveMetric()">Enregistrer</button>
</div></div>

<!-- Tâche -->
<div class="modal-bg" id="modal-add-task"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Tâche</div><button class="modal-close" onclick="closeModal('modal-add-task')">✕</button></div>
  <div class="inp-group"><div class="inp-lbl">Titre</div><input class="inp" id="task-title" placeholder="Ex: Créer nouvelle créa TikTok"></div>
  <div class="inp-group"><div class="inp-lbl">Priorité</div><select class="inp" id="task-priority"><option value="high"><svg width="8" height="8" viewBox="0 0 8 8" fill="var(--red)" style="display:inline-block;vertical-align:middle;border-radius:50%"><circle cx="4" cy="4" r="4"/></svg> Haute</option><option value="med" selected><svg width="8" height="8" viewBox="0 0 8 8" fill="var(--gold)" style="display:inline-block;vertical-align:middle;border-radius:50%"><circle cx="4" cy="4" r="4"/></svg> Moyenne</option><option value="low"><svg width="8" height="8" viewBox="0 0 8 8" fill="var(--g)" style="display:inline-block;vertical-align:middle;border-radius:50%"><circle cx="4" cy="4" r="4"/></svg> Faible</option></select></div>
  <div class="inp-group"><div class="inp-lbl">Catégorie</div><select class="inp" id="task-cat"><option>Business</option><option>Publicité</option><option>Produit</option><option>Finance</option><option>Autre</option></select></div>
  <div class="inp-group"><div class="inp-lbl">Deadline</div><input class="inp" type="date" id="task-deadline"></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addTask()">Ajouter</button>
</div></div>

<!-- Templates -->
<div class="modal-bg" id="modal-template"><div class="modal-box"><div class="modal-header"><div class="modal-title">Templates</div><button class="modal-close" onclick="closeModal('modal-template')">✕</button></div><div id="templates-list"></div></div></div>

<!-- Objectif -->
<div class="modal-bg" id="modal-add-goal"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Objectif</div><button class="modal-close" onclick="closeModal('modal-add-goal')">✕</button></div>
  <div class="inp-group"><div class="inp-lbl">Objectif</div><input class="inp" id="goal-title" placeholder="Ex: Atteindre 1000€/jour"></div>
  <div class="inp-group"><div class="inp-lbl">Horizon</div><select class="inp" id="goal-horizon"><option>Semaine</option><option>Mois</option><option>Trimestre</option><option>Année</option></select></div>
  <div class="inp-group"><div class="inp-lbl">Deadline</div><input class="inp" type="date" id="goal-deadline"></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addGoal()">Ajouter</button>
</div></div>

<!-- Lien avec gestion catégories -->
<div class="modal-bg" id="modal-add-link"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Lien</div><button class="modal-close" onclick="closeModal('modal-add-link')">✕</button></div>
  <div class="inp-group"><div class="inp-lbl">Nom</div><input class="inp" id="l-name" placeholder="Ex: Shopify Admin"></div>
  <div class="inp-group"><div class="inp-lbl">URL</div><input class="inp" id="l-url" placeholder="https://..."></div>
  <div class="inp-group"><div class="inp-lbl">Icône (emoji)</div><input class="inp" id="l-icon" placeholder="🔗" style="max-width:80px"></div>
  <div class="inp-group"><div class="inp-lbl">Catégorie</div>
    <select class="inp" id="l-cat"></select>
    <div style="display:flex;gap:8px;margin-top:8px">
      <input class="inp" id="l-new-cat" placeholder="Nouvelle catégorie...">
      <button class="btn btn-ghost btn-sm" onclick="addLinkCategory()" style="white-space:nowrap">+ Ajouter</button>
    </div>
  </div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addLink()">Ajouter</button>
</div></div>

<!-- Gérer catégories Hub -->
<div class="modal-bg" id="modal-manage-cats"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">Gérer les catégories</div><button class="modal-close" onclick="closeModal('modal-manage-cats')">✕</button></div>
  <div id="cats-list"></div>
  <div style="display:flex;gap:8px;margin-top:14px">
    <input class="inp" id="new-cat-input" placeholder="Nouvelle catégorie...">
    <button class="btn btn-primary btn-sm" onclick="addCatFromModal()">+ Créer</button>
  </div>
</div></div>

<!-- Ressource -->
<div class="modal-bg" id="modal-add-resource"><div class="modal-box">
  <div class="modal-header"><div class="modal-title" id="modal-resource-title">+ Nouvelle source</div><button class="modal-close" onclick="closeModal('modal-add-resource')">✕</button></div>
  <input type="hidden" id="r-edit-id">
  <div class="inp-group"><div class="inp-lbl">Titre *</div><input class="inp" id="r-title" placeholder="Ex: Formation Dropshipping"></div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,200px),1fr));gap:10px">
    <div class="inp-group"><div class="inp-lbl">Type</div><select class="inp" id="r-type"></select></div>
    <div class="inp-group"><div class="inp-lbl">Durée totale</div><div class="inp-row"><input class="inp" type="number" id="r-duration" placeholder="80" min="0" style="width:70px"><select class="inp" id="r-duration-unit" style="flex:1"><option value="h">h</option><option value="min">min</option><option value="pages">pages</option><option value="épisodes">épisodes</option><option value="chapitres">chapitres</option></select></div></div>
  </div>
  <div class="inp-group"><div class="inp-lbl">URL / Lien</div><input class="inp" id="r-url" placeholder="https://..."></div>
  <div class="inp-group"><div class="inp-lbl">Description courte</div><input class="inp" id="r-desc" placeholder="Ex: 80h de contenu · Accès privé"></div>
  <div class="inp-group"><div class="inp-lbl">Notes</div><textarea class="inp" id="r-notes" rows="3" placeholder="Ce que tu veux retenir..."></textarea></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveResource()">Enregistrer</button>
</div></div>

<!-- Gérer les types -->
<div class="modal-bg" id="modal-manage-types"><div class="modal-box">
  <div class="modal-header"><div class="modal-title"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><circle cx="10" cy="10" r="2.5"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.9 4.9l1.4 1.4M13.7 13.7l1.4 1.4M4.9 15.1l1.4-1.4M13.7 6.3l1.4-1.4"/></svg> Gérer les types</div><button class="modal-close" onclick="closeModal('modal-manage-types')">✕</button></div>
  <div id="types-list" style="margin-bottom:14px"></div>
  <div class="inp-row">
    <input class="inp" id="new-type-name" placeholder="Nom du type (ex: Podcast)">
    <input class="inp" id="new-type-emoji" placeholder="🎙" style="width:56px">
    <button class="btn btn-primary btn-sm" onclick="addCustomType()" style="white-space:nowrap">+ Ajouter</button>
  </div>
</div></div>

<!-- API Key -->
<div class="modal-bg" id="modal-api-key"><div class="modal-box">
  <div class="modal-header"><div class="modal-title"><svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="11.5" r="3.5"/><path d="M10.5 9L17 2M14 5l2 2"/></svg> Clé API Anthropic</div><button class="modal-close" onclick="closeModal('modal-api-key')">✕</button></div>
  <div class="alert alert-info" style="margin-bottom:14px">Ta clé est stockée uniquement sur ton appareil (localStorage).</div>
  <div class="inp-group"><div class="inp-lbl">Clé API</div><input class="inp" id="api-key-input" type="password" placeholder="sk-ant-..."></div>
  <button class="btn btn-primary" style="width:100%" onclick="saveApiKey()">Enregistrer</button>
</div></div>

<!-- Add Custom Integration -->
<div class="modal-bg" id="modal-add-integration"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Nouvelle intégration</div><button class="modal-close" onclick="closeModal('modal-add-integration')">✕</button></div>
  <div class="alert alert-info" style="margin-bottom:14px;font-size:.78rem">Ajoute n'importe quelle app avec une URL d'API et un token.</div>
  <div class="inp-group"><div class="inp-lbl">Nom du service</div><input class="inp" id="ci-name" placeholder="Ex: Google Ads, Stripe..."></div>
  <div class="inp-group"><div class="inp-lbl">Icône (emoji)</div><input class="inp" id="ci-icon" placeholder="📊" style="width:80px"></div>
  <div class="inp-group"><div class="inp-lbl">Description</div><input class="inp" id="ci-desc" placeholder="Ex: Campagnes Google"></div>
  <div class="inp-group"><div class="inp-lbl">URL de base de l'API</div><input class="inp" id="ci-url" placeholder="https://api.example.com/v1/..."></div>
  <div class="inp-group"><div class="inp-lbl">Token / Clé API</div><input class="inp" id="ci-token" type="password" placeholder="sk_live_..."></div>
  <div class="inp-group"><div class="inp-lbl">Auth</div><select class="inp" id="ci-auth-type"><option value="bearer">Bearer Token</option><option value="apikey">X-API-Key header</option><option value="basic">Basic Auth</option></select></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveCustomIntegration()">Enregistrer</button>
</div></div>

<!-- Habit modal -->
<div class="modal-overlay" id="habitModal">
  <div class="modal-sheet">
    <h3 id="modal-title" style="margin-bottom:18px">Nouvelle habitude</h3>
    <div class="modal-row"><div class="modal-label">Nom</div><input class="inp" id="modal-name" placeholder="Ex: Méditation"></div>
    <div class="modal-row"><div class="modal-label">Emoji</div><div class="emoji-grid" id="emoji-grid"></div></div>
    <div class="modal-row"><div class="modal-label">XP par complétion</div><input class="inp" id="modal-xp" type="number" placeholder="10" value="10" min="5" max="50"></div>
    <div class="modal-row"><div class="modal-label">Couleur</div><div class="color-picker-row" id="modal-color-picker"></div></div>
    <div class="modal-btns">
      <button class="btn btn-ghost" onclick="closeHabitModal()" style="flex:1">Annuler</button>
      <button class="btn btn-green" onclick="saveHabit()" style="flex:1">Enregistrer</button>
    </div>
  </div>
</div>

<!-- Recap -->
<div class="recap-modal" id="recapModal">
  <div class="recap-inner">
    <div class="recap-header">
      <div style="display:flex;justify-content:space-between;align-items:flex-start">
        <div>
          <div class="recap-logo">ASCEND</div>
          <div class="recap-title" id="recap-title">Bilan semaine</div>
          <div class="recap-date" id="recap-date-range">—</div>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <div class="recap-streak-badge" id="recap-streak-badge"><svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2C10 2 5 8 5 12.5a5 5 0 0010 0C15 8 10 2 10 2z"/><path d="M10 15.5a2 2 0 010-4"/></svg> 0 jour</div>
          <button class="modal-close" onclick="closeRecap()">✕</button>
        </div>
      </div>
    </div>
    <div class="recap-kpis">
      <div class="recap-kpi"><div class="recap-kpi-val" id="recap-kpi-pct" style="color:var(--p)">—</div><div class="recap-kpi-lbl">Complétion</div></div>
      <div class="recap-kpi"><div class="recap-kpi-val" id="recap-kpi-xp" style="color:var(--gold)">—</div><div class="recap-kpi-lbl">XP gagnés</div></div>
      <div class="recap-kpi"><div class="recap-kpi-val" id="recap-kpi-perfect" style="color:var(--g)">—</div><div class="recap-kpi-lbl">Jours parfaits</div></div>
    </div>
    <div class="recap-body">
      <div class="recap-section-lbl">Jours de la semaine</div>
      <div class="recap-day-dots" id="recap-day-dots"></div>
      <div class="recap-section-lbl">Par habitude</div>
      <div id="recap-habit-bars"></div>
      <div class="recap-section-lbl">Analyse</div>
      <div class="recap-phrase" id="recap-phrase"></div>
      <div class="recap-next" id="recap-next"></div>
      <div id="recap-insights"></div>
    </div>
    <div class="recap-footer">
      <div class="recap-badge" id="recap-badge">Grade A</div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" onclick="closeRecap()">Fermer</button>
        <button class="btn btn-green btn-sm" onclick="closeRecap();showPlanAction()">Plan d'action </button>
      </div>
    </div>
  </div>
</div>

<!-- Bilan History -->
<div class="recap-modal" id="bilanHistoryModal">
  <div class="recap-inner" style="max-width:640px">
    <div class="recap-header" style="display:flex;justify-content:space-between;align-items:center">
      <div><div class="recap-logo">ASCEND</div><div class="recap-title">Historique des Bilans</div><div class="recap-date">Toutes tes semaines passées</div></div>
      <button class="modal-close" onclick="closeBilanHistory()">✕</button>
    </div>
    <div id="bilan-compare-bar" style="padding:12px 20px 0;display:none">
      <div style="background:rgba(124,92,252,.07);border:1px solid rgba(124,92,252,.18);border-radius:11px;padding:12px 14px">
        <div style="font-size:.58rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--t2);font-weight:700;margin-bottom:8px"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 3v14M4 7l6-4 6 4M5 10l-2 4h4l-2-4zM15 10l-2 4h4l-2-4z"/></svg> Comparaison</div>
        <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:12px;align-items:center" id="bilan-compare-content"></div>
      </div>
    </div>
    <div class="recap-body"><div id="bilan-history-list"></div></div>
  </div>
</div>

<!-- Plan Action -->
<div class="recap-modal" id="planActionModal">
  <div class="recap-inner" style="max-width:620px">
    <div class="recap-header" style="display:flex;justify-content:space-between;align-items:flex-start">
      <div><div class="recap-logo">ASCEND</div><div class="recap-title">Plan d'action — cette semaine</div><div class="recap-date" id="plan-action-week-label">—</div></div>
      <button class="modal-close" onclick="closePlanAction()">✕</button>
    </div>
    <div class="recap-body">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
        <div style="width:34px;height:34px;border-radius:10px;background:rgba(0,229,160,.12);border:1px solid rgba(0,229,160,.25);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0"><svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M10 18V10M10 10C10 10 6 6 3 4c5-2 7 2 7 6M10 10c0 0 4-4 7-6-2 5-7 6-7 6"/></svg></div>
        <div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.92rem">Habitudes</div><div style="font-size:.7rem;color:var(--t1)">Actions pour améliorer ta régularité</div></div>
        <div id="plan-hab-count" style="margin-left:auto;font-size:.65rem;font-weight:700;color:var(--g);background:rgba(0,229,160,.1);border:1px solid rgba(0,229,160,.2);border-radius:999px;padding:2px 9px"></div>
      </div>
      <div id="plan-hab-list" style="margin-bottom:20px"></div>
      <div style="height:1px;background:var(--b0);margin-bottom:18px"></div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
        <div style="width:34px;height:34px;border-radius:10px;background:rgba(124,92,252,.12);border:1px solid rgba(124,92,252,.25);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0"><svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M11 2L4 11h7l-2 7 9-10h-7l2-8z"/></svg></div>
        <div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.92rem">Business</div><div style="font-size:.7rem;color:var(--t1)">Actions vers tes objectifs financiers</div></div>
        <div id="plan-biz-count" style="margin-left:auto;font-size:.65rem;font-weight:700;color:var(--p);background:rgba(124,92,252,.1);border:1px solid rgba(124,92,252,.2);border-radius:999px;padding:2px 9px"></div>
      </div>
      <div id="plan-biz-list"></div>
    </div>
    <div class="recap-footer">
      <div style="font-size:.67rem;color:var(--t2)">Définis tes priorités pour la semaine</div>
      <button class="btn btn-green btn-sm" onclick="closePlanAction()">C'est parti →</button>
    </div>
  </div>
</div>

<!-- Goal Plan -->
<div class="modal-bg" id="modal-goal-plan"><div class="modal-box" style="max-width:620px">
  <div class="modal-header"><div><div class="modal-title">Plan d'action — Aujourd'hui</div><div style="font-size:.74rem;color:var(--t1);margin-top:2px" id="goal-plan-subtitle">Ce que tu dois faire aujourd'hui</div></div><button class="modal-close" onclick="closeModal('modal-goal-plan')">✕</button></div>
  <div id="goal-plan-content"></div>
</div></div>

<div class="toast" id="toast"></div>
<div class="burst" id="burst"></div>
