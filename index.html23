// ══════════════════════════════════════════════════════
//  CALENDAR — Month + Week views
// ══════════════════════════════════════════════════════
if(!hState.calEvents) hState.calEvents = [];

const WCAL_DAYS_SHORT = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
const CAL_MONTHS = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
const CAL_DAYS   = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
const RECUR_LABELS = { once:'', daily:'↻ Quotidien', weekly:'↻ Hebdo', mon:'↻ Lun', tue:'↻ Mar', wed:'↻ Mer', thu:'↻ Jeu', fri:'↻ Ven', sat:'↻ Sam', sun:'↻ Dim' };
const RECUR_DOW = { mon:1, tue:2, wed:3, thu:4, fri:5, sat:6, sun:0 };

let calCurrentView = 'week';
let wcalWeekOffset = 0;   // weeks offset for week/3day view
let calDayOffset   = 0;   // days offset for day view
let calMonth = new Date().getMonth();
let calYear  = new Date().getFullYear();
let calSelDay = null;
let calEvColor = '#7c5cfc';
let calEditingId = null;

// ── Drawer ──
function toggleCalDrawer(){
  document.getElementById('calDrawer').classList.toggle('open');
  document.getElementById('calDrawerOverlay').classList.toggle('open');
}
function closeCalDrawer(){
  document.getElementById('calDrawer').classList.remove('open');
  document.getElementById('calDrawerOverlay').classList.remove('open');
}

// ── Set view ──
function calSetView(v){
  calCurrentView=v;
  const isTimeline = ['week','3day','day'].includes(v);
  document.getElementById('cal-month-view').style.display=v==='month'?'':'none';
  document.getElementById('cal-week-view').style.display=isTimeline?'':'none';
  const sv=document.getElementById('cal-schedule-view'); if(sv) sv.style.display=v==='schedule'?'':'none';
  // Update drawer active state
  document.querySelectorAll('.gcal-drawer-item').forEach(el=>el.classList.remove('active'));
  const target = document.querySelector('.gcal-drawer-item[data-view="'+v+'"]');
  if(target) target.classList.add('active');
  // Reset day offset when switching views
  if(v==='day') calDayOffset=0;
  if(v==='week'||v==='3day') wcalWeekOffset=0;
  renderCalendar();
}

// ── Navigation ──
function calNavPrev(){
  if(calCurrentView==='month'){ calPrevMonth(); }
  else if(calCurrentView==='day'){ calDayOffset--; renderCalendar(); }
  else if(calCurrentView==='3day'){ wcalWeekOffset -= 3/7; renderCalendar(); }
  else if(calCurrentView==='week'){ wcalPrevWeek(); }
  else if(calCurrentView==='schedule'){ calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); }
}
function calNavNext(){
  if(calCurrentView==='month'){ calNextMonth(); }
  else if(calCurrentView==='day'){ calDayOffset++; renderCalendar(); }
  else if(calCurrentView==='3day'){ wcalWeekOffset += 3/7; renderCalendar(); }
  else if(calCurrentView==='week'){ wcalNextWeek(); }
  else if(calCurrentView==='schedule'){ calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); }
}
function calNavToday(){
  wcalWeekOffset=0; calDayOffset=0;
  calMonth=new Date().getMonth(); calYear=new Date().getFullYear();
  renderCalendar();
}
function calPrevMonth(){ calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); }
function calNextMonth(){ calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); }

function wcalPrevWeek(){ wcalWeekOffset--; renderCalendar(); }
function wcalNextWeek(){ wcalWeekOffset++; renderCalendar(); }
function wcalGoToday(){ wcalWeekOffset=0; renderCalendar(); }

// ── Get N days starting from offset (for day/3day/week) ──
function wcalGetDays(n, offset){
  // For day view: offset is calDayOffset; for week/3day: use monday+weekOffset
  if(n===1){
    const base=new Date(); base.setDate(base.getDate()+offset); base.setHours(0,0,0,0);
    return [base];
  }
  // For 3day: base = today + offset days (stored in wcalWeekOffset*7 equivalent)
  if(n===3){
    const base=new Date(); base.setDate(base.getDate()+Math.round(wcalWeekOffset*7)); base.setHours(0,0,0,0);
    return Array.from({length:3},(_,i)=>{ const d=new Date(base); d.setDate(base.getDate()+i); return d; });
  }
  // Week: monday
  return Array.from({length:7},(_,i)=>{ const d=new Date(wcalGetMonday(wcalWeekOffset)); d.setDate(wcalGetMonday(wcalWeekOffset).getDate()+i); return d; });
}

function wcalGetMonday(offset){
  const now=new Date(),day=now.getDay(),diff=(day===0?-6:1-day);
  const m=new Date(now); m.setDate(now.getDate()+diff+offset*7); m.setHours(0,0,0,0); return m;
}
function wcalDayKey(date){ return date.getFullYear()+'-'+String(date.getMonth()+1).padStart(2,'0')+'-'+String(date.getDate()).padStart(2,'0'); }
function timeToMin(t){ const [h,m]=(t||'00:00').split(':').map(Number); return h*60+m; }
function wcalEventMatchesDay(ev,dayDate){
  if(!ev.recur||ev.recur==='once') return ev.date===wcalDayKey(dayDate);
  if(ev.recur==='daily') return true;
  if(ev.recur==='weekly'){const ed=new Date(ev.date+'T12:00:00');return ed.getDay()===dayDate.getDay();}
  if(RECUR_DOW[ev.recur]!==undefined) return dayDate.getDay()===RECUR_DOW[ev.recur];
  // Handle custom multi-day recurrence: "custom:mon,wed,fri"
  if(ev.recur && ev.recur.startsWith('custom:')){
    const days = ev.recur.replace('custom:','').split(',');
    const DOW_NAMES = ['sun','mon','tue','wed','thu','fri','sat'];
    return days.includes(DOW_NAMES[dayDate.getDay()]);
  }
  return false;
}

function renderCalendar(){
  if(calCurrentView==='month') renderMonthCal();
  else if(calCurrentView==='schedule') renderScheduleCal();
  else renderWeekCal(); // handles week, 3day, day
}

// ── Animated calendar navigation (slide in/out) ──
function calNavWithAnim(direction){ // direction: -1=prev, 1=next
  const view = document.getElementById('view-calendar');
  if(!view) return;
  // Slide out current content
  const slideOut = direction > 0 ? '-100%' : '100%';
  const slideIn  = direction > 0 ?  '100%' : '-100%';
  view.style.transition = 'none';
  view.style.transform  = 'translateX(0)';
  void view.offsetWidth;
  view.style.transition = 'transform .22s cubic-bezier(.4,0,.2,1)';
  view.style.transform  = `translateX(${slideOut})`;
  setTimeout(()=>{
    // Navigate
    if(direction > 0) calNavNext(); else calNavPrev();
    // Snap in from opposite side instantly, then slide to center
    view.style.transition = 'none';
    view.style.transform  = `translateX(${slideIn})`;
    void view.offsetWidth;
    view.style.transition = 'transform .22s cubic-bezier(.4,0,.2,1)';
    view.style.transform  = 'translateX(0)';
    setTimeout(()=>{ view.style.transition=''; view.style.transform=''; }, 240);
  }, 210);
}

// ── Global calendar swipe — works everywhere including wcal-body ──
// Uses velocity + angle to distinguish horizontal swipe from vertical scroll
let _calSwipeX=0, _calSwipeY=0, _calSwipeT=0, _calSwipeLocked=false, _calSwipeDir=null;
let _calSwipeDeltaX=0, _calSwipeDeltaY=0;
(function initCalGlobalSwipe(){
  const view = document.getElementById('view-calendar');
  if(!view) return;

  // Attach touchstart on the view, but also explicitly on non-interactive children
  // so buttons in gcal-header don't swallow the touch start
  function onTouchStart(e){
    // Reset first so guards in touchmove/touchend work even if we return early
    _calSwipeX = 0; _calSwipeY = 0;
    _calSwipeLocked = false; _calSwipeDir = null;
    _calSwipeDeltaX = 0; _calSwipeDeltaY = 0;
    // Ignore if touch starts on an interactive element (button, input, select)
    const tag = e.target.tagName;
    if(tag==='BUTTON'||tag==='INPUT'||tag==='SELECT'||tag==='A') return;
    if(e.touches.length!==1) return;
    _calSwipeX  = e.touches[0].clientX;
    _calSwipeY  = e.touches[0].clientY;
    _calSwipeT  = Date.now();
  }

  view.addEventListener('touchstart', onTouchStart,{passive:true});

  view.addEventListener('touchmove', e=>{
    if(_calSwipeLocked||e.touches.length!==1) return;
    if(_calSwipeX===0 && _calSwipeY===0) return; // touchstart was on a button, ignore
    _calSwipeDeltaX = e.touches[0].clientX - _calSwipeX;
    _calSwipeDeltaY = e.touches[0].clientY - _calSwipeY;
    if(!_calSwipeDir && (Math.abs(_calSwipeDeltaX)>8||Math.abs(_calSwipeDeltaY)>8)){
      _calSwipeDir = Math.abs(_calSwipeDeltaX) > Math.abs(_calSwipeDeltaY)*1.2 ? 'h' : 'v';
    }
    // If clearly horizontal, prevent vertical scroll
    if(_calSwipeDir==='h' && e.cancelable) e.preventDefault();
  },{passive:false});

  view.addEventListener('touchend', e=>{
    if(_calSwipeLocked) return;
    if(_calSwipeX===0 && _calSwipeY===0) return; // touchstart was on a button, ignore
    const dx = _calSwipeDeltaX;
    const dy = _calSwipeDeltaY;
    const dt = Date.now() - _calSwipeT;
    if(dt > 600) return;
    if(Math.abs(dx) < 40) return;
    if(_calSwipeDir !== 'h') return;
    // Extra safety: dx must dominate dy significantly
    if(Math.abs(dy) > Math.abs(dx) * 0.75) return;
    _calSwipeLocked = true;
    calNavWithAnim(dx < 0 ? 1 : -1);
  },{passive:true});
})();

function renderMonthCal(){
  const lbl=document.getElementById('cal-nav-label'); if(lbl) lbl.textContent=CAL_MONTHS[calMonth]+' '+calYear;
  const dh=document.getElementById('cal-day-headers');
  if(dh) dh.innerHTML=CAL_DAYS.map(d=>`<div style="text-align:center;font-size:.6rem;font-weight:700;color:var(--t2);text-transform:uppercase;padding:3px 0">${d}</div>`).join('');
  const grid=document.getElementById('cal-grid'); if(!grid) return;
  const today=todayKey(), firstDow=(new Date(calYear,calMonth,1).getDay()+6)%7, lastDate=new Date(calYear,calMonth+1,0).getDate();
  const evs=hState.calEvents||[]; let html='';
  for(let i=0;i<firstDow;i++) html+='<div></div>';
  for(let d=1;d<=lastDate;d++){
    const key=calYear+'-'+String(calMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const dateObj=new Date(key+'T12:00:00'), isToday=key===today, isSel=key===calSelDay;
    const dayEvs=evs.filter(e=>wcalEventMatchesDay(e,dateObj));
    const hasHab=hState.history[key]&&hState.habits.some(h=>hState.history[key][h.id]);
    let cls='cal-cell'; if(isToday)cls+=' is-today'; if(isSel)cls+=' is-sel';
    html+=`<div class="${cls}" id="calcell-${key}" onclick="calClickDay('${key}')">
      <div class="cal-cell-num">${d}</div>
      ${hasHab?'<div class="cal-habit-dot"></div>':''}
      ${dayEvs.slice(0,2).map(e=>`<div class="cal-ev-chip" style="background:${e.color}22;color:${e.color}">${e.title}</div>`).join('')}
      ${dayEvs.length>2?`<div style="font-size:.45rem;color:var(--t2);text-align:center">+${dayEvs.length-2}</div>`:''}
    </div>`;
  }
  grid.innerHTML=html;
  calRenderDay(calSelDay);
  calRenderUpcoming();
}

function calClickDay(key){
  calSelDay=key;
  document.querySelectorAll('.cal-cell').forEach(c=>c.classList.remove('is-sel'));
  const el=document.getElementById('calcell-'+key); if(el)el.classList.add('is-sel');
  calRenderDay(key);
}

function calRenderDay(key){
  if(!key) return;
  const lbl=document.getElementById('cal-selected-label'),box=document.getElementById('cal-day-events');
  if(!lbl||!box) return;
  const d=new Date(key+'T12:00:00');
  lbl.textContent=d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'});
  const evs=(hState.calEvents||[]).filter(e=>wcalEventMatchesDay(e,d)).sort((a,b)=>a.start>b.start?1:-1);
  if(!evs.length){box.innerHTML='<div class="empty-state">Aucun événement.</div>';return;}
  box.innerHTML=evs.map(e=>`<div class="gcal-event" style="margin-bottom:8px">
    <div class="gcal-dot" style="background:${e.color||'var(--p)'}"></div>
    <div class="gcal-time">${e.start}${e.end?' – '+e.end:''}</div>
    <div style="flex:1"><div class="gcal-title">${e.title}</div>${e.desc?'<div class="gcal-loc">'+e.desc+'</div>':''}</div>
    <button onclick="wcalOpenEditEvent('${e.id}',event)" style="background:none;border:none;color:var(--t1);cursor:pointer;font-size:.78rem"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M13 3l4 4-9 9H4v-4l9-9z"/><path d="M11 5l4 4"/></svg></button>
    <button onclick="delCalEvent('${e.id}')" style="background:none;border:none;color:var(--t2);cursor:pointer;font-size:.85rem">✕</button>
  </div>`).join('');
}

function calRenderUpcoming(){
  const el=document.getElementById('cal-upcoming'); if(!el) return;
  const today=todayKey();
  const oneTime=(hState.calEvents||[]).filter(e=>(!e.recur||e.recur==='once')&&e.date>=today).sort((a,b)=>a.date>b.date?1:a.date<b.date?-1:a.start>b.start?1:-1).slice(0,5);
  const recurring=(hState.calEvents||[]).filter(e=>e.recur&&e.recur!=='once').slice(0,4);
  const all=[...oneTime,...recurring];
  if(!all.length){el.innerHTML='<div class="empty-state">Aucun événement à venir.</div>';return;}
  el.innerHTML=all.map(e=>`<div class="gcal-event" style="margin-bottom:7px">
    <div class="gcal-dot" style="background:${e.color||'var(--p)'}"></div>
    <div class="gcal-time" style="min-width:80px;font-size:.68rem">${(!e.recur||e.recur==='once')?fmtDate(e.date):(RECUR_LABELS[e.recur]||'Récurrent')}</div>
    <div style="flex:1"><div class="gcal-title">${e.title}</div><div class="gcal-loc">${e.start}${e.end?' – '+e.end:''}</div></div>
    <button onclick="wcalOpenEditEvent('${e.id}',event)" style="background:none;border:none;color:var(--t1);cursor:pointer;font-size:.78rem"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M13 3l4 4-9 9H4v-4l9-9z"/><path d="M11 5l4 4"/></svg></button>
    <button onclick="delCalEvent('${e.id}')" style="background:none;border:none;color:var(--t2);cursor:pointer;font-size:.85rem">✕</button>
  </div>`).join('');
}

// ══════════════════════════════════════════════════════
//  WEEK CALENDAR — Pinch-zoom · Tap-to-add · Long-press drag
// ══════════════════════════════════════════════════════

let wcalHourH = 44;          // px per hour, mutated by pinch
const WCAL_MIN_HOUR_H = 28;
const WCAL_MAX_HOUR_H = 120;
let wcalDragState = null;     // active drag info

function wcalGetHourH(){
  // Base from CSS var, but we override with pinch zoom
  return wcalHourH;
}

function wcalApplyHourH(){
  document.documentElement.style.setProperty('--wcal-hour-h', wcalHourH+'px');
}

const CAL_MONTHS_SHORT=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];

function renderWeekCal(){
  // Determine days to show
  const nDays = calCurrentView==='day'?1 : calCurrentView==='3day'?3 : 7;
  let days;
  if(calCurrentView==='day'){
    const base=new Date(); base.setDate(base.getDate()+calDayOffset); base.setHours(0,0,0,0);
    days=[base];
  } else if(calCurrentView==='3day'){
    const base=new Date(); base.setDate(base.getDate()+Math.round(wcalWeekOffset*7)); base.setHours(0,0,0,0);
    days=Array.from({length:3},(_,i)=>{ const d=new Date(base); d.setDate(base.getDate()+i); return d; });
  } else {
    const monday=wcalGetMonday(wcalWeekOffset);
    days=Array.from({length:7},(_,i)=>{ const d=new Date(monday); d.setDate(monday.getDate()+i); return d; });
  }

  const todayStr=wcalDayKey(new Date());
  const fmt=d=>d.toLocaleDateString('fr-FR',{day:'numeric',month:'short'});

  // Period label (top)
  const first=days[0], last=days[days.length-1];
  const periodEl=document.getElementById('cal-period-label');
  if(periodEl){
    if(nDays===1){
      periodEl.textContent=first.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'});
    } else {
      const sameMonth=first.getMonth()===last.getMonth();
      periodEl.textContent=sameMonth
        ? CAL_MONTHS_SHORT[first.getMonth()]+' '+first.getFullYear()
        : CAL_MONTHS_SHORT[first.getMonth()]+' – '+CAL_MONTHS_SHORT[last.getMonth()]+' '+last.getFullYear();
    }
  }
  const lbl=document.getElementById('cal-nav-label');
  if(lbl) lbl.textContent=fmt(first)+' – '+fmt(last);

  // Header days (grid columns adapt)
  const hdr=document.getElementById('wcal-days-header');
  if(hdr){
    hdr.style.gridTemplateColumns=`repeat(${nDays},1fr)`;
    hdr.innerHTML=days.map((d,i)=>{
      const isToday=wcalDayKey(d)===todayStr;
      const dayName=nDays===1
        ? d.toLocaleDateString('fr-FR',{weekday:'short'}).toUpperCase()
        : WCAL_DAYS_SHORT[d.getDay()===0?6:d.getDay()-1];
      return `<div class="wcal-day-hd${isToday?' is-today':''}" data-datekey="${wcalDayKey(d)}">
        <div class="wcal-day-hd-name">${dayName}</div>
        <div class="wcal-day-hd-num">${d.getDate()}</div>
      </div>`;
    }).join('');
  }

  // Time column
  const timeCol=document.getElementById('wcal-time-col');
  if(timeCol){ let th='';
    for(let h=0;h<24;h++) th+=`<div class="wcal-hour-label" style="height:${wcalHourH}px">${h===0?'':String(h).padStart(2,'0')+'h'}</div>`;
    timeCol.innerHTML=th;
  }

  // Events grid
  const grid=document.getElementById('wcal-days-grid'); if(!grid) return;
  grid.style.gridTemplateColumns=`repeat(${nDays},1fr)`;
  const evs=hState.calEvents||[];
  const H=wcalHourH;

  grid.innerHTML=days.map((d,di)=>{    const dk=wcalDayKey(d);
    const dayEvs=evs.filter(ev=>wcalEventMatchesDay(ev,d)).sort((a,b)=>timeToMin(a.start)-timeToMin(b.start));
    let lines='';
    for(let h=0;h<24;h++){
      lines+=`<div class="wcal-hour-line" style="top:${h*H}px"></div>`;
      lines+=`<div class="wcal-hour-line half" style="top:${h*H+H/2}px"></div>`;
    }
    const evBlocks=dayEvs.map(ev=>{
      const startMin=timeToMin(ev.start), endMin=ev.end ? Math.max(timeToMin(ev.end),startMin+15) : startMin+30;
      const top=(startMin/60)*H, height=Math.max(((endMin-startMin)/60)*H-2,20);
      const col=ev.color||'#7c5cfc', isRecur=ev.recur&&ev.recur!=='once';
      return `<div class="wcal-event" data-evid="${ev.id}" data-daykey="${dk}"
        style="top:${top}px;height:${height}px;background:${col}cc;border-left:3px solid ${col}">
        <div class="wcal-event-title">${ev.title}</div>
        ${height>28?`<div class="wcal-event-time">${ev.start}${ev.end?' – '+ev.end:''} ${isRecur?(RECUR_LABELS[ev.recur]||''):''}  </div>`:''}
        ${isRecur?'<div class="wcal-recur-dot"></div>':''}
      </div>`;
    }).join('');
    let nowLine='';
    if(dk===todayStr){
      const now=new Date(), nowTop=((now.getHours()*60+now.getMinutes())/60)*H;
      nowLine=`<div class="wcal-now-line" style="top:${nowTop}px"><div style="position:relative"><div class="wcal-now-dot"></div><div class="wcal-now-bar"></div></div></div>`;
    }
    return `<div class="wcal-day-col" data-dayidx="${di}" data-datekey="${dk}" style="height:${24*H}px">${lines}${evBlocks}${nowLine}</div>`;
  }).join('');

  // Scroll to 6h on first load
  const body=document.getElementById('wcal-body');
  if(body && body._firstLoad!==true){
    body._firstLoad=true;
    setTimeout(()=>{ body.scrollTop=6*wcalHourH; },40);
  }

  // Attach interactions (including swipe)
  wcalAttachInteractions();
}

// ── Schedule / Planning view ──
function renderScheduleCal(){
  const periodEl=document.getElementById('cal-period-label');
  if(periodEl) periodEl.textContent=CAL_MONTHS_SHORT[calMonth]+' '+calYear;
  const lbl=document.getElementById('cal-nav-label'); if(lbl) lbl.textContent='Planning';
  document.getElementById('cal-month-view').style.display='none';
  document.getElementById('cal-week-view').style.display='none';
  let sv=document.getElementById('cal-schedule-view');
  if(!sv){
    sv=document.createElement('div'); sv.id='cal-schedule-view';
    document.getElementById('view-calendar').appendChild(sv);
  }
  sv.style.display='';
  const evs=(hState.calEvents||[]).slice().sort((a,b)=>a.date.localeCompare(b.date)||a.start.localeCompare(b.start));
  const today=todayKey();
  const upcoming=evs.filter(e=>e.date>=today).slice(0,30);
  if(!upcoming.length){
    sv.innerHTML='<div class="empty-state" style="margin:40px auto">Aucun événement à venir</div>';
    return;
  }
  let html='<div style="padding:0 0 80px">';
  let lastDay='';
  upcoming.forEach(ev=>{
    if(ev.date!==lastDay){
      lastDay=ev.date;
      const d=new Date(ev.date+'T12:00:00');
      const isToday=ev.date===today;
      html+=`<div style="padding:14px 16px 6px;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:${isToday?'var(--p)':'var(--t2)'}">${d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'})}</div>`;
    }
    const col=ev.color||'#7c5cfc';
    html+=`<div onclick="wcalOpenEditEvent('${ev.id}')" style="display:flex;align-items:center;gap:12px;padding:10px 16px;cursor:pointer;border-bottom:1px solid var(--b0);transition:background .12s" onmouseover="this.style.background='var(--b0)'" onmouseout="this.style.background=''">
      <div style="width:4px;height:40px;border-radius:2px;background:${col};flex-shrink:0"></div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${ev.title}</div>
        <div style="font-size:.72rem;color:var(--t1);margin-top:2px">${ev.start}${ev.end?' – '+ev.end:''}</div>
      </div>
    </div>`;
  });
  html+='</div>';
  sv.innerHTML=html;
}

// ── Snap minutes to 15-min grid ──
function snapMin(m){ return Math.round(m/15)*15; }
function minToTime(m){ m=Math.max(0,Math.min(23*60+59,m)); return String(Math.floor(m/60)).padStart(2,'0')+':'+String(m%60).padStart(2,'0'); }

// ── Open new event modal ──
function wcalOpenNewEventOnDay(dateKey, startMin){
  calEditingId = null;
  const start = minToTime(snapMin(startMin||9*60));
  const end   = minToTime(snapMin((startMin||9*60)+60));
  document.getElementById('cal-modal-title').textContent = '+ Événement';
  document.getElementById('cal-ev-title').value = '';
  document.getElementById('cal-ev-desc').value  = '';
  document.getElementById('cal-ev-date').value  = dateKey;
  document.getElementById('cal-ev-start').value = start;
  document.getElementById('cal-ev-end').value   = end;
  document.getElementById('cal-del-btn').style.display = 'none';
  calEvColor = '#7c5cfc';
  document.querySelectorAll('#modal-cal-event .color-dot').forEach(d=>d.classList.remove('sel'));
  document.getElementById('cal-col-p').classList.add('sel');
  calInitRecurUI('once');
  openModal('modal-cal-event');
}

// ── All touch/pointer interactions ──
function wcalAttachInteractions(){
  const body = document.getElementById('wcal-body');
  const grid = document.getElementById('wcal-days-grid');
  if(!body||!grid) return;

  // ── PINCH ZOOM ──
  let pinchStartDist=0, pinchStartH=0, pinchMidY=0, pinchScrollTop=0;
  let isPinching=false;

  body.addEventListener('touchstart', e=>{
    if(e.touches.length===2){
      isPinching=true;
      const [t1,t2]=e.touches;
      pinchStartDist=Math.hypot(t2.clientX-t1.clientX,t2.clientY-t1.clientY);
      pinchStartH=wcalHourH;
      pinchMidY=(t1.clientY+t2.clientY)/2;
      pinchScrollTop=body.scrollTop;
      e.preventDefault();
    }
  },{passive:false});

  body.addEventListener('touchmove', e=>{
    if(!isPinching||e.touches.length<2) return;
    e.preventDefault();
    const [t1,t2]=e.touches;
    const dist=Math.hypot(t2.clientX-t1.clientX,t2.clientY-t1.clientY);
    const ratio=dist/pinchStartDist;
    const newH=Math.min(WCAL_MAX_HOUR_H,Math.max(WCAL_MIN_HOUR_H,Math.round(pinchStartH*ratio)));
    if(newH===wcalHourH) return;
    // Keep the pinch midpoint anchored
    const anchorMin=(pinchScrollTop+pinchMidY-body.getBoundingClientRect().top)/pinchStartH*60;
    wcalHourH=newH;
    wcalApplyHourH();
    // Update heights without full re-render (just rescale positions)
    renderWeekCalPositions();
    body.scrollTop=anchorMin/60*wcalHourH-(pinchMidY-body.getBoundingClientRect().top);
  },{passive:false});

  body.addEventListener('touchend', e=>{
    if(e.touches.length<2) isPinching=false;
  },{passive:true});

  // ── TAP TO ADD (on day column background, not on event) ──
  // Use pointerdown/pointerup to detect short taps vs long-press
  let tapTimer=null, tapData=null, pointerOnEvent=false;

  grid.addEventListener('pointerdown', e=>{
    const evEl=e.target.closest('.wcal-event');
    if(evEl){
      pointerOnEvent=true;
      wcalStartDrag(e,evEl);
      return;
    }
    pointerOnEvent=false;
    const col=e.target.closest('.wcal-day-col');
    if(!col) return;
    const H=wcalHourH;
    // Correct calculation: position relative to the scrollable body top + scroll offset
    const bodyRect=body.getBoundingClientRect();
    const relY=(e.clientY - bodyRect.top) + body.scrollTop;
    const rawMin=(relY/H)*60;
    tapData={ dateKey:col.dataset.datekey, startMin:snapMin(rawMin), col };
    // Show ghost
    const ghostTop=(snapMin(rawMin)/60)*H;
    const ghost=document.createElement('div');
    ghost.className='wcal-tap-ghost';
    ghost.style.cssText=`top:${ghostTop}px;height:${H}px`;
    ghost.dataset.ghost='1';
    col.appendChild(ghost);
    tapTimer=setTimeout(()=>{ tapTimer=null; }, 500);
  });

  grid.addEventListener('pointerup', e=>{
    if(pointerOnEvent){ pointerOnEvent=false; return; }
    if(!tapData) return;
    // Remove ghost
    document.querySelectorAll('[data-ghost]').forEach(g=>g.remove());
    if(tapTimer!==null){
      clearTimeout(tapTimer); tapTimer=null;
      wcalOpenNewEventOnDay(tapData.dateKey, tapData.startMin);
    }
    tapData=null;
  });

  grid.addEventListener('pointerleave', ()=>{
    document.querySelectorAll('[data-ghost]').forEach(g=>g.remove());
    if(tapTimer){ clearTimeout(tapTimer); tapTimer=null; }
    tapData=null;
  });
}

// ── Rescale positions without full redraw (used during pinch) ──
function renderWeekCalPositions(){
  const H=wcalHourH;
  // Hour lines
  document.querySelectorAll('.wcal-hour-line:not(.half)').forEach((el,i)=>{ el.style.top=i*H+'px'; });
  document.querySelectorAll('.wcal-hour-line.half').forEach((el,i)=>{ el.style.top=i*H+H/2+'px'; });
  // Hour labels
  document.querySelectorAll('.wcal-hour-label').forEach(el=>{ el.style.height=H+'px'; });
  // Day cols height
  document.querySelectorAll('.wcal-day-col').forEach(el=>{ el.style.height=24*H+'px'; });
  const g=document.getElementById('wcal-days-grid'); if(g) g.style.height=24*H+'px';
  // Events
  const evs=hState.calEvents||[];
  document.querySelectorAll('.wcal-event').forEach(el=>{
    const id=el.dataset.evid;
    const ev=evs.find(e=>e.id===id); if(!ev) return;
    const startMin=timeToMin(ev.start), endMin=ev.end ? Math.max(timeToMin(ev.end),startMin+15) : startMin+30;
    el.style.top=(startMin/60)*H+'px';
    el.style.height=Math.max(((endMin-startMin)/60)*H-2,20)+'px';
  });
  // Now line
  document.querySelectorAll('.wcal-now-line').forEach(el=>{
    const now=new Date();
    el.style.top=((now.getHours()*60+now.getMinutes())/60)*H+'px';
  });
  // Ghost
  document.querySelectorAll('[data-ghost]').forEach(el=>{
    el.style.height=H+'px';
  });
}

// ── LONG-PRESS DRAG ──
let _dragEl=null, _dragEv=null, _dragOffsetY=0, _dragOrigTop=0;
let _dragOrigCol=null, _dragClone=null, _dragActive=false, _dragTimer=null;

function wcalStartDrag(e, evEl){
  e.preventDefault();
  const id=evEl.dataset.evid;
  const ev=(hState.calEvents||[]).find(x=>x.id===id); if(!ev) return;
  _dragEv=ev; _dragEl=evEl;
  const rect=evEl.getBoundingClientRect();
  _dragOffsetY=e.clientY-rect.top;
  _dragOrigTop=parseFloat(evEl.style.top)||0;
  _dragOrigCol=evEl.closest('.wcal-day-col');
  _dragActive=false;

  // Long-press threshold: 350ms
  _dragTimer=setTimeout(()=>{
    _dragActive=true;
    _dragEl.classList.add('dragging');
    evEl.setPointerCapture(e.pointerId);
  },350);

  function onMove(e2){
    if(!_dragActive) return;
    e2.preventDefault();
    const body=document.getElementById('wcal-body');
    const grid=document.getElementById('wcal-days-grid');
    const H=wcalHourH;
    // Which column are we over?
    const cols=document.querySelectorAll('.wcal-day-col');
    let targetCol=_dragOrigCol;
    cols.forEach(c=>{
      const r=c.getBoundingClientRect();
      if(e2.clientX>=r.left&&e2.clientX<=r.right) targetCol=c;
    });
    // Highlight target
    document.querySelectorAll('.wcal-day-col').forEach(c=>c.classList.remove('drop-target'));
    targetCol.classList.add('drop-target');

    // Compute new top
    const bodyRect=body.getBoundingClientRect();
    const relY=(e2.clientY - bodyRect.top) + body.scrollTop - _dragOffsetY;
    const rawMin=Math.max(0,(relY/H)*60);
    const snapped=snapMin(rawMin);
    const newTop=(snapped/60)*H;
    // Move visually — reparent clone if needed
    if(!_dragClone){
      _dragClone=_dragEl.cloneNode(true);
      _dragClone.classList.add('dragging');
      _dragClone.style.pointerEvents='none';
      targetCol.appendChild(_dragClone);
    }
    if(_dragClone.parentElement!==targetCol) targetCol.appendChild(_dragClone);
    _dragClone.style.top=newTop+'px';
  }

  function onEnd(e2){
    clearTimeout(_dragTimer);
    document.querySelectorAll('.wcal-day-col').forEach(c=>c.classList.remove('drop-target'));
    evEl.removeEventListener('pointermove',onMove);
    evEl.removeEventListener('pointerup',onEnd);
    evEl.removeEventListener('pointercancel',onEnd);

    if(!_dragActive){
      // Was a short tap — open edit
      if(_dragClone){ _dragClone.remove(); _dragClone=null; }
      _dragEl.classList.remove('dragging');
      wcalOpenEditEvent(id,e2);
      return;
    }

    // Compute final position
    const body=document.getElementById('wcal-body');
    const H=wcalHourH;
    const cols=document.querySelectorAll('.wcal-day-col');
    let targetCol=_dragOrigCol;
    cols.forEach(c=>{
      const r=c.getBoundingClientRect();
      if(e2.clientX>=r.left&&e2.clientX<=r.right) targetCol=c;
    });
    const colRect=targetCol.getBoundingClientRect();
    const bodyRect2=body.getBoundingClientRect();
    const relY=(e2.clientY - bodyRect2.top) + body.scrollTop - _dragOffsetY;
    const rawMin=Math.max(0,(relY/H)*60);
    const newStartMin=snapMin(rawMin);
    const dur=timeToMin(ev.end||ev.start)-timeToMin(ev.start);
    const newEndMin=newStartMin+(dur>0?dur:60);
    const newDate=targetCol.dataset.datekey||ev.date;

    // Update event
    const idx=(hState.calEvents||[]).findIndex(x=>x.id===id);
    if(idx>=0){
      hState.calEvents[idx].date=newDate;
      hState.calEvents[idx].start=minToTime(newStartMin);
      hState.calEvents[idx].end=minToTime(Math.min(newEndMin,24*60-1));
    }
    saveH();
    if(_dragClone){ _dragClone.remove(); _dragClone=null; }
    _dragEl.classList.remove('dragging');
    _dragActive=false;
    renderCalendar();
    toast('Événement déplacé ✓','var(--g)');
  }

  evEl.addEventListener('pointermove',onMove,{passive:false});
  evEl.addEventListener('pointerup',onEnd);
  evEl.addEventListener('pointercancel',onEnd);
}

function wcalOpenEditEvent(id, e){
  e && e.stopPropagation();
  const ev = (hState.calEvents||[]).find(x=>x.id===id);
  if(!ev) return;
  calEditingId = id;
  document.getElementById('cal-modal-title').textContent = 'Modifier l\'événement';
  document.getElementById('cal-ev-title').value = ev.title;
  document.getElementById('cal-ev-desc').value  = ev.desc||'';
  document.getElementById('cal-ev-date').value  = ev.date;
  document.getElementById('cal-ev-start').value = ev.start||'09:00';
  document.getElementById('cal-ev-end').value   = ev.end||'10:00';
  document.getElementById('cal-del-btn').style.display = '';
  calEvColor = ev.color || '#7c5cfc';
  document.querySelectorAll('#modal-cal-event .color-dot').forEach(d=>d.classList.remove('sel'));
  calInitRecurUI(ev.recur||'once');
  openModal('modal-cal-event');
}

function openCalEventModal(){
  wcalOpenNewEventOnDay(wcalDayKey(new Date()));
}

function delEditingCalEvent(){
  if(!calEditingId) return;
  hState.calEvents = (hState.calEvents||[]).filter(e=>e.id!==calEditingId);
  saveH(); closeModal('modal-cal-event'); renderCalendar();
  toast('Événement supprimé','var(--red)');
}

// ── Recurrence UI — state ──
let _calCustomDays = new Set(); // for 'custom' mode: selected days

function calSetFreq(freq){
  // Update chips
  document.querySelectorAll('.recur-chip').forEach(c=>c.classList.toggle('active', c.dataset.freq===freq));
  // Show/hide days row
  document.getElementById('recur-days-row').style.display = freq==='custom' ? '' : 'none';
  // Show/hide end row
  document.getElementById('recur-end-row').style.display  = freq==='once'   ? 'none' : '';
  // Show/hide date row (for the event date field)
  document.getElementById('cal-date-row').style.display   = freq==='once'   ? '' : 'none';
  // Sync hidden field
  calSyncRecurValue();
}

function calToggleDay(day){
  if(_calCustomDays.has(day)) _calCustomDays.delete(day);
  else _calCustomDays.add(day);
  document.querySelectorAll('.recur-day-btn').forEach(b=>{
    b.classList.toggle('active', _calCustomDays.has(b.dataset.day));
  });
  calSyncRecurValue();
}

function calSyncRecurValue(){
  const freq = document.querySelector('.recur-chip.active')?.dataset.freq || 'once';
  let val = freq;
  if(freq==='custom'){
    const days = ['mon','tue','wed','thu','fri','sat','sun'].filter(d=>_calCustomDays.has(d));
    // If only one day selected, store as that day key; else store comma-joined
    val = days.length===1 ? days[0] : (days.length>1 ? 'custom:'+days.join(',') : 'once');
  }
  document.getElementById('cal-ev-recur').value = val;
}

// ── Init recur UI when opening modal ──
function calInitRecurUI(recurVal){
  _calCustomDays.clear();
  let freq = 'once';
  const singleDays = ['mon','tue','wed','thu','fri','sat','sun'];
  if(recurVal==='daily')  freq='daily';
  else if(recurVal==='weekly') freq='weekly';
  else if(singleDays.includes(recurVal)){ freq='custom'; _calCustomDays.add(recurVal); }
  else if(recurVal && recurVal.startsWith('custom:')){ freq='custom'; recurVal.replace('custom:','').split(',').forEach(d=>_calCustomDays.add(d)); }
  else freq='once';

  // Chips
  document.querySelectorAll('.recur-chip').forEach(c=>c.classList.toggle('active', c.dataset.freq===freq));
  // Day buttons
  document.querySelectorAll('.recur-day-btn').forEach(b=>b.classList.toggle('active', _calCustomDays.has(b.dataset.day)));
  // Rows
  document.getElementById('recur-days-row').style.display = freq==='custom' ? '' : 'none';
  document.getElementById('recur-end-row').style.display  = freq==='once'   ? 'none' : '';
  document.getElementById('cal-date-row').style.display   = freq==='once'   ? '' : 'none';
  // Reset end to "never"
  const nv = document.getElementById('recur-end-never');
  if(nv) nv.checked = true;
}

function calSelectColor(col, id){
  calEvColor = col;
  document.querySelectorAll('#modal-cal-event .color-dot').forEach(d=>d.classList.remove('sel'));
  document.getElementById(id).classList.add('sel');
}

function saveCalEvent(){
  const title = document.getElementById('cal-ev-title').value.trim();
  if(!title){ toast('Ajoute un titre','var(--red)'); return; }
  if(!hState.calEvents) hState.calEvents = [];

  // Validate custom recurrence: must have at least one day selected
  const activeChip = document.querySelector('.recur-chip.active');
  if(activeChip && activeChip.dataset.freq==='custom' && _calCustomDays.size===0){
    toast('Sélectionne au moins un jour','var(--red)'); return;
  }

  const recur = document.getElementById('cal-ev-recur').value;
  const ev = {
    id: calEditingId || ('ce'+Date.now()),
    title,
    date:  (recur==='once' ? document.getElementById('cal-ev-date').value : wcalDayKey(new Date())) || todayKey(),
    start: document.getElementById('cal-ev-start').value || '09:00',
    end:   document.getElementById('cal-ev-end').value   || '10:00',
    desc:  document.getElementById('cal-ev-desc').value.trim(),
    color: calEvColor,
    recur,
  };

  if(calEditingId){
    const idx = hState.calEvents.findIndex(e=>e.id===calEditingId);
    if(idx>=0) hState.calEvents[idx] = ev; else hState.calEvents.push(ev);
  } else {
    hState.calEvents.push(ev);
  }

  saveH(); closeModal('modal-cal-event'); renderCalendar();
  toast(calEditingId ? 'Événement modifié ✓' : 'Événement ajouté ✓','var(--g)');
}

// Legacy stubs
function delCalEvent(id){ hState.calEvents=(hState.calEvents||[]).filter(e=>e.id!==id); saveH(); renderCalendar(); }

// Auto-refresh now-line every minute
setInterval(()=>{ 
  if(document.getElementById('view-calendar').classList.contains('active')) renderCalendar();
}, 60000);

// Init wcalHourH from CSS var on load
(function(){
  const v=parseInt(getComputedStyle(document.documentElement).getPropertyValue('--wcal-hour-h'));
  if(v&&!isNaN(v)) wcalHourH=v;
})();

</script>
<!-- ── MODAL: GÉRER LES ACTIVITÉS CHRONO ── -->
<div class="modal-bg" id="modal-chrono-activities"><div class="modal-box">
  <div class="modal-header">
    <div class="modal-title"><svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle"><path d="M11 2L4 11h7l-2 7 9-10h-7l2-8z"/></svg> Activités du Chrono</div>
    <button class="modal-close" onclick="closeModal('modal-chrono-activities')">✕</button>
  </div>
  <div style="margin-bottom:16px">
    <div class="inp-lbl" style="margin-bottom:6px">Ajouter une activité</div>
    <div style="display:flex;gap:8px">
      <input class="inp" id="new-chrono-act-input" placeholder="Ex: Lecture, Yoga, Code..." maxlength="32" onkeydown="if(event.key==='Enter')saveNewChronoActivity()">
      <button class="btn btn-green btn-sm" onclick="saveNewChronoActivity()" style="white-space:nowrap">+ Ajouter</button>
    </div>
  </div>
  <div class="inp-lbl" style="margin-bottom:8px">Activités actuelles</div>
  <div id="manage-chrono-activities-list"></div>
</div></div>

<!-- Hidden YouTube player for ambient sound -->
<iframe id="yt-player-frame" allow="autoplay" style="display:none;position:absolute;width:1px;height:1px;opacity:0;pointer-events:none" frameborder="0"></iframe>

<!-- ══════════════════════════════════════════
     BOTTOM NAV BAR (mobile only)
══════════════════════════════════════════ -->
<nav class="bottom-nav" id="bottomNav" aria-label="Navigation principale">
  <div class="bottom-nav-inner" id="bottomNavInner">
    <!-- tabs injected by JS depending on mode -->
  </div>
</nav>

<!-- ══ MORE DRAWER (bottom sheet) ══ -->
<div class="bottom-drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
<div class="bottom-drawer" id="bottomDrawer">
  <div class="drawer-handle"></div>

  <!-- Mode switcher inside drawer -->
  <div class="drawer-mode-section">
    <div class="drawer-mode-lbl">Mode</div>
    <div class="drawer-mode-switcher">
      <div class="drawer-mode-pill" id="drawer-pill-biz" onclick="setMode('biz');closeDrawer()">
        <svg viewBox="0 0 20 20"><path d="M10 3L4 11h5v6h2v-6h5L10 3z"/></svg> Business
      </div>
      <div class="drawer-mode-pill" id="drawer-pill-hab" onclick="setMode('hab');closeDrawer()">
        <svg viewBox="0 0 20 20"><path d="M10 2c0 0-7 4-7 9a7 7 0 0014 0c0-5-7-9-7-9z"/></svg> Habitudes
      </div>
    </div>
  </div>

  <!-- Extra nav items (everything not in the 4 main tabs) -->
  <div class="drawer-nav-section" id="drawerNavItems"></div>

  <!-- XP block -->
  <div class="drawer-xp-block" style="margin-bottom:16px">
    <div class="level-badge" id="drawer-level-badge"><svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 18V10M10 10C10 10 6 6 3 4c5-2 7 2 7 6M10 10c0 0 4-4 7-6-2 5-7 6-7 6"/></svg> Niveau 1</div>
    <div class="xp-bar-bg"><div class="xp-bar-fill" id="drawer-xp-bar" style="width:0%"></div></div>
    <div class="xp-lbl"><span id="drawer-xp-val">0 / 100 XP</span></div>
    <div class="streak-pill" id="drawer-streak" style="margin-top:8px"><svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2C10 2 5 8 5 12.5a5 5 0 0010 0C15 8 10 2 10 2z"/><path d="M10 15.5a2 2 0 010-4"/></svg> 0 jours</div>
  </div>
</div>

<script>
/* ══════════════════════════════════════════
   BOTTOM NAV LOGIC
══════════════════════════════════════════ */

// Tab definitions per mode
const BIZ_TABS = [
  { id:'command',  label:'Home',     svg:'<path d="M10 3L4 11h5v6h2v-6h5L10 3z"/>' },
  { id:'finance',  label:'Finance',  svg:'<rect x="2" y="12" width="4" height="6" rx="1"/><rect x="8" y="8" width="4" height="10" rx="1"/><rect x="14" y="4" width="4" height="14" rx="1"/>' },
  { id:'tasks',    label:'Tâches',   svg:'<path d="M9 5h8M9 10h8M9 15h8M4 5l1 1 2-2M4 10l1 1 2-2M4 15l1 1 2-2"/>' },
  { id:'coach',    label:'AI Coach', svg:'<rect x="3" y="5" width="14" height="10" rx="2"/><path d="M7 9h6M7 12h4"/><path d="M10 15v2"/>' },
  { id:'__more__', label:'Plus',     svg:'<circle cx="5" cy="10" r="1.2"/><circle cx="10" cy="10" r="1.2"/><circle cx="15" cy="10" r="1.2"/>' }
];

const HAB_TABS = [
  { id:'today',    label:'Aujourd\'hui', svg:'<circle cx="10" cy="10" r="4"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.2 4.2l1.4 1.4M14.4 14.4l1.4 1.4M4.2 15.8l1.4-1.4M14.4 5.6l1.4-1.4"/>' },
  { id:'calendar', label:'Agenda',       svg:'<rect x="3" y="4" width="14" height="13" rx="2"/><path d="M3 8h14M7 2v4M13 2v4"/>' },
  { id:'focus',    label:'Focus',        svg:'<circle cx="10" cy="10" r="7"/><path d="M10 7v3l2 2"/>' },
  { id:'stats',    label:'Stats',        svg:'<polyline points="3,16 7,10 11,13 17,7"/>' },
  { id:'__more__', label:'Plus',         svg:'<circle cx="5" cy="10" r="1.2"/><circle cx="10" cy="10" r="1.2"/><circle cx="15" cy="10" r="1.2"/>' }
];

// Extra items shown in drawer (everything not in main tabs)
const BIZ_DRAWER = [
  { group:'Business' },
  { id:'strategy',     label:'Stratégie',    svg:'<circle cx="10" cy="10" r="7"/><circle cx="10" cy="10" r="3"/><path d="M10 3v2M10 15v2M3 10h2M15 10h2"/>' },
  { id:'products',     label:'Product Lab',  svg:'<path d="M10 2l1.5 4.5H16l-3.5 2.5 1.5 4.5L10 11l-4 2.5 1.5-4.5L4 6.5h4.5L10 2z"/>' },
  { id:'ads',          label:'Ads Control',  svg:'<path d="M3 7h8l4-3v12l-4-3H3V7z"/><path d="M15 9a2 2 0 010 2"/>' },
  { id:'analytics',    label:'Analytics',    svg:'<polyline points="3,14 7,9 11,11 17,5"/><polyline points="13,5 17,5 17,9"/>' },
  { group:'Outils' },
  { id:'knowledge',    label:'Knowledge',    svg:'<path d="M4 4h12v12a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/><path d="M8 4v8l2-2 2 2V4"/>' },
  { id:'hub',          label:'Hub de liens', svg:'<path d="M10 13a3 3 0 100-6 3 3 0 000 6z"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2"/>' },
  { id:'integrations', label:'Intégrations', svg:'<path d="M12 2H8v4H4l2 2-2 2h4v4h4v-4h4l-2-2 2-2h-4V2z"/>' },
  { id:'settings',     label:'Paramètres',   svg:'<circle cx="10" cy="10" r="2.5"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.9 4.9l1.4 1.4M13.7 13.7l1.4 1.4M4.9 15.1l1.4-1.4M13.7 6.3l1.4-1.4"/>' }
];

const HAB_DRAWER = [
  { group:'Habitudes' },
  { id:'objectives', label:'Objectifs',   svg:'<path d="M4 4v12l6-3 6 3V4z"/>' },
  { id:'rewards',    label:'Récompenses', svg:'<path d="M10 2l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4z"/>' },
  { id:'manage',     label:'Gérer',       svg:'<path d="M3 6h14M3 10h14M3 14h8"/><path d="M15 11l4 4-4 4"/>' },
  { group:'Outils' },
  { id:'settings',   label:'Paramètres',  svg:'<circle cx="10" cy="10" r="2.5"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.9 4.9l1.4 1.4M13.7 13.7l1.4 1.4M4.9 15.1l1.4-1.4M13.7 6.3l1.4-1.4"/>' }
];

let _drawerOpen = false;
let _currentBnView = '';

function renderBottomNav(mode, activeView) {
  const tabs = mode === 'biz' ? BIZ_TABS : HAB_TABS;
  const inner = document.getElementById('bottomNavInner');
  inner.innerHTML = tabs.map(t => {
    const isMore = t.id === '__more__';
    const isActive = !isMore && t.id === activeView;
    return `<button class="bn-tab${isActive ? ' active' : ''}" 
      onclick="${isMore ? 'openDrawer()' : `bnNav('${t.id}')`}"
      aria-label="${t.label}">
      <span class="bn-icon">
        <svg viewBox="0 0 20 20">${t.svg}</svg>
      </span>
      <span class="bn-label">${t.label}</span>
    </button>`;
  }).join('');
  _currentBnView = activeView;
}

function renderDrawerNav(mode, activeView) {
  const items = mode === 'biz' ? BIZ_DRAWER : HAB_DRAWER;
  const el = document.getElementById('drawerNavItems');
  el.innerHTML = items.map(it => {
    if (it.group) return `<div class="drawer-nav-group">${it.group}</div>`;
    const isActive = it.id === activeView;
    return `<div class="drawer-nav-item${isActive ? ' active' : ''}" onclick="bnNav('${it.id}');closeDrawer()">
      <span class="drawer-nav-icon">
        <svg viewBox="0 0 20 20">${it.svg}</svg>
      </span>
      <span>${it.label}</span>
    </div>`;
  }).join('');

  // Update drawer mode pills
  const pillBiz = document.getElementById('drawer-pill-biz');
  const pillHab = document.getElementById('drawer-pill-hab');
  pillBiz.className = 'drawer-mode-pill' + (mode === 'biz' ? ' active-biz' : '');
  pillHab.className = 'drawer-mode-pill' + (mode === 'hab' ? ' active-hab' : '');
}

function bnNav(viewId) {
  showView(viewId);
  _currentBnView = viewId;
  renderBottomNav(currentMode, viewId);
  renderDrawerNav(currentMode, viewId);
}

function openDrawer() {
  _drawerOpen = true;
  document.getElementById('drawerOverlay').classList.add('open');
  const drawer = document.getElementById('bottomDrawer');
  drawer.classList.add('open');
  renderDrawerNav(currentMode, _currentBnView);
  // Sync XP data into drawer
  syncDrawerXP();
  document.body.style.overflow = 'hidden';
}

function closeDrawer() {
  _drawerOpen = false;
  document.getElementById('drawerOverlay').classList.remove('open');
  document.getElementById('bottomDrawer').classList.remove('open');
  document.body.style.overflow = '';
}

function syncDrawerXP() {
  // Mirror the sidebar XP block into the drawer
  const sLevel = document.getElementById('s-level-badge');
  const sBar   = document.getElementById('s-xp-bar');
  const sVal   = document.getElementById('s-xp-val');
  const sStrk  = document.getElementById('s-streak');
  if(sLevel) document.getElementById('drawer-level-badge').textContent = sLevel.textContent;
  if(sBar)   document.getElementById('drawer-xp-bar').style.width = sBar.style.width;
  if(sVal)   document.getElementById('drawer-xp-val').textContent = sVal.textContent;
  if(sStrk)  document.getElementById('drawer-streak').textContent = sStrk.textContent;
}

// Patch setMode to also update bottom nav
const _origSetMode = setMode;
setMode = function(mode) {
  _origSetMode(mode);
  const defaultView = mode === 'biz' ? 'command' : 'today';
  _currentBnView = defaultView;
  renderBottomNav(mode, defaultView);
  renderDrawerNav(mode, defaultView);
};

// Patch showView to also update bottom nav highlight
const _origShowView = showView;
showView = function(name) {
  _origShowView(name);
  if(window.innerWidth <= 900) {
    _currentBnView = name;
    renderBottomNav(currentMode, name);
  }
};

// Init on load
(function initBottomNav() {
  if(window.innerWidth > 900) return;
  const mode = currentMode || 'biz';
  const defaultView = mode === 'biz' ? 'command' : 'today';
  _currentBnView = defaultView;
  renderBottomNav(mode, defaultView);
  renderDrawerNav(mode, defaultView);
})();

// Re-init on resize
window.addEventListener('resize', () => {
  if(window.innerWidth <= 900) {
    renderBottomNav(currentMode, _currentBnView);
  }
});

// Swipe down to close drawer
(function() {
  let startY = 0;
  const drawer = document.getElementById('bottomDrawer');
  drawer.addEventListener('touchstart', e => { startY = e.touches[0].clientY; }, {passive:true});
  drawer.addEventListener('touchend', e => {
    const dy = e.changedTouches[0].clientY - startY;
    if(dy > 60) closeDrawer();
  }, {passive:true});
})();
</script>
</body>
</html>
