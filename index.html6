  <div class="inp-group"><div class="inp-label">Horizon</div><select class="inp" id="goal-horizon"><option>Semaine</option><option>Mois</option><option>Trimestre</option><option>Année</option></select></div>
  <div class="inp-group"><div class="inp-label">Deadline</div><input class="inp" type="date" id="goal-deadline"></div>
