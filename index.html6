    <div>
      <div class="modal-title">🎯 Plan d'action — Aujourd'hui</div>
      <div style="font-size:.76rem;color:var(--text2);margin-top:3px">Ce que tu dois faire pour te rapprocher de 4 000€/jour</div>
    </div>
    <button class="modal-close" onclick="closeModal('modal-goal-plan')">✕</button>
  </div>
  <div id="goal-plan-content"></div>
</div></div>

<!-- Add Habit -->
<div class="modal-overlay" id="habitModal">
  <div class="modal-sheet">
    <h3 id="modal-title" style="margin-bottom:16px">Nouvelle habitude</h3>
    <div class="modal-row"><div class="modal-label">Nom</div><input class="inp" id="modal-name" placeholder="Ex: Méditation"></div>
    <div class="modal-row"><div class="modal-label">Emoji</div><div class="emoji-grid" id="emoji-grid"></div></div>
    <div class="modal-row"><div class="modal-label">XP par complétion</div><input class="inp" id="modal-xp" type="number" placeholder="10" value="10" min="5" max="50"></div>
    <div class="modal-row"><div class="modal-label">Couleur</div><div class="color-picker-row" id="modal-color-picker"></div></div>
    <div class="modal-btns">
      <button class="btn btn-ghost" onclick="closeHabitModal()">Annuler</button>
      <button class="btn btn-green" onclick="saveHabit()">Enregistrer</button>
    </div>
  </div>
</div>

<!-- Recap -->
<div class="recap-modal" id="recapModal">
  <div class="recap-inner">
    <h2>Récap de la semaine 📋</h2>
    <div class="recap-badge" id="recap-badge">Grade S</div>
    <div class="recap-text" id="recap-content"></div>
    <div style="margin-top:20px;text-align:center"><button class="btn btn-green" onclick="closeRecap()">C'est noté ! 💪</button></div>
  </div>
</div>

<div class="toast" id="toast"></div>
<div class="burst" id="burst"></div>

<script>
// ══════════════════════════════════════════════════════
//  MODE SWITCHER
// ══════════════════════════════════════════════════════
let currentMode = localStorage.getItem('gabos_mode') || 'biz';

function setMode(mode) {
  currentMode = mode;
  localStorage.setItem('gabos_mode', mode);
  document.body.className = 'mode-' + mode;
  
  const bizNav = document.getElementById('nav-section-biz');
  const habNav = document.getElementById('nav-section-hab');
  const badge = document.getElementById('sidebar-mode-badge');
  const slider = document.getElementById('modeSlider');
  const pillBiz = document.querySelector('.mode-pill-biz');
  const pillHab = document.querySelector('.mode-pill-hab');
  const switcher = document.getElementById('modeSwitcher');
  
  if (mode === 'biz') {
    bizNav.classList.remove('hidden-section');
    habNav.classList.add('hidden-section');
    badge.textContent = '⚡ Business';
    pillBiz.classList.add('active-biz');
    pillHab.classList.remove('active-hab');
    // Position slider over biz pill
    const bizRect = pillBiz.getBoundingClientRect();
    const switchRect = switcher.getBoundingClientRect();
    slider.style.left = (bizRect.left - switchRect.left - 5) + 'px';
    slider.style.width = (bizRect.width + 10) + 'px';
    showView('command');
  } else {
    bizNav.classList.add('hidden-section');
    habNav.classList.remove('hidden-section');
    badge.textContent = '🌱 Habitudes';
    pillBiz.classList.remove('active-biz');
    pillHab.classList.add('active-hab');
    const habRect = pillHab.getBoundingClientRect();
    const switchRect = switcher.getBoundingClientRect();
    slider.style.left = (habRect.left - switchRect.left - 5) + 'px';
    slider.style.width = (habRect.width + 10) + 'px';
    showView('today');
  }
}

function initSlider() {
  const mode = currentMode;
  document.body.className = 'mode-' + mode;
  const slider = document.getElementById('modeSlider');
  const switcher = document.getElementById('modeSwitcher');
  const pill = document.querySelector('.mode-pill-' + mode);
  if (pill && switcher) {
    const pr = pill.getBoundingClientRect();
    const sr = switcher.getBoundingClientRect();
    slider.style.transition = 'none';
    slider.style.left = (pr.left - sr.left - 5) + 'px';
    slider.style.width = (pr.width + 10) + 'px';
    setTimeout(() => { slider.style.transition = ''; }, 50);
  }
  const bizNav = document.getElementById('nav-section-biz');
  const habNav = document.getElementById('nav-section-hab');
  const badge = document.getElementById('sidebar-mode-badge');
  if (mode === 'biz') {
    bizNav.classList.remove('hidden-section');
    habNav.classList.add('hidden-section');
    badge.textContent = '⚡ Business';
    document.querySelector('.mode-pill-biz').classList.add('active-biz');
  } else {
    bizNav.classList.add('hidden-section');
    habNav.classList.remove('hidden-section');
    badge.textContent = '🌱 Habitudes';
    document.querySelector('.mode-pill-hab').classList.add('active-hab');
  }
}

// ══════════════════════════════════════════════════════
//  CONSTANTS
// ══════════════════════════════════════════════════════
const COLORS = ['#7c5cfc','#fc5c7d','#00f5c4','#ffd166','#06d6a0','#ef476f','#4fc3ff','#f77f00'];
const EMOJIS = ['📚','💼','⚽','🧠','🤸','🧘','🏃','💪','🎯','🎨','🎵','🍎','💤','🧪','✍️','🌱','🔥','⚡'];
const BADGES = [
  {id:'b1',icon:'🔥',name:'7 Jours',cond:'7 jours de suite',req:{streak:7}},
  {id:'b2',icon:'💎',name:'30 Jours',cond:'30 jours de suite',req:{streak:30}},
  {id:'b3',icon:'⚡',name:'Perfectionniste',cond:'100% une journée',req:{perfect:1}},
  {id:'b4',icon:'🌟',name:'Semaine parfaite',cond:'7 jours parfaits',req:{perfectDays:7}},
  {id:'b5',icon:'🏆',name:'Niveau 5',cond:'Atteindre niveau 5',req:{level:5}},
  {id:'b6',icon:'🎯',name:'Maestro',cond:'Niveau 10',req:{level:10}},
  {id:'b7',icon:'🦅',name:'Matinal',cond:'5+ habitudes actives',req:{habitsCount:5}},
  {id:'b8',icon:'👑',name:'Légende',cond:'100 jours de streak',req:{streak:100}},
];
const LEVELS = [
  {min:0,name:'Débutant',emoji:'🌱'},
  {min:100,name:'Régulier',emoji:'⚡'},
  {min:300,name:'Déterminé',emoji:'🔥'},
  {min:600,name:'Discipliné',emoji:'💎'},
  {min:1000,name:'Elite',emoji:'🏆'},
  {min:2000,name:'Inarrêtable',emoji:'👑'},
];

// ══════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════
function defaultHabitState() {
  return {
    habits:[
      {id:'h1',name:'Devoirs',emoji:'📚',color:'#7c5cfc',xp:15},
      {id:'h2',name:'Business',emoji:'💼',color:'#ffd166',xp:20},
      {id:'h3',name:'Sport',emoji:'⚽',color:'#fc5c7d',xp:20},
      {id:'h4',name:'Apprendre',emoji:'🧠',color:'#4fc3ff',xp:15},
      {id:'h5',name:'Méditation',emoji:'🧘',color:'#00f5c4',xp:10},
    ],
    history:{},xp:0,perfectDays:0,unlockedBadges:[],
    notifs:{daily:true,weekly:true,streak:false},
    selectedColor:COLORS[0],editingHabit:null,lastRecapKey:null,
  };
}
function defaultBizState() {
  return {
    transactions:[],products:[],campaigns:[],metrics:[],tasks:[],goals:[],
    links:[
      {id:'l1',name:'Shopify Admin',url:'https://purrlopets.myshopify.com/admin',icon:'🛒',cat:'E-commerce'},
      {id:'l2',name:'Mega.nz Formation',url:'https://mega.nz/folder/FQg2lSaS#rYlByvveQyHOpaXHvHDITg',icon:'🎓',cat:'Formation'},
      {id:'l3',name:'Meta Ads',url:'https://business.facebook.com',icon:'📘',cat:'Publicité'},
      {id:'l4',name:'TikTok Ads',url:'https://ads.tiktok.com',icon:'🎵',cat:'Publicité'},
      {id:'l5',name:'Gmail',url:'https://mail.google.com',icon:'📧',cat:'Communication'},
    ],
    resources:[],formationActions:[],formationHours:0,formationNotes:'',strategyNotes:'',editingProductId:null,
  };
}

let hState, bState;
try { const hs=JSON.parse(localStorage.getItem('gabos_habits')||'null'); hState=hs?{...defaultHabitState(),...hs}:defaultHabitState(); } catch { hState=defaultHabitState(); }
try { const bs=JSON.parse(localStorage.getItem('gabos_biz')||'null'); bState=bs?{...defaultBizState(),...bs}:defaultBizState(); } catch { bState=defaultBizState(); }
function saveH() { localStorage.setItem('gabos_habits',JSON.stringify(hState)); }
function saveB() { localStorage.setItem('gabos_biz',JSON.stringify(bState)); }

// ══════════════════════════════════════════════════════
//  UTILS
// ══════════════════════════════════════════════════════
function todayKey() { return new Date().toISOString().slice(0,10); }
function keyForDate(d) { return d.toISOString().slice(0,10); }
function fmtDate(d) { return new Date(d+'T12:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'}); }
function daysLeft() { return Math.ceil((new Date('2026-12-01')-new Date())/(1000*60*60*24)); }
function todayData() { const k=todayKey();if(!hState.history[k])hState.history[k]={};return hState.history[k]; }
function getLast(n) { const days=[];for(let i=n-1;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);days.push(keyForDate(d));}return days; }
function dateShort(ds) { const d=new Date(ds+'T12:00:00');return['Di','Lu','Ma','Me','Je','Ve','Sa'][d.getDay()]; }
function formatDateFull(ds) { const d=new Date(ds+'T00:00:00');return d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'}); }

// ══════════════════════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════════════════════
function showView(name) {
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  const ni=document.getElementById('nav-'+name);if(ni)ni.classList.add('active');
  closeSidebar();
  if(name==='today'){renderToday();}
  if(name==='stats'){renderStats();}
  if(name==='objectives'){renderObjectives();}
  if(name==='rewards'){renderRewards();}
  if(name==='manage'){renderManage();renderColorPicker();}
  if(name==='command'){renderCommand();}
  if(name==='finance'){renderFinance('month');}
  if(name==='products'){renderProducts();}
  if(name==='ads'){renderAds();}
  if(name==='analytics'){renderAnalytics();}
  if(name==='tasks'){renderTasks();}
  if(name==='strategy'){renderStrategy();}
  if(name==='hub'){renderHub();}
  if(name==='knowledge'){renderKnowledge();}
}
function openSidebar(){document.getElementById('sidebar').classList.add('open');document.getElementById('sidebarOverlay').classList.add('show')}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('show')}
function openModal(id){document.getElementById(id).classList.add('open');document.querySelectorAll('#'+id+' input[type="date"]').forEach(i=>{if(!i.value)i.value=todayKey();});}
function closeModal(id){document.getElementById(id).classList.remove('open');}
function toast(msg,color){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=color||'var(--accent)';t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2500);}
function showToast(msg){toast(msg);}
function showBurst(em){const b=document.getElementById('burst');b.textContent=em;b.classList.remove('show');void b.offsetWidth;b.classList.add('show');setTimeout(()=>b.classList.remove('show'),700);}

// ══════════════════════════════════════════════════════
//  CLOCK
// ══════════════════════════════════════════════════════
function updateClock() {
  const n=new Date(),t=n.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const el=document.getElementById('cmd-clock');if(el)el.textContent=t;
  const el2=document.getElementById('clock-today');if(el2)el2.textContent=t.slice(0,5);
  const ds=document.getElementById('goal-days-left-sidebar');if(ds)ds.textContent=daysLeft()+' jours restants';
  setTimeout(updateClock,1000);
}

// ══════════════════════════════════════════════════════
//  HABIT CALCS
// ══════════════════════════════════════════════════════
function completionPct(dayKey){const h=hState.history[dayKey]||{};const total=hState.habits.length;if(!total)return 0;return Math.round((hState.habits.filter(hb=>h[hb.id]).length/total)*100);}
function avgPct(days){const vals=days.map(d=>completionPct(d));return Math.round(vals.reduce((a,b)=>a+b,0)/vals.length);}
function calcStreak(){let streak=0,d=new Date();while(streak<365){const k=keyForDate(d);if(completionPct(k)>=50)streak++;else break;d.setDate(d.getDate()-1);}return streak;}
function habitStreak(hid){let streak=0,d=new Date();d.setDate(d.getDate()-1);while(streak<365){const k=keyForDate(d);if(hState.history[k]&&hState.history[k][hid])streak++;else break;d.setDate(d.getDate()-1);}return streak;}
function levelInfo(){const xp=hState.xp||0;let lv=0;for(let i=0;i<LEVELS.length;i++){if(xp>=LEVELS[i].min)lv=i;}const cur=LEVELS[lv],next=LEVELS[lv+1],xpIn=xp-cur.min,xpNeed=next?next.min-cur.min:500,progress=Math.min(100,Math.round((xpIn/xpNeed)*100));return{num:lv+1,name:cur.name,emoji:cur.emoji,progress,xpIn,xpNeed};}
function updateXP(){
  const lv=levelInfo(),streak=calcStreak();
  document.getElementById('s-level-badge').textContent=`${lv.emoji} Niveau ${lv.num} — ${lv.name}`;
  document.getElementById('s-xp-val').textContent=`${lv.xpIn} / ${lv.xpNeed} XP`;
  document.getElementById('s-xp-bar').style.width=lv.progress+'%';
  document.getElementById('s-streak').textContent=`🔥 ${streak} jours`;
}
function addXP(amount){const oldLv=levelInfo().num;hState.xp=(hState.xp||0)+amount;if(levelInfo().num>oldLv)showToast(`🏆 NIVEAU ${levelInfo().num} ! ${levelInfo().emoji} ${levelInfo().name}`);updateXP();}
function checkBadges(){
  const streak=calcStreak(),lv=levelInfo().num;
  BADGES.forEach(b=>{
    if((hState.unlockedBadges||[]).includes(b.id))return;
    let unlock=false;
    if(b.req.streak&&streak>=b.req.streak)unlock=true;
    if(b.req.perfect&&(hState.perfectDays||0)>=b.req.perfect)unlock=true;
    if(b.req.perfectDays&&(hState.perfectDays||0)>=b.req.perfectDays)unlock=true;
    if(b.req.level&&lv>=b.req.level)unlock=true;
    if(b.req.habitsCount&&hState.habits.length>=b.req.habitsCount)unlock=true;
    if(unlock){hState.unlockedBadges=[...(hState.unlockedBadges||[]),b.id];setTimeout(()=>showToast(`★ Badge : ${b.icon} ${b.name} !`),800);}
  });
}

// ══════════════════════════════════════════════════════
//  RENDER TODAY (HABITS)
// ══════════════════════════════════════════════════════
function renderToday(){
  const td=todayData(),total=hState.habits.length,doneArr=hState.habits.filter(h=>td[h.id]),pct=total?Math.round((doneArr.length/total)*100):0;
  const now=new Date(),hour=now.getHours();
  document.getElementById('today-title').textContent=(hour<12?'Bonjour':'Bonsoir')+' '+getUserName()+' 👋';
  document.getElementById('today-date').textContent=formatDateFull(todayKey());
  const circ=2*Math.PI*54;
  document.getElementById('ring-circle').style.strokeDashoffset=circ-(pct/100)*circ;
  document.getElementById('ring-pct').textContent=pct+'%';
  document.getElementById('done-count').textContent=doneArr.length;
  document.getElementById('remain-count').textContent=total-doneArr.length;
  const xpEarned=doneArr.reduce((s,h)=>s+(h.xp||10),0)+(doneArr.length===total&&total>0?25:0);
  document.getElementById('today-xp-total').textContent=xpEarned;
  const msgs=[['Lance-toi !','Commence par une petite habitude.'],['Bel effort !','Tu es lancé, continue !'],['Plus de la moitié !','Tu es à mi-chemin !'],['Presque là !','Un dernier effort !'],['Journée parfaite ! 🎉','100% cochés. Tu es une machine !']];
  const mi=pct===100?4:pct>=75?3:pct>=50?2:pct>=25?1:0;
  document.getElementById('ring-msg').textContent=msgs[mi][0];
  document.getElementById('ring-submsg').textContent=msgs[mi][1];
  const list=document.getElementById('habits-list');list.innerHTML='';
  if(!hState.habits.length){list.innerHTML='<div class="empty-state">Aucune habitude. Va dans "Gérer habitudes" pour en ajouter !</div>';return;}
  hState.habits.forEach(h=>{
    const done=!!td[h.id],hs=habitStreak(h.id),card=document.createElement('div');
    card.className='habit-card'+(done?' done':'');
    card.style.setProperty('--habit-color',h.color||'#7c5cfc');
    card.innerHTML=`<div class="habit-emoji">${h.emoji||'⭐'}</div><div class="habit-info"><div class="habit-name">${h.name}</div><div class="habit-streak-text"><span style="color:var(--gold)">${hs}🔥</span> jours de suite</div></div><div class="habit-xp">+${h.xp||10} XP</div><div class="habit-actions"><button class="btn-icon" onclick="editHabitQuick('${h.id}',event)">✎</button><button class="btn-icon" onclick="removeHabit('${h.id}',event)" style="color:var(--red)">✕</button></div><div class="habit-check">${done?'✓':''}</div>`;
    card.addEventListener('click',e=>{if(!e.target.closest('.habit-actions'))toggleHabit(h.id,card);});
    list.appendChild(card);
  });
  const zone=document.getElementById('today-insight');
  if(pct===100)zone.innerHTML=`<div class="insight-card ok-card"><div class="i-head"><span class="i-icon">🎉</span><div><div class="i-title">Journée parfaite !</div></div></div><div class="i-body">Tu as tout complété aujourd'hui. Continue !</div></div>`;
  else if(pct>=50)zone.innerHTML=`<div class="insight-card"><div class="i-head"><span class="i-icon">👍</span><div><div class="i-title">Bonne avancée</div></div></div><div class="i-body">Plus que <strong>${total-doneArr.length}</strong> habitude(s) restante(s).</div></div>`;
  else zone.innerHTML='';
  updateXP();checkBadges();
}

function toggleHabit(hid,card){
  const td=todayData(),wasDone=!!td[hid],habit=hState.habits.find(h=>h.id===hid);
  td[hid]=!wasDone;
  if(!wasDone){
    addXP(habit.xp||10);showBurst(habit.emoji||'⭐');showToast(`+${habit.xp||10} XP — ${habit.name} ✓`);
    const allDone=hState.habits.every(h=>td[h.id]);
    if(allDone&&hState.habits.length>0){hState.perfectDays=(hState.perfectDays||0)+1;hState.xp=(hState.xp||0)+25;setTimeout(()=>{showBurst('🏆');showToast('🌟 Journée parfaite ! +25 XP bonus');},750);}
  }else{hState.xp=Math.max(0,(hState.xp||0)-(habit.xp||10));showToast(`${habit.name} retiré`);}
  saveH();checkBadges();renderToday();
}

// ══════════════════════════════════════════════════════
//  HABIT MANAGEMENT
// ══════════════════════════════════════════════════════
let selColor=COLORS[0],selEmoji=EMOJIS[0];
function renderColorPicker(){const cp=document.getElementById('color-picker');if(!cp)return;cp.innerHTML=COLORS.map(c=>`<div class="color-dot${c===selColor?' sel':''}" style="background:${c}" onclick="selectColor('${c}','color-picker')"></div>`).join('');}
function selectColor(c,pickerId){selColor=c;document.querySelectorAll('#'+pickerId+' .color-dot').forEach(d=>{d.classList.toggle('sel',d.style.background===c||d.style.backgroundColor===c);});}
function openAddModal(){hState.editingHabit=null;document.getElementById('modal-title').textContent='Nouvelle habitude';document.getElementById('modal-name').value='';document.getElementById('modal-xp').value=10;renderEmojiGrid();renderModalColorPicker();document.getElementById('habitModal').classList.add('open');}
function closeHabitModal(){document.getElementById('habitModal').classList.remove('open');}
function renderEmojiGrid(){const eg=document.getElementById('emoji-grid');eg.innerHTML=EMOJIS.map(e=>`<button class="emoji-btn${e===selEmoji?' sel':''}" onclick="selectEmoji('${e}')">${e}</button>`).join('');}
function selectEmoji(e){selEmoji=e;renderEmojiGrid();}
function renderModalColorPicker(){const mcp=document.getElementById('modal-color-picker');mcp.innerHTML=COLORS.map(c=>`<div class="color-dot${c===selColor?' sel':''}" style="background:${c}" onclick="selectColor('${c}','modal-color-picker')"></div>`).join('');}
function saveHabit(){
  const name=document.getElementById('modal-name').value.trim();if(!name){showToast('Donne un nom !');return;}
  const xp=parseInt(document.getElementById('modal-xp').value)||10;
  if(hState.editingHabit){const h=hState.habits.find(x=>x.id===hState.editingHabit);if(h){h.name=name;h.emoji=selEmoji;h.color=selColor;h.xp=xp;}}
  else hState.habits.push({id:'h'+Date.now(),name,emoji:selEmoji,color:selColor,xp});
  saveH();closeHabitModal();renderToday();renderManage&&renderManage();showToast('Habitude enregistrée ✓');
}
function editHabitQuick(id,e){e.stopPropagation();const h=hState.habits.find(x=>x.id===id);if(!h)return;hState.editingHabit=id;selEmoji=h.emoji||EMOJIS[0];selColor=h.color||COLORS[0];document.getElementById('modal-title').textContent='Modifier';document.getElementById('modal-name').value=h.name;document.getElementById('modal-xp').value=h.xp||10;renderEmojiGrid();renderModalColorPicker();document.getElementById('habitModal').classList.add('open');}
function removeHabit(id,e){e.stopPropagation();hState.habits=hState.habits.filter(h=>h.id!==id);saveH();renderToday();renderManage&&renderManage();}
function quickAddHabit(){const name=document.getElementById('quick-name').value.trim();if(!name)return;hState.habits.push({id:'h'+Date.now(),name,emoji:'⭐',color:selColor,xp:10});document.getElementById('quick-name').value='';saveH();renderToday();renderManage();showToast('Habitude ajoutée !');}
function renderManage(){
  const ml=document.getElementById('manage-list');if(!ml)return;
  ml.innerHTML=hState.habits.map(h=>`<div class="habit-manage-item"><div class="hm-emoji">${h.emoji||'⭐'}</div><div class="hm-name">${h.name}</div><div style="font-size:11px;color:var(--gold);margin-right:8px">+${h.xp||10}XP</div><div class="hm-btns"><button class="hm-btn" onclick="editHabitQuick2('${h.id}')">✎</button><button class="hm-btn" style="color:var(--red)" onclick="removeHabit('${h.id}',event)">✕</button></div></div>`).join('')||'<div class="empty-state">Aucune habitude</div>';
}
function editHabitQuick2(id){const h=hState.habits.find(x=>x.id===id);if(!h)return;hState.editingHabit=id;selEmoji=h.emoji||EMOJIS[0];selColor=h.color||COLORS[0];document.getElementById('modal-title').textContent='Modifier';document.getElementById('modal-name').value=h.name;document.getElementById('modal-xp').value=h.xp||10;renderEmojiGrid();renderModalColorPicker();document.getElementById('habitModal').classList.add('open');}
function toggleNotif(key,el){el.classList.toggle('on');hState.notifs[key]=el.classList.contains('on');saveH();if(hState.notifs[key]&&key==='daily'&&'Notification' in window){Notification.requestPermission().then(p=>showToast(p==='granted'?'Notifications activées ✅':'Notifications refusées'));}}
function confirmReset(){if(confirm('Réinitialiser toutes les données habitudes ?')){localStorage.removeItem('gabos_habits');hState=defaultHabitState();saveH();renderToday();renderManage();updateXP();showToast('Données réinitialisées');}}

// ══════════════════════════════════════════════════════
//  STATS (HABITS)
// ══════════════════════════════════════════════════════
let statRange='week',ch1,ch2;
function setStatRange(r,el){statRange=r;document.querySelectorAll('.chart-tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');renderStats();}
function renderStats(){
  const days=getLast(statRange==='week'?7:30),wa=avgPct(days),streak=calcStreak(),lv=levelInfo();
  document.getElementById('stats-kpis').innerHTML=`<div class="stat-card"><div class="s-val" style="color:var(--accent)">${wa}%</div><div class="s-lbl">Moy. ${statRange==='week'?'7j':'30j'}</div></div><div class="stat-card"><div class="s-val" style="color:var(--gold)">${streak}</div><div class="s-lbl">Streak 🔥</div></div><div class="stat-card"><div class="s-val" style="color:var(--accent3)">${hState.xp||0}</div><div class="s-lbl">XP Total</div></div><div class="stat-card"><div class="s-val" style="color:var(--accent2)">${hState.perfectDays||0}</div><div class="s-lbl">Jours parfaits</div></div>`;
  const pcts=days.map(d=>completionPct(d)),labels=days.map(dateShort);
  if(ch1)ch1.destroy();
  ch1=new Chart(document.getElementById('chart-daily'),{type:'bar',data:{labels,datasets:[{data:pcts,backgroundColor:pcts.map(p=>p>=80?'rgba(0,245,196,.7)':p>=50?'rgba(124,92,252,.7)':'rgba(252,92,125,.7)'),borderRadius:6,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{min:0,max:100,grid:{color:'rgba(255,255,255,.05)'},ticks:{color:'#7878a8',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#7878a8',font:{size:10}}}}}});
  const xpHistory=days.map((_,i)=>{let x=0;days.slice(0,i+1).forEach(d=>{const h2=hState.history[d]||{};hState.habits.forEach(h=>{if(h2[h.id])x+=h.xp||10;});});return x;});
  if(ch2)ch2.destroy();
  ch2=new Chart(document.getElementById('chart-xp'),{type:'line',data:{labels,datasets:[{data:xpHistory,borderColor:'var(--accent)',backgroundColor:'rgba(124,92,252,.1)',tension:.4,fill:true,pointBackgroundColor:'var(--accent)',pointRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{grid:{color:'rgba(255,255,255,.05)'},ticks:{color:'#7878a8',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#7878a8',font:{size:10}}}}}});
  const week7=getLast(7);
  document.getElementById('mini-bars').innerHTML=hState.habits.map(h=>{const d=week7.filter(day=>hState.history[day]&&hState.history[day][h.id]).length;const pct=Math.round(d/7*100);return`<div class="mini-bar-row"><div class="mini-bar-label">${h.emoji||''} ${h.name}</div><div class="mini-bar-bg"><div class="mini-bar-fill" style="width:${pct}%;background:${h.color||'var(--accent)'}"></div></div><div class="mini-bar-pct">${pct}%</div></div>`;}).join('');
  const ic=document.getElementById('insight-cards');ic.innerHTML='';
  if(wa>=80)ic.innerHTML+=`<div class="insight-card ok-card"><div class="i-head"><span class="i-icon">🚀</span><div><div class="i-title">Excellent momentum !</div></div></div><div class="i-body">Tu complètes ${wa}% de tes habitudes. Continue !</div></div>`;
  else if(wa<50)ic.innerHTML+=`<div class="insight-card warn-card"><div class="i-head"><span class="i-icon">⚠️</span><div><div class="i-title">Régularité à améliorer</div></div></div><div class="i-body">Beaucoup de jours incomplets. Fixe-toi 3 habitudes piliers non-négociables.</div></div>`;
  const ng=document.getElementById('next-goal-text');
  if(wa>=90)ng.textContent='Maintiens ton score. Essaie de ne pas manquer plus d\'1 habitude/jour.';
  else if(wa>=70)ng.textContent=`Passe de ${wa}% à ${Math.min(wa+10,100)}%. Focus sur tes habitudes les plus importantes.`;
  else ng.textContent='Objectif : 70% minimum. Choisis 3 habitudes piliers et ne les rate jamais.';
}

// ══════════════════════════════════════════════════════
//  OBJECTIVES (HABITS)
// ══════════════════════════════════════════════════════
function renderObjectives(){
  const streak=calcStreak(),lv=levelInfo(),wa7=avgPct(getLast(7)),wa30=avgPct(getLast(30));
  const days7=getLast(7);
  const habitStats=hState.habits.map(h=>{const done=days7.filter(d=>hState.history[d]&&hState.history[d][h.id]).length;return{h,done,pct:Math.round((done/7)*100)};});
  const sorted=[...habitStats].sort((a,b)=>b.pct-a.pct);
  const best=sorted[0],worst=sorted[sorted.length-1];

  // Next week goal
  let nextGoalTarget, nextGoalText;
  if(wa7>=90){nextGoalTarget=95;nextGoalText='Tu es au sommet ! Vise les 95% et maintiens le streak. Essaie de ne pas manquer plus d\'1 habitude par jour.';}
  else if(wa7>=75){nextGoalTarget=Math.min(wa7+10,100);nextGoalText=`Passe de ${wa7}% à ${nextGoalTarget}%. Focus intense sur ${worst?`<strong>${worst.h.emoji} ${worst.h.name}</strong>`:'tes habitudes faibles'} chaque jour.`;}
  else if(wa7>=50){nextGoalTarget=70;nextGoalText=`Atteins les 70%. Commence chaque journée en cochant tes 3 habitudes les plus importantes en premier.`;}
  else{nextGoalTarget=50;nextGoalText=`Objectif minimal : 50%. Concentre-toi sur seulement <strong>2-3 habitudes piliers</strong> — la quantité viendra après.`;}

  // Amélioration axes
  let axes=[];
  if(streak===0)axes.push({icon:'🔥',title:'Construire un streak',text:'Tu n\'as pas encore de streak actif. Commence aujourd\'hui et fais au moins 50% chaque jour.'});
  else if(streak<7)axes.push({icon:'🔥',title:'Stabiliser le streak',text:`${streak} jour(s) de streak. Atteins 7 jours consécutifs pour débloquer le badge 🔥 et créer l'habitude de la régularité.`});
  if(worst&&worst.pct<50)axes.push({icon:'⚠️',title:`${worst.h.emoji} ${worst.h.name} à rattraper`,text:`Seulement ${worst.pct}% cette semaine. Techniques : lie-la à une habitude existante, pose-la juste avant un moment fixe de ta journée.`});
  if(wa7<wa30&&wa30>0)axes.push({icon:'📉',title:'Régression récente',text:`Ta moyenne 7j (${wa7}%) est sous ta moyenne 30j (${wa30}%). Quelque chose a perturbé ta routine — identifie quoi.`});
  if(hState.habits.length<3)axes.push({icon:'➕',title:'Trop peu d\'habitudes',text:'Moins de 3 habitudes actives. Ajoute des habitudes clés pour maximiser ton XP et ton développement.'});
  if(lv.progress<20&&lv.num<5)axes.push({icon:'⚡',title:'XP à accélérer',text:`Tu es à ${lv.xpIn}/${lv.xpNeed} XP pour le niveau ${lv.num+1}. Complète toutes tes habitudes pendant 3 jours consécutifs.`});

  // Conseils personnalisés
  let conseils=[];
  const hour=new Date().getHours();
  if(hour<10)conseils.push({icon:'☀️',text:'<strong>Routine matinale :</strong> Coche tes habitudes simples en premier (hydratation, méditation) pour démarrer avec de l\'élan.'});
  else if(hour>20)conseils.push({icon:'🌙',text:'<strong>Récap de soirée :</strong> Avant de dormir, revois tes habitudes de demain. La préparation mentale augmente de 40% la réussite.'});
  if(streak>=3)conseils.push({icon:'🔗',text:`<strong>Effet chaîne :</strong> ${streak} jours de streak, ne brise pas la chaîne ! Si tu risques de rater, fais au moins 1 minute de chaque habitude.`});
  if(best&&best.pct===100)conseils.push({icon:'💎',text:`<strong>Point fort confirmé :</strong> ${best.h.emoji} <strong>${best.h.name}</strong> est ta meilleure habitude. Utilise cet élan pour en enchaîner une plus difficile juste après.`});
  if(wa7>=80)conseils.push({icon:'🚀',text:'<strong>Zone de fluidité :</strong> Tu es à 80%+. C\'est le moment d\'ajouter une nouvelle habitude ambitieuse — ton cerveau est en mode "construction".'});
  if(hState.perfectDays>0)conseils.push({icon:'🌟',text:`<strong>${hState.perfectDays} jour(s) parfait(s) !</strong> Tu sais que c'est possible. Vise-en un de plus cette semaine.`});
  if(conseils.length===0)conseils.push({icon:'💡',text:'<strong>Conseil du jour :</strong> La régularité bat l\'intensité. Vaut mieux 10 min/jour tous les jours que 2h une fois par semaine.'});

  document.getElementById('objectives-content').innerHTML=`
  <div class="grid-2">
    <div class="card">
      <div class="card-title">📊 Performance</div>
      <div class="grid-2" style="margin-bottom:0">
        <div style="text-align:center;padding:16px 0"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:2rem;color:var(--accent)">${wa7}%</div><div style="font-size:.72rem;color:var(--text2);margin-top:4px">Moy. 7 jours</div></div>
        <div style="text-align:center;padding:16px 0"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:2rem;color:var(--accent3)">${wa30}%</div><div style="font-size:.72rem;color:var(--text2);margin-top:4px">Moy. 30 jours</div></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">🏆 Niveau & XP</div>
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:12px">
        <div style="font-size:3rem">${lv.emoji}</div>
        <div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem">${lv.name}</div><div style="font-size:.8rem;color:var(--text2)">Niveau ${lv.num} · ${hState.xp||0} XP total</div></div>
      </div>
      <div class="xp-bar-bg"><div class="xp-bar-fill" style="width:${lv.progress}%"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:.72rem;color:var(--text2);margin-top:6px"><span>${lv.xpIn} XP</span><span>${lv.xpNeed} XP → niveau ${lv.num+1}</span></div>
    </div>
  </div>

  <div class="card" style="margin-bottom:16px">
    <div class="card-title">🔥 Streak actuel</div>
    <div style="display:flex;align-items:center;gap:20px">
      <div style="font-family:'Syne',sans-serif;font-size:3.5rem;font-weight:800;color:var(--gold)">${streak}</div>
      <div><div style="font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700">jours consécutifs</div><div style="font-size:.82rem;color:var(--text2);margin-top:4px">${streak>=30?'Incroyable ! Tu es au sommet 👑':streak>=14?'Excellent rythme ! 💎':streak>=7?'Très bien ! Continue 🔥':streak>0?'Lance-toi, construis la régularité ⚡':'Commence aujourd\'hui — 1 jour à la fois 🌱'}</div></div>
    </div>
  </div>

  <div class="card" style="margin-bottom:16px;border-color:rgba(124,92,252,.25)">
    <div class="card-title">🎯 Objectif semaine prochaine</div>
    <div style="display:flex;align-items:center;gap:16px">
      <div style="font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:800;color:var(--accent)">${nextGoalTarget}%</div>
      <div style="font-size:.88rem;color:var(--text2);line-height:1.6">${nextGoalText}</div>
    </div>
    <div class="prog-bg" style="margin-top:12px"><div class="prog-fill" style="width:${wa7}%;background:linear-gradient(90deg,var(--accent),var(--accent2))"></div></div>
    <div style="display:flex;justify-content:space-between;font-size:.7rem;color:var(--text3);margin-top:5px"><span>Actuel : ${wa7}%</span><span>Cible : ${nextGoalTarget}%</span></div>
  </div>

  ${axes.length?`<div class="card" style="margin-bottom:16px;border-color:rgba(255,209,102,.2)">
    <div class="card-title">⚠️ Axes d'amélioration</div>
    ${axes.map(a=>`<div style="display:flex;gap:12px;align-items:flex-start;padding:10px 0;border-bottom:1px solid var(--border)">
      <div style="font-size:1.3rem;flex-shrink:0">${a.icon}</div>
      <div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;margin-bottom:3px">${a.title}</div><div style="font-size:.8rem;color:var(--text2);line-height:1.5">${a.text}</div></div>
    </div>`).join('')}
  </div>`:''}

  <div class="card" style="border-color:rgba(0,245,196,.2)">
    <div class="card-title">💡 Conseils personnalisés</div>
    ${conseils.map(c=>`<div style="display:flex;gap:12px;align-items:flex-start;padding:10px 0;border-bottom:1px solid var(--border)">
      <div style="font-size:1.3rem;flex-shrink:0">${c.icon}</div>
      <div style="font-size:.84rem;color:var(--text2);line-height:1.6">${c.text}</div>
    </div>`).join('')}
  </div>`;
}

// ══════════════════════════════════════════════════════
//  REWARDS
// ══════════════════════════════════════════════════════
function renderRewards(){
  const streak=calcStreak(),lv=levelInfo();
  document.getElementById('rewards-stats').innerHTML=`<div class="stat-card"><div class="s-val" style="color:var(--accent)">${hState.xp||0}</div><div class="s-lbl">XP Total</div></div><div class="stat-card"><div class="s-val" style="color:var(--gold)">${lv.num}</div><div class="s-lbl">Niveau</div></div><div class="stat-card"><div class="s-val" style="color:var(--accent3)">${(hState.unlockedBadges||[]).length}/${BADGES.length}</div><div class="s-lbl">Badges</div></div><div class="stat-card"><div class="s-val" style="color:var(--accent2)">${hState.perfectDays||0}</div><div class="s-lbl">Jours parfaits</div></div>`;
  const grid=document.getElementById('rewards-grid');
  grid.innerHTML=BADGES.map(b=>{const unlocked=(hState.unlockedBadges||[]).includes(b.id);return`<div class="reward-card ${unlocked?'unlocked':'locked'}"><div class="reward-icon">${b.icon}</div><div class="reward-name">${b.name}</div><div class="reward-cond">${b.cond}</div>${unlocked?`<div class="reward-unlocked-tag">DÉBLOQUÉ ✓</div>`:''}</div>`;}).join('');
}

// ══════════════════════════════════════════════════════
//  RECAP
// ══════════════════════════════════════════════════════
function showRecap(){
  const wa=avgPct(getLast(7)),streak=calcStreak(),lv=levelInfo(),days7=getLast(7);
  const habitStats=hState.habits.map(h=>{const done=days7.filter(d=>hState.history[d]&&hState.history[d][h.id]).length;return{h,done,pct:Math.round((done/7)*100)};});
  const best=[...habitStats].sort((a,b)=>b.pct-a.pct)[0];
  const worst=[...habitStats].sort((a,b)=>a.pct-b.pct)[0];
  const grade=wa>=90?'S':wa>=75?'A':wa>=60?'B':wa>=40?'C':'D';
  const grEmoji=wa>=90?'🏆':wa>=75?'🌟':wa>=60?'👍':wa>=40?'⚠️':'💪';
  document.getElementById('recap-badge').textContent=`Grade ${grade} — ${grEmoji}`;
  let html=`<strong>Semaine terminée !</strong> Voici ton bilan 👇<br><br>📊 <strong>Complétion : ${wa}%</strong><br>🔥 <strong>Streak : ${streak} jours</strong><br>⚡ <strong>Niveau : ${lv.num} — ${lv.emoji} ${lv.name}</strong><br>💎 <strong>XP total : ${hState.xp||0}</strong>`;
  document.getElementById('recap-content').innerHTML=html;
  document.getElementById('recapModal').classList.add('open');
}
function closeRecap(){document.getElementById('recapModal').classList.remove('open');}

// ══════════════════════════════════════════════════════
//  BUSINESS: COMMAND CENTER
// ══════════════════════════════════════════════════════
function renderCommand(){
  const now=new Date(),hour=now.getHours();
  document.getElementById('cmd-greeting').textContent=(hour<12?'Bonjour':'Bonsoir')+', '+getUserName()+' 👋';
  document.getElementById('cmd-date').textContent=formatDateFull(todayKey());
  const totalRev=bState.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=bState.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=totalRev-totalExp;
  const todayRev=bState.transactions.filter(t=>t.type==='revenue'&&t.date===todayKey()).reduce((s,t)=>s+t.amount,0);
  const activeProds=bState.products.filter(p=>p.status==='scaling'||p.status==='testing').length;
  const adBudget=bState.campaigns.filter(c=>c.status==='active').reduce((s,c)=>s+c.budget,0);
  document.getElementById('cmd-kpis').innerHTML=`
    <div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">CA Total</div><div class="kpi-value" style="color:var(--accent3)">${totalRev.toFixed(0)}€</div></div>
    <div class="kpi-card" style="--kpi-color:${profit>=0?'var(--green)':'var(--red)'}"><div class="kpi-label">Profit net</div><div class="kpi-value" style="color:${profit>=0?'var(--green)':'var(--red)'}">${profit.toFixed(0)}€</div></div>
    <div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">Produits actifs</div><div class="kpi-value" style="color:var(--accent)">${activeProds}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">Budget pub/j</div><div class="kpi-value" style="color:var(--gold)">${adBudget}€</div></div>`;
  const urgentTasks=bState.tasks.filter(t=>!t.done&&t.priority==='high').slice(0,4);
  document.getElementById('cmd-tasks').innerHTML=urgentTasks.length?urgentTasks.map(t=>`<div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)"><input type="checkbox" onchange="toggleTask('${t.id}')" style="accent-color:var(--accent);cursor:pointer"><span style="font-size:.84rem">${t.title}</span></div>`).join(''):'<div class="empty" style="padding:16px 0"><p>Aucune tâche urgente 🎉</p></div>';
  const activePList=bState.products.filter(p=>p.status==='scaling'||p.status==='testing').slice(0,4);
  document.getElementById('cmd-products').innerHTML=activePList.length?activePList.map(p=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)"><span style="font-size:.84rem">${p.name}</span><span class="tag ${p.status==='scaling'?'tag-green':'tag-purple'}">${p.status==='scaling'?'🚀 Scaling':'🧪 Test'}</span></div>`).join(''):'<div class="empty" style="padding:16px 0"><p>Aucun produit actif</p></div>';
  const dl=document.getElementById('goal-days-left');if(dl)dl.textContent=daysLeft()+' jours restants';
  const pb=document.getElementById('goal-progress-bar');if(pb)pb.style.width=Math.min(100,(totalRev/4000*100).toFixed(1))+'%';
  const az=document.getElementById('cmd-alert-zone');if(!az)return;
  let alerts=[];
  if(bState.campaigns.filter(c=>c.status==='active').length===0)alerts.push({type:'warn',msg:'⚠️ Aucune campagne pub active — tu n\'as pas de trafic en cours !'});
  if(profit<0&&totalRev>0)alerts.push({type:'danger',msg:'🔴 Profit négatif — tes dépenses dépassent tes revenus. Analyse tes coûts.'});
  az.innerHTML=alerts.map(a=>`<div class="alert alert-${a.type}">${a.msg}</div>`).join('');
}

// ══════════════════════════════════════════════════════
//  BUSINESS: FINANCE
// ══════════════════════════════════════════════════════
let chF,chP;
function addTransaction(){
  const desc=document.getElementById('t-desc').value.trim();
  const amount=parseFloat(document.getElementById('t-amount').value)||0;
  if(!desc||!amount){toast('Remplis tous les champs','var(--red)');return;}
  bState.transactions.push({id:'t'+Date.now(),type:document.getElementById('t-type').value,desc,amount,cat:document.getElementById('t-cat').value,date:document.getElementById('t-date').value||todayKey()});
  saveB();closeModal('modal-add-transaction');document.getElementById('t-desc').value='';document.getElementById('t-amount').value='';renderFinance('month');toast('Transaction ajoutée ✓');
}
function renderFinance(range){
  const all=range==='all';
  const cutoff=all?'2000-01-01':new Date(Date.now()-30*86400000).toISOString().slice(0,10);
  const trans=bState.transactions.filter(t=>t.date>=cutoff).sort((a,b)=>b.date>a.date?1:-1);
  const rev=trans.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const exp=trans.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=rev-exp;const margin=rev>0?((profit/rev)*100).toFixed(1):0;
  document.getElementById('finance-kpis').innerHTML=`
    <div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">CA</div><div class="kpi-value" style="color:var(--accent3)">${rev.toFixed(0)}€</div><div class="kpi-sub">${all?'Total':'30 derniers jours'}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--red)"><div class="kpi-label">Dépenses</div><div class="kpi-value" style="color:var(--red)">${exp.toFixed(0)}€</div></div>
    <div class="kpi-card" style="--kpi-color:${profit>=0?'var(--green)':'var(--red)'}"><div class="kpi-label">Profit</div><div class="kpi-value" style="color:${profit>=0?'var(--green)':'var(--red)'}">${profit.toFixed(0)}€</div></div>
    <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">Marge</div><div class="kpi-value" style="color:var(--gold)">${margin}%</div></div>`;
  // Chart finance
  const last7=getLast(7);const chartLabels=last7.map(dateShort);
  const chartRev=last7.map(d=>bState.transactions.filter(t=>t.type==='revenue'&&t.date===d).reduce((s,t)=>s+t.amount,0));
  const chartExp=last7.map(d=>bState.transactions.filter(t=>t.type==='expense'&&t.date===d).reduce((s,t)=>s+t.amount,0));
  if(chF)chF.destroy();
  chF=new Chart(document.getElementById('chart-finance'),{type:'bar',data:{labels:chartLabels,datasets:[{label:'Revenus',data:chartRev,backgroundColor:'rgba(0,245,196,.6)',borderRadius:4},{label:'Dépenses',data:chartExp,backgroundColor:'rgba(239,71,111,.6)',borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7878a8',font:{size:10}}}},scales:{y:{grid:{color:'rgba(255,255,255,.05)'},ticks:{color:'#7878a8',font:{size:10}}},x:{grid:{display:false},ticks:{color:'#7878a8',font:{size:10}}}}}});
  const catExp={};trans.filter(t=>t.type==='expense').forEach(t=>{catExp[t.cat]=(catExp[t.cat]||0)+t.amount;});
  if(chP)chP.destroy();
  if(Object.keys(catExp).length){chP=new Chart(document.getElementById('chart-pie'),{type:'doughnut',data:{labels:Object.keys(catExp),datasets:[{data:Object.values(catExp),backgroundColor:['rgba(124,92,252,.7)','rgba(252,92,125,.7)','rgba(0,245,196,.7)','rgba(255,209,102,.7)','rgba(79,195,255,.7)']}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7878a8',font:{size:10}}}}}});}
  // Table
  document.getElementById('transactions-table').innerHTML=trans.length?`<table class="data-table"><thead><tr><th>Date</th><th>Description</th><th>Catégorie</th><th>Montant</th></tr></thead><tbody>${trans.slice(0,30).map(t=>`<tr><td class="mono" style="font-size:.74rem">${fmtDate(t.date)}</td><td style="font-size:.84rem">${t.desc}</td><td><span class="tag ${t.type==='revenue'?'tag-green':'tag-red'}">${t.cat}</span></td><td style="font-family:'DM Mono',monospace;font-weight:700;color:${t.type==='revenue'?'var(--accent3)':'var(--red)'};">${t.type==='revenue'?'+':'−'}${t.amount}€ <button onclick="delTransaction('${t.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer;margin-left:8px">✕</button></td></tr>`).join('')}</tbody></table>`:'<div class="empty"><div class="ei">💰</div><p>Ajoute tes transactions</p></div>';
}
function delTransaction(id){bState.transactions=bState.transactions.filter(t=>t.id!==id);saveB();renderFinance('month');}

// ══════════════════════════════════════════════════════
//  BUSINESS: PRODUCTS
// ══════════════════════════════════════════════════════
function calcProductMetrics(){
  const price=parseFloat(document.getElementById('p-price').value)||0;
  const cost=parseFloat(document.getElementById('p-cost').value)||0;
  const revenue=parseFloat(document.getElementById('p-revenue').value)||0;
  const preview=document.getElementById('p-metrics-preview');
  if(!price&&!cost&&!revenue){preview.style.display='none';return;}
  preview.style.display='block';
  const profitPerSale=price-cost;
  const margin=price>0?((profitPerSale/price)*100).toFixed(1):'—';
  const roi=cost>0?((profitPerSale/cost)*100).toFixed(0):'—';
  document.getElementById('p-calc-margin').textContent=margin!=='—'?margin+'%':'—';
  document.getElementById('p-calc-profit').textContent=price>0?profitPerSale.toFixed(2)+'€':'—';
  document.getElementById('p-calc-roi').textContent=roi!=='—'?roi+'%':'—';
  document.getElementById('p-calc-margin').style.color=parseFloat(margin)>=50?'var(--green)':parseFloat(margin)>=30?'var(--gold)':'var(--red)';
  document.getElementById('p-calc-roi').style.color=parseFloat(roi)>=200?'var(--green)':parseFloat(roi)>=100?'var(--gold)':'var(--red)';
}

function scoreProduct(p) {
  // Calcule une note sur 10 basée sur 5 critères pondérés
  let score = 0;
  const details = [];

  // 1. MARGE BRUTE /3 pts
  if (p.price && p.cost) {
    const margin = ((p.price - p.cost) / p.price) * 100;
    if (margin >= 65)      { score += 3.0; details.push({label:'Marge', pts:3.0, max:3, comment:`${margin.toFixed(0)}% — Excellente`}); }
    else if (margin >= 50) { score += 2.2; details.push({label:'Marge', pts:2.2, max:3, comment:`${margin.toFixed(0)}% — Bonne`}); }
    else if (margin >= 35) { score += 1.4; details.push({label:'Marge', pts:1.4, max:3, comment:`${margin.toFixed(0)}% — Correcte`}); }
    else if (margin >= 20) { score += 0.7; details.push({label:'Marge', pts:0.7, max:3, comment:`${margin.toFixed(0)}% — Faible`}); }
    else                   { score += 0.0; details.push({label:'Marge', pts:0.0, max:3, comment:`${margin.toFixed(0)}% — Trop faible`}); }
  } else {
    details.push({label:'Marge', pts:0, max:3, comment:'Données manquantes'});
  }

  // 2. ROI /2 pts
  if (p.price && p.cost && p.cost > 0) {
    const roi = ((p.price - p.cost) / p.cost) * 100;
    if (roi >= 400)      { score += 2.0; details.push({label:'ROI', pts:2.0, max:2, comment:`${roi.toFixed(0)}% — Exceptionnel`}); }
    else if (roi >= 250) { score += 1.5; details.push({label:'ROI', pts:1.5, max:2, comment:`${roi.toFixed(0)}% — Très bon`}); }
    else if (roi >= 150) { score += 1.0; details.push({label:'ROI', pts:1.0, max:2, comment:`${roi.toFixed(0)}% — Correct`}); }
    else if (roi >= 80)  { score += 0.5; details.push({label:'ROI', pts:0.5, max:2, comment:`${roi.toFixed(0)}% — Passable`}); }
    else                 { score += 0.0; details.push({label:'ROI', pts:0.0, max:2, comment:`${roi.toFixed(0)}% — Insuffisant`}); }
  } else {
    details.push({label:'ROI', pts:0, max:2, comment:'Données manquantes'});
  }

  // 3. REVENUS GÉNÉRÉS /2 pts (indicateur de traction réelle)
  const rev = p.revenue || 0;
  if (rev >= 5000)      { score += 2.0; details.push({label:'Traction', pts:2.0, max:2, comment:`${rev}€ — Fort`}); }
  else if (rev >= 1000) { score += 1.5; details.push({label:'Traction', pts:1.5, max:2, comment:`${rev}€ — Bon signal`}); }
  else if (rev >= 200)  { score += 1.0; details.push({label:'Traction', pts:1.0, max:2, comment:`${rev}€ — Début`}); }
  else if (rev >= 1)    { score += 0.5; details.push({label:'Traction', pts:0.5, max:2, comment:`${rev}€ — Très débutant`}); }
  else                  { score += 0.0; details.push({label:'Traction', pts:0.0, max:2, comment:'0€ — Pas encore vendu'}); }

  // 4. RAPPORT ROAS (revenus / budget pub) /2 pts
  if (p.revenue > 0 && p.adbudget > 0) {
    const roas = p.revenue / p.adbudget;
    if (roas >= 4)      { score += 2.0; details.push({label:'ROAS', pts:2.0, max:2, comment:`${roas.toFixed(1)}x — Excellent`}); }
    else if (roas >= 2.5){ score += 1.5; details.push({label:'ROAS', pts:1.5, max:2, comment:`${roas.toFixed(1)}x — Bon`}); }
    else if (roas >= 1.5){ score += 1.0; details.push({label:'ROAS', pts:1.0, max:2, comment:`${roas.toFixed(1)}x — Passable`}); }
    else if (roas >= 1)  { score += 0.4; details.push({label:'ROAS', pts:0.4, max:2, comment:`${roas.toFixed(1)}x — À surveiller`}); }
    else                 { score += 0.0; details.push({label:'ROAS', pts:0.0, max:2, comment:`${roas.toFixed(1)}x — Déficitaire`}); }
  } else if (p.revenue === 0 && p.adbudget > 0) {
    details.push({label:'ROAS', pts:0, max:2, comment:'0 revenu pour ce budget'});
  } else {
    details.push({label:'ROAS', pts:0, max:2, comment:'Budget pub non renseigné'});
  }

  // 5. STATUT BONUS /1 pt
  if (p.status === 'scaling')      { score += 1.0; details.push({label:'Statut', pts:1.0, max:1, comment:'Scaling — validé'}); }
  else if (p.status === 'testing') { score += 0.5; details.push({label:'Statut', pts:0.5, max:1, comment:'En test — à confirmer'}); }
  else if (p.status === 'paused')  { score += 0.2; details.push({label:'Statut', pts:0.2, max:1, comment:'Pausé — potentiel à revoir'}); }
  else                             { score += 0.0; details.push({label:'Statut', pts:0.0, max:1, comment:'Mort — à écarter'}); }

  const final = Math.min(10, Math.round(score * 10) / 10);
  return { score: final, details };
}

function scoreLabel(s) {
  if (s >= 8.5) return { emoji:'🏆', label:'Pépite', color:'var(--accent3)' };
  if (s >= 7)   return { emoji:'🚀', label:'Très prometteur', color:'var(--green)' };
  if (s >= 5.5) return { emoji:'✅', label:'Correct', color:'var(--gold)' };
  if (s >= 4)   return { emoji:'⚠️', label:'À optimiser', color:'#ff9f43' };
  if (s >= 2)   return { emoji:'🔻', label:'Faible', color:'var(--red)' };
  return              { emoji:'💀', label:'À écarter', color:'var(--text3)' };
}

function renderProducts(){
  const statusInfo={testing:{label:'🧪 Test',color:'tag-purple'},scaling:{label:'🚀 Scaling',color:'tag-green'},paused:{label:'⏸ Pausé',color:'tag-gold'},dead:{label:'💀 Mort',color:'tag-red'}};
  // Sort by score descending
  const sorted=[...bState.products].sort((a,b)=>scoreProduct(b).score - scoreProduct(a).score);

  document.getElementById('products-list').innerHTML=sorted.length?sorted.map(p=>{
    const si=statusInfo[p.status]||statusInfo.testing;
    const profitPerSale=p.price&&p.cost?(p.price-p.cost):null;
    const margin=p.price&&p.cost?((profitPerSale/p.price)*100).toFixed(1):null;
    const roi=p.cost>0&&profitPerSale!=null?((profitPerSale/p.cost)*100).toFixed(0):null;
    const marginColor=margin?parseFloat(margin)>=50?'var(--green)':parseFloat(margin)>=30?'var(--gold)':'var(--red)':'var(--text3)';
    const roiColor=roi?parseFloat(roi)>=200?'var(--green)':parseFloat(roi)>=100?'var(--gold)':'var(--red)':'var(--text3)';
    const {score, details} = scoreProduct(p);
    const sl = scoreLabel(score);
    // Score bar segments
    const filled = Math.round(score);
    const dots = Array.from({length:10},(_,i)=>
      `<div style="flex:1;height:6px;border-radius:3px;background:${i<filled?sl.color:'var(--surface3)'}"></div>`
    ).join('');

    return`<div class="card" style="margin-bottom:16px;position:relative;overflow:hidden">
      <div style="position:absolute;top:0;left:0;right:0;height:3px;background:${p.status==='scaling'?'linear-gradient(90deg,var(--accent3),var(--green))':p.status==='testing'?'linear-gradient(90deg,var(--accent),var(--accent2))':p.status==='paused'?'var(--gold)':'var(--text3)'}"></div>

      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;padding-top:6px;gap:12px">
        <div style="flex:1;min-width:0">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;margin-bottom:4px">${p.name}</div>
          ${p.url?`<a href="${p.url}" target="_blank" style="font-size:.72rem;color:var(--accent);text-decoration:none">🔗 ${p.url.replace(/^https?:\/\//,'').split('/').slice(0,3).join('/')} →</a>`:''}
        </div>

        <!-- SCORE BADGE -->
        <div onclick="toggleScoreDetails('score-${p.id}')" style="cursor:pointer;flex-shrink:0;background:var(--surface2);border:2px solid ${sl.color}55;border-radius:14px;padding:10px 14px;text-align:center;min-width:80px;transition:all .2s" onmouseover="this.style.borderColor='${sl.color}'" onmouseout="this.style.borderColor='${sl.color}55'">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.6rem;line-height:1;color:${sl.color}">${score}</div>
          <div style="font-size:.58rem;font-weight:700;color:${sl.color};margin-top:2px;text-transform:uppercase;letter-spacing:.5px">/10</div>
          <div style="font-size:.65rem;color:var(--text2);margin-top:3px">${sl.emoji} ${sl.label}</div>
        </div>

        <div style="display:flex;gap:6px;flex-shrink:0">
          <span class="tag ${si.color}">${si.label}</span>
          <button class="btn-icon" onclick="editProduct('${p.id}')">✎</button>
          <button class="btn-icon" onclick="delProduct('${p.id}')" style="color:var(--red)">✕</button>
        </div>
      </div>

      <!-- Score bar -->
      <div style="display:flex;gap:3px;margin-bottom:14px">
        ${dots}
      </div>

      <!-- Score breakdown (toggle) -->
      <div id="score-${p.id}" style="display:none;background:var(--surface2);border-radius:10px;padding:12px;margin-bottom:12px">
        <div style="font-size:.66rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);font-weight:700;margin-bottom:10px">Détail de la note</div>
        ${details.map(d=>`<div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
          <div style="font-size:.75rem;color:var(--text2);width:60px;flex-shrink:0">${d.label}</div>
          <div style="flex:1;height:5px;background:var(--surface3);border-radius:3px;overflow:hidden">
            <div style="height:100%;width:${(d.pts/d.max)*100}%;background:${sl.color};border-radius:3px;transition:width .5s ease"></div>
          </div>
          <div style="font-size:.72rem;color:${sl.color};font-weight:700;width:28px;text-align:right">${d.pts}/${d.max}</div>
          <div style="font-size:.72rem;color:var(--text3);min-width:0;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${d.comment}</div>
        </div>`).join('')}
      </div>

      <!-- Métriques -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:${p.notes?'12px':'0'}" class="product-metrics-grid">
        <div style="background:var(--surface2);border-radius:10px;padding:10px;text-align:center">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:var(--accent3)">${p.price||0}€</div>
          <div style="font-size:.6rem;color:var(--text2);margin-top:3px">Vente</div>
        </div>
        <div style="background:var(--surface2);border-radius:10px;padding:10px;text-align:center">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:var(--red)">${p.cost||0}€</div>
          <div style="font-size:.6rem;color:var(--text2);margin-top:3px">Coût</div>
        </div>
        <div style="background:var(--surface2);border-radius:10px;padding:10px;text-align:center">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:var(--gold)">${p.adbudget||0}€</div>
          <div style="font-size:.6rem;color:var(--text2);margin-top:3px">Pub/j</div>
        </div>
        <div style="background:var(--surface2);border-radius:10px;padding:10px;text-align:center">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:var(--blue)">${p.revenue||0}€</div>
          <div style="font-size:.6rem;color:var(--text2);margin-top:3px">Revenus</div>
        </div>
        <div style="background:var(--surface2);border-radius:10px;padding:10px;text-align:center;border:1px solid ${marginColor}33">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:${marginColor}">${margin||'—'}${margin?'%':''}</div>
          <div style="font-size:.6rem;color:var(--text2);margin-top:3px">Marge</div>
        </div>
        <div style="background:var(--surface2);border-radius:10px;padding:10px;text-align:center;border:1px solid ${roiColor}33">
          <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:${roiColor}">${roi||'—'}${roi?'%':''}</div>
          <div style="font-size:.6rem;color:var(--text2);margin-top:3px">ROI</div>
        </div>
      </div>
      ${p.notes?`<div style="background:var(--surface2);border-radius:8px;padding:10px;font-size:.78rem;color:var(--text2);line-height:1.6;white-space:pre-wrap;margin-top:0">${p.notes}</div>`:''}
    </div>`;
  }).join(''):'<div class="empty"><div class="ei">🧪</div><p>Ajoute tes produits testés</p></div>';
}

function toggleScoreDetails(id){
  const el=document.getElementById(id);
  if(!el)return;
  el.style.display=el.style.display==='none'?'block':'none';
}
function saveProduct(){
  const name=document.getElementById('p-name').value.trim();if(!name){toast('Nom requis','var(--red)');return;}
  const data={name,status:document.getElementById('p-status').value,price:parseFloat(document.getElementById('p-price').value)||0,cost:parseFloat(document.getElementById('p-cost').value)||0,adbudget:parseFloat(document.getElementById('p-adbudget').value)||0,revenue:parseFloat(document.getElementById('p-revenue').value)||0,url:document.getElementById('p-url').value.trim(),notes:document.getElementById('p-notes').value.trim()};
  if(bState.editingProductId){const p=bState.products.find(x=>x.id===bState.editingProductId);if(p)Object.assign(p,data);}
  else bState.products.push({id:'p'+Date.now(),...data});
  bState.editingProductId=null;saveB();closeModal('modal-add-product');document.getElementById('p-name').value='';document.getElementById('p-metrics-preview').style.display='none';renderProducts();toast('Produit enregistré ✓');
}
function editProduct(id){
  const p=bState.products.find(x=>x.id===id);if(!p)return;
  bState.editingProductId=id;
  document.getElementById('modal-product-title').textContent='Modifier produit';
  document.getElementById('p-name').value=p.name;
  document.getElementById('p-status').value=p.status;
  document.getElementById('p-price').value=p.price||'';
  document.getElementById('p-cost').value=p.cost||'';
  document.getElementById('p-adbudget').value=p.adbudget||'';
  document.getElementById('p-revenue').value=p.revenue||'';
  document.getElementById('p-url').value=p.url||'';
  document.getElementById('p-notes').value=p.notes||'';
  calcProductMetrics();
  openModal('modal-add-product');
}
function delProduct(id){bState.products=bState.products.filter(p=>p.id!==id);saveB();renderProducts();}

// ══════════════════════════════════════════════════════
//  BUSINESS: ADS
// ══════════════════════════════════════════════════════
function renderAds(){
  const active=bState.campaigns.filter(c=>c.status==='active');
  const totalBudget=active.reduce((s,c)=>s+c.budget,0);
  const totalRev=active.reduce((s,c)=>s+c.revenue,0);
  const avgRoas=totalBudget>0?(totalRev/totalBudget).toFixed(2):0;
  const avgCtr=active.length>0?(active.reduce((s,c)=>s+c.ctr,0)/active.length).toFixed(2):'0.00';
  document.getElementById('ads-kpis').innerHTML=`
    <div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">Campagnes actives</div><div class="kpi-value" style="color:var(--accent)">${active.length}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--red)"><div class="kpi-label">Budget total/j</div><div class="kpi-value" style="color:var(--red)">${totalBudget}€</div></div>
    <div class="kpi-card" style="--kpi-color:${avgRoas>=2?'var(--green)':'var(--red)'}"><div class="kpi-label">ROAS moyen</div><div class="kpi-value" style="color:${avgRoas>=2?'var(--green)':'var(--red)'}">${avgRoas}x</div></div>
    <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">CTR moyen</div><div class="kpi-value" style="color:var(--gold)">${avgCtr}%</div></div>`;
  // Suggestions
  let suggestions=[];
  bState.campaigns.forEach(c=>{
    if(c.status==='active'&&c.budget>0&&c.revenue/c.budget<1)suggestions.push(`<div class="alert alert-danger">🔴 ${c.name} — ROAS négatif (${(c.revenue/c.budget).toFixed(2)}x). Envisage de couper.</div>`);
    if(c.status==='active'&&c.ctr<1&&c.budget>0)suggestions.push(`<div class="alert alert-warn">⚠️ ${c.name} — CTR faible (${c.ctr}%). Teste un nouveau créatif.</div>`);
  });
  document.getElementById('ads-suggestions').innerHTML=suggestions.slice(0,3).join('');
  const list=document.getElementById('campaigns-list'),empty=document.getElementById('campaigns-empty');
  if(!bState.campaigns.length){list.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  const statusColor={active:'tag-green',paused:'tag-gold',dead:'tag-red'};
  list.innerHTML=bState.campaigns.map(c=>{const roas=c.budget>0?(c.revenue/c.budget).toFixed(2):'—';return`<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--border)"><div style="flex:1"><div style="font-weight:600;font-size:.88rem">${c.name}</div><div style="font-size:.74rem;color:var(--text2);margin-top:2px">${c.platform} · ${c.budget}€/j · CTR ${c.ctr}%</div></div><div style="display:flex;gap:8px;align-items:center"><span style="font-family:'DM Mono',monospace;font-size:.82rem;color:${roas==='—'||parseFloat(roas)<1?'var(--red)':parseFloat(roas)>=2?'var(--green)':'var(--gold)'}">${roas}x ROAS</span><span class="tag ${statusColor[c.status]||'tag-purple'}">${c.status}</span><button onclick="delCamp('${c.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div></div>`;}).join('');
}
function addCampaign(){
  const name=document.getElementById('c-name').value.trim();if(!name){toast('Nom requis','var(--red)');return;}
  bState.campaigns.push({id:'c'+Date.now(),name,platform:document.getElementById('c-platform').value,budget:parseFloat(document.getElementById('c-budget').value)||0,revenue:parseFloat(document.getElementById('c-revenue').value)||0,ctr:parseFloat(document.getElementById('c-ctr').value)||0,status:document.getElementById('c-status').value});
  saveB();closeModal('modal-add-campaign');document.getElementById('c-name').value='';renderAds();toast('Campagne ajoutée ✓');
}
function delCamp(id){bState.campaigns=bState.campaigns.filter(c=>c.id!==id);saveB();renderAds();}

// ══════════════════════════════════════════════════════
//  BUSINESS: ANALYTICS
// ══════════════════════════════════════════════════════
function saveMetric(){const date=document.getElementById('m-date').value||todayKey();const existing=bState.metrics.findIndex(m=>m.date===date);const metric={date,visitors:parseInt(document.getElementById('m-visitors').value)||0,orders:parseInt(document.getElementById('m-orders').value)||0,revenue:parseFloat(document.getElementById('m-revenue').value)||0,adspend:parseFloat(document.getElementById('m-adspend').value)||0};if(existing>=0)bState.metrics[existing]=metric;else bState.metrics.push(metric);saveB();closeModal('modal-add-metric');renderAnalytics();toast('Métriques enregistrées ✓');}
function renderAnalytics(){
  const tm=bState.metrics.find(m=>m.date===todayKey())||{visitors:0,orders:0,revenue:0,adspend:0};
  const conv=tm.visitors>0?((tm.orders/tm.visitors)*100).toFixed(2):'—',aov=tm.orders>0?(tm.revenue/tm.orders).toFixed(0):'—',roas=tm.adspend>0?(tm.revenue/tm.adspend).toFixed(2):'—';
  document.getElementById('analytics-kpis').innerHTML=`<div class="kpi-card" style="--kpi-color:var(--blue)"><div class="kpi-label">Visiteurs</div><div class="kpi-value" style="color:var(--blue)">${tm.visitors}</div></div><div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">Commandes</div><div class="kpi-value" style="color:var(--accent3)">${tm.orders}</div></div><div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">Conversion</div><div class="kpi-value" style="color:var(--gold)">${conv}%</div></div><div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">Panier moyen</div><div class="kpi-value" style="color:var(--accent)">${aov}${aov!=='—'?'€':''}</div></div>`;
  const cart=Math.round(tm.visitors*.15),checkout=Math.round(cart*.4);
  document.getElementById('funnel').innerHTML=[{l:'Visiteurs',v:tm.visitors,c:'var(--blue)',p:100},{l:'Ajout panier',v:cart,c:'var(--accent)',p:tm.visitors>0?(cart/tm.visitors*100):0},{l:'Checkout',v:checkout,c:'var(--gold)',p:tm.visitors>0?(checkout/tm.visitors*100):0},{l:'Commandes',v:tm.orders,c:'var(--accent3)',p:tm.visitors>0?(tm.orders/tm.visitors*100):0}].map(s=>`<div style="margin-bottom:12px"><div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:4px"><span style="color:var(--text2)">${s.l}</span><span style="font-weight:700;color:${s.c}">${s.v} (${s.p.toFixed(1)}%)</span></div><div class="prog-bg"><div class="prog-fill" style="width:${s.p}%;background:${s.c}"></div></div></div>`).join('');
  const last7=bState.metrics.slice().sort((a,b)=>b.date>a.date?1:-1).slice(0,7);
  document.getElementById('metrics-history').innerHTML=last7.length?`<table class="data-table"><thead><tr><th>Date</th><th>Vis.</th><th>Cmd</th><th>CA</th><th>ROAS</th></tr></thead><tbody>${last7.map(m=>{const r=m.adspend>0?(m.revenue/m.adspend).toFixed(1):'—';return`<tr><td class="mono" style="font-size:.74rem">${fmtDate(m.date)}</td><td>${m.visitors}</td><td>${m.orders}</td><td style="color:var(--accent3)">${m.revenue}€</td><td style="color:${r==='—'?'var(--text2)':parseFloat(r)>=2?'var(--green)':'var(--red)'}">${r}</td></tr>`;}).join('')}</tbody></table>`:'<div class="empty"><div class="ei">📊</div><p>Ajoute tes métriques</p></div>';
}

// ══════════════════════════════════════════════════════
//  BUSINESS: TASKS
// ══════════════════════════════════════════════════════
const TEMPLATES=[
  {name:'🚀 Lancer un produit',tasks:['Trouver le produit sur AliExpress/CJ','Créer la page produit Shopify','Configurer les prix & marges','Créer le créatif publicitaire','Lancer campagne test 5-10€/j','Analyser les résultats à J+3']},
  {name:'📣 Tester une créa',tasks:['Définir l\'angle marketing','Créer le visuel/vidéo','Dupliquer l\'adset existant','Lancer à 5€/j','Analyser CTR à 24h']},
  {name:'📈 Optimiser campagne',tasks:['Analyser ROAS par adset','Couper les adsets perdants','Scale les adsets rentables x1.5','Tester nouveau public','Vérifier le pixel Shopify']},
];
function renderTasks(){
  const high=bState.tasks.filter(t=>t.priority==='high'),med=bState.tasks.filter(t=>t.priority==='med'),low=bState.tasks.filter(t=>t.priority==='low'||t.done);
  document.getElementById('count-high').textContent=high.filter(t=>!t.done).length;
  document.getElementById('count-med').textContent=med.filter(t=>!t.done).length;
  document.getElementById('count-low').textContent=low.length;
  ['high','med','low'].forEach(p=>{const list=p==='low'?low:bState.tasks.filter(t=>t.priority===p);document.getElementById('tasks-'+p).innerHTML=list.length?list.map(t=>`<div style="display:flex;align-items:flex-start;gap:8px;padding:10px 0;border-bottom:1px solid var(--border);${t.done?'opacity:.5':''}"><input type="checkbox" ${t.done?'checked':''} onchange="toggleTask('${t.id}')" style="margin-top:3px;accent-color:var(--accent);cursor:pointer"><div style="flex:1"><div style="font-size:.84rem;font-weight:500;${t.done?'text-decoration:line-through':''}">${t.title}</div><div style="font-size:.72rem;color:var(--text2)">${t.cat||''}${t.deadline?' · ⏰ '+fmtDate(t.deadline):''}</div></div><button onclick="delTask('${t.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div>`).join(''):'<div class="empty" style="padding:20px"><p>Aucune tâche</p></div>';});
  document.getElementById('templates-list').innerHTML=TEMPLATES.map((tpl,i)=>`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:10px"><div style="font-weight:700;margin-bottom:4px">${tpl.name}</div><div style="font-size:.8rem;color:var(--text2);margin-bottom:10px">${tpl.tasks.length} tâches</div><button class="btn btn-primary btn-sm" onclick="applyTemplate(${i})">Appliquer</button></div>`).join('');
}
function addTask(){const title=document.getElementById('task-title').value.trim();if(!title){toast('Écris une tâche','var(--red)');return;}bState.tasks.push({id:'t'+Date.now(),title,priority:document.getElementById('task-priority').value,deadline:document.getElementById('task-deadline').value||null,cat:document.getElementById('task-cat').value,done:false});saveB();closeModal('modal-add-task');document.getElementById('task-title').value='';renderTasks();toast('Tâche ajoutée ✓');}
function toggleTask(id){const t=bState.tasks.find(x=>x.id===id);if(t)t.done=!t.done;saveB();renderTasks();}
function delTask(id){bState.tasks=bState.tasks.filter(t=>t.id!==id);saveB();renderTasks();}
function applyTemplate(idx){const tpl=TEMPLATES[idx];tpl.tasks.forEach(title=>bState.tasks.push({id:'t'+Date.now()+Math.random(),title,priority:'high',deadline:null,cat:'Business',done:false}));saveB();closeModal('modal-template');renderTasks();toast(`Template "${tpl.name}" appliqué ✓`);}

// ══════════════════════════════════════════════════════
//  BUSINESS: STRATEGY
// ══════════════════════════════════════════════════════
function renderStrategy(){
  document.getElementById('strategy-notes').value=bState.strategyNotes||'';
  document.getElementById('goals-list').innerHTML=bState.goals.length?bState.goals.map(g=>`<div style="display:flex;justify-content:space-between;align-items:flex-start;padding:12px 0;border-bottom:1px solid var(--border)"><div><div style="font-weight:600;font-size:.88rem">${g.title}</div>${g.deadline?`<div style="font-size:.72rem;color:var(--text2);margin-top:2px">⏰ ${fmtDate(g.deadline)}</div>`:''}</div><div style="display:flex;gap:6px;align-items:center"><span class="tag tag-purple">${g.horizon}</span><button onclick="delGoal('${g.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div></div>`).join(''):'<div class="empty"><div class="ei">🎯</div><p>Définis tes objectifs</p></div>';
  const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'],now=new Date();
  document.getElementById('roadmap').innerHTML=`<div style="font-size:.78rem;color:var(--text2);margin-bottom:12px">Mars 2026 → Décembre 2026 · Objectif : 4 000€/jour</div><div style="display:flex;gap:4px;flex-wrap:wrap">${Array.from({length:10},(_,i)=>{const m=(now.getMonth()+i)%12,isCur=i===0;return`<div style="flex:1;min-width:50px;background:${isCur?'rgba(124,92,252,.15)':'var(--surface2)'};border:1px solid ${isCur?'rgba(124,92,252,.3)':'var(--border)'};border-radius:8px;padding:8px 4px;text-align:center"><div style="font-size:.72rem;font-weight:700;color:${isCur?'var(--accent)':'var(--text2)'}">${months[m]}</div></div>`;}).join('')}</div><div style="font-size:.72rem;color:var(--text3);margin-top:10px;text-align:center">9 mois · ${daysLeft()} jours restants</div>`;
}
function addGoal(){const title=document.getElementById('goal-title').value.trim();if(!title){toast('Écris un objectif','var(--red)');return;}bState.goals.push({id:'g'+Date.now(),title,deadline:document.getElementById('goal-deadline').value||null,horizon:document.getElementById('goal-horizon').value});saveB();closeModal('modal-add-goal');renderStrategy();toast('Objectif ajouté ✓');}
function delGoal(id){bState.goals=bState.goals.filter(g=>g.id!==id);saveB();renderStrategy();}
function saveStrategyNotes(){bState.strategyNotes=document.getElementById('strategy-notes').value;saveB();}

// ══════════════════════════════════════════════════════
//  HUB
// ══════════════════════════════════════════════════════
function renderHub(){
  const cats={};bState.links.forEach(l=>{if(!cats[l.cat])cats[l.cat]=[];cats[l.cat].push(l);});
  document.getElementById('hub-categories').innerHTML=Object.entries(cats).map(([cat,links])=>`<div style="margin-bottom:24px"><div class="section-title">${cat}</div><div class="grid-auto">${links.map(l=>`<div onclick="window.open('${l.url}','_blank')" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;cursor:pointer;transition:all .2s" onmouseover="this.style.borderColor='var(--accent)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='var(--border)';this.style.transform='none'"><div style="font-size:1.6rem;margin-bottom:8px">${l.icon||'🔗'}</div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;margin-bottom:4px">${l.name}</div><div style="font-size:.68rem;color:var(--text3);word-break:break-all">${l.url.replace(/^https?:\/\//,'').split('/')[0]}</div><button onclick="event.stopPropagation();delLink('${l.id}')" style="display:block;margin-top:8px;background:none;border:none;color:var(--text3);cursor:pointer;font-size:.72rem">Supprimer</button></div>`).join('')}</div></div>`).join('')||'<div class="empty"><div class="ei">🔗</div><p>Ajoute des liens</p></div>';
}
function addLink(){const name=document.getElementById('l-name').value.trim();let url=document.getElementById('l-url').value.trim();if(!name||!url){toast('Remplis le nom et l\'URL','var(--red)');return;}if(!url.startsWith('http'))url='https://'+url;bState.links.push({id:'l'+Date.now(),name,url,icon:document.getElementById('l-icon').value.trim()||'🔗',cat:document.getElementById('l-cat').value});saveB();closeModal('modal-add-link');renderHub();toast('Lien ajouté ✓');}
function delLink(id){bState.links=bState.links.filter(l=>l.id!==id);saveB();renderHub();}

// ══════════════════════════════════════════════════════
//  KNOWLEDGE
// ══════════════════════════════════════════════════════
function renderKnowledge(){
  const h=bState.formationHours||0;
  document.getElementById('formation-hours').value=h;
  document.getElementById('formation-bar').style.width=(h/80*100)+'%';
  document.getElementById('formation-pct').textContent=(h/80*100).toFixed(0)+'%';
  document.getElementById('formation-remaining').textContent=(80-h)+'h restantes';
  document.getElementById('formation-notes').value=bState.formationNotes||'';
  const list=document.getElementById('resources-list'),empty=document.getElementById('resources-empty');
  if(!bState.resources.length){list.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  list.innerHTML=bState.resources.map(r=>`<div style="display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);align-items:flex-start"><div style="font-size:1.2rem">${r.type==='Vidéo'?'🎬':r.type==='Article'?'📄':r.type==='Formation'?'🎓':'📦'}</div><div style="flex:1"><div style="font-weight:600;font-size:.84rem">${r.title}</div>${r.notes?`<div style="font-size:.74rem;color:var(--text2);margin-top:2px">${r.notes}</div>`:''} ${r.url?`<a href="${r.url}" target="_blank" style="font-size:.72rem;color:var(--accent)">Ouvrir →</a>`:''}</div><button onclick="delResource('${r.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div>`).join('');
  document.getElementById('formation-actions').innerHTML=bState.formationActions.length?bState.formationActions.map(a=>`<div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)"><input type="checkbox" ${a.done?'checked':''} onchange="toggleFA('${a.id}')" style="accent-color:var(--accent);cursor:pointer"><span style="flex:1;font-size:.84rem;${a.done?'text-decoration:line-through;opacity:.5':''}">${a.text}</span><button onclick="delFA('${a.id}')" style="background:none;border:none;color:var(--text3);cursor:pointer">✕</button></div>`).join(''):'';
}
function updateFormationProgress(){const h=parseInt(document.getElementById('formation-hours').value)||0;bState.formationHours=h;document.getElementById('formation-bar').style.width=(h/80*100)+'%';document.getElementById('formation-pct').textContent=(h/80*100).toFixed(0)+'%';document.getElementById('formation-remaining').textContent=(80-h)+'h restantes';saveB();}
function saveFormationNotes(){bState.formationNotes=document.getElementById('formation-notes').value;saveB();}
function addResource(){const title=document.getElementById('r-title').value.trim();if(!title){toast('Donne un titre','var(--red)');return;}bState.resources.push({id:'r'+Date.now(),title,url:document.getElementById('r-url').value.trim(),type:document.getElementById('r-type').value,notes:document.getElementById('r-notes').value.trim()});saveB();closeModal('modal-add-resource');renderKnowledge();toast('Ressource ajoutée ✓');}
function delResource(id){bState.resources=bState.resources.filter(r=>r.id!==id);saveB();renderKnowledge();}
function addFormationAction(){const text=document.getElementById('new-formation-action').value.trim();if(!text)return;bState.formationActions.push({id:'fa'+Date.now(),text,done:false});document.getElementById('new-formation-action').value='';saveB();renderKnowledge();}
function toggleFA(id){const a=bState.formationActions.find(x=>x.id===id);if(a)a.done=!a.done;saveB();renderKnowledge();}
function delFA(id){bState.formationActions=bState.formationActions.filter(a=>a.id!==id);saveB();renderKnowledge();}

// ══════════════════════════════════════════════════════
//  AI COACH
// ══════════════════════════════════════════════════════
function saveApiKey(){const key=document.getElementById('api-key-input').value.trim();if(!key)return;localStorage.setItem('gabos_apikey',key);closeModal('modal-api-key');toast('Clé API enregistrée ✓','var(--green)');}
function getApiKey(){return localStorage.getItem('gabos_apikey');}
function coachQuick(type){const p={analyse:'Analyse mon business en détail.',today:'Que dois-je absolument faire aujourd\'hui ?',product:'Comment valider un produit avant de mettre trop de budget pub ?',motivation:'J\'ai besoin d\'un boost. Dis-moi pourquoi je vais y arriver.'};document.getElementById('coach-input').value=p[type];sendCoach();}
async function sendCoach(){
  const input=document.getElementById('coach-input'),msg=input.value.trim();if(!msg)return;input.value='';
  const apiKey=getApiKey();if(!apiKey){openModal('modal-api-key');return;}
  const mode=document.getElementById('coach-mode').value;
  const modes={normal:'Sois direct et concret.',strict:'Sois très exigeant, pousse à l\'action immédiate.',soft:'Sois encourageant et bienveillant.'};
  const streak=calcStreak(),lv=levelInfo();
  const totalRev=bState.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=bState.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const sys=`Tu es l'AI Business Coach de ${getUserName()}, 100% dédié à son succès.\n\nCONTEXTE:\n- Boutique: purrlopets.com (dropshipping)\n- Objectif: 4 000€/jour en décembre 2026 (${daysLeft()} jours restants)\n- Lycéen, entrepreneur autodidacte\n- CA total: ${totalRev.toFixed(0)}€ | Profit: ${(totalRev-totalExp).toFixed(0)}€\n- Habitudes: Streak ${streak} jours, Niveau ${lv.num} ${lv.emoji}\n- Formation: ${bState.formationHours||0}/80h\n\nMODE: ${modes[mode]}\n\nRéponds en français, avec des actions concrètes. Utilise des emojis. Sois bref.`;
  const box=document.getElementById('coach-messages');
  box.innerHTML+=`<div class="ai-label user" style="margin-top:16px">TOI</div><div class="ai-message user">${msg}</div>`;
  const tid='ty'+Date.now();
  box.innerHTML+=`<div id="${tid}"><div class="ai-label coach">COACH</div><div class="ai-message"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`;
  document.getElementById('coach-box').scrollTop=99999;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:1500,system:sys,messages:[{role:'user',content:msg}]})});
    const d=await r.json();
    if(d.error){document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message" style="color:var(--red)">❌ Erreur API : ${d.error.message||d.error.type}<br><span style="font-size:.75rem;color:var(--text3)">Vérifie ta clé API dans le bouton 🔑</span></div>`;return;}
    const reply=d.content?.[0]?.text||'Réponse vide.';
    document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message">${reply.replace(/\n/g,'<br>')}</div>`;
  }catch(e){document.getElementById(tid).innerHTML=`<div class="ai-label coach">COACH</div><div class="ai-message" style="color:var(--red)">❌ Erreur réseau — vérifie ta connexion et ta clé API.<br><small style="color:var(--text3)">${e.message}</small></div>`;}
  document.getElementById('coach-box').scrollTop=99999;
}
function clearCoach(){document.getElementById('coach-messages').innerHTML='<div class="ai-label coach">ASCEND COACH</div><div class="ai-message">Conversation effacée. Prêt à travailler, '+getUserName()+' 💪</div>';}

// ══════════════════════════════════════════════════════
//  GOAL PLAN — Plan d'action quotidien vers 4 000€/jour
// ══════════════════════════════════════════════════════
function openGoalPlan(){
  const totalRev=bState.transactions.filter(t=>t.type==='revenue').reduce((s,t)=>s+t.amount,0);
  const totalExp=bState.transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const profit=totalRev-totalExp;
  const activeCampaigns=bState.campaigns.filter(c=>c.status==='active');
  const scalingProducts=bState.products.filter(p=>p.status==='scaling');
  const testingProducts=bState.products.filter(p=>p.status==='testing');
  const urgentTasks=bState.tasks.filter(t=>!t.done&&t.priority==='high').slice(0,3);
  const dl=daysLeft();
  const streak=calcStreak();
  const formationPct=Math.round((bState.formationHours||0)/80*100);

  // Determine phase based on revenue
  let phase,phaseColor,phaseDesc;
  if(totalRev===0){phase='Phase 0 : Démarrage';phaseColor='var(--text2)';phaseDesc='Tu n\'as pas encore de revenus enregistrés. Priorité absolue : lancer ton premier produit.';}
  else if(totalRev<500){phase='Phase 1 : Validation';phaseColor='var(--accent)';phaseDesc='Premiers revenus — valide ton produit et ton angle avant de scaler.';}
  else if(totalRev<5000){phase='Phase 2 : Croissance';phaseColor='var(--gold)';phaseDesc='Tu as de la traction. L\'objectif est de multiplier ce qui fonctionne.';}
  else if(totalRev<50000){phase='Phase 3 : Scaling';phaseColor='var(--green)';phaseDesc='Tu scales. Optimise les campagnes rentables et élimine ce qui perd de l\'argent.';}
  else{phase='Phase 4 : Domination';phaseColor='var(--accent3)';phaseDesc='Tu es en route. Automatise, délègue, et scalable à l\'infini.';}

  // Build action plan based on actual data
  let actions=[];

  // Pub actions
  if(activeCampaigns.length===0){
    actions.push({priority:'🔴',cat:'Publicité',action:'Lancer au moins 1 campagne pub aujourd\'hui',detail:'Sans trafic = 0 vente. Même 5€/j sur Meta ou TikTok. C\'est la priorité n°1.'});
  } else {
    const badCampaigns=activeCampaigns.filter(c=>c.budget>0&&c.revenue/c.budget<1);
    if(badCampaigns.length>0)actions.push({priority:'🔴',cat:'Publicité',action:`Couper les ${badCampaigns.length} campagne(s) déficitaire(s)`,detail:`${badCampaigns.map(c=>c.name).join(', ')} — ROAS négatif. Chaque euro dépensé là est une perte sèche.`});
    const goodCampaigns=activeCampaigns.filter(c=>c.budget>0&&c.revenue/c.budget>=2);
    if(goodCampaigns.length>0)actions.push({priority:'🟡',cat:'Publicité',action:`Scaler ${goodCampaigns.map(c=>c.name.split(' ')[0]).join(', ')} de +20%`,detail:`ROAS ≥ 2x = campagne rentable. Augmente le budget prudemment (+20% max/jour).`});
    if(activeCampaigns.every(c=>c.ctr<1.5))actions.push({priority:'🟡',cat:'Créatif',action:'Tester un nouveau créatif publicitaire aujourd\'hui',detail:'CTR faible sur toutes les campagnes. Un meilleur visuel peut doubler tes résultats sans changer le budget.'});
  }

  // Product actions
  if(scalingProducts.length===0&&testingProducts.length===0){
    actions.push({priority:'🔴',cat:'Produit',action:'Trouver et lister 1 nouveau produit à tester',detail:`0 produit actif. Cherche sur AliExpress / CJ un produit avec fort potentiel viral et marge > 50%.`});
  } else if(testingProducts.length>0&&scalingProducts.length===0){
    actions.push({priority:'🟡',cat:'Produit',action:`Analyser les résultats de "${testingProducts[0].name}"`,detail:`3+ jours de test ? Il est temps de décider : scaler ou tuer. Un ROAS > 1.5x = signal positif.`});
  }

  // Formation action
  if(formationPct<100&&bState.formationHours<80){
    const remaining=80-(bState.formationHours||0);
    actions.push({priority:'🟢',cat:'Formation',action:`Regarder au moins 30min de formation aujourd'hui`,detail:`${formationPct}% complété (${bState.formationHours||0}/80h). ${remaining}h restantes. La formation = ton avantage concurrentiel.`});
  }

  // Habit / focus action
  if(streak<3)actions.push({priority:'🟢',cat:'Habitudes',action:'Compléter 100% de tes habitudes ce soir',detail:`Streak actuel : ${streak} jour(s). Un entrepreneur discipliné surpasse systématiquement un entrepreneur "talentueux" mais irrégulier.`});

  // Urgent tasks
  if(urgentTasks.length>0)actions.push({priority:'🔴',cat:'Tâches',action:`Terminer : "${urgentTasks[0].title}"`,detail:`Tâche haute priorité en attente. Bloque 30 min maintenant et fais-le.`});

  // Fallback if no actions
  if(actions.length===0)actions.push({priority:'🟢',cat:'Optimisation',action:'Analyser tes métriques Shopify d\'aujourd\'hui',detail:'Note tes visiteurs, commandes, CA et ROAS dans l\'onglet Analytics pour tracker ta progression vers 4 000€/jour.'});

  // Progress calculation
  const dailyAvg=totalRev>0?totalRev/Math.max(1,Math.ceil((new Date()-new Date('2026-03-22'))/(1000*60*60*24))):0;
  const progressTo4k=Math.min(100,(dailyAvg/4000*100)).toFixed(1);

  document.getElementById('goal-plan-content').innerHTML=`
  <div style="background:linear-gradient(135deg,rgba(0,245,196,.08),rgba(124,92,252,.08));border:1px solid rgba(0,245,196,.2);border-radius:var(--radius);padding:16px;margin-bottom:20px">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px">
      <div>
        <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:4px">Phase actuelle</div>
        <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:${phaseColor}">${phase}</div>
        <div style="font-size:.8rem;color:var(--text2);margin-top:4px;max-width:320px">${phaseDesc}</div>
      </div>
      <div style="text-align:right">
        <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:4px">Moy. journalière</div>
        <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.5rem;color:var(--accent3)">${dailyAvg.toFixed(0)}€<span style="font-size:.8rem;color:var(--text2)">/j</span></div>
        <div style="font-size:.74rem;color:var(--text2)">→ Objectif : 4 000€/j · <strong style="color:${dl<90?'var(--red)':'var(--gold)'}">${dl} jours</strong></div>
      </div>
    </div>
    <div class="prog-bg" style="margin-top:12px;height:8px"><div class="prog-fill" style="width:${progressTo4k}%;background:linear-gradient(90deg,var(--accent),var(--accent3))"></div></div>
    <div style="font-size:.7rem;color:var(--text3);margin-top:5px">${progressTo4k}% du chemin vers 4 000€/jour</div>
  </div>

  <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.78rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:12px">⚡ Actions concrètes — À faire aujourd'hui</div>
  ${actions.map((a,i)=>`<div style="display:flex;gap:12px;align-items:flex-start;padding:14px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:8px;transition:border-color .2s" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
    <div style="font-size:1.1rem;flex-shrink:0">${a.priority}</div>
    <div style="flex:1">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
        <span class="tag tag-purple" style="font-size:.62rem">${a.cat}</span>
        <span style="font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem">${a.action}</span>
      </div>
      <div style="font-size:.78rem;color:var(--text2);line-height:1.5">${a.detail}</div>
    </div>
  </div>`).join('')}

  <div style="margin-top:16px;padding:12px;background:rgba(124,92,252,.06);border:1px solid rgba(124,92,252,.15);border-radius:var(--radius-sm);font-size:.8rem;color:var(--text2);text-align:center">
    💬 Pour un plan encore plus précis, utilise le <span style="color:var(--accent);cursor:pointer;font-weight:600" onclick="closeModal('modal-goal-plan');showView('coach')">AI Coach →</span>
  </div>`;

  openModal('modal-goal-plan');
}

// ══════════════════════════════════════════════════════
//  INTEGRATIONS
// ══════════════════════════════════════════════════════
// ══════════════════════════════════════════════════════
//  INTEGRATIONS — New system with detail panels
// ══════════════════════════════════════════════════════
let currentIntegration = null;

const INT_CONFIG = {
  shopify: {
    name:'Shopify', icon:'🛒', color:'#96bf47',
    fields:[
      {id:'shopify-store', label:'Boutique (.myshopify.com)', placeholder:'purrlopets.myshopify.com', type:'text'},
      {id:'shopify-token', label:'Admin API Token', placeholder:'shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx', type:'password'}
    ],
    how:'Admin Shopify → Paramètres → Applications → Développer des apps → Créer une app → Accès API Admin → Activer <code>read_orders</code> <code>read_products</code> → Installer → copier le token shpat_...',
    save: saveShopifyKey, fetch: fetchShopifyData
  },
  meta: {
    name:'Meta Ads', icon:'📘', color:'#4f85ff',
    fields:[
      {id:'meta-token', label:'Access Token (EAA...)', placeholder:'EAAxxxxxxxxxxxxxxxx', type:'password'},
      {id:'meta-account', label:'Ad Account ID', placeholder:'act_123456789', type:'text'}
    ],
    how:'developers.facebook.com → Mes apps → Explorateur de l\'API Graph → Générer token → Permissions : <code>ads_read</code>',
    save: saveMetaKey, fetch: fetchMetaData
  },
  tiktok: {
    name:'TikTok Ads', icon:'🎵', color:'#ff0050',
    fields:[
      {id:'tiktok-token', label:'Access Token', placeholder:'Token TikTok Ads', type:'password'},
      {id:'tiktok-account', label:'Advertiser ID', placeholder:'7xxxxxxxxxxxxxxxxx', type:'text'}
    ],
    how:'ads.tiktok.com → Actifs → Business Center → API Management → Create App',
    save: saveTikTokKey, fetch: fetchTikTokData
  }
};

function openIntDetail(key){
  currentIntegration = key;
  const cfg = INT_CONFIG[key];
  if(!cfg) return;
  document.getElementById('int-list-view').style.display='none';
  document.getElementById('int-detail-view').style.display='block';
  document.getElementById('int-detail-title').textContent = cfg.icon+' '+cfg.name;

  // Build config fields
  let fieldsHtml = '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-bottom:10px">';
  cfg.fields.forEach(f=>{
    const saved = localStorage.getItem('gabos_'+f.id.replace('-','_').replace('-','_'));
    fieldsHtml += `<div><div class="inp-label">${f.label}</div><input class="inp" id="detail-${f.id}" type="${f.type}" placeholder="${f.placeholder}" value="${saved||''}"></div>`;
  });
  fieldsHtml += '</div>';
  fieldsHtml += `<button class="btn btn-primary" onclick="saveCurrentIntegration()">Connecter / Mettre à jour</button>`;
  document.getElementById('int-detail-config-fields').innerHTML = fieldsHtml;
  document.getElementById('int-detail-how').innerHTML = `📌 <strong style="color:var(--text2)">Comment obtenir le token :</strong> ${cfg.how}`;

  // Show disconnect if connected
  const badge = document.getElementById(key+'-card-status');
  const isConnected = badge && badge.innerHTML.includes('Connecté');
  document.getElementById('int-detail-disconnect-btn').style.display = isConnected?'block':'none';

  // Render data if already connected
  renderIntDetailData(key);
  updateDetailBadge(key);
}

function closeIntDetail(){
  document.getElementById('int-list-view').style.display='block';
  document.getElementById('int-detail-view').style.display='none';
  currentIntegration = null;
}

function saveCurrentIntegration(){
  if(!currentIntegration) return;
  const cfg = INT_CONFIG[currentIntegration];
  cfg.fields.forEach(f=>{
    const val = document.getElementById('detail-'+f.id)?.value.trim();
    if(val) {
      const key = f.id === 'shopify-store' ? 'gabos_shopify_store' : f.id === 'shopify-token' ? 'gabos_shopify_token' : f.id === 'meta-token' ? 'gabos_meta_token' : f.id === 'meta-account' ? 'gabos_meta_account' : f.id === 'tiktok-token' ? 'gabos_tiktok_token' : 'gabos_tiktok_account';
      localStorage.setItem(key, val);
    }
  });
  cfg.fetch();
  toast(cfg.name+' connecté ✓','var(--green)');
}

function syncCurrentIntegration(){
  if(!currentIntegration) return;
  INT_CONFIG[currentIntegration]?.fetch();
  toast('Sync lancée...','var(--accent)');
}

function disconnectCurrentIntegration(){
  if(!currentIntegration) return;
  const cfg = INT_CONFIG[currentIntegration];
  cfg.fields.forEach(f=>{
    const key = f.id === 'shopify-store' ? 'gabos_shopify_store' : f.id === 'shopify-token' ? 'gabos_shopify_token' : f.id === 'meta-token' ? 'gabos_meta_token' : f.id === 'meta-account' ? 'gabos_meta_account' : f.id === 'tiktok-token' ? 'gabos_tiktok_token' : 'gabos_tiktok_account';
    localStorage.removeItem(key);
  });
  updateCardStatus(currentIntegration, false);
  document.getElementById('int-detail-data').innerHTML='';
  document.getElementById('int-detail-disconnect-btn').style.display='none';
  updateDetailBadge(currentIntegration);
  toast(cfg.name+' déconnecté','var(--text2)');
}

function updateCardStatus(key, connected, text){
  const el = document.getElementById(key+'-card-status');
  if(!el) return;
  el.innerHTML = connected
    ? `<span class="tag tag-green" style="font-size:.62rem">✓ Connecté</span>`
    : `<span class="tag tag-red" style="font-size:.62rem">${text||'Non connecté'}</span>`;
}

function updateDetailBadge(key){
  const badge = document.getElementById('int-detail-badge');
  const cardStatus = document.getElementById(key+'-card-status');
  if(!badge||!cardStatus) return;
  const connected = cardStatus.innerHTML.includes('Connecté');
  badge.className = connected?'tag tag-green':'tag tag-red';
  badge.textContent = connected?'Connecté ✓':'Non connecté';
  document.getElementById('int-detail-disconnect-btn').style.display = connected?'block':'none';
}

function renderIntDetailData(key){
  const container = document.getElementById('int-detail-data');
  // Data gets populated by fetch functions below
  if(key==='shopify') fetchShopifyData(true);
  else if(key==='meta') fetchMetaData(true);
  else if(key==='tiktok') fetchTikTokData(true);
}

// ── CUSTOM INTEGRATIONS ──
function openAddCustomIntegration(){ openModal('modal-add-integration'); }

function saveCustomIntegration(){
  const name=document.getElementById('ci-name').value.trim();
  if(!name){toast('Donne un nom','var(--red)');return;}
  const ci={
    id:'ci'+Date.now(),
    name, icon:document.getElementById('ci-icon').value.trim()||'🔗',
    desc:document.getElementById('ci-desc').value.trim(),
    url:document.getElementById('ci-url').value.trim(),
    token:document.getElementById('ci-token').value.trim(),
    authType:document.getElementById('ci-auth-type').value
  };
  const customs=JSON.parse(localStorage.getItem('gabos_custom_integrations')||'[]');
  customs.push(ci);
  localStorage.setItem('gabos_custom_integrations',JSON.stringify(customs));
  renderCustomIntCards();
  closeModal('modal-add-integration');
  toast(name+' ajouté ✓','var(--green)');
}

function renderCustomIntCards(){
  const customs=JSON.parse(localStorage.getItem('gabos_custom_integrations')||'[]');
  const container=document.getElementById('custom-int-cards');
  if(!container) return;
  container.innerHTML=customs.map(ci=>`
    <div class="int-api-card" onclick="openCustomIntDetail('${ci.id}')" style="position:relative">
      <div class="int-card-icon" style="background:rgba(124,92,252,.08);border-color:rgba(124,92,252,.2)">${ci.icon}</div>
      <div class="int-card-name">${ci.name}</div>
      <div class="int-card-desc">${ci.desc||'Intégration custom'}</div>
      <div class="int-card-status"><span class="tag tag-purple" style="font-size:.62rem">Custom</span></div>
    </div>`).join('');
}

function openCustomIntDetail(id){
  const customs=JSON.parse(localStorage.getItem('gabos_custom_integrations')||'[]');
  const ci=customs.find(c=>c.id===id);
  if(!ci)return;
  document.getElementById('int-list-view').style.display='none';
  document.getElementById('int-detail-view').style.display='block';
  document.getElementById('int-detail-title').textContent=ci.icon+' '+ci.name;
  document.getElementById('int-detail-badge').className='tag tag-purple';
  document.getElementById('int-detail-badge').textContent='Custom';
  document.getElementById('int-detail-config-fields').innerHTML=`
    <div style="display:grid;gap:10px;margin-bottom:10px">
      <div><div class="inp-label">URL API</div><input class="inp" value="${ci.url}" readonly></div>
      <div><div class="inp-label">Token</div><input class="inp" type="password" value="${ci.token}" readonly></div>
    </div>
    <button class="btn danger btn-sm" onclick="deleteCustomIntegration('${id}')">Supprimer</button>`;
  document.getElementById('int-detail-how').innerHTML='';
  document.getElementById('int-detail-data').innerHTML=`
    <div class="card">
      <div class="card-title">📡 Test de connexion</div>
      <button class="btn btn-primary btn-sm" onclick="testCustomIntegration('${id}')">Tester l'API →</button>
      <div id="custom-test-result" style="margin-top:12px"></div>
    </div>`;
  document.getElementById('int-detail-disconnect-btn').style.display='none';
}

function deleteCustomIntegration(id){
  let customs=JSON.parse(localStorage.getItem('gabos_custom_integrations')||'[]');
  customs=customs.filter(c=>c.id!==id);
  localStorage.setItem('gabos_custom_integrations',JSON.stringify(customs));
  renderCustomIntCards();
  closeIntDetail();
  toast('Intégration supprimée','var(--text2)');
}

async function testCustomIntegration(id){
  const customs=JSON.parse(localStorage.getItem('gabos_custom_integrations')||'[]');
  const ci=customs.find(c=>c.id===id);
  if(!ci)return;
  const result=document.getElementById('custom-test-result');
  result.innerHTML='<span style="color:var(--text2)">Test en cours...</span>';
  try{
    const headers={'Content-Type':'application/json'};
    if(ci.authType==='bearer')headers['Authorization']='Bearer '+ci.token;
    else if(ci.authType==='apikey')headers['X-API-Key']=ci.token;
    const r=await fetch(ci.url,{headers});
    if(r.ok){
      const data=await r.json();
      result.innerHTML=`<div class="alert alert-success">✓ Connexion réussie (${r.status})<pre style="font-size:.72rem;margin-top:8px;overflow:auto;max-height:200px">${JSON.stringify(data,null,2).slice(0,500)}</pre></div>`;
    } else {
      result.innerHTML=`<div class="alert alert-danger">✗ Erreur ${r.status} — Vérifie l'URL et le token</div>`;
    }
  }catch(e){
    result.innerHTML=`<div class="alert alert-danger">✗ Erreur réseau — ${e.message}<br><small>Probablement un problème CORS. Essaie depuis Netlify.</small></div>`;
  }
}

// ── SHOPIFY FETCH ──
function saveShopifyKey(){
  const store=document.getElementById('shopify-store')?.value.trim()||document.getElementById('detail-shopify-store')?.value.trim();
  const token=document.getElementById('shopify-token')?.value.trim()||document.getElementById('detail-shopify-token')?.value.trim();
  if(!store||!token){toast('Remplis les deux champs','var(--red)');return;}
  const s=store.includes('.')?store:store+'.myshopify.com';
  localStorage.setItem('gabos_shopify_store',s);
  localStorage.setItem('gabos_shopify_token',token);
  toast('Shopify enregistré ✓','var(--green)');
  fetchShopifyData();
}

async function fetchShopifyData(fromDetail=false){
  const store=localStorage.getItem('gabos_shopify_store');
  const token=localStorage.getItem('gabos_shopify_token');
  if(!store||!token)return;
  updateCardStatus('shopify',false,'Chargement...');
  try{
    const today=new Date().toISOString().split('T')[0];
    const thirtyAgo=new Date(Date.now()-30*86400000).toISOString().split('T')[0];
    const url=`https://${store}/admin/api/2024-01/orders.json?status=any&created_at_min=${thirtyAgo}T00:00:00&limit=50&fields=id,name,total_price,financial_status,created_at,line_items`;
    const r=await fetch(url,{headers:{'X-Shopify-Access-Token':token,'Content-Type':'application/json'}});
    if(!r.ok)throw new Error('HTTP '+r.status);
    const data=await r.json();
    const orders=data.orders||[];
    const paid=orders.filter(o=>o.financial_status==='paid');
    const totalRev=paid.reduce((s,o)=>s+parseFloat(o.total_price||0),0);
    const todayOrders=orders.filter(o=>o.created_at?.startsWith(today));
    const todayRev=todayOrders.filter(o=>o.financial_status==='paid').reduce((s,o)=>s+parseFloat(o.total_price||0),0);
    const avgOrder=paid.length?totalRev/paid.length:0;
    updateCardStatus('shopify',true);
    if(currentIntegration==='shopify'||fromDetail){
      updateDetailBadge('shopify');
      document.getElementById('int-detail-data').innerHTML=`
        <div class="grid-4" style="margin-bottom:16px">
          <div class="kpi-card" style="--kpi-color:var(--green)"><div class="kpi-label">CA Aujourd'hui</div><div class="kpi-value" style="color:var(--green)">${todayRev.toFixed(0)}€</div><div class="kpi-sub">${todayOrders.length} commande(s)</div></div>
          <div class="kpi-card" style="--kpi-color:var(--accent3)"><div class="kpi-label">CA 30 jours</div><div class="kpi-value" style="color:var(--accent3)">${totalRev.toFixed(0)}€</div><div class="kpi-sub">${paid.length} payées</div></div>
          <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">Panier moyen</div><div class="kpi-value" style="color:var(--gold)">${avgOrder.toFixed(0)}€</div></div>
          <div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">Total commandes</div><div class="kpi-value" style="color:var(--accent)">${orders.length}</div><div class="kpi-sub">30 derniers jours</div></div>
        </div>
        <div class="card">
          <div class="card-title">📦 Dernières commandes</div>
          ${orders.slice(0,15).length?`<table class="data-table"><thead><tr><th>#</th><th>Date</th><th>Montant</th><th>Statut</th></tr></thead><tbody>${orders.slice(0,15).map(o=>`<tr><td class="mono">${o.name}</td><td style="color:var(--text2)">${new Date(o.created_at).toLocaleDateString('fr-FR')}</td><td style="color:var(--accent3);font-weight:700">${parseFloat(o.total_price||0).toFixed(2)}€</td><td><span class="tag ${o.financial_status==='paid'?'tag-green':'tag-gold'}">${o.financial_status}</span></td></tr>`).join('')}</tbody></table>`:'<div class="empty-state">Aucune commande</div>'}
        </div>`;
    }
  }catch(e){
    updateCardStatus('shopify',false,'Erreur');
    if(currentIntegration==='shopify'||fromDetail) updateDetailBadge('shopify');
    toast('Erreur Shopify : '+e.message,'var(--red)');
  }
}

// ── META FETCH ──
function saveMetaKey(){
  const token=document.getElementById('meta-token')?.value.trim()||document.getElementById('detail-meta-token')?.value.trim();
  const account=document.getElementById('meta-account')?.value.trim()||document.getElementById('detail-meta-account')?.value.trim();
  if(!token||!account){toast('Remplis les deux champs','var(--red)');return;}
  localStorage.setItem('gabos_meta_token',token);
  localStorage.setItem('gabos_meta_account',account);
  toast('Meta Ads enregistré ✓','var(--green)');
  fetchMetaData();
}

async function fetchMetaData(fromDetail=false){
  const token=localStorage.getItem('gabos_meta_token');
  const account=localStorage.getItem('gabos_meta_account');
  if(!token||!account)return;
  updateCardStatus('meta',false,'Chargement...');
  try{
    const since=new Date(Date.now()-30*86400000).toISOString().split('T')[0];
    const until=new Date().toISOString().split('T')[0];
    const url=`https://graph.facebook.com/v18.0/${account}/insights?fields=spend,impressions,clicks,cpc,cpm,actions&time_range={"since":"${since}","until":"${until}"}&access_token=${token}`;
    const r=await fetch(url);
    if(!r.ok)throw new Error('HTTP '+r.status);
    const data=await r.json();
    if(data.error)throw new Error(data.error.message);
    const ins=data.data?.[0]||{};
    const spend=parseFloat(ins.spend||0);
    const impressions=parseInt(ins.impressions||0);
    const clicks=parseInt(ins.clicks||0);
    const cpc=parseFloat(ins.cpc||0);
    const purchases=(ins.actions||[]).find(a=>a.action_type==='purchase');
    const revenue=purchases?parseFloat(purchases.value||0):0;
    const roas=spend>0?(revenue/spend).toFixed(2):0;
    updateCardStatus('meta',true);
    if(currentIntegration==='meta'||fromDetail){
      updateDetailBadge('meta');
      document.getElementById('int-detail-data').innerHTML=`
        <div class="grid-4" style="margin-bottom:16px">
          <div class="kpi-card" style="--kpi-color:var(--red)"><div class="kpi-label">Dépenses 30j</div><div class="kpi-value" style="color:var(--red)">${spend.toFixed(0)}€</div></div>
          <div class="kpi-card" style="--kpi-color:${roas>=2?'var(--green)':'var(--red)'}"><div class="kpi-label">ROAS</div><div class="kpi-value" style="color:${roas>=2?'var(--green)':'var(--red)'}">${roas}x</div></div>
          <div class="kpi-card" style="--kpi-color:var(--blue)"><div class="kpi-label">Impressions</div><div class="kpi-value" style="color:var(--blue);font-size:1.3rem">${(impressions/1000).toFixed(1)}k</div></div>
          <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">CPC moyen</div><div class="kpi-value" style="color:var(--gold)">${cpc.toFixed(2)}€</div><div class="kpi-sub">${clicks} clics</div></div>
        </div>
        <div class="card">
          <div class="card-title">📘 Stats Meta Ads — 30 derniers jours</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:8px">
            <div style="background:var(--surface2);border-radius:var(--radius-sm);padding:14px"><div style="font-size:.7rem;color:var(--text2);margin-bottom:4px">Revenue généré</div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;color:var(--green)">${revenue.toFixed(0)}€</div></div>
            <div style="background:var(--surface2);border-radius:var(--radius-sm);padding:14px"><div style="font-size:.7rem;color:var(--text2);margin-bottom:4px">CPM</div><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;color:var(--accent)">${parseFloat(ins.cpm||0).toFixed(2)}€</div></div>
          </div>
        </div>`;
    }
  }catch(e){
    updateCardStatus('meta',false,'Erreur');
    if(currentIntegration==='meta'||fromDetail) updateDetailBadge('meta');
    toast('Erreur Meta Ads — '+e.message,'var(--red)');
  }
}

// ── TIKTOK FETCH ──
function saveTikTokKey(){
  const token=document.getElementById('tiktok-token')?.value.trim()||document.getElementById('detail-tiktok-token')?.value.trim();
  const account=document.getElementById('tiktok-account')?.value.trim()||document.getElementById('detail-tiktok-account')?.value.trim();
  if(!token||!account){toast('Remplis les deux champs','var(--red)');return;}
  localStorage.setItem('gabos_tiktok_token',token);
  localStorage.setItem('gabos_tiktok_account',account);
  toast('TikTok Ads enregistré ✓','var(--green)');
  fetchTikTokData();
}

async function fetchTikTokData(fromDetail=false){
  const token=localStorage.getItem('gabos_tiktok_token');
  const account=localStorage.getItem('gabos_tiktok_account');
  if(!token||!account)return;
  updateCardStatus('tiktok',false,'Chargement...');
  try{
    const endDate=new Date().toISOString().split('T')[0];
    const startDate=new Date(Date.now()-30*86400000).toISOString().split('T')[0];
    const url=`https://business-api.tiktok.com/open_api/v1.3/report/integrated/get/?advertiser_id=${account}&report_type=BASIC&data_level=AUCTION_ADVERTISER&dimensions=["stat_time_day"]&metrics=["spend","impressions","clicks","cpc","cpm"]&start_date=${startDate}&end_date=${endDate}&page_size=30`;
    const r=await fetch(url,{headers:{'Access-Token':token,'Content-Type':'application/json'}});
    if(!r.ok)throw new Error('HTTP '+r.status);
    const data=await r.json();
    if(data.code!==0)throw new Error(data.message||'Erreur TikTok');
    const rows=data.data?.list||[];
    const spend=rows.reduce((s,r)=>s+parseFloat(r.metrics?.spend||0),0);
    const impressions=rows.reduce((s,r)=>s+parseInt(r.metrics?.impressions||0),0);
    const clicks=rows.reduce((s,r)=>s+parseInt(r.metrics?.clicks||0),0);
    const cpc=clicks>0?(spend/clicks):0;
    updateCardStatus('tiktok',true);
    if(currentIntegration==='tiktok'||fromDetail){
      updateDetailBadge('tiktok');
      document.getElementById('int-detail-data').innerHTML=`
        <div class="grid-4" style="margin-bottom:16px">
          <div class="kpi-card" style="--kpi-color:var(--red)"><div class="kpi-label">Dépenses 30j</div><div class="kpi-value" style="color:var(--red)">${spend.toFixed(0)}€</div></div>
          <div class="kpi-card" style="--kpi-color:var(--blue)"><div class="kpi-label">Impressions</div><div class="kpi-value" style="color:var(--blue);font-size:1.3rem">${(impressions/1000).toFixed(1)}k</div></div>
          <div class="kpi-card" style="--kpi-color:var(--gold)"><div class="kpi-label">Clics</div><div class="kpi-value" style="color:var(--gold)">${clicks}</div></div>
          <div class="kpi-card" style="--kpi-color:var(--accent)"><div class="kpi-label">CPC moyen</div><div class="kpi-value" style="color:var(--accent)">${cpc.toFixed(2)}€</div></div>
        </div>
        <div class="card">
          <div class="card-title">🎵 Évolution TikTok Ads — 30j</div>
          ${rows.length?`<table class="data-table"><thead><tr><th>Date</th><th>Dépenses</th><th>Impressions</th><th>Clics</th></tr></thead><tbody>${rows.slice(0,10).map(row=>`<tr><td style="color:var(--text2)">${row.dimensions?.stat_time_day||'-'}</td><td style="color:var(--red)">${parseFloat(row.metrics?.spend||0).toFixed(2)}€</td><td>${parseInt(row.metrics?.impressions||0).toLocaleString()}</td><td style="color:var(--accent)">${parseInt(row.metrics?.clicks||0)}</td></tr>`).join('')}</tbody></table>`:'<div class="empty-state">Aucune donnée</div>'}
        </div>`;
    }
  }catch(e){
    updateCardStatus('tiktok',false,'Erreur');
    if(currentIntegration==='tiktok'||fromDetail) updateDetailBadge('tiktok');
    toast('Erreur TikTok Ads — '+e.message,'var(--red)');
  }
}

function updateConsolidated(){}

function syncAllIntegrations(){
  fetchShopifyData();
  fetchMetaData();
  fetchTikTokData();
  toast('Sync lancée...','var(--accent)');
}

function initIntegrations(){
  renderCustomIntCards();
  if(localStorage.getItem('gabos_shopify_token'))fetchShopifyData();
  if(localStorage.getItem('gabos_meta_token'))fetchMetaData();
  if(localStorage.getItem('gabos_tiktok_token'))fetchTikTokData();
}

// ══════════════════════════════════════════════════════
//  ONBOARDING & USER NAME
// ══════════════════════════════════════════════════════
function getUserName(){
  return localStorage.getItem('ascend_username')||'toi';
}

function finishOnboarding(){
  const name=document.getElementById('onboarding-name').value.trim();
  if(!name){
    document.getElementById('onboarding-name').style.borderColor='var(--red)';
    document.getElementById('onboarding-name').placeholder='Écris ton prénom/blaze !';
    return;
  }
  localStorage.setItem('ascend_username', name);
  const overlay=document.getElementById('onboarding-overlay');
  overlay.style.opacity='0';
  overlay.style.transition='opacity .4s ease';
  setTimeout(()=>{overlay.style.display='none';},400);
  // Update all name references
  refreshUserName();
}

function refreshUserName(){
  const name=getUserName();
  // Coach welcome
  const welcomeMsg=document.getElementById('coach-welcome-msg');
  if(welcomeMsg) welcomeMsg.innerHTML=`Salut ${name} 👋 Je suis ton AI Business Coach, 100% dédié à ton objectif : <strong>4 000€/jour en décembre 2026</strong>.<br><br>Configure ta clé API Anthropic (bouton 🔑 en haut) pour activer le coaching IA. 💪`;
  // Greetings get refreshed on next clock tick automatically
}

function checkOnboarding(){
  const name=localStorage.getItem('ascend_username');
  if(!name){
    document.getElementById('onboarding-overlay').style.display='flex';
    setTimeout(()=>document.getElementById('onboarding-name').focus(), 300);
  } else {
    document.getElementById('onboarding-overlay').style.display='none';
    refreshUserName();
  }
}

// ══════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════
document.querySelectorAll('.modal-bg').forEach(bg=>bg.addEventListener('click',e=>{if(e.target===bg)bg.classList.remove('open');}));

// Init mode
document.body.className='mode-'+currentMode;
if(currentMode==='hab'){
  document.getElementById('nav-section-biz').classList.add('hidden-section');
  document.getElementById('nav-section-hab').classList.remove('hidden-section');
  document.getElementById('sidebar-mode-badge').textContent='🌱 Habitudes';
  document.querySelector('.mode-pill-biz').classList.remove('active-biz');
  document.querySelector('.mode-pill-hab').classList.add('active-hab');
  showView('today');
} else {
  showView('command');
}

updateClock();
renderColorPicker();
updateXP();
initIntegrations();
checkOnboarding();

// Init slider after DOM is ready
requestAnimationFrame(() => { requestAnimationFrame(initSlider); });
window.addEventListener('resize', initSlider);
</script>
</body>
</html>
