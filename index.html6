</div></div>

<!-- Lien -->
<div class="modal-bg" id="modal-add-link"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Lien</div><button class="modal-close" onclick="closeModal('modal-add-link')">✕</button></div>
  <div class="inp-group"><div class="inp-label">Nom</div><input class="inp" id="l-name" placeholder="Ex: Shopify Admin"></div>
  <div class="inp-group"><div class="inp-label">URL</div><input class="inp" id="l-url" placeholder="https://..."></div>
  <div class="inp-group"><div class="inp-label">Icône</div><input class="inp" id="l-icon" placeholder="🔗"></div>
  <div class="inp-group"><div class="inp-label">Catégorie</div><select class="inp" id="l-cat"><option>E-commerce</option><option>Publicité</option><option>Formation</option><option>Communication</option><option>Outils</option><option>Autre</option></select></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addLink()">Ajouter</button>
</div></div>

<!-- Ressource -->
<div class="modal-bg" id="modal-add-resource"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Ressource</div><button class="modal-close" onclick="closeModal('modal-add-resource')">✕</button></div>
  <div class="inp-group"><div class="inp-label">Titre</div><input class="inp" id="r-title" placeholder="Ex: Vidéo stratégie TikTok Ads"></div>
  <div class="inp-group"><div class="inp-label">URL</div><input class="inp" id="r-url" placeholder="https://..."></div>
  <div class="inp-group"><div class="inp-label">Type</div><select class="inp" id="r-type"><option>Vidéo</option><option>Article</option><option>Formation</option><option>Outil</option><option>Autre</option></select></div>
  <div class="inp-group"><div class="inp-label">Notes</div><textarea class="inp" id="r-notes" rows="3" placeholder="Ce que tu veux retenir..."></textarea></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addResource()">Ajouter</button>
</div></div>

<!-- API Key -->
<div class="modal-bg" id="modal-api-key"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">🔑 Clé API Anthropic</div><button class="modal-close" onclick="closeModal('modal-api-key')">✕</button></div>
