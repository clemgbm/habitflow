  <div class="inp-group"><div class="inp-label">Priorité</div><select class="inp" id="task-priority"><option value="high">🔴 Haute</option><option value="med" selected>🟡 Moyenne</option><option value="low">🟢 Faible</option></select></div>
  <div class="inp-group"><div class="inp-label">Catégorie</div><select class="inp" id="task-cat"><option>Business</option><option>Publicité</option><option>Produit</option><option>Finance</option><option>Autre</option></select></div>
  <div class="inp-group"><div class="inp-label">Deadline</div><input class="inp" type="date" id="task-deadline"></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addTask()">Ajouter</button>
</div></div>

<!-- Templates -->
<div class="modal-bg" id="modal-template"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">📋 Templates</div><button class="modal-close" onclick="closeModal('modal-template')">✕</button></div>
  <div id="templates-list"></div>
</div></div>

<!-- Objectif -->
<div class="modal-bg" id="modal-add-goal"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Objectif</div><button class="modal-close" onclick="closeModal('modal-add-goal')">✕</button></div>
