<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="dark light">
<meta name="theme-color" content="#07070f" media="(prefers-color-scheme: dark)">
<meta name="theme-color" content="#f4f4fa" media="(prefers-color-scheme: light)">
<title>ASCEND — Unified Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg:#07070f;--bg2:#0c0c1a;--surface:#101020;--surface2:#181828;--surface3:#22223a;
  --border:#ffffff0d;--border2:#ffffff1a;--border3:#ffffff28;
  --text:#f0f0fa;--text2:#7878a8;--text3:#36365a;
  --accent:#7c5cfc;--accent2:#fc5c7d;--accent3:#00f5c4;--gold:#ffd166;
  --red:#ef476f;--green:#06d6a0;--blue:#4fc3ff;
  --biz:#7c5cfc;--biz-glow:rgba(124,92,252,.18);
  --hab:#00f5c4;--hab-glow:rgba(0,245,196,.18);
  --radius:16px;--radius-sm:10px;
  --shadow:0 0 40px rgba(124,92,252,.1);
  --sidebar:240px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
h1,h2,h3,h4{font-family:'Syne',sans-serif}
.mono{font-family:'DM Mono',monospace}

/* ════════════════════════════════
   MODE SWITCHER
════════════════════════════════ */
.mode-switcher-wrap {
  position:fixed;top:0;left:var(--sidebar);right:0;z-index:200;
  display:flex;justify-content:center;align-items:center;
  padding:14px 24px;
  background:linear-gradient(180deg,var(--bg) 60%,transparent 100%);
  pointer-events:none;
}
.mode-switcher {
  pointer-events:all;
  display:inline-flex;align-items:center;
  background:var(--surface);border:1px solid var(--border3);
  border-radius:999px;padding:5px;gap:3px;
  box-shadow:0 4px 24px rgba(0,0,0,.4),0 0 0 1px var(--border);
  position:relative;
}
.mode-pill {
  display:flex;align-items:center;gap:8px;
  padding:9px 22px;border-radius:999px;
  font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;
  cursor:pointer;transition:all .28s cubic-bezier(.4,0,.2,1);
  color:var(--text3);letter-spacing:.3px;user-select:none;position:relative;z-index:1;
}
.mode-pill .mp-icon{font-size:1rem;transition:transform .28s}
.mode-pill:hover{color:var(--text2)}
.mode-pill.active-biz{color:#fff}
.mode-pill.active-hab{color:#fff}
.mode-slider{
  position:absolute;top:5px;height:calc(100% - 10px);
  border-radius:999px;transition:all .32s cubic-bezier(.4,0,.2,1);
  z-index:0;
}
body.mode-biz .mode-slider{background:linear-gradient(135deg,var(--accent),var(--accent2));box-shadow:0 0 20px var(--biz-glow)}
body.mode-hab .mode-slider{background:linear-gradient(135deg,#00c49a,var(--accent3));box-shadow:0 0 20px var(--hab-glow)}
body.mode-biz .mode-pill-biz .mp-icon{transform:scale(1.15)}
body.mode-hab .mode-pill-hab .mp-icon{transform:scale(1.15)}
.mode-divider{width:1px;height:20px;background:var(--border3);margin:0 2px}

/* ════════════════════════════════
   LAYOUT
════════════════════════════════ */
.app{display:flex;min-height:100vh}
.sidebar{
  width:var(--sidebar);min-height:100vh;
  background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;padding:24px 16px;
  position:fixed;top:0;left:0;bottom:0;z-index:100;
  transition:transform .3s;overflow-y:auto;
}
.sidebar-logo{
  font-family:'Syne',sans-serif;font-weight:800;font-size:1.25rem;
  letter-spacing:2px;margin-bottom:6px;padding:0 6px;
  background:linear-gradient(135deg,#7c5cfc,#fc5c7d);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.sidebar-logo small{display:block;font-size:.52rem;font-weight:400;-webkit-text-fill-color:var(--text3);color:var(--text3);letter-spacing:3px;text-transform:uppercase;margin-top:2px}
.sidebar-mode-badge{
  display:inline-flex;align-items:center;gap:6px;
  border-radius:999px;padding:5px 12px;font-size:.72rem;font-weight:700;
  margin-bottom:20px;margin-left:2px;transition:all .3s;
  font-family:'Syne',sans-serif;
}
body.mode-biz .sidebar-mode-badge{background:var(--biz-glow);color:var(--accent);border:1px solid rgba(124,92,252,.3)}
body.mode-hab .sidebar-mode-badge{background:var(--hab-glow);color:var(--accent3);border:1px solid rgba(0,245,196,.3)}

.nav-section{margin-bottom:6px;transition:all .3s}
.nav-section.hidden-section{display:none}
.nav-group-label{font-size:.58rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3);padding:0 8px;margin-bottom:5px;margin-top:12px}
.nav-item{
  display:flex;align-items:center;gap:10px;padding:9px 10px;
  border-radius:var(--radius-sm);cursor:pointer;font-size:.84rem;font-weight:500;
  color:var(--text2);transition:all .18s;margin-bottom:2px;border:1px solid transparent;user-select:none;
}
.nav-item:hover{color:var(--text);background:var(--surface2)}
.nav-item.active{color:var(--text);background:var(--surface2);border-color:var(--border2)}
body.mode-biz .nav-item.active{border-left:3px solid var(--accent)}
body.mode-hab .nav-item.active{border-left:3px solid var(--accent3)}
.nav-item .ni{font-size:.95rem;width:18px;text-align:center}
.sidebar-footer{margin-top:auto;padding-top:16px;border-top:1px solid var(--border)}
.xp-block{background:linear-gradient(135deg,rgba(124,92,252,.1),transparent);border:1px solid rgba(124,92,252,.18);border-radius:var(--radius-sm);padding:12px;margin-bottom:10px}
.level-badge{font-family:'Syne',sans-serif;font-size:.78rem;font-weight:700;color:var(--gold);margin-bottom:4px}
.xp-bar-bg{background:var(--surface2);border-radius:999px;height:6px;overflow:hidden;margin:6px 0}
.xp-bar-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .6s cubic-bezier(.4,0,.2,1)}
.xp-label{display:flex;justify-content:space-between;font-size:.7rem;color:var(--text2)}
.streak-pill{display:inline-flex;align-items:center;gap:5px;background:rgba(255,209,102,.1);border:1px solid rgba(255,209,102,.2);color:var(--gold);border-radius:999px;padding:4px 10px;font-size:.76rem;font-weight:600;margin-top:8px}
.goal-block{background:linear-gradient(135deg,rgba(124,92,252,.15),rgba(252,92,125,.08));border:1px solid rgba(124,92,252,.25);border-radius:var(--radius-sm);padding:12px;margin-top:10px}
.goal-label{font-size:.62rem;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.goal-val{font-family:'Syne',sans-serif;font-weight:800;font-size:1.05rem;color:var(--accent3)}
.goal-sub{font-size:.68rem;color:var(--text2);margin-top:2px}
.goal-bar-bg{height:4px;background:var(--surface3);border-radius:4px;margin-top:8px;overflow:hidden}
.goal-bar-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--accent3));transition:width .6s ease}

/* ════════════════════════════════
   MAIN
════════════════════════════════ */
.main{margin-left:var(--sidebar);flex:1;padding:80px 32px 32px;min-height:100vh}

/* ════════════════════════════════
   TOPBAR
════════════════════════════════ */
.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px}
.topbar-left h2{font-size:1.45rem;font-weight:800;letter-spacing:-.5px}
.topbar-left .sub{font-size:.8rem;color:var(--text2);margin-top:2px}
.topbar-right{display:flex;gap:10px;align-items:center}
.date-chip{background:var(--surface);border:1px solid var(--border2);border-radius:999px;padding:7px 16px;font-size:.78rem;color:var(--text2);font-family:'DM Mono',monospace}
.btn{padding:8px 18px;border-radius:var(--radius-sm);border:none;cursor:pointer;font-family:'Syne',sans-serif;font-weight:700;font-size:.8rem;transition:all .18s;letter-spacing:.2px}
.btn-primary{background:var(--accent);color:white}
.btn-primary:hover{background:#6a4ee8;transform:translateY(-1px)}
.btn-green{background:linear-gradient(135deg,#00c49a,var(--accent3));color:#000}
.btn-green:hover{opacity:.9;transform:translateY(-1px)}
.btn.danger{background:var(--red);color:white}
.btn-ghost{background:var(--surface2);border:1px solid var(--border2);color:var(--text2)}
.btn-ghost:hover{color:var(--text);border-color:var(--accent)}
.btn-sm{padding:6px 13px;font-size:.75rem}
.btn-icon{background:var(--surface2);border:1px solid var(--border);color:var(--text2);border-radius:8px;width:28px;height:28px;cursor:pointer;font-size:.8rem;display:flex;align-items:center;justify-content:center;transition:all .15s}
.btn-icon:hover{color:var(--text);border-color:var(--accent)}

/* ════════════════════════════════
   VIEWS
════════════════════════════════ */
.view{display:none}
.view.active{display:block;animation:fadeUp .22s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ════════════════════════════════
   GRIDS
════════════════════════════════ */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.grid-auto{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:20px}
.col-span-2{grid-column:span 2}

/* ════════════════════════════════
   CARDS
════════════════════════════════ */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;transition:border-color .2s}
.card:hover{border-color:var(--border2)}
.card-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.76rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:14px;display:flex;justify-content:space-between;align-items:center}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;position:relative;overflow:hidden;transition:all .2s}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--kpi-color,var(--accent))}
.kpi-card:hover{border-color:var(--border2);transform:translateY(-1px)}
.kpi-label{font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:8px}
.kpi-value{font-family:'Syne',sans-serif;font-weight:800;font-size:1.75rem;letter-spacing:-1px}
.kpi-sub{font-size:.7rem;color:var(--text2);margin-top:4px}
.section-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;margin-bottom:16px;display:flex;align-items:center;gap:10px}

/* ════════════════════════════════
   INPUTS
════════════════════════════════ */
.inp{background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:10px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s;width:100%}
.inp:focus{border-color:var(--accent)}
.inp::placeholder{color:var(--text3)}
.inp-row{display:flex;gap:8px;margin-bottom:10px}
.inp-label{font-size:.7rem;color:var(--text2);margin-bottom:5px;font-weight:600;letter-spacing:.5px}
.inp-group{margin-bottom:12px}
select.inp{cursor:pointer}

/* ════════════════════════════════
   TAGS
════════════════════════════════ */
.tag{display:inline-flex;align-items:center;gap:4px;border-radius:999px;padding:3px 10px;font-size:.7rem;font-weight:700}
.tag-purple{background:rgba(124,92,252,.15);border:1px solid rgba(124,92,252,.3);color:var(--accent)}
.tag-green{background:rgba(0,245,196,.12);border:1px solid rgba(0,245,196,.25);color:var(--accent3)}
.tag-red{background:rgba(239,71,111,.12);border:1px solid rgba(239,71,111,.25);color:var(--red)}
.tag-gold{background:rgba(255,209,102,.12);border:1px solid rgba(255,209,102,.25);color:var(--gold)}
.tag-blue{background:rgba(79,195,255,.12);border:1px solid rgba(79,195,255,.25);color:var(--blue)}

/* ════════════════════════════════
   PROGRESS
════════════════════════════════ */
.prog-bg{height:6px;background:var(--surface3);border-radius:6px;overflow:hidden;margin-top:6px}
.prog-fill{height:100%;border-radius:6px;transition:width .6s ease}

/* ════════════════════════════════
   TABLE
════════════════════════════════ */
.data-table{width:100%;border-collapse:collapse}
.data-table th{font-size:.66rem;text-transform:uppercase;letter-spacing:1px;color:var(--text3);font-weight:700;padding:8px 12px;text-align:left;border-bottom:1px solid var(--border)}
.data-table td{padding:11px 12px;font-size:.84rem;border-bottom:1px solid var(--border);vertical-align:middle}
.data-table tr:last-child td{border-bottom:none}
.data-table tr:hover td{background:var(--surface2)}
.divider{height:1px;background:var(--border);margin:20px 0}

/* ════════════════════════════════
   TOAST + BURST
════════════════════════════════ */
.toast{position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:12px 20px;font-size:.84rem;font-weight:600;box-shadow:var(--shadow);opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none;max-width:300px}
.toast.show{opacity:1;transform:translateY(0)}
.burst{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);font-size:4rem;z-index:9998;pointer-events:none;transition:transform .3s cubic-bezier(.34,1.56,.64,1),opacity .3s}
.burst.show{transform:translate(-50%,-50%) scale(1);opacity:1}
.burst:not(.show){opacity:0;transform:translate(-50%,-50%) scale(0)}

/* ════════════════════════════════
   MODALS
════════════════════════════════ */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(10px);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .25s}
.modal-bg.open{opacity:1;pointer-events:all}
.modal-box{background:var(--surface);border:1px solid var(--border2);border-radius:20px;padding:28px;width:100%;max-width:500px;max-height:85vh;overflow-y:auto;transform:scale(.96);transition:transform .25s}
.modal-bg.open .modal-box{transform:scale(1)}
.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.modal-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem}
.modal-close{background:var(--surface2);border:1px solid var(--border2);color:var(--text2);border-radius:8px;width:30px;height:30px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal-sheet{background:var(--surface);border-radius:24px 24px 0 0;padding:24px 20px 36px;width:100%;max-width:480px;transform:translateY(30px);transition:transform .3s cubic-bezier(.4,0,.2,1)}
.modal-overlay.open .modal-sheet{transform:translateY(0)}
.modal-row{margin-bottom:14px}
.modal-label{font-size:.76rem;color:var(--text2);margin-bottom:7px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.modal-btns{display:flex;gap:10px;margin-top:20px}

/* ════════════════════════════════
   EMPTY
════════════════════════════════ */
.empty{text-align:center;padding:40px 20px;color:var(--text2)}
.empty .ei{font-size:2.5rem;margin-bottom:12px}
.empty p{font-size:.88rem}
.empty-state{text-align:center;padding:24px;color:var(--text3);font-size:.85rem}

/* ════════════════════════════════
   ALERTS
════════════════════════════════ */
.alert{border-radius:var(--radius-sm);padding:12px 16px;font-size:.83rem;margin-bottom:10px;display:flex;gap:10px;align-items:flex-start}
.alert-warn{background:rgba(255,209,102,.08);border:1px solid rgba(255,209,102,.2);color:var(--gold)}
.alert-danger{background:rgba(239,71,111,.08);border:1px solid rgba(239,71,111,.2);color:var(--red)}
.alert-success{background:rgba(0,245,196,.08);border:1px solid rgba(0,245,196,.2);color:var(--accent3)}
.alert-info{background:rgba(124,92,252,.08);border:1px solid rgba(124,92,252,.2);color:var(--accent)}

/* ════════════════════════════════
   AI COACH
════════════════════════════════ */
.ai-message{background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius);padding:16px;margin-bottom:12px;font-size:.87rem;line-height:1.7}
.ai-message.user{background:rgba(124,92,252,.08);border-color:rgba(124,92,252,.2)}
.ai-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.ai-label.coach{color:var(--accent3)}
.ai-label.user{color:var(--text2)}
.typing-dots span{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--accent);margin:0 2px;animation:blink 1.2s infinite}
.typing-dots span:nth-child(2){animation-delay:.2s}
.typing-dots span:nth-child(3){animation-delay:.4s}
@keyframes blink{0%,80%,100%{opacity:.2}40%{opacity:1}}

/* ════════════════════════════════
   HABIT SPECIFIC
════════════════════════════════ */
.ring-block{display:flex;align-items:center;gap:28px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:20px}
.ring-wrap{position:relative;width:130px;height:130px;flex-shrink:0}
.progress-ring{transform:rotate(-90deg);transform-origin:center}
.ring-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.ring-pct{font-family:'Syne',sans-serif;font-size:1.7rem;font-weight:800}
.ring-sub{font-size:.66rem;color:var(--text2)}
.ring-info{flex:1}
.ring-msg{font-family:'Syne',sans-serif;font-size:1.15rem;font-weight:800;margin-bottom:5px}
.ring-submsg{color:var(--text2);font-size:.84rem;margin-bottom:14px}
.tag-row{display:flex;gap:8px;flex-wrap:wrap}
.habits-list{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
.habit-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:16px 18px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:transform .15s,border-color .2s;position:relative;overflow:hidden;user-select:none}
.habit-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--habit-color,var(--accent));border-radius:4px 0 0 4px}
.habit-card:active{transform:scale(.985)}
.habit-card.done{border-color:var(--accent3);background:linear-gradient(135deg,var(--surface) 0%,rgba(0,245,196,.05) 100%)}
.habit-emoji{font-size:26px;flex-shrink:0}
.habit-info{flex:1;min-width:0}
.habit-name{font-family:'Syne',sans-serif;font-weight:700;font-size:15px}
.habit-card.done .habit-name{opacity:.55;text-decoration:line-through}
.habit-streak-text{font-size:11px;color:var(--text2);margin-top:2px}
.habit-xp{font-size:10px;font-weight:700;color:var(--gold);background:rgba(255,209,102,.12);padding:2px 7px;border-radius:8px;margin-right:6px}
.habit-card.done .habit-xp{color:var(--accent3);background:rgba(0,245,196,.12)}
.habit-check{width:32px;height:32px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:15px;transition:all .2s;flex-shrink:0;background:var(--surface2);color:transparent}
.habit-card.done .habit-check{background:var(--accent3);border-color:var(--accent3);color:#000}
.habit-actions{display:flex;gap:5px;margin-right:6px}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;text-align:center}
.s-val{font-family:'Syne',sans-serif;font-weight:800;font-size:1.6rem;letter-spacing:-1px}
.s-lbl{font-size:.7rem;color:var(--text2);margin-top:4px;text-transform:uppercase;letter-spacing:.5px}
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px}
.chart-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.8rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:14px}
.chart-tabs{display:flex;gap:4px;background:var(--surface2);border-radius:8px;padding:3px}
.chart-tab{background:none;border:none;color:var(--text2);border-radius:6px;padding:5px 12px;font-family:'Syne',sans-serif;font-size:.75rem;font-weight:700;cursor:pointer;transition:all .18s}
.chart-tab.active{background:var(--accent);color:white}
.mini-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.mini-bar-label{font-size:.82rem;width:130px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mini-bar-bg{flex:1;height:6px;background:var(--surface3);border-radius:6px;overflow:hidden}
.mini-bar-fill{height:100%;border-radius:6px;transition:width .5s ease}
.mini-bar-pct{font-size:.72rem;color:var(--text2);width:36px;text-align:right}
.insight-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:10px}
.insight-card.ok-card{border-color:rgba(0,245,196,.25);background:rgba(0,245,196,.04)}
.insight-card.warn-card{border-color:rgba(255,209,102,.25);background:rgba(255,209,102,.04)}
.insight-card.goal-card{border-color:rgba(124,92,252,.25);background:rgba(124,92,252,.04)}
.i-head{display:flex;align-items:flex-start;gap:12px;margin-bottom:8px}
.i-icon{font-size:1.4rem;line-height:1}
.i-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem}
.i-body{font-size:.84rem;color:var(--text2);line-height:1.6}
.manage-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:16px}
.separator{height:1px;background:var(--border);margin:0 0 16px}
.habit-manage-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.habit-manage-item:last-child{border-bottom:none}
.hm-emoji{font-size:1.3rem;width:30px;text-align:center}
.hm-name{flex:1;font-size:.88rem;font-weight:600}
.hm-btns{display:flex;gap:5px}
.hm-btn{background:var(--surface2);border:1px solid var(--border);color:var(--text2);border-radius:7px;width:28px;height:28px;cursor:pointer;font-size:.82rem;display:flex;align-items:center;justify-content:center;transition:all .15s}
.hm-btn:hover{color:var(--text)}
.color-picker-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}
.color-dot{width:22px;height:22px;border-radius:50%;cursor:pointer;transition:transform .15s;border:2px solid transparent}
.color-dot.sel{border-color:white;transform:scale(1.2)}
.emoji-grid{display:flex;flex-wrap:wrap;gap:8px}
.emoji-btn{font-size:22px;background:var(--surface2);border:2px solid transparent;border-radius:10px;padding:6px 9px;cursor:pointer;transition:all .15s}
.emoji-btn.sel{border-color:var(--accent);background:rgba(124,92,252,.15)}
.notif-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px}
.notif-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.notif-row:last-child{border-bottom:none}
.notif-label{font-size:.85rem;font-weight:600}
.notif-sub{font-size:.72rem;color:var(--text2);margin-top:2px}
.toggle{width:36px;height:20px;background:var(--surface3);border-radius:999px;cursor:pointer;position:relative;transition:background .2s;flex-shrink:0}
.toggle::after{content:'';width:14px;height:14px;background:white;border-radius:50%;position:absolute;top:3px;left:3px;transition:left .2s}
.toggle.on{background:var(--accent)}
.toggle.on::after{left:19px}
.reward-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:20px}
.rewards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:20px}
.reward-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;text-align:center;transition:all .2s}
.reward-card.unlocked{border-color:rgba(255,209,102,.3);background:rgba(255,209,102,.04)}
.reward-card.locked{opacity:.5;filter:grayscale(.5)}
.reward-icon{font-size:2rem;margin-bottom:8px}
.reward-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;margin-bottom:4px}
.reward-cond{font-size:.7rem;color:var(--text2)}
.reward-unlocked-tag{display:inline-block;margin-top:8px;background:rgba(255,209,102,.15);border:1px solid rgba(255,209,102,.25);color:var(--gold);border-radius:999px;padding:2px 8px;font-size:.65rem;font-weight:700}
.recap-modal{position:fixed;inset:0;background:rgba(0,0,0,.88);backdrop-filter:blur(12px);z-index:300;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s}
.recap-modal.open{opacity:1;pointer-events:all}
.recap-inner{background:var(--surface);border:1px solid var(--border2);border-radius:20px;padding:28px;max-width:540px;width:100%;max-height:85vh;overflow-y:auto}
.recap-inner h2{font-size:1.4rem;margin-bottom:12px}
.recap-badge{display:inline-block;background:linear-gradient(90deg,var(--accent),var(--accent2));color:white;font-family:'Syne',sans-serif;font-weight:800;padding:6px 18px;border-radius:999px;font-size:.88rem;margin-bottom:16px}
.recap-text{font-size:.87rem;line-height:1.8;color:var(--text2)}
.recap-section{margin-top:18px;padding-top:16px;border-top:1px solid var(--border)}
.recap-section h4{font-size:.9rem;margin-bottom:10px;color:var(--text)}

/* ════════════════════════════════
   INTEGRATION CARDS
════════════════════════════════ */
.int-api-card{
  background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);
  padding:18px 16px;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;gap:6px;
}
.int-api-card:hover{border-color:var(--accent);transform:translateY(-2px);background:var(--surface2)}
.int-add-card{border-style:dashed;border-color:var(--border3)}
.int-add-card:hover{border-color:var(--accent);border-style:solid}
.int-card-icon{width:44px;height:44px;border-radius:12px;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:1.3rem;margin-bottom:4px}
.int-card-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.92rem}
.int-card-desc{font-size:.74rem;color:var(--text2)}
.int-card-status{margin-top:4px}

/* ════════════════════════════════
   HAMBURGER + MOBILE
════════════════════════════════ */
.hamburger{display:none;background:var(--surface);border:1px solid var(--border2);border-radius:8px;width:36px;height:36px;cursor:pointer;color:var(--text);font-size:1.1rem;align-items:center;justify-content:center;pointer-events:all;position:relative;z-index:201}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99}
.sidebar-overlay.show{display:block}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:4px}

/* ════════════════════════════════
   LIGHT THEME
════════════════════════════════ */
@media(prefers-color-scheme:light){
  :root{
    --bg:#f4f4fa;--bg2:#ebebf5;--surface:#ffffff;--surface2:#f0f0f8;--surface3:#e0e0ef;
    --border:#00000010;--border2:#00000018;--border3:#00000025;
    --text:#0d0d1a;--text2:#555580;--text3:#aaaacc;
    --shadow:0 0 40px rgba(124,92,252,.08);
  }
  body{color-scheme:light}
  .sidebar{background:var(--surface);border-right-color:var(--border2)}
  .mode-switcher{background:var(--surface2)}
  .card{background:var(--surface)}
  .kpi-card{background:var(--surface)}
  .inp{background:var(--surface2);color:var(--text)}
  .modal-box,.modal-sheet,.recap-inner{background:var(--surface)}
  .ai-message{background:var(--surface2)}
  .notif-card{background:var(--surface2)}
  .xp-block{background:linear-gradient(135deg,rgba(124,92,252,.07),transparent)}
  .goal-block{background:linear-gradient(135deg,rgba(124,92,252,.1),rgba(252,92,125,.05))}
  .topbar-right .date-chip{background:var(--surface);border-color:var(--border2)}
  .btn-ghost{background:var(--surface2);border-color:var(--border2)}
  .btn-icon{background:var(--surface2)}
  .chart-card,.insight-card,.manage-section{background:var(--surface)}
  .habit-card{background:var(--surface)}
  .stat-card{background:var(--surface)}
  .reward-card{background:var(--surface)}
}

/* ════════════════════════════════
   PRODUCT METRICS GRID RESPONSIVE
════════════════════════════════ */
.product-metrics-grid{
  display:grid;
  grid-template-columns:repeat(6,1fr);
  gap:8px;
}
@media(max-width:900px){
  .product-metrics-grid{grid-template-columns:repeat(3,1fr)}
}

/* ════════════════════════════════
   MODE TRANSITION GLOW
════════════════════════════════ */
body.mode-biz{--active-accent:var(--biz);--active-glow:var(--biz-glow)}
body.mode-hab{--active-accent:var(--hab);--active-glow:var(--hab-glow)}

/* ════════════════════════════════
   MOBILE
════════════════════════════════ */
@media(max-width:900px){
  :root{--sidebar:0px}
  .sidebar{transform:translateX(-260px);width:260px}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0;padding:72px 16px 24px}
  .mode-switcher-wrap{left:0}
  .hamburger{display:flex}
  .grid-4,.grid-3,.grid-2{grid-template-columns:1fr}
  .stats-grid{grid-template-columns:1fr 1fr}
  .col-span-2{grid-column:span 1}
  .chart-grid{grid-template-columns:1fr}
  .ring-block{flex-direction:column;text-align:center}
  .tag-row{justify-content:center}
}
</style>
</head>
<body class="mode-biz">

<!-- ══════════════════════ ONBOARDING ══════════════════════ -->
<div id="onboarding-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column">
  <div style="text-align:center;max-width:420px;padding:32px;animation:fadeUp .4s ease">
    <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:2rem;letter-spacing:3px;background:linear-gradient(135deg,#7c5cfc,#fc5c7d);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:6px">ASCEND</div>
    <div style="font-size:.65rem;color:var(--text3);letter-spacing:3px;text-transform:uppercase;margin-bottom:48px">Unified Dashboard</div>
    <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.6rem;margin-bottom:8px;color:var(--text)">Comment je t'appelle ? 👋</div>
    <div style="font-size:.9rem;color:var(--text2);margin-bottom:32px">Rentre ton prénom ou ton blaze</div>
    <input id="onboarding-name" class="inp" placeholder="Ex: Gab, Shadow, Zeus..." style="text-align:center;font-size:1.1rem;padding:14px;border-radius:999px;margin-bottom:16px" onkeydown="if(event.key==='Enter')finishOnboarding()">
    <button class="btn btn-primary" onclick="finishOnboarding()" style="width:100%;padding:14px;border-radius:999px;font-size:.95rem;background:linear-gradient(135deg,var(--accent),var(--accent2))">Commencer →</button>
  </div>
</div>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="app">
<!-- ══════════════════════ SIDEBAR ══════════════════════ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">ASCEND<small>Unified Dashboard</small></div>
  <div class="sidebar-mode-badge" id="sidebar-mode-badge">⚡ Business</div>

  <!-- BUSINESS NAV -->
  <div class="nav-section" id="nav-section-biz">
    <div class="nav-group-label">Business</div>
    <div class="nav-item" onclick="showView('command')" id="nav-command"><span class="ni">⚡</span> Command Center</div>
    <div class="nav-item" onclick="showView('finance')" id="nav-finance"><span class="ni">💰</span> Finance</div>
    <div class="nav-item" onclick="showView('products')" id="nav-products"><span class="ni">🧪</span> Product Lab</div>
    <div class="nav-item" onclick="showView('ads')" id="nav-ads"><span class="ni">📣</span> Ads Control</div>
    <div class="nav-item" onclick="showView('analytics')" id="nav-analytics"><span class="ni">📊</span> Analytics</div>
    <div class="nav-item" onclick="showView('tasks')" id="nav-tasks"><span class="ni">✅</span> Execution Panel</div>
    <div class="nav-item" onclick="showView('strategy')" id="nav-strategy"><span class="ni">🗺</span> Strategy Board</div>
    <div class="nav-group-label">Outils</div>
    <div class="nav-item" onclick="showView('hub')" id="nav-hub"><span class="ni">🔗</span> Hub de liens</div>
    <div class="nav-item" onclick="showView('knowledge')" id="nav-knowledge"><span class="ni">🎓</span> Knowledge</div>
    <div class="nav-item" onclick="showView('coach')" id="nav-coach"><span class="ni">🤖</span> AI Coach</div>
    <div class="nav-item" onclick="showView('integrations')" id="nav-integrations"><span class="ni">🔌</span> Intégrations API</div>
  </div>

  <!-- HABITUDES NAV -->
  <div class="nav-section hidden-section" id="nav-section-hab">
    <div class="nav-group-label">Habitudes</div>
    <div class="nav-item" onclick="showView('today')" id="nav-today"><span class="ni">✦</span> Aujourd'hui</div>
    <div class="nav-item" onclick="showView('stats')" id="nav-stats"><span class="ni">◈</span> Statistiques</div>
    <div class="nav-item" onclick="showView('objectives')" id="nav-objectives"><span class="ni">◎</span> Objectifs</div>
    <div class="nav-item" onclick="showView('rewards')" id="nav-rewards"><span class="ni">★</span> Récompenses</div>
    <div class="nav-item" onclick="showView('manage')" id="nav-manage"><span class="ni">⚙</span> Gérer habitudes</div>
  </div>

  <div class="sidebar-footer">
    <div class="xp-block">
      <div class="level-badge" id="s-level-badge">🌱 Niveau 1</div>
      <div class="xp-bar-bg"><div class="xp-bar-fill" id="s-xp-bar" style="width:0%"></div></div>
      <div class="xp-label"><span id="s-xp-val">0 / 100 XP</span></div>
      <div class="streak-pill" id="s-streak">🔥 0 jours</div>
    </div>
    <div class="goal-block" onclick="openGoalPlan()" style="cursor:pointer;transition:all .2s" onmouseover="this.style.borderColor='rgba(0,245,196,.4)'" onmouseout="this.style.borderColor=''">
      <div class="goal-label">Objectif Business <span style="font-size:.6rem;color:var(--accent3)">— Cliquer →</span></div>
      <div class="goal-val">4 000€/jour</div>
      <div class="goal-sub" id="goal-days-left-sidebar">— jours restants</div>
      <div class="goal-bar-bg"><div class="goal-bar-fill" id="goal-bar-sidebar" style="width:2%"></div></div>
    </div>
  </div>
</aside>

<!-- ══════════════════════ MODE SWITCHER ══════════════════════ -->
<div class="mode-switcher-wrap">
  <div style="display:flex;gap:10px;align-items:center">
    <button class="hamburger" onclick="openSidebar()">☰</button>
    <div class="mode-switcher" id="modeSwitcher">
      <div class="mode-slider" id="modeSlider"></div>
      <div class="mode-pill mode-pill-biz active-biz" onclick="setMode('biz')">
        <span class="mp-icon">⚡</span> Business
      </div>
      <div class="mode-divider"></div>
      <div class="mode-pill mode-pill-hab" onclick="setMode('hab')">
        <span class="mp-icon">🌱</span> Habitudes
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════ MAIN ══════════════════════ -->
<main class="main">

<!-- ══════ BUSINESS: COMMAND CENTER ══════ -->
<div class="view active" id="view-command">
  <div class="topbar">
    <div class="topbar-left"><div><h2 id="cmd-greeting">Bonjour, Gab 👋</h2><div class="sub" id="cmd-date"></div></div></div>
    <div class="topbar-right"><div class="date-chip mono" id="cmd-clock">--:--:--</div></div>
  </div>
  <div id="cmd-alert-zone" style="margin-bottom:16px"></div>
  <div class="grid-4" id="cmd-kpis"></div>
  <div class="grid-2">
    <div class="card"><div class="card-title">⚡ Tâches du jour</div><div id="cmd-tasks"></div><button class="btn btn-ghost btn-sm" onclick="closeSidebar();showView('tasks')" style="margin-top:10px;width:100%">Voir tout →</button></div>
    <div class="card"><div class="card-title">🧪 Produits actifs</div><div id="cmd-products"></div><button class="btn btn-ghost btn-sm" onclick="closeSidebar();showView('products')" style="margin-top:10px;width:100%">Voir tout →</button></div>
  </div>
  <div class="card" onclick="openGoalPlan()" style="margin-top:0;cursor:pointer;transition:all .2s" onmouseover="this.style.borderColor='rgba(0,245,196,.3)'" onmouseout="this.style.borderColor=''">
    <div class="card-title">🎯 Objectif final <span class="tag tag-green" style="font-size:.62rem">Voir plan →</span></div>
    <div style="font-size:.8rem;color:var(--text2);margin-bottom:8px" id="goal-days-left">— jours restants</div>
    <div style="font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:var(--accent3)">4 000€/jour en Décembre 2026</div>
    <div class="goal-bar-bg" style="margin-top:12px"><div class="goal-bar-fill" id="goal-progress-bar" style="width:1%"></div></div>
  </div>
</div>

<!-- ══════ BUSINESS: FINANCE ══════ -->
<div class="view" id="view-finance">
  <div class="topbar">
    <div class="topbar-left"><h2>💰 Finance Tracker</h2></div>
    <div class="topbar-right">
      <button class="btn btn-ghost btn-sm" onclick="renderFinance('month')">30j</button>
      <button class="btn btn-ghost btn-sm" onclick="renderFinance('all')">Tout</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-add-transaction')">+ Transaction</button>
    </div>
  </div>
  <div class="grid-4" id="finance-kpis"></div>
  <div class="grid-2">
    <div class="card"><div class="card-title">📈 Revenus vs Dépenses</div><div style="position:relative;height:200px"><canvas id="chart-finance"></canvas></div></div>
    <div class="card"><div class="card-title">🥧 Répartition dépenses</div><div style="position:relative;height:200px"><canvas id="chart-pie"></canvas></div></div>
  </div>
  <div class="card"><div class="card-title">📋 Historique transactions</div><div id="transactions-table"></div></div>
</div>

<!-- ══════ BUSINESS: PRODUCTS ══════ -->
<div class="view" id="view-products">
  <div class="topbar">
    <div class="topbar-left"><h2>🧪 Product Lab</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-product')">+ Produit</button></div>
  </div>
  <div id="products-list"></div>
</div>

<!-- ══════ BUSINESS: ADS ══════ -->
<div class="view" id="view-ads">
  <div class="topbar">
    <div class="topbar-left"><h2>📣 Ads Control</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-campaign')">+ Campagne</button></div>
  </div>
  <div class="grid-4" id="ads-kpis"></div>
  <div id="ads-suggestions" style="margin-bottom:16px"></div>
  <div class="card"><div class="card-title">📋 Campagnes</div><div id="campaigns-list"></div><div class="empty" id="campaigns-empty" style="display:none"><div class="ei">📣</div><p>Ajoute tes campagnes pub</p></div></div>
</div>

<!-- ══════ BUSINESS: ANALYTICS ══════ -->
<div class="view" id="view-analytics">
  <div class="topbar">
    <div class="topbar-left"><h2>📊 Analytics</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-metric')">+ Métriques</button></div>
  </div>
  <div class="grid-4" id="analytics-kpis"></div>
  <div class="grid-2">
    <div class="card"><div class="card-title">🔽 Funnel</div><div id="funnel"></div></div>
    <div class="card"><div class="card-title">📋 Historique 7j</div><div id="metrics-history"></div></div>
  </div>
</div>

<!-- ══════ BUSINESS: TASKS ══════ -->
<div class="view" id="view-tasks">
  <div class="topbar">
    <div class="topbar-left"><h2>✅ Execution Panel</h2></div>
    <div class="topbar-right">
      <button class="btn btn-ghost btn-sm" onclick="openModal('modal-template')">📋 Templates</button>
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-add-task')">+ Tâche</button>
    </div>
  </div>
  <div class="grid-3">
    <div class="card"><div class="card-title">🔴 Haute <span class="tag tag-red" id="count-high">0</span></div><div id="tasks-high"></div></div>
    <div class="card"><div class="card-title">🟡 Moyenne <span class="tag tag-gold" id="count-med">0</span></div><div id="tasks-med"></div></div>
    <div class="card"><div class="card-title">🟢 Faible / Done <span class="tag tag-green" id="count-low">0</span></div><div id="tasks-low"></div></div>
  </div>
</div>

<!-- ══════ BUSINESS: STRATEGY ══════ -->
<div class="view" id="view-strategy">
  <div class="topbar">
    <div class="topbar-left"><h2>🗺 Strategy Board</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-goal')">+ Objectif</button></div>
  </div>
  <div class="grid-2">
    <div class="card"><div class="card-title">🎯 Vision & Objectifs</div><div id="goals-list"></div></div>
    <div class="card"><div class="card-title">🗓 Roadmap 2026</div><div id="roadmap"></div></div>
  </div>
  <div class="card" style="margin-top:0">
    <div class="card-title">📝 Notes stratégiques</div>
    <textarea class="inp" id="strategy-notes" rows="6" placeholder="Angles marketing, idées, observations..." style="resize:vertical" oninput="saveStrategyNotes()"></textarea>
  </div>
</div>

<!-- ══════ HUB ══════ -->
<div class="view" id="view-hub">
  <div class="topbar">
    <div class="topbar-left"><h2>🔗 Hub de liens</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-link')">+ Lien</button></div>
  </div>
  <div id="hub-categories"></div>
</div>

<!-- ══════ KNOWLEDGE ══════ -->
<div class="view" id="view-knowledge">
  <div class="topbar">
    <div class="topbar-left"><h2>🎓 Knowledge Center</h2></div>
    <div class="topbar-right"><button class="btn btn-primary btn-sm" onclick="openModal('modal-add-resource')">+ Ressource</button></div>
  </div>
  <div class="grid-2">
    <div class="card" style="border-color:rgba(124,92,252,.3)">
      <div class="card-title">⚡ Formation principale <span class="tag tag-purple">Mega.nz</span></div>
      <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:4px">Formation Dropshipping</div>
      <div style="font-size:.82rem;color:var(--text2);margin-bottom:14px">80h de contenu · Accès privé</div>
      <div class="inp-group"><div class="inp-label">Heures visionnées</div><div class="inp-row"><input class="inp" type="number" id="formation-hours" placeholder="0" min="0" max="80" oninput="updateFormationProgress()"><span style="display:flex;align-items:center;color:var(--text2);font-size:.85rem;white-space:nowrap">/ 80h</span></div></div>
      <div class="prog-bg" style="height:8px;margin-bottom:8px"><div class="prog-fill" id="formation-bar" style="width:0%;background:linear-gradient(90deg,var(--accent),var(--accent3))"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:.75rem;color:var(--text2)"><span id="formation-pct">0%</span><span id="formation-remaining">80h restantes</span></div>
      <div class="inp-group" style="margin-top:14px"><div class="inp-label">Notes</div><textarea class="inp" id="formation-notes" rows="4" placeholder="Ce que tu as retenu..." oninput="saveFormationNotes()" style="resize:vertical"></textarea></div>
      <a href="https://mega.nz/folder/FQg2lSaS#rYlByvveQyHOpaXHvHDITg" target="_blank" class="btn btn-primary" style="width:100%;text-align:center;text-decoration:none;display:block;margin-top:12px">▶ Ouvrir sur Mega.nz</a>
    </div>
    <div class="card"><div class="card-title">📚 Autres ressources</div><div id="resources-list"></div><div class="empty" id="resources-empty"><div class="ei">📚</div><p>Ajoute des vidéos, articles, formations...</p></div></div>
  </div>
  <div class="card" style="margin-top:0">
    <div class="card-title">✅ Actions à appliquer</div>
    <div id="formation-actions"></div>
    <div class="inp-row" style="margin-top:12px"><input class="inp" id="new-formation-action" placeholder="Action concrète à appliquer..."><button class="btn btn-primary btn-sm" onclick="addFormationAction()" style="white-space:nowrap">+ Ajouter</button></div>
  </div>
</div>

<!-- ══════ AI COACH ══════ -->
<div class="view" id="view-coach">
  <div class="topbar">
    <div class="topbar-left"><h2>🤖 AI Business Coach</h2></div>
    <div class="topbar-right">
      <select class="inp" id="coach-mode" style="width:auto;padding:6px 12px;font-size:.8rem"><option value="normal">Mode Normal</option><option value="strict">Mode Strict 🔥</option><option value="soft">Mode Soft</option></select>
      <button class="btn btn-ghost btn-sm" onclick="clearCoach()">Effacer</button>
      <button class="btn btn-ghost btn-sm" onclick="openModal('modal-api-key')">🔑 API</button>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:16px">
    <button class="btn btn-ghost" onclick="coachQuick('analyse')" style="font-size:.8rem">📊 Analyser</button>
    <button class="btn btn-ghost" onclick="coachQuick('today')" style="font-size:.8rem">⚡ Que faire ?</button>
    <button class="btn btn-ghost" onclick="coachQuick('product')" style="font-size:.8rem">🧪 Valider produit</button>
    <button class="btn btn-ghost" onclick="coachQuick('motivation')" style="font-size:.8rem">🔥 Remotiver</button>
  </div>
  <div class="card" style="margin-bottom:16px;min-height:300px;max-height:500px;overflow-y:auto" id="coach-box">
    <div id="coach-messages">
      <div class="ai-label coach">GAB OS COACH</div>
      <div class="ai-message" id="coach-welcome-msg">Salut 👋 Je suis ton AI Business Coach, 100% dédié à ton objectif : <strong>4 000€/jour en décembre 2026</strong>.<br><br>Configure ta clé API Anthropic (bouton 🔑 en haut) pour activer le coaching IA. 💪</div>
    </div>
  </div>
  <div class="inp-row"><input class="inp" id="coach-input" placeholder="Pose une question ou décris ta situation..." onkeydown="if(event.key==='Enter')sendCoach()"><button class="btn btn-primary" onclick="sendCoach()">Envoyer</button></div>
  <div style="font-size:.72rem;color:var(--text3);margin-top:6px">Nécessite une clé API Anthropic — <span style="color:var(--accent);cursor:pointer" onclick="openModal('modal-api-key')">Configurer →</span></div>
</div>


<!-- ══════ BUSINESS: INTEGRATIONS ══════ -->
<div class="view" id="view-integrations">
  <!-- LIST VIEW -->
  <div id="int-list-view">
    <div class="topbar">
      <div class="topbar-left"><h2>🔌 Intégrations API</h2><div class="sub">Clique sur une intégration pour voir tes données</div></div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm" onclick="syncAllIntegrations()">🔄 Sync toutes</button>
        <button class="btn btn-primary btn-sm" onclick="openAddCustomIntegration()">+ Ajouter</button>
      </div>
    </div>

    <!-- CONNECTED INTEGRATIONS GRID -->
    <div style="margin-bottom:24px">
      <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.72rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--text3);margin-bottom:12px">Mes intégrations</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px" id="int-cards-grid">

        <!-- SHOPIFY CARD -->
        <div class="int-api-card" id="int-card-shopify" onclick="openIntDetail('shopify')">
          <div class="int-card-icon" style="background:linear-gradient(135deg,rgba(150,191,71,.15),rgba(150,191,71,.05));border-color:rgba(150,191,71,.2)">🛒</div>
          <div class="int-card-name">Shopify</div>
          <div class="int-card-desc">Commandes & revenus</div>
          <div class="int-card-status" id="shopify-card-status"><span class="tag tag-red" style="font-size:.62rem">Non connecté</span></div>
        </div>

        <!-- META CARD -->
        <div class="int-api-card" id="int-card-meta" onclick="openIntDetail('meta')">
          <div class="int-card-icon" style="background:linear-gradient(135deg,rgba(79,133,255,.15),rgba(79,133,255,.05));border-color:rgba(79,133,255,.2)">📘</div>
          <div class="int-card-name">Meta Ads</div>
          <div class="int-card-desc">Facebook & Instagram</div>
          <div class="int-card-status" id="meta-card-status"><span class="tag tag-red" style="font-size:.62rem">Non connecté</span></div>
        </div>

        <!-- TIKTOK CARD -->
        <div class="int-api-card" id="int-card-tiktok" onclick="openIntDetail('tiktok')">
          <div class="int-card-icon" style="background:linear-gradient(135deg,rgba(255,0,80,.12),rgba(255,0,80,.04));border-color:rgba(255,0,80,.18)">🎵</div>
          <div class="int-card-name">TikTok Ads</div>
          <div class="int-card-desc">Campagnes TikTok</div>
          <div class="int-card-status" id="tiktok-card-status"><span class="tag tag-red" style="font-size:.62rem">Non connecté</span></div>
        </div>

        <!-- CUSTOM INTEGRATIONS (rendered by JS) -->
        <div id="custom-int-cards"></div>

        <!-- ADD CARD -->
        <div class="int-api-card int-add-card" onclick="openAddCustomIntegration()">
          <div class="int-card-icon" style="background:rgba(124,92,252,.08);border-color:rgba(124,92,252,.2);font-size:1.4rem">+</div>
          <div class="int-card-name" style="color:var(--accent)">Ajouter</div>
          <div class="int-card-desc">Nouvelle intégration</div>
        </div>
      </div>
    </div>

    <!-- COMING SOON -->
    <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.72rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--text3);margin-bottom:12px">Bientôt disponible</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px">
      <div class="int-api-card" style="opacity:.45;cursor:default">
        <div class="int-card-icon" style="background:rgba(234,67,53,.08);border-color:rgba(234,67,53,.15)">📊</div>
        <div class="int-card-name">Google Analytics</div>
        <div class="int-card-desc">Traffic & conversions</div>
        <div class="int-card-status"><span class="tag tag-gold" style="font-size:.62rem">Bientôt</span></div>
      </div>
      <div class="int-api-card" style="opacity:.45;cursor:default">
        <div class="int-card-icon" style="background:rgba(255,209,102,.08);border-color:rgba(255,209,102,.15)">📧</div>
        <div class="int-card-name">Klaviyo</div>
        <div class="int-card-desc">Email marketing</div>
        <div class="int-card-status"><span class="tag tag-gold" style="font-size:.62rem">Bientôt</span></div>
      </div>
      <div class="int-api-card" style="opacity:.45;cursor:default">
        <div class="int-card-icon" style="background:rgba(79,195,255,.08);border-color:rgba(79,195,255,.15)">📦</div>
        <div class="int-card-name">CJ Dropshipping</div>
        <div class="int-card-desc">Fournisseur & stock</div>
        <div class="int-card-status"><span class="tag tag-gold" style="font-size:.62rem">Bientôt</span></div>
      </div>
    </div>
  </div>

  <!-- DETAIL VIEW (hidden by default) -->
  <div id="int-detail-view" style="display:none">
    <div class="topbar">
      <div class="topbar-left" style="display:flex;align-items:center;gap:12px">
        <button class="btn btn-ghost btn-sm" onclick="closeIntDetail()" style="padding:6px 10px">← Retour</button>
        <h2 id="int-detail-title">Shopify</h2>
        <span id="int-detail-badge" class="tag tag-red">Non connecté</span>
      </div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm" id="int-detail-sync-btn" onclick="syncCurrentIntegration()">🔄 Sync</button>
        <button class="btn danger btn-sm" id="int-detail-disconnect-btn" onclick="disconnectCurrentIntegration()" style="display:none">Déconnecter</button>
      </div>
    </div>

    <!-- CONFIG SECTION -->
    <div class="card" style="margin-bottom:16px" id="int-detail-config">
      <div class="card-title">🔑 Configuration</div>
      <div id="int-detail-config-fields"></div>
      <div id="int-detail-how" style="font-size:.7rem;color:var(--text3);margin-top:10px;line-height:1.7"></div>
    </div>

    <!-- DATA SECTION -->
    <div id="int-detail-data"></div>
  </div>
</div>

<!-- MODAL: Add Custom Integration -->
<div class="modal-bg" id="modal-add-integration">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title">+ Nouvelle intégration</div>
      <button class="modal-close" onclick="closeModal('modal-add-integration')">✕</button>
    </div>
    <div class="alert alert-info" style="margin-bottom:16px;font-size:.8rem">Ajoute n'importe quelle app ou service avec une URL d'API et un token.</div>
    <div class="inp-group"><div class="inp-label">Nom du service</div><input class="inp" id="ci-name" placeholder="Ex: Google Ads, Stripe, Klaviyo..."></div>
    <div class="inp-group"><div class="inp-label">Icône (emoji)</div><input class="inp" id="ci-icon" placeholder="📊" style="width:80px"></div>
    <div class="inp-group"><div class="inp-label">Description courte</div><input class="inp" id="ci-desc" placeholder="Ex: Campagnes Google"></div>
    <div class="inp-group"><div class="inp-label">URL de base de l'API</div><input class="inp" id="ci-url" placeholder="https://api.example.com/v1/..."></div>
    <div class="inp-group"><div class="inp-label">Token / Clé API</div><input class="inp" id="ci-token" type="password" placeholder="sk_live_..."></div>
    <div class="inp-group"><div class="inp-label">Header d'authentification</div>
      <select class="inp" id="ci-auth-type">
        <option value="bearer">Bearer Token (Authorization: Bearer ...)</option>
        <option value="apikey">X-API-Key header</option>
        <option value="basic">Basic Auth</option>
      </select>
    </div>
    <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveCustomIntegration()">Enregistrer</button>
  </div>
</div>
<!-- ══════ HABITS: TODAY ══════ -->
<div class="view" id="view-today">
  <div class="topbar">
    <div class="topbar-left"><div><h2 id="today-title">Bonjour 👋</h2><div class="sub" id="today-date"></div></div></div>
    <div class="topbar-right">
      <div class="date-chip" id="clock-today">--:--</div>
      <button class="btn btn-green btn-sm" onclick="openAddModal()">+ Habitude</button>
    </div>
  </div>
  <div class="ring-block">
    <div class="ring-wrap">
      <svg class="progress-ring" width="130" height="130" viewBox="0 0 130 130">
        <circle cx="65" cy="65" r="54" fill="none" stroke="var(--surface3)" stroke-width="10"/>
        <circle id="ring-circle" cx="65" cy="65" r="54" fill="none" stroke="url(#ringGrad)" stroke-width="10" stroke-linecap="round" stroke-dasharray="339.3" stroke-dashoffset="339.3" style="transition:stroke-dashoffset .7s cubic-bezier(.4,0,.2,1)"/>
        <defs><linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#00c49a"/><stop offset="100%" stop-color="var(--accent3)"/></linearGradient></defs>
      </svg>
      <div class="ring-label"><div class="ring-pct" id="ring-pct">0%</div><div class="ring-sub">Complété</div></div>
    </div>
    <div class="ring-info">
      <div class="ring-msg" id="ring-msg">Lance-toi !</div>
      <div class="ring-submsg" id="ring-submsg">Commence par une petite habitude.</div>
      <div class="tag-row">
        <span class="tag tag-green">✓ <span id="done-count">0</span> faites</span>
        <span class="tag tag-purple">⏳ <span id="remain-count">0</span> restantes</span>
        <span class="tag tag-gold">⚡ +<span id="today-xp-total">0</span> XP</span>
      </div>
    </div>
  </div>
  <div class="habits-list" id="habits-list"></div>
  <div id="today-insight"></div>
</div>

<!-- ══════ HABITS: STATS ══════ -->
<div class="view" id="view-stats">
  <div class="topbar">
    <div class="topbar-left"><h2>📈 Statistiques</h2></div>
    <div class="topbar-right">
      <div class="chart-tabs">
        <button class="chart-tab active" id="tab-week" onclick="setStatRange('week',this)">7j</button>
        <button class="chart-tab" id="tab-month" onclick="setStatRange('month',this)">30j</button>
      </div>
    </div>
  </div>
  <div class="stats-grid" id="stats-kpis"></div>
  <div class="chart-grid">
    <div class="chart-card"><div class="chart-title">Complétion quotidienne</div><div style="position:relative;height:190px"><canvas id="chart-daily"></canvas></div></div>
    <div class="chart-card"><div class="chart-title">Progression XP</div><div style="position:relative;height:190px"><canvas id="chart-xp"></canvas></div></div>
  </div>
  <div class="chart-card" style="margin-bottom:16px"><div class="chart-title">Par habitude cette semaine</div><div id="mini-bars"></div></div>
  <div id="insight-cards"></div>
  <div class="insight-card goal-card" id="next-goal">
    <div class="i-head"><span class="i-icon">🎯</span><div><div class="i-title">Objectif semaine prochaine</div></div></div>
    <div class="i-body" id="next-goal-text">Complète au moins 5 habitudes/jour.</div>
  </div>
</div>

<!-- ══════ HABITS: OBJECTIVES ══════ -->
<div class="view" id="view-objectives">
  <div class="topbar"><div class="topbar-left"><h2>🎯 Objectifs & Analyse</h2></div></div>
  <div id="objectives-content"></div>
</div>

<!-- ══════ HABITS: REWARDS ══════ -->
<div class="view" id="view-rewards">
  <div class="topbar"><div class="topbar-left"><h2>🏆 Récompenses</h2></div></div>
  <div class="stats-grid" id="rewards-stats"></div>
  <div class="section-title">Badges</div>
  <div class="rewards-grid" id="rewards-grid"></div>
</div>

<!-- ══════ HABITS: MANAGE ══════ -->
<div class="view" id="view-manage">
  <div class="topbar"><div class="topbar-left"><h2>⚙ Gérer les habitudes</h2></div></div>
  <div class="manage-section">
    <div class="section-title">Mes habitudes</div>
    <div id="manage-list"></div>
    <button class="btn btn-green" onclick="openAddModal()" style="width:100%;margin-top:8px">+ Nouvelle habitude</button>
  </div>
  <div class="separator"></div>
  <div class="manage-section">
    <div class="section-title">Ajouter rapidement</div>
    <div style="display:flex;gap:8px;margin-bottom:10px">
      <input class="inp" id="quick-name" placeholder="Nom de l'habitude...">
      <button class="btn btn-green btn-sm" onclick="quickAddHabit()" style="white-space:nowrap">Ajouter</button>
    </div>
    <div class="color-picker-row" id="color-picker"></div>
  </div>
  <div class="separator"></div>
  <div class="manage-section">
    <div class="section-title">Notifications</div>
    <div class="notif-card">
      <div class="notif-row"><div><div class="notif-label">Rappel quotidien — 21h</div><div class="notif-sub">Rappel pour compléter tes habitudes</div></div><div class="toggle on" id="tog-daily" onclick="toggleNotif('daily',this)"></div></div>
      <div class="notif-row"><div><div class="notif-label">Récap lundi — 21h</div><div class="notif-sub">Bilan semaine + objectifs</div></div><div class="toggle on" id="tog-weekly" onclick="toggleNotif('weekly',this)"></div></div>
      <div class="notif-row"><div><div class="notif-label">Alerte streak en danger</div><div class="notif-sub">Si tu n'as rien fait à 20h</div></div><div class="toggle" id="tog-streak" onclick="toggleNotif('streak',this)"></div></div>
    </div>
  </div>
  <div class="separator"></div>
  <div class="manage-section">
    <div class="section-title">Danger Zone</div>
    <button class="btn danger" style="width:100%" onclick="confirmReset()">🗑 Réinitialiser les données habitudes</button>
  </div>
</div>

</main>
</div>

<!-- ══════════════════════ MODALS ══════════════════════ -->
<!-- Transaction -->
<div class="modal-bg" id="modal-add-transaction"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Transaction</div><button class="modal-close" onclick="closeModal('modal-add-transaction')">✕</button></div>
  <div class="inp-group"><div class="inp-label">Type</div><select class="inp" id="t-type"><option value="revenue">Revenu 📈</option><option value="expense">Dépense 📉</option></select></div>
  <div class="inp-group"><div class="inp-label">Description</div><input class="inp" id="t-desc" placeholder="Ex: Vente produit X"></div>
  <div class="inp-group"><div class="inp-label">Montant (€)</div><input class="inp" type="number" id="t-amount" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-label">Catégorie</div><select class="inp" id="t-cat"><option>Ventes</option><option>Publicité</option><option>Abonnements</option><option>Fournisseur</option><option>Autre</option></select></div>
  <div class="inp-group"><div class="inp-label">Date</div><input class="inp" type="date" id="t-date"></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addTransaction()">Ajouter</button>
</div></div>

<!-- Produit -->
<div class="modal-bg" id="modal-add-product"><div class="modal-box" style="max-width:560px">
  <div class="modal-header"><div class="modal-title" id="modal-product-title">+ Produit</div><button class="modal-close" onclick="closeModal('modal-add-product')">✕</button></div>
  <div class="inp-group"><div class="inp-label">Nom du produit</div><input class="inp" id="p-name" placeholder="Ex: Collier LED chat"></div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
    <div class="inp-group"><div class="inp-label">Statut</div><select class="inp" id="p-status"><option value="testing">🧪 En test</option><option value="scaling">🚀 Scaling</option><option value="paused">⏸ Pausé</option><option value="dead">💀 Mort</option></select></div>
    <div class="inp-group"><div class="inp-label">Budget pub/jour (€)</div><input class="inp" type="number" id="p-adbudget" placeholder="10" min="0" step="0.01"></div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
    <div class="inp-group"><div class="inp-label">Prix de vente (€)</div><input class="inp" type="number" id="p-price" placeholder="29.99" min="0" step="0.01" oninput="calcProductMetrics()"></div>
    <div class="inp-group"><div class="inp-label">Coût produit (€)</div><input class="inp" type="number" id="p-cost" placeholder="5.00" min="0" step="0.01" oninput="calcProductMetrics()"></div>
    <div class="inp-group"><div class="inp-label">Revenus générés (€)</div><input class="inp" type="number" id="p-revenue" placeholder="0" min="0" step="0.01" oninput="calcProductMetrics()"></div>
  </div>
  <!-- Auto-calculated metrics -->
  <div id="p-metrics-preview" style="display:none;background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:12px;margin-bottom:12px">
    <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:10px;font-weight:700">Calculé automatiquement</div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;text-align:center">
      <div><div id="p-calc-margin" style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;color:var(--gold)">—</div><div style="font-size:.68rem;color:var(--text2)">Marge brute</div></div>
      <div><div id="p-calc-profit" style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;color:var(--accent3)">—</div><div style="font-size:.68rem;color:var(--text2)">Profit / vente</div></div>
      <div><div id="p-calc-roi" style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;color:var(--accent)">—</div><div style="font-size:.68rem;color:var(--text2)">ROI</div></div>
    </div>
  </div>
  <div class="inp-group"><div class="inp-label">URL produit / landing page</div><input class="inp" id="p-url" placeholder="https://purrlopets.com/products/..."></div>
  <div class="inp-group"><div class="inp-label">📝 Notes (fournisseur, angles testés, observations)</div><textarea class="inp" id="p-notes" rows="3" placeholder="Ex: Angle 1 testé = amour des chats — CTR 2.1%&#10;Fournisseur: CJ SKU #12345&#10;À tester: angle cadeau pour Noël"></textarea></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveProduct()">Enregistrer</button>
</div></div>

<!-- Campagne -->
<div class="modal-bg" id="modal-add-campaign"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Campagne</div><button class="modal-close" onclick="closeModal('modal-add-campaign')">✕</button></div>
  <div class="inp-group"><div class="inp-label">Nom</div><input class="inp" id="c-name" placeholder="Ex: LED Cat Collar - FR"></div>
  <div class="inp-group"><div class="inp-label">Plateforme</div><select class="inp" id="c-platform"><option>Meta Ads</option><option>TikTok Ads</option><option>Google Ads</option><option>Pinterest Ads</option></select></div>
  <div class="inp-group"><div class="inp-label">Budget/jour (€)</div><input class="inp" type="number" id="c-budget" placeholder="10" min="0"></div>
  <div class="inp-group"><div class="inp-label">Revenus générés (€)</div><input class="inp" type="number" id="c-revenue" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-label">CTR (%)</div><input class="inp" type="number" id="c-ctr" placeholder="0.00" step="0.01" min="0"></div>
  <div class="inp-group"><div class="inp-label">Statut</div><select class="inp" id="c-status"><option value="active">Active</option><option value="paused">Pausée</option><option value="dead">Coupée</option></select></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="addCampaign()">Ajouter</button>
</div></div>

<!-- Métriques -->
<div class="modal-bg" id="modal-add-metric"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Métriques du jour</div><button class="modal-close" onclick="closeModal('modal-add-metric')">✕</button></div>
  <div class="inp-group"><div class="inp-label">Date</div><input class="inp" type="date" id="m-date"></div>
  <div class="inp-group"><div class="inp-label">Visiteurs</div><input class="inp" type="number" id="m-visitors" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-label">Commandes</div><input class="inp" type="number" id="m-orders" placeholder="0" min="0"></div>
  <div class="inp-group"><div class="inp-label">Revenus (€)</div><input class="inp" type="number" id="m-revenue" placeholder="0" min="0" step="0.01"></div>
  <div class="inp-group"><div class="inp-label">Dépenses pub (€)</div><input class="inp" type="number" id="m-adspend" placeholder="0" min="0" step="0.01"></div>
  <button class="btn btn-primary" style="width:100%;margin-top:8px" onclick="saveMetric()">Enregistrer</button>
</div></div>

<!-- Tâche -->
<div class="modal-bg" id="modal-add-task"><div class="modal-box">
  <div class="modal-header"><div class="modal-title">+ Tâche</div><button class="modal-close" onclick="closeModal('modal-add-task')">✕</button></div>
